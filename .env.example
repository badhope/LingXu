# ============================================
# 灵墟档案馆 - 环境变量配置模板
# ============================================
# 复制此文件为 .env.local 并填入实际值
# ============================================

# ============================================
# 基础配置
# ============================================

NODE_ENV=development
NEXT_PUBLIC_APP_NAME=灵墟档案馆
NEXT_PUBLIC_APP_VERSION=1.0.0

# ============================================
# 部署环境
# ============================================

# GitHub Pages 专用配置
# NEXT_PUBLIC_BASE_PATH=/LingXu

# Vercel 自动设置此变量，无需手动设置
# VERCEL=1

# ============================================
# 功能开关
# ============================================

# 启用性能分析
ANALYZE=false

# 启用调试模式
NEXT_PUBLIC_DEBUG_MODE=false

# 启用 Analytics
NEXT_PUBLIC_ENABLE_ANALYTICS=true

# ============================================
# API 配置 (后续加后端时使用)
# ============================================

# 后端 API 地址
# NEXT_PUBLIC_API_BASE=https://api.lingxu.example.com

# ============================================
# AI 功能配置 (后续加 AI 解卦时使用)
# ============================================

# OpenAI API Key
# OPENAI_API_KEY=sk-xxx

# 文心一言 / 通义千问
# AI_PROVIDER=openai
# AI_MODEL=gpt-4

# ============================================
# 数据库配置 (后续加用户系统时使用)
# ============================================

# PostgreSQL / Vercel Postgres
# DATABASE_URL=postgres://user:pass@host:5432/db

# Redis 缓存
# REDIS_URL=redis://localhost:6379

# ============================================
# 认证配置 (后续加用户登录时使用)
# ============================================

# NextAuth.js
# NEXTAUTH_URL=https://your-domain.com
# NEXTAUTH_SECRET=your-secret-key-here

# GitHub OAuth
# GITHUB_ID=xxx
# GITHUB_SECRET=xxx

# ============================================
# 支付配置 (后续加 VIP 系统时使用)
# ============================================

# 微信支付
# WECHAT_PAY_MCH_ID=xxx
# WECHAT_PAY_KEY=xxx

# 支付宝
# ALIPAY_APP_ID=xxx

# ============================================
# CDN 和存储配置
# ============================================

# 七牛云 / 阿里云 OSS
# CDN_BASE_URL=https://cdn.example.com
# OSS_ACCESS_KEY=xxx
# OSS_SECRET_KEY=xxx

# ============================================
# Sentry 错误监控 (可选)
# ============================================

# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_AUTH_TOKEN=xxx
