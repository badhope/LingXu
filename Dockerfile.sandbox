FROM python:3.12-slim

WORKDIR /workspace

RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    gcc \
    g++ \
    python3-dev \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir \
    numpy \
    pandas \
    matplotlib \
    scipy \
    scikit-learn \
    requests \
    beautifulsoup4 \
    pillow \
    jupyter \
    ipython \
    pytest \
    aiohttp \
    httpx \
    fastapi \
    uvicorn \
    sqlalchemy \
    redis \
    docker \
    loguru \
    pyyaml \
    tiktoken \
    openai \
    tenacity \
    datasets \
    transformers \
    huggingface-hub \
    accelerate \
    sentence-transformers \
    faiss-cpu \
    langchain \
    langchain-openai \
    langchain-community \
    chromadb \
    pinecone-client \
    cohere \
    anthropic \
    boto3 \
    websockets \
    paramiko \
    python-dotenv \
    pydantic \
    cryptography \
    PyJWT \
    lxml \
    selenium \
    playwright \
    flask \
    django \
    tornado \
    tornado \
    starlette \
    orjson \
    ujson \
    msgpack \
    protobuf \
    grpcio \
    pyarrow \
    fastparquet \
    openpyxl \
    xlsxwriter \
    python-docx \
    python-pptx \
    pdfplumber \
    nltk \
    spacy \
    textblob \
    gensim \
    wordcloud \
    pattern \
    polyglot \
    pycld2 \
    langdetect \
    googletrans \
    translate \
    deep-translator \
    fuzzywuzzy \
    python-Levenshtein \
    jellyfish \
    distance \
    networkx \
    igraph \
    seaborn \
    plotly \
    bokeh \
    altair \
    plotnine \
    missingno \
    pandas-profiling \
    sweetviz \
    autoviz \
    dtale \
    shap \
    lime \
    eli5 \
    yellowbrick \
    scikit-plot \
    mlflow \
    comet-ml \
    wandb \
    optuna \
    hyperopt \
    scikit-optimize \
    bayesian-optimization \
    deap \
    xgboost \
    lightgbm \
    catboost \
    prophet \
    pmdarima \
    statsmodels \
    pymc3 \
    pyro-ppl \
    stanfordnlp \
    allennlp \
    flair \
    transformers \
    tokenizers \
    evaluate \
    accelerate \
    peft \
    trl \
    diffusers \
    gradio \
    streamlit \
    dash \
    panel \
    voila \
    nbconvert \
    nbformat \
    ipywidgets \
    ipyparallel \
    multiprocess \
    concurrent-futures

CMD ["tail", "-f", "/dev/null"]