---
/**
 * 灵墟 - 基础布局组件
 * Base Layout Component
 * 
 * 全站统一的基础布局，包含全局样式和交互效果
 */

import '../styles/global.css';
import '../styles/motion.css';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import MotionController from '@components/interactive/MotionController.astro';
import ParticleField from '@components/interactive/ParticleField.astro';
import MouseEffects from '@components/interactive/MouseEffects.astro';
import DynamicBackground from '@components/interactive/DynamicBackground.astro';
import { SITE_CONFIG } from '@lib/constants';

interface Props {
  title?: string;
  description?: string;
  moduleId?: string;
}

const {
  title = SITE_CONFIG.name,
  description = SITE_CONFIG.description,
  moduleId,
} = Astro.props;

const fullTitle = title === SITE_CONFIG.name ? title : `${title} - ${SITE_CONFIG.name}`;
const basePath = import.meta.env.BASE_URL || SITE_CONFIG.base;
const normalizedBase = basePath === '/' ? '' : basePath;
---

<!DOCTYPE html>
<html lang={SITE_CONFIG.locale} data-module={moduleId}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#050508" />
    <meta name="color-scheme" content="dark" />
    
    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={SITE_CONFIG.url} />
    <meta property="og:site_name" content={SITE_CONFIG.name} />
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    
    <!-- Preload 关键资源 -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://fonts.googleapis.com/css2?family=Ma+Shan+Zheng&family=Noto+Serif+SC:wght@200;300;400;500;600;700&family=ZCOOL+XiaoWei&display=swap" />
    
    <title>{fullTitle}</title>
    <link rel="icon" type="image/svg+xml" href={`${normalizedBase}/favicon.svg`} />
    
    <!-- 页面过渡动画 -->
    <style>
      /* 页面过渡遮罩 */
      .page-transition-overlay {
        position: fixed;
        inset: 0;
        z-index: 99999;
        pointer-events: none;
        opacity: 0;
        background: #050508;
        transition: opacity 0.4s ease;
      }

      .page-transition-overlay.active {
        opacity: 1;
        pointer-events: auto;
      }

      /* 入场动画 */
      .page-loaded main {
        animation: pageEnter 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      }

      @keyframes pageEnter {
        from {
          opacity: 0;
          transform: translateY(20px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      /* 滚动触发动画 */
      .scroll-reveal {
        opacity: 0;
        transform: translateY(30px);
        transition: 
          opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1),
          transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
      }

      .scroll-reveal.revealed {
        opacity: 1;
        transform: translateY(0);
      }

      /* 交错动画 */
      .stagger-item {
        opacity: 0;
        transform: translateY(20px);
        transition: 
          opacity 0.6s ease,
          transform 0.6s ease;
      }

      .stagger-item.revealed {
        opacity: 1;
        transform: translateY(0);
      }

      /* 减少动画偏好 */
      @media (prefers-reduced-motion: reduce) {
        .page-transition-overlay,
        .page-loaded main,
        .scroll-reveal,
        .stagger-item {
          animation: none !important;
          transition: none !important;
          opacity: 1 !important;
          transform: none !important;
        }
      }
    </style>
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- 页面过渡遮罩 -->
    <div id="page-transition-overlay" class="page-transition-overlay"></div>
    
    <!-- 全局效果层 -->
    <div class="mist-layer"></div>
    <ParticleField />
    <MouseEffects />
    <DynamicBackground />
    
    <!-- 头部导航 -->
    <Header />
    
    <!-- 主内容区 -->
    <main class="flex-1 relative z-20" data-page-transition>
      <slot />
    </main>
    
    <!-- 页脚 -->
    <Footer />
    
    <!-- 动效控制器 -->
    <MotionController />
    
    <!-- 页面过渡脚本 -->
    <script>
      /**
       * 页面过渡与动画控制
       */
      class PageTransitionController {
        private overlay: HTMLElement | null;
        private isTransitioning: boolean = false;

        constructor() {
          this.overlay = document.getElementById('page-transition-overlay');
          this.init();
        }

        private init(): void {
          // 监听页面加载
          window.addEventListener('load', () => {
            document.body.classList.add('page-loaded');
          });

          // 监听链接点击（内部导航）
          document.addEventListener('click', this.handleLinkClick.bind(this));

          // 监听浏览器前进后退
          window.addEventListener('popstate', () => {
            this.animateTransition('fade');
          });

          // 初始化滚动观察器
          this.initScrollObserver();
        }

        private handleLinkClick(e: MouseEvent): void {
          const target = e.target as HTMLElement;
          const link = target.closest('a[href]') as HTMLAnchorElement | null;
          
          if (!link) return;

          const href = link.getAttribute('href');
          if (!href) return;

          // 跳过外部链接、锚点、特殊链接
          if (
            href.startsWith('http') ||
            href.startsWith('https') ||
            href.startsWith('mailto:') ||
            href.startsWith('tel:') ||
            href.startsWith('#') ||
            href.startsWith('javascript:') ||
            link.target === '_blank'
          ) {
            return;
          }

          // 执行过渡动画
          e.preventDefault();
          this.transitionTo(href);
        }

        private async transitionTo(href: string): Promise<void> {
          if (this.isTransitioning) return;
          this.isTransitioning = true;

          // 离场动画
          await this.animateTransition('fade-in');

          // 导航
          window.location.href = href;
        }

        private async animateTransition(type: 'fade-in' | 'fade-out'): Promise<void> {
          if (!this.overlay) return;

          const duration = type === 'fade-in' ? 300 : 300;

          return new Promise((resolve) => {
            if (type === 'fade-in') {
              this.overlay!.classList.add('active');
            }

            setTimeout(() => {
              if (type === 'fade-out') {
                this.overlay!.classList.remove('active');
              }
              this.isTransitioning = false;
              resolve();
            }, duration);
          });
        }

        private initScrollObserver(): void {
          const observerOptions = {
            root: null,
            rootMargin: '0px 0px -50px 0px',
            threshold: 0.1,
          };

          const observer = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('revealed');
                observer.unobserve(entry.target);
              }
            });
          }, observerOptions);

          // 观察所有需要滚动触发的元素
          document.querySelectorAll('.scroll-reveal, .stagger-item').forEach((el) => {
            observer.observe(el);
          });
        }

        // 公开方法：手动触发入场
        public triggerPageEnter(): void {
          document.body.classList.add('page-loaded');
        }
      }

      // 初始化
      document.addEventListener('DOMContentLoaded', () => {
        new PageTransitionController();
      });

      // Astro 页面切换监听
      document.addEventListener('astro:page-load', () => {
        new PageTransitionController();
      });
    </script>
  </body>
</html>
