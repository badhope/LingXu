---
import { MODULES, getModuleById } from '@data/modules';
import { withBase } from '../lib/utils';

interface Props {
  moduleId: string;
  title?: string;
  description?: string;
}

const { moduleId, title, description } = Astro.props;
const module = getModuleById(moduleId);

if (!module) {
  return Astro.redirect(withBase('/home'));
}
---

<!DOCTYPE html>
<html lang="zh-CN" data-module={moduleId}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title ? `${title} - ` : ''}{module.char} {module.name} - 灵墟</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
  </head>
  <body class="module-body" style={`--module-color: ${module.color}; --module-bg: ${module.bgGradient};`}>
    <div class="bg-effects">
      <canvas id="module-particles" class="particle-canvas"></canvas>
      <div class="gradient-overlay"></div>
      <div class="parallax-layer layer-1" data-depth="0.05"></div>
      <div class="parallax-layer layer-2" data-depth="0.1"></div>
      <div class="parallax-layer layer-3" data-depth="0.15"></div>
      <div class="floating-orbs"></div>
    </div>

    <div class="module-container">
      <nav class="module-nav">
        <a href={withBase('/home')} class="back-btn">
          <span class="back-icon">←</span>
          <span class="back-text">返回</span>
        </a>
        <div class="module-tabs">
          {MODULES.map((m) => (
            <a
              href={m.href}
              class={`module-tab ${m.id === moduleId ? 'active' : ''}`}
              style={`--tab-color: ${m.color}`}
            >
              <span class="tab-char">{m.char}</span>
              <span class="tab-name">{m.name}</span>
            </a>
          ))}
        </div>
        <div class="nav-actions">
          <a href={withBase('/search')} class="action-btn">🔍</a>
          <a href={withBase('/bookmarks')} class="action-btn">📖</a>
          <a href={withBase('/profile')} class="action-btn">👤</a>
        </div>
      </nav>

      <header class="module-header">
        <div class="header-bg"></div>
        <div class="header-content">
          <h1 class="module-title">
            <span class="title-char">{module.char}</span>
            <span class="title-name">{module.name}</span>
          </h1>
          <p class="module-desc">{module.description}</p>
        </div>
        <div class="header-decoration">
          <div class="deco-line"></div>
          <div class="deco-dot"></div>
          <div class="deco-line"></div>
        </div>
      </header>

      <main class="module-main">
        <slot />
      </main>

      <aside class="module-sidebar">
        <div class="submodule-list">
          <h3 class="sidebar-title">功能</h3>
          {module.subModules.map((sub) => (
            <a href={sub.href} class="submodule-item">
              <span class="sub-icon">{sub.icon}</span>
              <span class="sub-name">{sub.name}</span>
            </a>
          ))}
        </div>
      </aside>

      <footer class="module-footer">
        <div class="footer-content">
          <span class="footer-text">天地玄黄 · 宇宙洪荒</span>
        </div>
      </footer>
    </div>

    <script define:vars={{ moduleColor: module.color }}>
      class ModuleParticleBackground {
        constructor() {
          this.canvas = document.getElementById('module-particles');
          if (!this.canvas) return;
          this.ctx = this.canvas.getContext('2d');
          this.particles = [];
          this.isMobile = window.innerWidth < 768;
          this.animationId = null;
          this.lastTime = 0;
          this.targetFPS = 45;
          this.mouseX = 0;
          this.mouseY = 0;
          this.init();
        }

        init() {
          this.resize();
          this.createParticles();
          this.bindEvents();
          this.animate();
        }

        resize() {
          if (!this.canvas) return;
          this.canvas.width = window.innerWidth;
          this.canvas.height = window.innerHeight;
        }

        createParticles() {
          const density = this.isMobile ? 30 : 60;
          this.particles = [];
          for (let i = 0; i < density; i++) {
            this.particles.push({
              x: Math.random() * this.canvas.width,
              y: Math.random() * this.canvas.height,
              size: Math.random() * 1.5 + 0.5,
              speedX: (Math.random() - 0.5) * 0.2,
              speedY: (Math.random() - 0.5) * 0.2,
              opacity: Math.random() * 0.3 + 0.1,
              hue: 38 + Math.random() * 20 - 10
            });
          }
        }

        bindEvents() {
          let resizeTimeout;
          window.addEventListener('resize', () => {
            clearTimeout(resizeTimeout);
            resizeTimeout = setTimeout(() => {
              this.resize();
              this.createParticles();
            }, 200);
          }, { passive: true });

          document.addEventListener('mousemove', (e) => {
            this.mouseX = e.clientX;
            this.mouseY = e.clientY;
          }, { passive: true });
        }

        animate = (currentTime = 0) => {
          if (!this.canvas || !this.ctx) return;

          const frameInterval = 1000 / this.targetFPS;
          const elapsed = currentTime - this.lastTime;
          if (elapsed < frameInterval) {
            this.animationId = requestAnimationFrame(this.animate);
            return;
          }
          this.lastTime = currentTime - (elapsed % frameInterval);

          this.ctx.clearRect(0, 0, this.canvas.width, this.canvas.height);

          this.particles.forEach((p) => {
            p.x += p.speedX;
            p.y += p.speedY;

            const dx = this.mouseX - p.x;
            const dy = this.mouseY - p.y;
            const dist = Math.sqrt(dx * dx + dy * dy);
            if (dist < 120) {
              const force = (120 - dist) / 120 * 0.015;
              p.x -= dx * force;
              p.y -= dy * force;
            }

            if (p.x < 0) p.x = this.canvas.width;
            if (p.x > this.canvas.width) p.x = 0;
            if (p.y < 0) p.y = this.canvas.height;
            if (p.y > this.canvas.height) p.y = 0;

            this.ctx.beginPath();
            this.ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
            this.ctx.fillStyle = `hsla(${p.hue}, 50%, 60%, ${p.opacity})`;
            this.ctx.fill();
          });

          for (let i = 0; i < this.particles.length; i++) {
            for (let j = i + 1; j < this.particles.length; j++) {
              const dx = this.particles[i].x - this.particles[j].x;
              const dy = this.particles[i].y - this.particles[j].y;
              const dist = Math.sqrt(dx * dx + dy * dy);
              if (dist < 80) {
                this.ctx.beginPath();
                this.ctx.moveTo(this.particles[i].x, this.particles[i].y);
                this.ctx.lineTo(this.particles[j].x, this.particles[j].y);
                this.ctx.strokeStyle = `hsla(38, 50%, 60%, ${0.08 * (1 - dist / 80)})`;
                this.ctx.lineWidth = 0.3;
                this.ctx.stroke();
              }
            }
          }

          this.animationId = requestAnimationFrame(this.animate);
        };

        destroy() {
          if (this.animationId) {
            cancelAnimationFrame(this.animationId);
          }
        }
      }

      class ModuleParallax {
        constructor() {
          this.layers = document.querySelectorAll('.parallax-layer');
          if (this.layers.length === 0) return;
          this.bindEvents();
        }

        bindEvents() {
          let lastY = 0;
          window.addEventListener('scroll', () => {
            lastY = window.scrollY;
            this.update(lastY);
          }, { passive: true });
        }

        update(scrollY) {
          this.layers.forEach((layer) => {
            const depth = parseFloat(layer.dataset.depth || '0.1');
            const movement = scrollY * depth * 0.3;
            layer.style.transform = `translateY(${movement}px)`;
          });
        }
      }

      function initModuleEffects() {
        new ModuleParticleBackground();
        new ModuleParallax();
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initModuleEffects);
      } else {
        initModuleEffects();
      }

      document.addEventListener('astro:page-load', initModuleEffects);
    </script>

    <style define:vars={{ moduleColor: module.color }}>
      .bg-effects {
        position: fixed;
        inset: 0;
        z-index: 0;
        overflow: hidden;
        pointer-events: none;
      }

      .particle-canvas {
        position: absolute;
        inset: 0;
        opacity: 0.6;
      }

      .gradient-overlay {
        position: absolute;
        inset: 0;
        background: 
          radial-gradient(ellipse at 20% 0%, rgba(201, 162, 39, 0.06) 0%, transparent 50%),
          radial-gradient(ellipse at 80% 100%, rgba(107, 74, 138, 0.05) 0%, transparent 50%);
        animation: gradientPulse 20s ease-in-out infinite;
      }

      @keyframes gradientPulse {
        0%, 100% { opacity: 0.8; }
        50% { opacity: 1; }
      }

      .parallax-layer {
        position: absolute;
        border-radius: 50%;
        filter: blur(40px);
        opacity: 0.4;
        transition: transform 0.1s ease-out;
      }

      .layer-1 {
        width: 400px;
        height: 400px;
        top: -100px;
        left: -100px;
        background: radial-gradient(circle, rgba(201, 162, 39, 0.08) 0%, transparent 70%);
      }

      .layer-2 {
        width: 500px;
        height: 500px;
        top: 30%;
        right: -150px;
        background: radial-gradient(circle, rgba(107, 74, 138, 0.06) 0%, transparent 70%);
      }

      .layer-3 {
        width: 350px;
        height: 350px;
        bottom: 10%;
        left: 20%;
        background: radial-gradient(circle, rgba(168, 120, 184, 0.05) 0%, transparent 70%);
      }

      .floating-orbs {
        position: absolute;
        inset: 0;
        background-image: 
          radial-gradient(1px 1px at 20% 30%, rgba(201, 162, 39, 0.4) 0%, transparent 100%),
          radial-gradient(1px 1px at 40% 70%, rgba(201, 162, 39, 0.3) 0%, transparent 100%),
          radial-gradient(1px 1px at 60% 20%, rgba(201, 162, 39, 0.35) 0%, transparent 100%),
          radial-gradient(1px 1px at 80% 50%, rgba(201, 162, 39, 0.25) 0%, transparent 100%);
        background-size: 200px 200px;
        animation: orbFloat 30s linear infinite;
      }

      @keyframes orbFloat {
        0% { transform: translateY(0); }
        100% { transform: translateY(-200px); }
      }

      :root {
        --module-color: #c9a227;
        --module-bg: radial-gradient(ellipse at center, #0a0a0a 0%, #050505 100%);
      }

      .module-body {
        margin: 0;
        padding: 0;
        background: var(--module-bg);
        color: #e8d48b;
        min-height: 100vh;
        font-family: 'Noto Serif SC', 'Songti SC', serif;
      }

      .module-container {
        display: grid;
        grid-template-columns: 220px 1fr 280px;
        grid-template-rows: auto 1fr auto;
        min-height: 100vh;
        gap: 0;
        position: relative;
        z-index: 1;
      }

      .module-nav {
        grid-column: 1 / -1;
        display: flex;
        align-items: center;
        padding: 1rem 2rem;
        background: rgba(10, 10, 15, 0.95);
        border-bottom: 1px solid rgba(201, 162, 39, 0.2);
        position: sticky;
        top: 0;
        z-index: 100;
      }

      .back-btn {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: #c9a227;
        text-decoration: none;
        padding: 0.5rem 1rem;
        border-radius: 4px;
        transition: all 0.3s ease;
      }

      .back-btn:hover {
        background: rgba(201, 162, 39, 0.1);
      }

      .module-tabs {
        display: flex;
        gap: 0.5rem;
        margin-left: 2rem;
      }

      .module-tab {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 0.5rem 1rem;
        text-decoration: none;
        color: #888;
        border-radius: 4px;
        transition: all 0.3s ease;
      }

      .module-tab:hover,
      .module-tab.active {
        color: var(--tab-color);
        background: rgba(var(--tab-color), 0.1);
      }

      .module-tab.active {
        background: rgba(201, 162, 39, 0.1);
        color: #c9a227;
      }

      .tab-char {
        font-size: 1.5rem;
        line-height: 1;
      }

      .tab-name {
        font-size: 0.7rem;
        margin-top: 0.25rem;
      }

      .nav-actions {
        margin-left: auto;
        display: flex;
        gap: 0.5rem;
      }

      .action-btn {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(201, 162, 39, 0.2);
        border-radius: 4px;
        text-decoration: none;
        font-size: 1.2rem;
        transition: all 0.3s ease;
      }

      .action-btn:hover {
        background: rgba(201, 162, 39, 0.1);
        border-color: #c9a227;
      }

      .module-header {
        padding: 3rem 2rem;
        text-align: center;
        position: relative;
        grid-column: 1 / -1;
      }

      .header-bg {
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse at center top, var(--module-color) 0%, transparent 60%);
        opacity: 0.1;
      }

      .header-content {
        position: relative;
        z-index: 1;
      }

      .module-title {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1rem;
        margin: 0;
      }

      .title-char {
        font-size: 4rem;
        color: var(--module-color);
        text-shadow: 0 0 30px var(--module-color);
      }

      .title-name {
        font-size: 2rem;
        letter-spacing: 0.3em;
        color: #e8d48b;
      }

      .module-desc {
        margin-top: 1rem;
        font-size: 1rem;
        color: #888;
        letter-spacing: 0.1em;
      }

      .header-decoration {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1rem;
        margin-top: 2rem;
      }

      .deco-line {
        width: 100px;
        height: 1px;
        background: linear-gradient(to right, transparent, var(--module-color), transparent);
      }

      .deco-dot {
        width: 8px;
        height: 8px;
        background: var(--module-color);
        border-radius: 50%;
        box-shadow: 0 0 10px var(--module-color);
      }

      .module-sidebar {
        padding: 2rem;
        border-right: 1px solid rgba(201, 162, 39, 0.1);
        background: rgba(5, 5, 8, 0.5);
      }

      .sidebar-title {
        font-size: 0.8rem;
        color: #666;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        margin: 0 0 1rem 0;
      }

      .submodule-list {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
      }

      .submodule-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.75rem 1rem;
        background: rgba(10, 10, 15, 0.6);
        border: 1px solid rgba(201, 162, 39, 0.1);
        border-radius: 4px;
        text-decoration: none;
        color: #aaa;
        transition: all 0.3s ease;
      }

      .submodule-item:hover {
        background: rgba(201, 162, 39, 0.1);
        border-color: var(--module-color);
        color: var(--module-color);
        transform: translateX(4px);
      }

      .sub-icon {
        font-size: 1.25rem;
      }

      .sub-name {
        font-size: 0.95rem;
      }

      .module-main {
        padding: 2rem;
        min-height: 60vh;
      }

      .module-footer {
        grid-column: 1 / -1;
        padding: 1.5rem;
        text-align: center;
        border-top: 1px solid rgba(201, 162, 39, 0.1);
        background: rgba(5, 5, 8, 0.8);
      }

      .footer-text {
        font-size: 0.8rem;
        color: #666;
        letter-spacing: 0.3em;
      }

      @media (max-width: 1200px) {
        .module-container {
          grid-template-columns: 200px 1fr;
        }

        .module-sidebar {
          display: none;
        }
      }

      @media (max-width: 768px) {
        .module-container {
          grid-template-columns: 1fr;
        }

        .module-tabs {
          display: none;
        }

        .title-char {
          font-size: 3rem;
        }

        .title-name {
          font-size: 1.5rem;
        }

        .nav-actions {
          gap: 0.25rem;
        }

        .action-btn {
          width: 36px;
          height: 36px;
        }
      }
    </style>
  </body>
</html>
