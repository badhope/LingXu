---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_CONFIG } from '../lib/constants';
---

<BaseLayout title="灵墟 - 入口">
  <div class="intro-container">
    <div class="stars-container">
      <canvas id="stars-canvas"></canvas>
    </div>
    <div class="nebula-layer"></div>
    <div class="mist"></div>

    <div class="content-wrapper">
      <div class="flip-card" id="flipCard">
        <div class="flip-card-inner">
          <div class="flip-card-front">
            <button class="taiji-entry" id="taijiEntry" aria-label="进入灵墟">
              <div class="taiji">
                <div class="taiji-inner">
                  <div class="yin-yang">
                    <div class="dot yang"></div>
                    <div class="dot yin"></div>
                  </div>
                  <svg class="bagua" viewBox="0 0 200 200">
                    <g class="trigrams">
                      <text x="100" y="25" text-anchor="middle" class="trigram">☰</text>
                      <text x="175" y="100" text-anchor="middle" class="trigram">☱</text>
                      <text x="100" y="175" text-anchor="middle" class="trigram">☲</text>
                      <text x="25" y="100" text-anchor="middle" class="trigram">☴</text>
                    </g>
                  </svg>
                </div>
                <div class="orbit-ring ring-1"></div>
                <div class="orbit-ring ring-2"></div>
                <div class="orbit-ring ring-3"></div>
              </div>
              <div class="entry-hint">
                <span>点击进入</span>
              </div>
            </button>
          </div>
          <div class="flip-card-back">
            <div class="back-content">
              <h2>灵墟</h2>
              <p>末法时代 · 失落修行文明档案馆</p>
              <div class="manifesto">
                <span>天地玄黄</span>
                <span>宇宙洪荒</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="ambient-orbs">
      <div class="orb orb-1"></div>
      <div class="orb orb-2"></div>
      <div class="orb orb-3"></div>
    </div>
  </div>

  <style>
    .intro-container {
      position: fixed;
      inset: 0;
      background: radial-gradient(ellipse at center, #0a0a0a 0%, #050505 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }

    .stars-container {
      position: absolute;
      inset: 0;
      z-index: 1;
    }

    #stars-canvas {
      width: 100%;
      height: 100%;
      will-change: transform;
    }

    .nebula-layer {
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse at 20% 30%, rgba(201, 162, 39, 0.03) 0%, transparent 50%),
        radial-gradient(ellipse at 80% 70%, rgba(107, 74, 138, 0.03) 0%, transparent 50%),
        radial-gradient(ellipse at 50% 50%, rgba(64, 176, 176, 0.02) 0%, transparent 60%);
      animation: nebulaPulse 15s ease-in-out infinite;
      will-change: opacity;
    }

    @keyframes nebulaPulse {
      0%, 100% { opacity: 0.6; transform: scale(1); }
      50% { opacity: 1; transform: scale(1.05); }
    }

    .mist {
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse at 50% 50%, transparent 0%, rgba(5, 5, 5, 0.7) 100%),
        linear-gradient(to bottom, transparent 0%, rgba(5, 5, 5, 0.3) 100%);
      pointer-events: none;
      z-index: 2;
    }

    .content-wrapper {
      position: relative;
      z-index: 10;
      perspective: 1000px;
    }

    .flip-card {
      width: 320px;
      height: 320px;
      cursor: pointer;
    }

    .flip-card-inner {
      position: relative;
      width: 100%;
      height: 100%;
      transform-style: preserve-3d;
      transition: transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .flip-card:hover .flip-card-inner {
      transform: rotateY(180deg);
    }

    .flip-card-front,
    .flip-card-back {
      position: absolute;
      inset: 0;
      backface-visibility: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .flip-card-back {
      transform: rotateY(180deg);
      background: radial-gradient(ellipse at center, rgba(201, 162, 39, 0.1) 0%, rgba(10, 10, 15, 0.95) 100%);
      border: 1px solid rgba(201, 162, 39, 0.3);
      border-radius: 12px;
      box-shadow:
        0 0 60px rgba(201, 162, 39, 0.2),
        inset 0 0 60px rgba(201, 162, 39, 0.05);
    }

    .back-content {
      text-align: center;
      padding: 2rem;
    }

    .back-content h2 {
      font-size: 3rem;
      color: #e8d48b;
      letter-spacing: 0.3em;
      margin: 0 0 1rem 0;
      text-shadow: 0 0 30px rgba(201, 162, 39, 0.5);
    }

    .back-content p {
      color: #888;
      font-size: 0.9rem;
      letter-spacing: 0.2em;
      margin: 0 0 2rem 0;
    }

    .manifesto {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .manifesto span {
      color: #c9a227;
      font-size: 1.1rem;
      letter-spacing: 0.5em;
      animation: fadeSlide 0.8s ease backwards;
    }

    .manifesto span:nth-child(2) {
      animation-delay: 0.2s;
    }

    @keyframes fadeSlide {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .taiji-entry {
      position: relative;
      width: 280px;
      height: 280px;
      background: transparent;
      border: none;
      cursor: pointer;
      transform-style: preserve-3d;
    }

    .taiji {
      position: relative;
      width: 100%;
      height: 100%;
      animation: rotate 20s linear infinite;
      transform-style: preserve-3d;
    }

    .taiji-entry:hover .taiji {
      animation: rotate 8s linear infinite;
    }

    .taiji-entry:hover .yang {
      transform: translateX(-50%) scale(1.15);
    }

    .taiji-entry:hover .yin {
      transform: translateX(-50%) scale(1.15);
    }

    .taiji-entry:hover .orbit-ring {
      animation-duration: 3s;
    }

    .taiji-entry:hover .entry-hint {
      opacity: 1;
    }

    .taiji-inner {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 160px;
      height: 160px;
      border-radius: 50%;
      background: conic-gradient(from 0deg, #c9a227 0deg, #e8d48b 90deg, #c9a227 180deg, #1a1a1a 270deg, #c9a227 360deg);
      box-shadow:
        0 0 60px rgba(201, 162, 39, 0.5),
        0 0 120px rgba(201, 162, 39, 0.25),
        inset 0 0 40px rgba(0, 0, 0, 0.5);
      will-change: transform;
    }

    .yin-yang {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 140px;
      height: 140px;
      border-radius: 50%;
      background: linear-gradient(to right, #c9a227 50%, #1a1a1a 50%);
      animation: counter-rotate 20s linear infinite;
      will-change: transform;
    }

    .taiji-entry:hover .yin-yang {
      animation-duration: 8s;
    }

    .dot {
      position: absolute;
      width: 60px;
      height: 60px;
      border-radius: 50%;
      transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      will-change: transform;
    }

    .dot.yang {
      top: 10px;
      left: 50%;
      transform: translateX(-50%);
      background: radial-gradient(circle at 30% 30%, #f0e6c8, #c9a227);
      box-shadow: 0 0 20px rgba(201, 162, 39, 0.5);
    }

    .dot.yin {
      bottom: 10px;
      left: 50%;
      transform: translateX(-50%);
      background: radial-gradient(circle at 30% 30%, #4a4a4a, #1a1a1a);
      box-shadow: 0 0 20px rgba(0, 0, 0, 0.5);
    }

    .bagua {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 240px;
      height: 240px;
      opacity: 0.7;
      animation: counter-rotate 30s linear infinite;
      will-change: transform;
    }

    .trigram {
      font-size: 24px;
      fill: #c9a227;
      font-family: serif;
    }

    .orbit-ring {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      border: 1px solid rgba(201, 162, 39, 0.3);
      border-radius: 50%;
      animation: pulse-ring 3s ease-in-out infinite;
      will-change: transform, opacity;
    }

    .ring-1 { width: 220px; height: 220px; animation-delay: 0s; }
    .ring-2 { width: 260px; height: 260px; animation-delay: 0.5s; }
    .ring-3 { width: 300px; height: 300px; animation-delay: 1s; }

    .entry-hint {
      position: absolute;
      bottom: -40px;
      left: 50%;
      transform: translateX(-50%);
      color: #c9a227;
      font-size: 14px;
      letter-spacing: 4px;
      opacity: 0;
      transition: opacity 0.5s ease;
      text-shadow: 0 0 10px rgba(201, 162, 39, 0.5);
      animation: float 2s ease-in-out infinite;
    }

    @keyframes rotate {
      from { transform: rotateY(0deg); }
      to { transform: rotateY(360deg); }
    }

    @keyframes counter-rotate {
      from { transform: translate(-50%, -50%) rotateY(0deg); }
      to { transform: translate(-50%, -50%) rotateY(-360deg); }
    }

    @keyframes pulse-ring {
      0%, 100% {
        opacity: 0.3;
        transform: translate(-50%, -50%) scale(1);
      }
      50% {
        opacity: 0.7;
        transform: translate(-50%, -50%) scale(1.05);
      }
    }

    @keyframes float {
      0%, 100% { transform: translateX(-50%) translateY(0); }
      50% { transform: translateX(-50%) translateY(-5px); }
    }

    .ambient-orbs {
      position: absolute;
      inset: 0;
      pointer-events: none;
      z-index: 1;
    }

    .orb {
      position: absolute;
      border-radius: 50%;
      filter: blur(60px);
      animation: orbFloat 20s ease-in-out infinite;
      will-change: transform;
    }

    .orb-1 {
      width: 300px;
      height: 300px;
      background: radial-gradient(circle, rgba(201, 162, 39, 0.15) 0%, transparent 70%);
      top: 10%;
      left: 10%;
      animation-delay: 0s;
    }

    .orb-2 {
      width: 250px;
      height: 250px;
      background: radial-gradient(circle, rgba(107, 74, 138, 0.1) 0%, transparent 70%);
      bottom: 20%;
      right: 15%;
      animation-delay: -7s;
    }

    .orb-3 {
      width: 200px;
      height: 200px;
      background: radial-gradient(circle, rgba(64, 176, 176, 0.08) 0%, transparent 70%);
      top: 40%;
      left: 60%;
      animation-delay: -14s;
    }

    @keyframes orbFloat {
      0%, 100% { transform: translate(0, 0) scale(1); }
      25% { transform: translate(20px, -30px) scale(1.1); }
      50% { transform: translate(-10px, 20px) scale(0.95); }
      75% { transform: translate(30px, 10px) scale(1.05); }
    }

    .intro-container.transitioning {
      animation: fadeOut 1s ease forwards;
    }

    @keyframes fadeOut {
      to {
        opacity: 0;
        pointer-events: none;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .taiji, .yin-yang, .bagua, .orbit-ring, .entry-hint, .nebula-layer, .orb {
        animation: none;
      }
      .flip-card:hover .flip-card-inner {
        transform: none;
      }
    }

    @media (max-width: 480px) {
      .flip-card {
        width: 260px;
        height: 260px;
      }
      .taiji-entry {
        width: 220px;
        height: 220px;
      }
      .taiji-inner {
        width: 120px;
        height: 120px;
      }
      .yin-yang {
        width: 105px;
        height: 105px;
      }
      .dot {
        width: 45px;
        height: 45px;
      }
      .dot.yang { top: 7px; }
      .dot.yin { bottom: 7px; }
      .bagua {
        width: 180px;
        height: 180px;
      }
      .ring-1 { width: 170px; height: 170px; }
      .ring-2 { width: 200px; height: 200px; }
      .ring-3 { width: 230px; height: 230px; }
    }
  </style>

  <script>
    class StarsCanvas {
      constructor(canvas) {
        this.canvas = canvas;
        this.ctx = canvas.getContext('2d');
        this.stars = [];
        this.shootingStars = [];
        this.maxStars = 150;
        this.animationId = 0;
        this.mouseX = 0;
        this.mouseY = 0;
        this.init();
      }

      init() {
        this.resize();
        this.createStars();
        this.bindEvents();
        this.animate();
      }

      resize() {
        this.canvas.width = window.innerWidth * window.devicePixelRatio;
        this.canvas.height = window.innerHeight * window.devicePixelRatio;
        this.ctx.scale(window.devicePixelRatio, window.devicePixelRatio);
      }

      createStars() {
        this.stars = [];
        for (let i = 0; i < this.maxStars; i++) {
          this.stars.push({
            x: Math.random() * window.innerWidth,
            y: Math.random() * window.innerHeight,
            radius: Math.random() * 1.5 + 0.5,
            alpha: Math.random(),
            alphaChange: (Math.random() - 0.5) * 0.02,
            twinkleSpeed: Math.random() * 0.02 + 0.005
          });
        }
      }

      bindEvents() {
        window.addEventListener('resize', () => {
          this.resize();
          this.createStars();
        });

        window.addEventListener('mousemove', (e) => {
          this.mouseX = e.clientX;
          this.mouseY = e.clientY;
        });

        document.addEventListener('click', () => {
          if (Math.random() > 0.7) {
            this.createShootingStar();
          }
        });
      }

      createShootingStar() {
        this.shootingStars.push({
          x: Math.random() * window.innerWidth,
          y: Math.random() * window.innerHeight * 0.5,
          length: Math.random() * 80 + 40,
          speed: Math.random() * 8 + 6,
          angle: Math.PI / 4 + (Math.random() - 0.5) * 0.3,
          alpha: 1,
          decay: Math.random() * 0.015 + 0.01
        });
      }

      animate() {
        this.ctx.clearRect(0, 0, window.innerWidth, window.innerHeight);

        this.stars.forEach(star => {
          star.alpha += star.alphaChange;
          if (star.alpha <= 0.1 || star.alpha >= 1) {
            star.alphaChange *= -1;
          }

          const twinkle = Math.sin(Date.now() * star.twinkleSpeed) * 0.3 + 0.7;

          this.ctx.beginPath();
          this.ctx.arc(star.x, star.y, star.radius, 0, Math.PI * 2);
          this.ctx.fillStyle = `rgba(232, 212, 139, ${star.alpha * twinkle})`;
          this.ctx.fill();

          if (star.radius > 1) {
            this.ctx.beginPath();
            this.ctx.arc(star.x, star.y, star.radius * 2, 0, Math.PI * 2);
            this.ctx.fillStyle = `rgba(232, 212, 139, ${star.alpha * twinkle * 0.1})`;
            this.ctx.fill();
          }
        });

        this.shootingStars = this.shootingStars.filter(ss => {
          ss.x += Math.cos(ss.angle) * ss.speed;
          ss.y += Math.sin(ss.angle) * ss.speed;
          ss.alpha -= ss.decay;

          if (ss.alpha <= 0) return false;

          const gradient = this.ctx.createLinearGradient(
            ss.x, ss.y,
            ss.x - Math.cos(ss.angle) * ss.length,
            ss.y - Math.sin(ss.angle) * ss.length
          );
          gradient.addColorStop(0, `rgba(232, 212, 139, ${ss.alpha})`);
          gradient.addColorStop(1, 'rgba(232, 212, 139, 0)');

          this.ctx.beginPath();
          this.ctx.moveTo(ss.x, ss.y);
          this.ctx.lineTo(
            ss.x - Math.cos(ss.angle) * ss.length,
            ss.y - Math.sin(ss.angle) * ss.length
          );
          this.ctx.strokeStyle = gradient;
          this.ctx.lineWidth = 2;
          this.ctx.lineCap = 'round';
          this.ctx.stroke();

          return true;
        });

        this.animationId = requestAnimationFrame(() => this.animate());
      }
    }

    const canvas = document.getElementById('stars-canvas');
    if (canvas) {
      new StarsCanvas(canvas);
    }

    const flipCard = document.getElementById('flipCard');
    const taijiEntry = document.getElementById('taijiEntry');
    const container = document.querySelector('.intro-container');

    flipCard?.addEventListener('click', () => {
      container?.classList.add('transitioning');
      setTimeout(() => {
        window.location.href = '/LingXu/home';
      }, 800);
    });

    taijiEntry?.addEventListener('click', (e) => {
      e.stopPropagation();
      container?.classList.add('transitioning');
      setTimeout(() => {
        window.location.href = '/LingXu/home';
      }, 800);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        container?.classList.add('transitioning');
        setTimeout(() => {
          window.location.href = '/LingXu/home';
        }, 800);
      }
    });
  </script>
</BaseLayout>