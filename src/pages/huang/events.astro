---
import ModuleLayout from '../../layouts/ModuleLayout.astro';

const events = [
  { name: '盘古开天', era: '洪荒', significance: '极高', desc: '混沌中诞生的巨神盘古，以神斧劈开混沌，清气上升为天，浊气下沉为地。此后天地分离，万物始生。', participants: ['盘古'], result: '天地开辟' },
  { name: '龙汉初劫', era: '洪荒', significance: '极高', desc: '龙族、凤凰族、麒麟族三族为争夺天地霸主之位爆发大战。三族损伤惨重，从此衰落。', participants: ['祖龙', '元凤', '始麒麟'], result: '三族衰落' },
  { name: '巫妖大战', era: '洪荒', significance: '极高', desc: '巫族与妖族天庭爆发全面战争。十二祖巫与妖族圣人决战，最终两败俱伤，退出历史舞台。', participants: ['十二祖巫', '帝俊', '东皇太一'], result: '两族退出' },
  { name: '后羿射日', era: '洪荒', significance: '高', desc: '帝俊十子化为太阳为祸人间。后羿得西王母赐神弓，射落九日，只余其一。嫦娥因此偷药奔月。', participants: ['后羿', '嫦娥', '帝俊'], result: '九日陨落' },
  { name: '共工触山', era: '洪荒', significance: '高', desc: '水神共工与火神祝融大战，共工败北，怒触不周山。天柱折断，天地倾斜，引发女娲补天。', participants: ['共工', '祝融'], result: '天柱折断' },
  { name: '女娲补天', era: '洪荒', significance: '极高', desc: '天柱折断后，女娲炼五色石补天，斩巨龟足撑四极，平定洪水凶兽，还天下太平。', participants: ['女娲'], result: '天地平定' },
  { name: '封神大劫', era: '封神', significance: '极高', desc: '昊天上帝命十二金仙称臣，三教共议封神榜。阐截二教争斗，三百六十五路正神归位。', participants: ['姜子牙', '申公豹', '十二金仙'], result: '众神归位' },
  { name: '武王伐纣', era: '封神', significance: '高', desc: '纣王失德，妲己乱商。周文王、武王在姜子牙辅佐下起兵伐纣，建立周朝。', participants: ['纣王', '妲己', '周文王', '姜子牙'], result: '商灭周兴' },
  { name: '大闹天宫', era: '西游', significance: '高', desc: '孙悟空学艺归来，大闹天宫，击败十万天兵天将。最终被如来佛祖镇压于五行山下。', participants: ['孙悟空', '玉帝', '如来'], result: '被压五行山' },
  { name: '西天取经', era: '西游', significance: '极高', desc: '唐三藏在孙悟空、猪八戒、沙僧保护下，历经九九八十一难，前往西天取经，最终得道成佛。', participants: ['唐三藏', '孙悟空', '猪八戒', '沙僧'], result: '取经成功' },
  { name: '仙道大兴', era: '仙道', significance: '高', desc: '人族修行之法逐渐完善，各大仙道门派建立。金丹大道成为主流修行之路。', participants: ['诸多宗师'], result: '门派林立' },
  { name: '末法降临', era: '末法', significance: '极高', desc: '天地灵气逐渐稀薄，修行变得极为艰难。诸多大能选择沉睡，等待灵气复苏。', participants: ['诸多大能'], result: '灵气衰退' },
];

const eraColors: Record<string, string> = {
  '洪荒': '#f08040',
  '封神': '#4080f0',
  '西游': '#ffa500',
  '仙道': '#40f080',
  '末法': '#a0a0a0',
};
---

<ModuleLayout moduleId="huang" title="事件" description="修行界重大历史事件">
  <div class="events-page">
    <section class="intro-section">
      <h2>历史事件</h2>
      <p>修行界之兴衰，皆系于重大事件。开天辟地、龙汉大劫、巫妖大战、封神大劫……每一次大劫，都是天地重新洗牌的契机。知其因果，方能趋吉避凶。</p>
    </section>

    <section class="events-timeline">
      <h2>大事年表</h2>
      <div class="events-list">
        {events.map(evt => (
          <div class="event-card">
            <div class="event-era-tag" style={`background: ${eraColors[evt.era] || '#808080'}`}>
              {evt.era}
            </div>
            <div class="event-content">
              <div class="event-header">
                <h3>{evt.name}</h3>
                <span class="event-significance" data-level={evt.significance}>
                  {evt.significance}
                </span>
              </div>
              <p class="event-desc">{evt.desc}</p>
              <div class="event-details">
                <div class="event-participants">
                  <span class="detail-label">参与:</span>
                  <span>{evt.participants.join('、')}</span>
                </div>
                <div class="event-result">
                  <span class="detail-label">结果:</span>
                  <span>{evt.result}</span>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>
  </div>
</ModuleLayout>

<style>
  .events-page {
    max-width: 1000px;
    margin: 0 auto;
    padding: 2rem;
  }

  .intro-section {
    text-align: center;
    margin-bottom: 3rem;
    padding: 2rem;
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
    border-radius: 12px;
  }

  .intro-section h2 {
    font-size: 2rem;
    color: #f0c040;
    margin-bottom: 1rem;
  }

  .intro-section p {
    color: #a0a0a0;
    line-height: 1.8;
    font-size: 1.1rem;
  }

  h2 {
    font-size: 1.5rem;
    color: #e0e0e0;
    margin-bottom: 1.5rem;
    padding-left: 1rem;
    border-left: 4px solid #f0c040;
  }

  .events-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .event-card {
    display: flex;
    gap: 1.5rem;
    background: #1a1a2e;
    border-radius: 12px;
    padding: 1.5rem;
    border: 1px solid #2a2a4a;
    transition: transform 0.3s ease;
  }

  .event-card:hover {
    transform: translateX(8px);
  }

  .event-era-tag {
    min-width: 70px;
    height: fit-content;
    padding: 0.4rem 0.8rem;
    border-radius: 8px;
    text-align: center;
    font-size: 0.85rem;
    font-weight: bold;
    color: #1a1a2e;
  }

  .event-content {
    flex: 1;
  }

  .event-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.8rem;
  }

  .event-header h3 {
    font-size: 1.3rem;
    color: #f0c040;
    margin: 0;
  }

  .event-significance {
    padding: 0.2rem 0.6rem;
    border-radius: 12px;
    font-size: 0.8rem;
    font-weight: bold;
  }

  .event-significance[data-level="极高"] { background: #f04040; color: #fff; }
  .event-significance[data-level="高"] { background: #f0c040; color: #1a1a2e; }

  .event-desc {
    color: #a0a0a0;
    line-height: 1.7;
    margin-bottom: 1rem;
    font-size: 0.95rem;
  }

  .event-details {
    display: flex;
    gap: 2rem;
    padding-top: 1rem;
    border-top: 1px solid #2a2a4a;
  }

  .event-participants, .event-result {
    font-size: 0.9rem;
  }

  .detail-label {
    color: #808080;
    margin-right: 0.5rem;
  }

  .event-participants span:last-child, .event-result span:last-child {
    color: #c0c0c0;
  }

  @media (max-width: 768px) {
    .events-page {
      padding: 1rem;
    }

    .event-card {
      flex-direction: column;
      gap: 1rem;
    }

    .event-details {
      flex-direction: column;
      gap: 0.5rem;
    }
  }
</style>