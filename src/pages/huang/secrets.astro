---
import ModuleLayout from '../../layouts/ModuleLayout.astro';

const secrets = [
  { title: '天机不可泄露', category: '天机', icon: '🔮', desc: '天道运行自有其规律，泄露天机者必遭天谴。算命者若直言祸福，轻则折寿，重则遭雷劫。', warning: '修行者切勿主动泄露天机' },
  { title: '五弊三缺', category: '因果', icon: '⚡', desc: '修行中人若用神通改命，必遭五弊三缺之报。不得长寿、富贵、康宁、善终，或缺命、缺财、缺权。', warning: '命运自有定数，不可强求' },
  { title: '心魔之劫', category: '修行', icon: '👻', desc: '修行者在突破境界时，会遭遇心魔入侵。心魔由自身恶念所化，会幻化出最恐惧的景象。', warning: '需心境圆满方可渡劫' },
  { title: '走火入魔', category: '修行', icon: '🔥', desc: '修炼时若心性不稳或方法有误，会导致真气逆乱，轻则走火，重则入魔。入魔者六亲不认，危害人间。', warning: '修炼需有师长指点' },
  { title: '夺舍之术', category: '秘法', icon: '💀', desc: '高阶修士可夺舍他人身体，以延续生命。但夺舍需承受原主记忆冲击，且伤天害理，必有天劫。', warning: '天道不容，慎用' },
  { title: '双修之忌', category: '秘法', icon: '💕', desc: '双修可加速修行，但需双方自愿、心意相通。若一方存邪念，另一方必受其害。', warning: '邪修会借双修吸人精元' },
  { title: '祭祀之罪', category: '因果', icon: '🩸', desc: '以活人祭祀神灵为大罪，必遭天谴。无论出于何种目的，杀生祭祀都会背负沉重因果。', warning: '血食祭祀触犯天条' },
  { title: '偷盗天机', category: '因果', icon: '📜', desc: '修行者可推演天机，但不可偷学天界神通。如偷学封神榜、西游记等大劫秘密，必遭大祸。', warning: '大劫秘密不可探查' },
  { title: '妖修之道', category: '秘法', icon: '🦊', desc: '妖兽修炼需化形为人，过程艰辛。天劫威力远超人族，且化形后仍有天敌克制。', warning: '化形雷劫九死一生' },
  { title: '器灵觉醒', category: '器修', icon: '⚔️', desc: '神兵利器若机缘巧合可诞生器灵。器灵觉醒后会拥有独立意识，可能反噬主人。', warning: '器修需与器灵建立信任' },
  { title: '功德天劫', category: '因果', icon: '✨', desc: '积德行善可获功德，功德圆满可渡天劫飞升。但功德与罪孽相抵，罪业深重者功德再多也无用。', warning: '功德需清净无染' },
  { title: '轮回秘密', category: '幽冥', icon: '🌉', desc: '轮回之道乃天道最高机密。修士死后灵魂入幽冥，判官根据生前善恶判定轮回去向。不可探查，不可干涉。', warning: '干涉轮回必遭天罚' },
];

const categories = ['天机', '因果', '修行', '秘法', '器修', '幽冥'];
---

<ModuleLayout moduleId="huang" title="秘闻" description="修行界秘闻与禁忌">
  <div class="secrets-page">
    <section class="intro-section">
      <h2>修行秘闻</h2>
      <p>修行界有诸多不传之秘，或为天机不可泄露，或为因果报应不爽，或为千年修行之忌。知其一二，可避大祸；不知而行，必遭天谴。</p>
    </section>

    <section class="category-bar">
      <span class="category-label">分类:</span>
      {categories.map(cat => (
        <span class="category-tag">{cat}</span>
      ))}
    </section>

    <section class="secrets-grid">
      <h2>秘闻详解</h2>
      <div class="secrets-list">
        {secrets.map(secret => (
          <div class="secret-card">
            <div class="secret-header">
              <span class="secret-icon">{secret.icon}</span>
              <span class="secret-category">{secret.category}</span>
            </div>
            <h3>{secret.title}</h3>
            <p class="secret-desc">{secret.desc}</p>
            <div class="secret-warning">
              <span class="warning-icon">⚠️</span>
              <span>{secret.warning}</span>
            </div>
          </div>
        ))}
      </div>
    </section>
  </div>
</ModuleLayout>

<style>
  .secrets-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }

  .intro-section {
    text-align: center;
    margin-bottom: 2rem;
    padding: 2rem;
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
    border-radius: 12px;
  }

  .intro-section h2 {
    font-size: 2rem;
    color: #f0c040;
    margin-bottom: 1rem;
  }

  .intro-section p {
    color: #a0a0a0;
    line-height: 1.8;
    font-size: 1.1rem;
  }

  .category-bar {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
    padding: 1rem;
    background: #1a1a2e;
    border-radius: 10px;
    overflow-x: auto;
  }

  .category-label {
    color: #808080;
    font-weight: bold;
  }

  .category-tag {
    background: #2a2a4a;
    padding: 0.4rem 1rem;
    border-radius: 20px;
    font-size: 0.9rem;
    color: #c0c0c0;
    white-space: nowrap;
  }

  h2 {
    font-size: 1.5rem;
    color: #e0e0e0;
    margin-bottom: 1.5rem;
    padding-left: 1rem;
    border-left: 4px solid #f0c040;
  }

  .secrets-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  .secret-card {
    background: #1a1a2e;
    border-radius: 12px;
    padding: 1.5rem;
    border: 1px solid #2a2a4a;
    transition: transform 0.3s ease, border-color 0.3s ease;
  }

  .secret-card:hover {
    transform: translateY(-4px);
    border-color: #f08040;
  }

  .secret-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .secret-icon {
    font-size: 1.5rem;
  }

  .secret-category {
    background: #2a2a4a;
    padding: 0.3rem 0.8rem;
    border-radius: 12px;
    font-size: 0.8rem;
    color: #f08040;
  }

  .secret-card h3 {
    font-size: 1.2rem;
    color: #f0c040;
    margin: 0 0 1rem 0;
  }

  .secret-desc {
    color: #a0a0a0;
    line-height: 1.7;
    margin-bottom: 1rem;
    font-size: 0.95rem;
  }

  .secret-warning {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    padding: 0.8rem;
    background: rgba(240, 64, 64, 0.1);
    border-radius: 8px;
    border-left: 3px solid #f04040;
  }

  .warning-icon {
    flex-shrink: 0;
  }

  .secret-warning span:last-child {
    color: #f08080;
    font-size: 0.9rem;
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .secrets-page {
      padding: 1rem;
    }

    .secrets-list {
      grid-template-columns: 1fr;
    }

    .category-bar {
      flex-wrap: wrap;
    }
  }
</style>