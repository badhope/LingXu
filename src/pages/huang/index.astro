---
import ModuleLayout from '../../layouts/ModuleLayout.astro';
---

<ModuleLayout moduleId="huang" title="历史">
  <div class="huang-overview">
    <section class="intro-section">
      <h2>千古兴亡之鉴</h2>
      <p>历史者，记载千古兴亡之书也。修行文明之传承，皆载于历代典籍。末法时代，诸多秘辛被禁毁，唯有档案之中，尚存一二。</p>
    </section>

    <section class="features-grid">
      <a href="/huang/scrolls" class="feature-card scroll-card">
        <div class="card-icon">📜</div>
        <h3>历史卷轴</h3>
        <p>卷轴式历史浏览</p>
      </a>
      <a href="/huang/era-convert" class="feature-card">
        <div class="card-icon">🔢</div>
        <h3>纪年转换</h3>
        <p>纪年方式互转</p>
      </a>
      <a href="/huang/figures" class="feature-card">
        <div class="card-icon">👤</div>
        <h3>人物谱</h3>
        <p>历史人物传记</p>
      </a>
      <a href="/huang/events" class="feature-card">
        <div class="card-icon">⚔️</div>
        <h3>大事件</h3>
        <p>历史时间线</p>
      </a>
      <a href="/huang/secrets" class="feature-card secret-card">
        <div class="card-icon">🔒</div>
        <h3>秘辛档案</h3>
        <p>禁毁隐秘记载</p>
      </a>
    </section>

    <section class="eras-section">
      <h2>时代划分</h2>
      <div class="eras-timeline">
        <div class="era-item">
          <div class="era-marker">洪</div>
          <div class="era-content">
            <h3>洪荒纪元</h3>
            <p>混沌初开，神魔并起</p>
          </div>
        </div>
        <div class="era-item">
          <div class="era-marker">古</div>
          <div class="era-content">
            <h3>上古纪元</h3>
            <p>三皇五帝，修行鼎盛</p>
          </div>
        </div>
        <div class="era-item">
          <div class="era-marker">中</div>
          <div class="era-content">
            <h3>中古纪元</h3>
            <p>诸派林立，百家争鸣</p>
          </div>
        </div>
        <div class="era-item">
          <div class="era-marker">近</div>
          <div class="era-content">
            <h3>近古纪元</h3>
            <p>灵气渐衰，传承断续</p>
          </div>
        </div>
        <div class="era-item current">
          <div class="era-marker">末</div>
          <div class="era-content">
            <h3>末法纪元</h3>
            <p>天地失序，修行艰难</p>
          </div>
        </div>
      </div>
    </section>
  </div>

  <style>
    .huang-overview { max-width: 1200px; margin: 0 auto; }
    .intro-section { text-align: center; margin-bottom: 3rem; padding: 2rem; background: rgba(192, 128, 64, 0.05); border: 1px solid rgba(192, 128, 64, 0.2); border-radius: 8px; }
    .intro-section h2 { color: #c08040; margin-bottom: 1rem; }
    .intro-section p { color: #888; line-height: 1.8; max-width: 600px; margin: 0 auto; }
    .features-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem; margin-bottom: 3rem; }
    .feature-card { display: flex; flex-direction: column; align-items: center; padding: 2rem 1.5rem; background: rgba(10, 10, 15, 0.8); border: 1px solid rgba(192, 128, 64, 0.2); border-radius: 8px; text-decoration: none; transition: all 0.3s ease; }
    .feature-card:hover { transform: translateY(-4px); border-color: #c08040; box-shadow: 0 8px 24px rgba(192, 128, 64, 0.15); }
    .feature-card.secret-card { border-color: rgba(128, 0, 0, 0.3); }
    .feature-card.secret-card:hover { border-color: #800000; box-shadow: 0 8px 24px rgba(128, 0, 0, 0.2); }
    .card-icon { font-size: 2.5rem; margin-bottom: 1rem; }
    .feature-card h3 { color: #f0e8d8; margin: 0 0 0.5rem 0; }
    .feature-card p { color: #888; margin: 0; font-size: 0.85rem; }
    .eras-section h2 { color: #c08040; font-size: 1.25rem; margin-bottom: 1.5rem; text-align: center; }
    .eras-timeline { position: relative; padding-left: 2rem; }
    .eras-timeline::before { content: ''; position: absolute; left: 0.75rem; top: 0; bottom: 0; width: 2px; background: linear-gradient(to bottom, #c08040, #8b6914); }
    .era-item { position: relative; padding: 1rem 0 1rem 2rem; }
    .era-item::before { content: ''; position: absolute; left: -1.5rem; top: 1.25rem; width: 12px; height: 12px; background: #050505; border: 2px solid #c08040; border-radius: 50%; }
    .era-item.current::before { background: #c08040; box-shadow: 0 0 10px #c08040; }
    .era-marker { font-size: 1.5rem; color: #c08040; margin-bottom: 0.25rem; }
    .era-content h3 { color: #f0e8d8; margin: 0 0 0.25rem 0; font-size: 1rem; }
    .era-content p { color: #888; margin: 0; font-size: 0.85rem; }
  </style>
</ModuleLayout>
