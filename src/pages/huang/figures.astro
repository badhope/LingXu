---
import ModuleLayout from '../../layouts/ModuleLayout.astro';

const figures = [
  { name: '盘古', era: '洪荒', title: '创世神', desc: '混沌中诞生的巨神，以斧开天，身化万物。左眼为日，右眼为月，头发化为星辰。', power: '开天辟地', status: '化为万物' },
  { name: '女娲', era: '洪荒', title: '大地之母', desc: '人首蛇身，炼石补天，捏土造人。是人族圣母，妖族圣人。', power: '炼石补天', status: '隐居' },
  { name: '伏羲', era: '洪荒', title: '天皇', desc: '女娲之兄，创八卦、定嫁娶、演文字。为人族文明始祖。', power: '演算八卦', status: '归隐' },
  { name: '神农', era: '洪荒', title: '炎帝', desc: '亲尝百草，发明医药。刀耕火种，开创农业。被尊为药王神。', power: '尝百草', status: '乘龙飞升' },
  { name: '黄帝', era: '洪荒', title: '轩辕', desc: '统一华夏部落，创内经，制衣冠。建立中华文明根基。', power: '一统天下', status: '乘龙飞升' },
  { name: '蚩尤', era: '洪荒', title: '九黎之主', desc: '面如牛首，背生双翼，有八十一兄弟。勇猛善战，与黄帝争雄。', power: '铜头铁额', status: '败亡' },
  { name: '帝俊', era: '洪荒', title: '天帝', desc: '妖族天庭之主，与东皇太一共创妖庭。统领日月星辰。', power: '统御妖庭', status: '陨落' },
  { name: '东皇太一', era: '洪荒', title: '妖帝', desc: '手持东皇钟，实力滔天。巫妖大战中与帝俊共陨。', power: '东皇钟', status: '陨落' },
  { name: '十二祖巫', era: '洪荒', title: '巫族首领', desc: '帝江、共工、祝融等十二人，各掌一种天赋神通。巫族最强战力。', power: '天赋神通', status: '大部陨落' },
  { name: '后羿', era: '洪荒', title: '射日英雄', desc: '嫦娥之夫，巫族大巫。射落九日，救民于水火。', power: '射日', status: '被害' },
  { name: '嫦娥', era: '洪荒', title: '月神', desc: '后羿之妻，偷食仙药飞升月宫。为月中女神。', power: '月华', status: '永居月宫' },
  { name: '姜子牙', era: '封神', title: '封神者', desc: '元始天尊弟子，奉命主持封神榜。助周伐纣，分封诸神。', power: '封神榜', status: '主持封神' },
];

const categories = [
  { name: '创世神', color: '#f0c040', count: 3 },
  { name: '上古大帝', color: '#f08040', count: 4 },
  { name: '巫妖首领', color: '#f04040', count: 5 },
  { name: '封神人物', color: '#4080f0', count: 1 },
];
---

<ModuleLayout moduleId="huang" title="人物" description="历史人物与神话人物">
  <div class="figures-page">
    <section class="intro-section">
      <h2>历史人物</h2>
      <p>修行界之兴衰，皆由人物所系。上古大能、帝王将相、仙道宗师，或以力惊天，或以德服人，或以智谋世。知其人，方能知其道。</p>
    </section>

    <section class="categories-section">
      <h2>人物分类</h2>
      <div class="categories-grid">
        {categories.map(cat => (
          <div class="category-card" style={`--cat-color: ${cat.color}`}>
            <span class="cat-count">{cat.count}</span>
            <span class="cat-name">{cat.name}</span>
          </div>
        ))}
      </div>
    </section>

    <section class="figures-grid-section">
      <h2>人物图鉴</h2>
      <div class="figures-grid">
        {figures.map(fig => (
          <div class="figure-card">
            <div class="figure-header">
              <div class="figure-avatar">{fig.name[0]}</div>
              <div class="figure-title">
                <h3>{fig.name}</h3>
                <span class="figure-era">{fig.era}</span>
              </div>
            </div>
            <div class="figure-role">{fig.title}</div>
            <p class="figure-desc">{fig.desc}</p>
            <div class="figure-footer">
              <div class="figure-power">
                <span class="power-label">神通:</span>
                <span>{fig.power}</span>
              </div>
              <div class="figure-status">
                <span class="status-label">结局:</span>
                <span>{fig.status}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>
  </div>
</ModuleLayout>

<style>
  .figures-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }

  .intro-section {
    text-align: center;
    margin-bottom: 3rem;
    padding: 2rem;
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
    border-radius: 12px;
  }

  .intro-section h2 {
    font-size: 2rem;
    color: #f0c040;
    margin-bottom: 1rem;
  }

  .intro-section p {
    color: #a0a0a0;
    line-height: 1.8;
    font-size: 1.1rem;
  }

  h2 {
    font-size: 1.5rem;
    color: #e0e0e0;
    margin-bottom: 1.5rem;
    padding-left: 1rem;
    border-left: 4px solid #f0c040;
  }

  .categories-grid {
    display: flex;
    gap: 1rem;
    margin-bottom: 3rem;
    flex-wrap: wrap;
  }

  .category-card {
    background: #1a1a2e;
    border-radius: 12px;
    padding: 1rem 1.5rem;
    border: 1px solid var(--cat-color);
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .cat-count {
    font-size: 1.5rem;
    font-weight: bold;
    color: var(--cat-color);
  }

  .cat-name {
    color: #c0c0c0;
    font-size: 1rem;
  }

  .figures-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  .figure-card {
    background: #1a1a2e;
    border-radius: 12px;
    padding: 1.5rem;
    border: 1px solid #2a2a4a;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .figure-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(240, 192, 64, 0.1);
  }

  .figure-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .figure-avatar {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background: linear-gradient(135deg, #f0c040, #f08040);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    font-weight: bold;
    color: #1a1a2e;
  }

  .figure-title h3 {
    font-size: 1.3rem;
    color: #f0c040;
    margin: 0;
  }

  .figure-era {
    font-size: 0.85rem;
    color: #808080;
  }

  .figure-role {
    display: inline-block;
    background: #2a2a4a;
    padding: 0.3rem 0.8rem;
    border-radius: 20px;
    font-size: 0.85rem;
    color: #c0c0c0;
    margin-bottom: 1rem;
  }

  .figure-desc {
    color: #a0a0a0;
    line-height: 1.6;
    margin-bottom: 1rem;
    font-size: 0.95rem;
  }

  .figure-footer {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-top: 1rem;
    border-top: 1px solid #2a2a4a;
  }

  .figure-power, .figure-status {
    font-size: 0.9rem;
  }

  .power-label { color: #40b040; }
  .status-label { color: #808080; }
  .figure-power span:last-child, .figure-status span:last-child { color: #c0c0c0; }

  @media (max-width: 768px) {
    .figures-page {
      padding: 1rem;
    }

    .figures-grid {
      grid-template-columns: 1fr;
    }

    .categories-grid {
      flex-direction: column;
    }
  }
</style>