---
import ModuleLayout from '../../layouts/ModuleLayout.astro';

const constellations = [
  { name: '东方青龙', stars: 46, meaning: '苍龙七宿', fortune: '大吉' },
  { name: '北方玄武', stars: 65, meaning: '龟蛇合体', fortune: '吉' },
  { name: '西方白虎', stars: 54, meaning: '白虎七宿', fortune: '平' },
  { name: '南方朱雀', stars: 42, meaning: '朱雀七宿', fortune: '凶' },
];

const fiveStars = [
  { name: '太白', element: '金', color: 'white', period: '晨见东方', meaning: '主杀伐' },
  { name: '岁星', element: '木', color: 'green', period: '十二年一周', meaning: '主吉昌' },
  { name: '辰星', element: '水', color: 'black', period: '常现北方', meaning: '主智慧' },
  { name: '荧惑', element: '火', color: 'red', period: '逆行不定', meaning: '主灾祸' },
  { name: '镇星', element: '土', color: 'yellow', period: '二十八年一周', meaning: '主守信' },
];

const moonPhases = [
  { phase: '朔月', day: '初一', energy: '最弱', practice: '宜静坐冥想' },
  { phase: '上弦月', day: '初七至初八', energy: '渐强', practice: '宜吸纳月华' },
  { phase: '望月', day: '十五至十六', energy: '最强', practice: '宜修炼突破' },
  { phase: '下弦月', day: '廿二至廿三', energy: '渐弱', practice: '宜内观反思' },
];
---

<ModuleLayout moduleId="tian" title="星辰运行" description="二十八宿，灵气潮汐，星象知识">
  <div class="stars-page">
    <section class="intro-section">
      <h2>星象学概述</h2>
      <p>星辰者，天之经也。二十八宿分布四方，二十八宿分布于黄道四周，分为四象：青龙、白虎、朱雀、玄武。各宿皆有主事，影响人间吉凶。</p>
    </section>

    <section class="four-xiu">
      <h2>四象二十八宿</h2>
      <div class="xiu-grid">
        {constellations.map((xiu) => {
          const beast = xiu.name.includes('青龙') ? 'qinglong' :
                        xiu.name.includes('玄武') ? 'xuanwu' :
                        xiu.name.includes('白虎') ? 'baihu' : 'zhuque';
          return (
            <div class={`xiu-card ${beast}`}>
              <div class="xiu-header">
                <span class="xiu-symbol">
                  {xiu.name.includes('青龙') ? '🐉' : xiu.name.includes('玄武') ? '🐢' : xiu.name.includes('白虎') ? '🐅' : '🔥'}
                </span>
                <span class="xiu-name">{xiu.name}</span>
              </div>
            <div class="xiu-details">
              <div class="detail-item">
                <span class="detail-label">星数</span>
                <span class="detail-value">{xiu.stars}°</span>
              </div>
              <div class="detail-item">
                <span class="detail-label">含义</span>
                <span class="detail-value">{xiu.meaning}</span>
              </div>
              <div class="detail-item">
                <span class="detail-label">今日</span>
                <span class={`detail-value fortune ${xiu.fortune}`}>{xiu.fortune}</span>
              </div>
            </div>
          </div>
          );
        })}
      </div>
    </section>

    <section class="five-planets">
      <h2>五星运行</h2>
      <div class="planets-table">
        <div class="table-header">
          <span>星名</span>
          <span>五行</span>
          <span>颜色</span>
          <span>运行周期</span>
          <span>主事</span>
        </div>
        {fiveStars.map((star) => (
          <div class="table-row">
            <span class="star-name">{star.name}</span>
            <span class={`star-element ${star.element.toLowerCase()}`}>{star.element}</span>
            <span class="star-color">{star.color}</span>
            <span class="star-period">{star.period}</span>
            <span class="star-meaning">{star.meaning}</span>
          </div>
        ))}
      </div>
    </section>

    <section class="moon-tides">
      <h2>灵气潮汐</h2>
      <p class="section-intro">月圆之夜灵气最盛修行者多于此时吸收月华。日出时分阳气升腾，宜行吐纳之术。</p>
      <div class="tides-grid">
        {moonPhases.map((phase) => (
          <div class="tide-card">
            <div class="tide-icon">
              {phase.phase === '朔月' ? '🌑' : phase.phase === '上弦月' ? '🌓' : phase.phase === '望月' ? '🌕' : '🌗'}
            </div>
            <div class="tide-info">
              <h3>{phase.phase}</h3>
              <p class="tide-day">{phase.day}</p>
              <div class="tide-energy">
                <span class="energy-label">灵气</span>
                <span class={`energy-value ${phase.energy}`}>{phase.energy}</span>
              </div>
              <p class="tide-practice">{phase.practice}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="lucky-stars">
      <h2>今日吉星</h2>
      <div class="lucky-list">
        <div class="lucky-item">
          <span class="star-emoji">⭐</span>
          <div class="lucky-info">
            <h3>心星</h3>
            <p>位于东方青龙房宿之中，主姻缘与情感</p>
          </div>
          <span class="lucky-time">最佳时辰：卯时(5-7点)</span>
        </div>
        <div class="lucky-item">
          <span class="star-emoji">⭐</span>
          <div class="lucky-info">
            <h3>魁星</h3>
            <p>北斗七星之首，主文运与考试</p>
          </div>
          <span class="lucky-time">最佳时辰：子时(23-1点)</span>
        </div>
      </div>
    </section>

    <section class="knowledge-section">
      <h2>星象知识</h2>
      <div class="knowledge-cards">
        <article class="knowledge-item">
          <h3>三垣</h3>
          <p>紫微垣、太微垣、天市垣，分布于北天极周围，为帝王朝庭与天下市场之象征。</p>
        </article>
        <article class="knowledge-item">
          <h3>九野</h3>
          <p>钧天、苍天、变天、玄天、幽天、颢天、盛天、寒天、成品，属古代宇宙结构说。</p>
        </article>
        <article class="knowledge-item">
          <h3>七政四纪</h3>
          <p>日、月、金、木、水、火、土为七政；立春为木纪星等为四纪。</p>
        </article>
      </div>
    </section>
  </div>

  <style>
    .stars-page { max-width: 1000px; margin: 0 auto; }

    .intro-section, .four-xiu, .five-planets, .moon-tides, .lucky-stars, .knowledge-section {
      background: rgba(240, 192, 64, 0.05);
      border: 1px solid rgba(240, 192, 64, 0.2);
      border-radius: 8px;
      padding: 1.5rem;
      margin-bottom: 2rem;
    }

    h2 {
      color: #f0c040;
      font-size: 1.25rem;
      margin-bottom: 1rem;
      border-bottom: 1px solid rgba(240, 192, 64, 0.2);
      padding-bottom: 0.5rem;
    }

    .section-intro {
      color: #888;
      margin-bottom: 1.5rem;
      font-size: 0.9rem;
    }

    .xiu-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }

    .xiu-card {
      background: rgba(0, 0, 0, 0.3);
      border-radius: 8px;
      padding: 1rem;
    }

    .xiu-header {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 1rem;
    }

    .xiu-symbol { font-size: 1.5rem; }
    .xiu-name { color: #ffe066; font-size: 1.1rem; font-weight: 600; }

    .xiu-details { display: flex; flex-direction: column; gap: 0.5rem; }

    .detail-item {
      display: flex;
      justify-content: space-between;
      font-size: 0.875rem;
    }

    .detail-label { color: #888; }
    .detail-value { color: #ccc; }
    .detail-value.fortune.大吉 { color: #4ade80; }
    .detail-value.fortune.吉 { color: #86efac; }
    .detail-value.fortune.平 { color: #fbbf24; }
    .detail-value.fortune.凶 { color: #f87171; }

    .planets-table { width: 100%; }

    .table-header, .table-row {
      display: grid;
      grid-template-columns: 1fr 0.8fr 1fr 1.5fr 1fr;
      gap: 0.5rem;
      padding: 0.75rem;
      text-align: center;
    }

    .table-header {
      background: rgba(240, 192, 64, 0.2);
      border-radius: 4px;
      color: #f0c040;
      font-size: 0.875rem;
    }

    .table-row {
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
      font-size: 0.875rem;
    }

    .star-name { color: #ffe066; font-weight: 600; }
    .star-element { color: #ccc; }
    .star-element.金 { color: #c0c0c0; }
    .star-element.木 { color: #4ade80; }
    .star-element.水 { color: #60a5fa; }
    .star-element.火 { color: #f87171; }
    .star-element.土 { color: #fbbf24; }
    .star-color { color: #888; text-transform: capitalize; }
    .star-period { color: #666; font-size: 0.75rem; }
    .star-meaning { color: #aaa; }

    .tides-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
    }

    .tide-card {
      background: rgba(0, 0, 0, 0.3);
      border-radius: 8px;
      padding: 1rem;
      text-align: center;
    }

    .tide-icon { font-size: 2rem; margin-bottom: 0.5rem; }
    .tide-info h3 { color: #ffe066; margin-bottom: 0.25rem; }
    .tide-day { color: #888; font-size: 0.75rem; margin-bottom: 0.5rem; }

    .tide-energy {
      display: flex;
      justify-content: center;
      gap: 0.5rem;
      margin-bottom: 0.5rem;
    }

    .energy-label { color: #888; font-size: 0.75rem; }
    .energy-value { font-size: 0.875rem; font-weight: 600; }
    .energy-value.最强 { color: #f0c040; }
    .energy-value.渐强 { color: #4ade80; }
    .energy-value.渐弱 { color: #fbbf24; }
    .energy-value.最弱 { color: #888; }

    .tide-practice { color: #aaa; font-size: 0.75rem; }

    .lucky-list { display: flex; flex-direction: column; gap: 1rem; }

    .lucky-item {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 1rem;
      background: rgba(0, 0, 0, 0.3);
      border-radius: 8px;
    }

    .star-emoji { font-size: 2rem; }
    .lucky-info { flex: 1; }
    .lucky-info h3 { color: #ffe066; margin-bottom: 0.25rem; }
    .lucky-info p { color: #888; font-size: 0.875rem; }
    .lucky-time {
      color: #4ade80;
      font-size: 0.75rem;
      padding: 0.25rem 0.5rem;
      background: rgba(74, 222, 128, 0.1);
      border-radius: 4px;
    }

    .knowledge-cards {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
    }

    .knowledge-item {
      padding: 1rem;
      background: rgba(0, 0, 0, 0.3);
      border-radius: 6px;
    }

    .knowledge-item h3 { color: #f0c040; margin-bottom: 0.5rem; font-size: 0.9rem; }
    .knowledge-item p { color: #888; font-size: 0.8rem; line-height: 1.5; }

    @media (max-width: 768px) {
      .xiu-grid { grid-template-columns: 1fr; }
      .tides-grid { grid-template-columns: repeat(2, 1fr); }
      .table-header, .table-row { grid-template-columns: 1fr 0.6fr 0.8fr; }
      .star-period, .star-meaning { display: none; }
      .knowledge-cards { grid-template-columns: 1fr; }
    }
  </style>
</ModuleLayout>