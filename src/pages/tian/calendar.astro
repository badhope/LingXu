---
import ModuleLayout from '../../layouts/ModuleLayout.astro';

const today = new Date();
const lunarDate = getLunarDate(today);

function getLunarDate(date: Date) {
  const cyclicalYear = ['甲子', '乙丑', '丙寅', '丁卯', '戊辰', '己巳', '庚午', '辛未', '壬申', '癸酉',
                        '甲戌', '乙亥', '丙子', '丁丑', '戊寅', '己卯', '庚辰', '辛巳', '壬午', '癸未',
                        '甲申', '乙酉', '丙戌', '丁亥', '戊子', '己丑', '庚寅', '辛卯', '壬辰', '癸巳',
                        '甲午', '乙未', '丙申', '丁酉', '戊戌', '己亥', '庚子', '辛丑', '壬寅', '癸丑',
                        '甲辰', '乙巳', '丙午', '丁未', '戊申', '己酉', '庚戌', '辛亥', '壬子', '癸丑',
                        '甲寅', '乙卯', '丙辰', '丁巳', '戊午', '己未', '庚申', '辛酉', '壬戌', '癸亥'][(date.getFullYear() - 1984) % 60];
  const monthNames = ['正', '二', '三', '四', '五', '六', '七', '八', '九', '十', '冬', '腊'];
  const dayNames = ['初一', '初二', '初三', '初四', '初五', '初六', '初七', '初八', '初九', '初十',
                    '十一', '十二', '十三', '十四', '十五', '十六', '十七', '十八', '十九', '二十',
                    '廿一', '廿二', '廿三', '廿四', '廿五', '廿六', '廿七', '廿八', '廿九', '三十'];
  return {
    year: cyclicalYear,
    month: monthNames[0],
    day: dayNames[date.getDate() - 1]
  };
}

const goodThings = ['祭祀', '祈福', '开光', '动土', '搬家', '嫁娶', '订婚', '纳采'];
const avoidThings = ['安葬', '破土', '动土', '装修', '开业', '投资', '借贷'];
---

<ModuleLayout moduleId="tian" title="黄历吉凶" description="每日宜忌查询，今日运势解读">
  <div class="calendar-page">
    <section class="today-section">
      <div class="date-display">
        <div class="solar-date">
          <span class="date-label">公历</span>
          <span class="date-value">{today.getFullYear()}年{ today.getMonth() + 1 }月{ today.getDate() }日</span>
        </div>
        <div class="lunar-date">
          <span class="date-label">农历</span>
          <span class="date-value">{lunarDate.year}年 {lunarDate.month}月 {lunarDate.day}</span>
        </div>
      </div>
    </section>

    <section class="fortune-section">
      <h2>今日运势</h2>
      <div class="fortune-grid">
        <div class="fortune-card overall">
          <div class="fortune-icon">☀️</div>
          <h3>综合运势</h3>
          <div class="fortune-level">
            <div class="level-bar" style="--level: 78%"></div>
          </div>
          <p class="fortune-desc">今日宜静心修行，灵气充沛，可尝试突破境界</p>
        </div>
        <div class="fortune-card career">
          <div class="fortune-icon">⚔️</div>
          <h3>事业</h3>
          <div class="fortune-level">
            <div class="level-bar" style="--level: 65%"></div>
          </div>
          <p class="fortune-desc">事业平稳推进，贵人运佳</p>
        </div>
        <div class="fortune-card health">
          <div class="fortune-icon">💪</div>
          <h3>健康</h3>
          <div class="fortune-level">
            <div class="level-bar" style="--level: 82%"></div>
          </div>
          <p class="fortune-desc">身心和谐，注意午休养神</p>
        </div>
        <div class="fortune-card love">
          <div class="fortune-icon">💕</div>
          <h3>感情</h3>
          <div class="fortune-level">
            <div class="level-bar" style="--level: 70%"></div>
          </div>
          <p class="fortune-desc">感情运势平稳，单身者有桃花</p>
        </div>
      </div>
    </section>

    <section class="almanac-section">
      <div class="almanac-column good">
        <h3>✅ 宜</h3>
        <ul class="thing-list">
          {goodThings.map(thing => <li>{thing}</li>)}
        </ul>
      </div>
      <div class="almanac-column avoid">
        <h3>❌ 忌</h3>
        <ul class="thing-list">
          {avoidThings.map(thing => <li>{thing}</li>)}
        </ul>
      </div>
    </section>

    <section class="time-luck-section">
      <h2>时辰吉凶</h2>
      <div class="time-table">
        <div class="time-row header">
          <span>时辰</span>
          <span>时间</span>
          <span>吉凶</span>
          <span>宜忌</span>
        </div>
        <div class="time-row good">
          <span class="time-name">子时</span>
          <span class="time-range">23:00-01:00</span>
          <span class="time-fortune">大吉</span>
          <span class="time-desc">灵气最盛，适合修炼</span>
        </div>
        <div class="time-row good">
          <span class="time-name">丑时</span>
          <span class="time-range">01:00-03:00</span>
          <span class="time-fortune">吉</span>
          <span class="time-desc">适合休息，养精蓄锐</span>
        </div>
        <div class="time-row bad">
          <span class="time-name">寅时</span>
          <span class="time-range">03:00-05:00</span>
          <span class="time-fortune">凶</span>
          <span class="time-desc">阴气重，不宜外出</span>
        </div>
        <div class="time-row good">
          <span class="time-name">卯时</span>
          <span class="time-range">05:00-07:00</span>
          <span class="time-fortune">吉</span>
          <span class="time-desc">旭日东升，宜吐纳</span>
        </div>
        <div class="time-row neutral">
          <span class="time-name">辰时</span>
          <span class="time-range">07:00-09:00</span>
          <span class="time-fortune">平</span>
          <span class="time-desc">日常事务处理</span>
        </div>
      </div>
    </section>

    <section class="quote-section">
      <blockquote>
        <p>天行健，君子以自强不息；地势坤，君子以厚德载物。</p>
        <cite>—— 《周易》</cite>
      </blockquote>
    </section>
  </div>

  <style>
    .calendar-page {
      max-width: 900px;
      margin: 0 auto;
    }

    .today-section {
      margin-bottom: 2rem;
    }

    .date-display {
      display: flex;
      justify-content: center;
      gap: 3rem;
      padding: 2rem;
      background: linear-gradient(135deg, rgba(240, 192, 64, 0.1) 0%, rgba(201, 162, 39, 0.05) 100%);
      border: 1px solid rgba(240, 192, 64, 0.3);
      border-radius: 12px;
    }

    .date-label {
      display: block;
      font-size: 0.75rem;
      color: #888;
      text-transform: uppercase;
      letter-spacing: 0.2em;
      margin-bottom: 0.5rem;
    }

    .date-value {
      font-size: 1.5rem;
      color: #f0c040;
    }

    .fortune-section h2,
    .time-luck-section h2 {
      color: #f0c040;
      font-size: 1.25rem;
      margin-bottom: 1.5rem;
      text-align: center;
    }

    .fortune-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1rem;
      margin-bottom: 2rem;
    }

    .fortune-card {
      padding: 1.5rem;
      background: rgba(10, 10, 15, 0.8);
      border: 1px solid rgba(240, 192, 64, 0.2);
      border-radius: 8px;
      text-align: center;
    }

    .fortune-icon {
      font-size: 2rem;
      margin-bottom: 0.5rem;
    }

    .fortune-card h3 {
      color: #f0e6c8;
      margin: 0 0 0.75rem 0;
      font-size: 1rem;
    }

    .fortune-level {
      height: 6px;
      background: rgba(255, 255, 255, 0.1);
      border-radius: 3px;
      margin-bottom: 0.75rem;
      overflow: hidden;
    }

    .level-bar {
      height: 100%;
      width: var(--level);
      background: linear-gradient(to right, #f0c040, #ffe066);
      border-radius: 3px;
      transition: width 0.5s ease;
    }

    .fortune-desc {
      color: #888;
      font-size: 0.8rem;
      margin: 0;
      line-height: 1.4;
    }

    .almanac-section {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
      margin-bottom: 2rem;
    }

    .almanac-column {
      padding: 1.5rem;
      border-radius: 8px;
    }

    .almanac-column.good {
      background: rgba(64, 176, 64, 0.1);
      border: 1px solid rgba(64, 176, 64, 0.3);
    }

    .almanac-column.avoid {
      background: rgba(240, 64, 64, 0.1);
      border: 1px solid rgba(240, 64, 64, 0.3);
    }

    .almanac-column h3 {
      margin: 0 0 1rem 0;
      font-size: 1rem;
    }

    .good .almanac-column h3 {
      color: #40b040;
    }

    .avoid .almanac-column h3 {
      color: #f04040;
    }

    .thing-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .thing-list li {
      padding: 0.5rem 1rem;
      background: rgba(255, 255, 255, 0.05);
      border-radius: 4px;
      font-size: 0.9rem;
    }

    .time-table {
      background: rgba(10, 10, 15, 0.8);
      border: 1px solid rgba(201, 162, 39, 0.2);
      border-radius: 8px;
      overflow: hidden;
    }

    .time-row {
      display: grid;
      grid-template-columns: 80px 100px 80px 1fr;
      padding: 1rem;
      border-bottom: 1px solid rgba(201, 162, 39, 0.1);
    }

    .time-row:last-child {
      border-bottom: none;
    }

    .time-row.header {
      background: rgba(201, 162, 39, 0.1);
      font-weight: 500;
      color: #888;
      font-size: 0.85rem;
    }

    .time-name {
      color: #f0c040;
      font-weight: 500;
    }

    .time-range {
      color: #666;
      font-size: 0.85rem;
    }

    .time-fortune {
      font-weight: 500;
    }

    .time-row.good .time-fortune {
      color: #40b040;
    }

    .time-row.bad .time-fortune {
      color: #f04040;
    }

    .time-row.neutral .time-fortune {
      color: #888;
    }

    .time-desc {
      color: #aaa;
      font-size: 0.85rem;
    }

    .quote-section {
      margin-top: 2rem;
      text-align: center;
    }

    blockquote {
      padding: 2rem;
      background: rgba(240, 192, 64, 0.05);
      border-left: 3px solid #f0c040;
      border-radius: 0 8px 8px 0;
      margin: 0;
    }

    blockquote p {
      color: #e8d48b;
      font-size: 1.1rem;
      margin: 0 0 0.5rem 0;
      line-height: 1.6;
    }

    blockquote cite {
      color: #888;
      font-size: 0.85rem;
      font-style: normal;
    }

    @media (max-width: 768px) {
      .date-display {
        flex-direction: column;
        gap: 1.5rem;
        align-items: center;
      }

      .almanac-section {
        grid-template-columns: 1fr;
      }

      .time-row {
        grid-template-columns: 60px 80px 60px 1fr;
        font-size: 0.85rem;
      }
    }
  </style>
</ModuleLayout>
