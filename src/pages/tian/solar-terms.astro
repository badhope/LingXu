---
import ModuleLayout from '../../layouts/ModuleLayout.astro';

const solarTerms = [
  { name: '立春', month: '二月', day: '3-5', element: '木', nature: '发陈', health: '养肝护肝，宜早起散步', farm: '春耕开始', mood: '希望萌芽' },
  { name: '雨水', month: '二月', day: '18-20', element: '木', nature: '萌动', health: '祛湿健脾，多食山药', farm: '灌溉施肥', mood: '生机盎然' },
  { name: '惊蛰', month: '三月', day: '5-7', element: '木', nature: '启发', health: '防春困，伸懒腰最佳', farm: '耕种时节', mood: '惊醒奋进' },
  { name: '春分', month: '三月', day: '20-22', element: '木', nature: '平衡', health: '调和阴阳，舒肝理气', farm: '播种佳期', mood: '阴阳平衡' },
  { name: '清明', month: '四月', day: '4-6', element: '火', nature: '清洁', health: '清肝明目，郊游踏青', farm: '春播扫墓', mood: '清新明朗' },
  { name: '谷雨', month: '四月', day: '19-21', element: '土', nature: '生发', health: '健脾祛湿，谨防过敏', farm: '播种最后时机', mood: '雨生百谷' },
  { name: '立夏', month: '五月', day: '5-7', element: '火', nature: ' Vol {', health: '养心安神，午休小憩', farm: '田间管理', mood: '热情活力' },
  { name: '小满', month: '五月', day: '20-22', element: '火', nature: '盈满', health: '清热祛湿，少食辛辣', farm: '小麦灌浆', mood: '充实满足' },
];

const currentSeason = { name: '春季', start: '立春', months: '二月至四月', element: '木', direction: '东方', practices: ['早起吐纳', '踏青养肝', '郊游舒心'] };
---

<ModuleLayout moduleId="tian" title="节气养生" description="节气计算，养生要点，农事指导">
  <div class="solar-terms-page">
    <section class="season-overview">
      <div class="season-header">
        <h2>{currentSeason.name}</h2>
        <span class="season-badge">{currentSeason.start} 开始</span>
      </div>
      <div class="season-info">
        <div class="info-item">
          <span class="info-icon">🗓️</span>
          <span class="info-label">时节</span>
          <span class="info-value">{currentSeason.months}</span>
        </div>
        <div class="info-item">
          <span class="info-icon">🌿</span>
          <span class="info-label">五行</span>
          <span class="info-value">{currentSeason.element}</span>
        </div>
        <div class="info-item">
          <span class="info-icon">🧭</span>
          <span class="info-label">方位</span>
          <span class="info-value">{currentSeason.direction}</span>
        </div>
      </div>
      <div class="practice-list">
        <h3>春季修行建议</h3>
        <ul>
          {currentSeason.practices.map(p => <li>{p}</li>)}
        </ul>
      </div>
    </section>

    <section class="terms-grid-section">
      <h2>二十四节气</h2>
      <div class="terms-grid">
        {solarTerms.map((term) => (
          <div class={`term-card ${term.element}`}>
            <div class="term-header">
              <span class="term-name">{term.name}</span>
              <span class="term-date">{term.month} {term.day}</span>
            </div>
            <div class="term-body">
              <div class="term-row">
                <span class="term-label">五行</span>
                <span class={`term-value element-${term.element.toLowerCase()}`}>{term.element}</span>
              </div>
              <div class="term-row">
                <span class="term-label">特性</span>
                <span class="term-value">{term.nature}</span>
              </div>
              <div class="term-row">
                <span class="term-label">养生</span>
                <span class="term-value">{term.health}</span>
              </div>
              <div class="term-row">
                <span class="term-label">农事</span>
                <span class="term-value">{term.farm}</span>
              </div>
              <div class="term-row">
                <span class="term-label">心绪</span>
                <span class="term-value mood">{term.mood}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="health-guidance">
      <h2>节气养生要点</h2>
      <div class="guidance-grid">
        <div class="guidance-card">
          <div class="guidance-icon">🌅</div>
          <h3>起居</h3>
          <p>春季宜早睡早起，与鸡同鸣。早晨散步可吸纳春日的清新之气，有助于肝气疏泄。</p>
        </div>
        <div class="guidance-card">
          <div class="guidance-icon">🍵</div>
          <h3>饮食</h3>
          <p>少酸多甘，宜食韭菜、香椿、豆芽等应季蔬菜。忌辛辣油腻，以免助火伤肝。</p>
        </div>
        <div class="guidance-card">
          <div class="guidance-icon">🧘</div>
          <h3>修炼</h3>
          <p>春季木气旺盛，宜练习疏肝理气的功法。太极拳、八段锦等柔和运动最为适宜。</p>
        </div>
        <div class="guidance-card">
          <div class="guidance-icon">😴</div>
          <h3>情志</h3>
          <p>春季对应肝脏，情志上宜舒展条达。保持心情愉快，忌忧郁愤怒。</p>
        </div>
      </div>
    </section>

    <section class="farm-calendar">
      <h2>农事参照</h2>
      <div class="farm-table">
        <div class="farm-row header">
          <span>节气</span>
          <span>时间</span>
          <span>主要农事</span>
          <span>注意事项</span>
        </div>
        <div class="farm-row">
          <span class="farm-term">立春</span>
          <span>2月3-5日</span>
          <span>准备春耕</span>
          <span>检修农具</span>
        </div>
        <div class="farm-row">
          <span class="farm-term">雨水</span>
          <span>2月18-20日</span>
          <span>灌溉追肥</span>
          <span>防涝排水</span>
        </div>
        <div class="farm-row">
          <span class="farm-term">惊蛰</span>
          <span>3月5-7日</span>
          <span>春播开始</span>
          <span>防虫保苗</span>
        </div>
        <div class="farm-row">
          <span class="farm-term">春分</span>
          <span>3月20-22日</span>
          <span>播种插秧</span>
          <span>合理密植</span>
        </div>
      </div>
    </section>

    <section class="monthly-nourishment">
      <h2>逐月调养</h2>
      <div class="month-list">
        <div class="month-item">
          <span class="month-num">正月</span>
          <span class="month-focus">养肝</span>
          <span class="month-foods">韭菜、豆芽、山楂</span>
        </div>
        <div class="month-item">
          <span class="month-num">二月</span>
          <span class="month-focus">祛湿</span>
          <span class="month-foods">薏米、红豆、冬瓜</span>
        </div>
        <div class="month-item">
          <span class="month-num">三月</span>
          <span class="month-focus">清热</span>
          <span class="month-foods">菊花、绿茶、芹菜</span>
        </div>
      </div>
    </section>
  </div>

  <style>
    .solar-terms-page { max-width: 1000px; margin: 0 auto; }

    .season-overview, .terms-grid-section, .health-guidance, .farm-calendar, .monthly-nourishment {
      background: rgba(240, 192, 64, 0.05);
      border: 1px solid rgba(240, 192, 64, 0.2);
      border-radius: 8px;
      padding: 1.5rem;
      margin-bottom: 2rem;
    }

    h2 {
      color: #f0c040;
      font-size: 1.25rem;
      margin-bottom: 1rem;
      border-bottom: 1px solid rgba(240, 192, 64, 0.2);
      padding-bottom: 0.5rem;
    }

    .season-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 1rem;
    }

    .season-header h2 { border: none; margin: 0; padding: 0; color: #ffe066; font-size: 1.5rem; }

    .season-badge {
      background: rgba(74, 222, 128, 0.2);
      color: #4ade80;
      padding: 0.25rem 0.75rem;
      border-radius: 20px;
      font-size: 0.8rem;
    }

    .season-info {
      display: flex;
      gap: 2rem;
      margin-bottom: 1.5rem;
    }

    .info-item { display: flex; align-items: center; gap: 0.5rem; }
    .info-icon { font-size: 1.25rem; }
    .info-label { color: #888; font-size: 0.8rem; }
    .info-value { color: #ffe066; font-weight: 600; }

    .practice-list h3 { color: #f0c040; font-size: 0.9rem; margin-bottom: 0.5rem; }
    .practice-list ul { display: flex; gap: 1.5rem; list-style: none; padding: 0; }
    .practice-list li { color: #ccc; font-size: 0.875rem; }

    .terms-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
    }

    .term-card {
      background: rgba(0, 0, 0, 0.3);
      border-radius: 8px;
      overflow: hidden;
    }

    .term-header {
      padding: 0.75rem;
      text-align: center;
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .term-name { color: #ffe066; font-size: 1rem; display: block; }
    .term-date { color: #888; font-size: 0.7rem; }

    .term-body { padding: 0.75rem; }

    .term-row {
      display: flex;
      flex-direction: column;
      margin-bottom: 0.5rem;
    }

    .term-label { color: #666; font-size: 0.65rem; text-transform: uppercase; }
    .term-value { color: #ccc; font-size: 0.8rem; }
    .term-value.mood { color: #f0c040; }
    .element-木 { color: #4ade80; }
    .element-火 { color: #f87171; }
    .element-土 { color: #fbbf24; }
    .element-金 { color: #c0c0c0; }
    .element-水 { color: #60a5fa; }

    .guidance-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
    }

    .guidance-card {
      background: rgba(0, 0, 0, 0.3);
      border-radius: 8px;
      padding: 1rem;
      text-align: center;
    }

    .guidance-icon { font-size: 2rem; margin-bottom: 0.5rem; }
    .guidance-card h3 { color: #f0c040; margin-bottom: 0.5rem; font-size: 0.9rem; }
    .guidance-card p { color: #888; font-size: 0.75rem; line-height: 1.5; }

    .farm-table { width: 100%; }

    .farm-row {
      display: grid;
      grid-template-columns: 1fr 1.5fr 2fr 1.5fr;
      gap: 0.5rem;
      padding: 0.75rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
      font-size: 0.85rem;
    }

    .farm-row.header { background: rgba(240, 192, 64, 0.2); border-radius: 4px; color: #f0c040; }
    .farm-term { color: #ffe066; font-weight: 600; }
    .farm-row span:not(.farm-term) { color: #aaa; }

    .month-list { display: flex; flex-direction: column; gap: 0.5rem; }

    .month-item {
      display: grid;
      grid-template-columns: 1fr 1fr 2fr;
      gap: 1rem;
      padding: 0.75rem;
      background: rgba(0, 0, 0, 0.3);
      border-radius: 6px;
    }

    .month-num { color: #f0c040; }
    .month-focus { color: #4ade80; }
    .month-foods { color: #888; font-size: 0.85rem; }

    @media (max-width: 768px) {
      .terms-grid { grid-template-columns: repeat(2, 1fr); }
      .guidance-grid { grid-template-columns: repeat(2, 1fr); }
      .farm-row { grid-template-columns: 1fr 1fr; }
      .farm-row span:nth-child(3), .farm-row span:nth-child(4) { display: none; }
      .season-info { flex-wrap: wrap; }
    }
  </style>
</ModuleLayout>