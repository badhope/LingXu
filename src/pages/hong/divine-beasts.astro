---
import ModuleLayout from '../../layouts/ModuleLayout.astro';

const divineBeasts = [
  { name: '青龙', element: '木', color: '#40b040', desc: '东方之神，鳞虫之长。能幽能明，能细能巨。呼风唤雨，主宰海域。', ability: '行云布雨、统御鳞族', habitat: '东海深渊' },
  { name: '白虎', element: '金', color: '#e0e0e0', desc: '西方之神，兽中之王。白虎属金，主杀伐。兵戈之事，必应此神。', ability: '战伐之威、肃杀之气', habitat: '昆仑山巅' },
  { name: '朱雀', element: '火', color: '#f04040', desc: '南方之神，鸟中之凤。浴火重生，主宰南方。天下文明，莫不有关。', ability: '涅槃重生、文明之火', habitat: '丹穴之山' },
  { name: '玄武', element: '水', color: '#4080f0', desc: '北方之神，龟蛇合体。北方水位，主长寿与幽冥。龟蛇合体，阴阳交泰。', ability: '长寿永生、幽冥之主', habitat: '北海深渊' },
  { name: '麒麟', element: '土', color: '#c08040', desc: '中央之神，走兽之长。麒麟出圣人现，天下太平。仁兽也，不履生虫。', ability: '祥瑞降临、太平之象', habitat: '神州大地' },
  { name: '凤凰', element: '火', color: '#ff6b6b', desc: '百鸟之王，涅槃重生。五色备举，飞则百鸟从之。火之精也。', ability: '浴火重生、百鸟朝凤', habitat: '朝阳之山' },
  { name: '龙', element: '水', color: '#6040f0', desc: '鳞虫之长，四灵之首。九似之物：角似鹿、头似驼、眼似兔...', ability: '变化无穷、海晏河清', habitat: '江河湖海' },
  { name: '鲲鹏', element: '风', color: '#40c0f0', desc: '北冥之鱼，化而为鸟。翼若垂天之云，水击三千里，抟扶摇而上者九万里。', ability: '扶摇直上、逍遥自在', habitat: '北冥深渊' },
];
---

<ModuleLayout moduleId="hong" title="神兽录" description="祥瑞神兽图鉴，四灵神兽">
  <div class="divine-beasts-page">
    <section class="intro-section">
      <h2>神兽图鉴</h2>
      <p>洪荒之时，神兽降世，或为祥瑞，或兆吉凶。修行者知其性、明其理，方能善加利用，化凶为吉。</p>
    </section>

    <section class="four-spirits">
      <h2>四灵神兽</h2>
      <div class="spirits-grid">
        {divineBeasts.slice(0, 4).map(beast => (
          <div class="beast-card spirit-card" style={`--beast-color: ${beast.color}`}>
            <div class="beast-icon">{beast.name[0]}</div>
            <div class="beast-header">
              <h3>{beast.name}</h3>
              <span class="beast-element">{beast.element}属</span>
            </div>
            <p class="beast-desc">{beast.desc}</p>
            <div class="beast-details">
              <div class="detail">
                <span class="detail-label">天赋:</span>
                <span>{beast.ability}</span>
              </div>
              <div class="detail">
                <span class="detail-label">栖息:</span>
                <span>{beast.habitat}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="other-spirits">
      <h2>其他祥瑞</h2>
      <div class="spirits-grid">
        {divineBeasts.slice(4).map(beast => (
          <div class="beast-card" style={`--beast-color: ${beast.color}`}>
            <div class="beast-icon">{beast.name[0]}</div>
            <div class="beast-header">
              <h3>{beast.name}</h3>
              <span class="beast-element">{beast.element}属</span>
            </div>
            <p class="beast-desc">{beast.desc}</p>
            <div class="beast-details">
              <div class="detail">
                <span class="detail-label">天赋:</span>
                <span>{beast.ability}</span>
              </div>
              <div class="detail">
                <span class="detail-label">栖息:</span>
                <span>{beast.habitat}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="legend-section">
      <h2>神兽传说</h2>
      <div class="legends">
        <div class="legend">
          <h3>龙之九子</h3>
          <p>龙生九子，各有不同：囚牛喜音乐、睚眦嗜杀、嘲风好险、蒲牢好鸣、狻猊好坐、赑屃好力、狴犴好讼、负屃好文、螭吻好吞。</p>
        </div>
        <div class="legend">
          <h3>凤凰涅槃</h3>
          <p>凤凰每隔五百年，衔香木而自焚。浴火重生之后，羽更丰、音更清、神更髓。此为涅槃之道，修行者可悟其理。</p>
        </div>
        <div class="legend">
          <h3>麒麟送子</h3>
          <p>圣人将出，麒麟必至。相传孔子诞生之夜，有麒麟现于阙里，口吐玉书。此乃祥瑞之极致。</p>
        </div>
      </div>
    </section>
  </div>
</ModuleLayout>

<style>
  .divine-beasts-page {
    max-width: 1200px;
    margin: 0 auto;
  }

  .intro-section {
    text-align: center;
    margin-bottom: 3rem;
  }

  .intro-section h2 {
    font-size: 1.8rem;
    color: #d4af37;
    margin-bottom: 1rem;
  }

  .intro-section p {
    color: #888;
    line-height: 1.8;
    max-width: 800px;
    margin: 0 auto;
  }

  section {
    margin-bottom: 3rem;
  }

  section h2 {
    font-size: 1.4rem;
    color: #c9a227;
    margin-bottom: 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(201, 162, 39, 0.2);
  }

  .spirits-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .beast-card {
    background: linear-gradient(135deg, rgba(20, 20, 20, 0.9), rgba(30, 30, 30, 0.8));
    border: 1px solid var(--beast-color);
    border-radius: 12px;
    padding: 1.5rem;
    transition: all 0.3s ease;
  }

  .beast-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3), 0 0 20px color-mix(in srgb, var(--beast-color) 20%, transparent);
  }

  .beast-icon {
    width: 60px;
    height: 60px;
    background: linear-gradient(135deg, var(--beast-color), color-mix(in srgb, var(--beast-color) 50%, #000));
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.8rem;
    color: #fff;
    margin-bottom: 1rem;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
  }

  .beast-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .beast-header h3 {
    color: var(--beast-color);
    font-size: 1.3rem;
    margin: 0;
  }

  .beast-element {
    color: #888;
    font-size: 0.85rem;
  }

  .beast-desc {
    color: #ccc;
    line-height: 1.6;
    margin-bottom: 1rem;
    font-size: 0.9rem;
  }

  .beast-details {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .detail {
    font-size: 0.85rem;
  }

  .detail-label {
    color: #888;
    margin-right: 0.5rem;
  }

  .detail span:last-child {
    color: #aaa;
  }

  .legend-section .legends {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .legend {
    background: rgba(20, 20, 20, 0.6);
    border: 1px solid rgba(201, 162, 39, 0.2);
    border-radius: 8px;
    padding: 1.5rem;
  }

  .legend h3 {
    color: #d4af37;
    margin-bottom: 0.8rem;
  }

  .legend p {
    color: #888;
    line-height: 1.6;
    margin: 0;
  }
</style>
