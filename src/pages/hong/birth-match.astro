---
import ModuleLayout from '../../layouts/ModuleLayout.astro';

const birthMatches = [
  { year: '甲子', element: '金', animal: '鼠', trait: '甲子年生人机敏多智，善于谋略，一生顺利', compatible: ['乙丑', '壬申', '癸酉'], incompatible: ['庚午', '辛未'] },
  { year: '乙丑', element: '金', animal: '牛', trait: '乙丑年生人稳重踏实，意志坚定，晚景佳', compatible: ['甲子', '壬申', '癸酉'], incompatible: ['庚午', '辛未'] },
  { year: '丙寅', element: '火', animal: '虎', trait: '丙寅年生人热情大方，胆识过人，创业兴家', compatible: ['丁卯', '甲午', '乙未'], incompatible: ['壬戌', '癸亥'] },
  { year: '丁卯', element: '火', animal: '兔', trait: '丁卯年生人文雅温和，才华出众，婚姻美满', compatible: ['丙寅', '甲午', '乙未'], incompatible: ['壬戌', '癸亥'] },
  { year: '戊辰', element: '土', animal: '龙', trait: '戊辰年生人精力充沛，领导力强，地位显赫', compatible: ['己巳', '丙戌', '丁亥'], incompatible: ['甲申', '乙酉'] },
  { year: '己巳', element: '土', animal: '蛇', trait: '己巳年生人聪明伶俐，反应敏捷，善于交际', compatible: ['戊辰', '丙戌', '丁亥'], incompatible: ['甲申', '乙酉'] },
  { year: '庚午', element: '金', animal: '马', trait: '庚午年生人性格豪爽，正义感强，适合从政', compatible: ['辛未', '壬子', '癸丑'], incompatible: ['甲子', '乙丑'] },
  { year: '辛未', element: '金', animal: '羊', trait: '辛未年生人温柔细腻，感情丰富，艺术天赋', compatible: ['庚午', '壬子', '癸丑'], incompatible: ['甲子', '乙丑'] },
  { year: '壬申', element: '水', animal: '猴', trait: '壬申年生人机智灵活，善于理财，多子多福', compatible: ['癸酉', '甲辰', '乙巳'], incompatible: ['丙午', '丁未'] },
  { year: '癸酉', element: '水', animal: '鸡', trait: '癸酉年生人细心认真，讲究整洁，财运平稳', compatible: ['壬申', '甲辰', '乙巳'], incompatible: ['丙午', '丁未'] },
  { year: '甲戌', element: '木', animal: '狗', trait: '甲戌年生人忠诚可靠，侠义心肠，朋友众多', compatible: ['乙亥', '壬午', '癸未'], incompatible: ['戊辰', '己巳'] },
  { year: '乙亥', element: '木', animal: '猪', trait: '乙亥年生人和善可亲，人缘极佳，子孙孝顺', compatible: ['甲戌', '壬午', '癸未'], incompatible: ['戊辰', '己巳'] },
];

const elementRelations = [
  { element: '木', color: '#40b040', generates: '火', weakens: '金', harmonizes: ['火', '水'] },
  { element: '火', color: '#f04040', generates: '土', weakens: '水', harmonizes: ['土', '木'] },
  { element: '土', color: '#c08040', generates: '金', weakens: '木', harmonizes: ['金', '火'] },
  { element: '金', color: '#e0e0e0', generates: '水', weakens: '火', harmonizes: ['水', '土'] },
  { element: '水', color: '#4080f0', generates: '木', weakens: '土', harmonizes: ['木', '金'] },
];

const tips = [
  '出生年份的五行属性影响一生运势',
  '配合流年、大运可推断吉凶祸福',
  '婚姻配对需看双方年柱是否相合',
  '姓名笔画可补足命格五行缺失',
  '风水调整可化解部分先天不足',
];
---

<ModuleLayout moduleId="hong" title="出生配对" description="生辰八字与五行配对">
  <div class="birth-page">
    <section class="intro-section">
      <h2>出生配对</h2>
      <p>生辰八字，乃先天命格之基。五行生克，乃天地运行之理。知其命格，方能趋吉避凶；明其配对，方能姻缘美满。</p>
    </section>

    <section class="element-relations">
      <h2>五行生克</h2>
      <div class="elements-grid">
        {elementRelations.map(el => (
          <div class="element-card" style={`--el-color: ${el.color}`}>
            <span class="el-name">{el.element}</span>
            <div class="el-relations">
              <span class="el-generates">生 → {el.generates}</span>
              <span class="el-weakens">克 → {el.weakens}</span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="birth-matches">
      <h2>六十甲子命格</h2>
      <div class="matches-grid">
        {birthMatches.map(match => (
          <div class="match-card">
            <div class="match-header">
              <span class="match-year">{match.year}</span>
              <span class="match-animal">{match.animal}</span>
            </div>
            <div class="match-element" style={`color: ${elementRelations.find(e => e.element === match.element)?.color}`}>
              {match.element}命
            </div>
            <p class="match-trait">{match.trait}</p>
            <div class="match-compatibility">
              <div class="compatible">
                <span class="comp-label">相合:</span>
                <span>{match.compatible.join('、')}</span>
              </div>
              <div class="incompatible">
                <span class="comp-label">相冲:</span>
                <span>{match.incompatible.join('、')}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="tips-section">
      <h2>命理小贴士</h2>
      <ul class="tips-list">
        {tips.map(tip => (
          <li>{tip}</li>
        ))}
      </ul>
    </section>
  </div>
</ModuleLayout>

<style>
  .birth-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }

  .intro-section {
    text-align: center;
    margin-bottom: 3rem;
    padding: 2rem;
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
    border-radius: 12px;
  }

  .intro-section h2 {
    font-size: 2rem;
    color: #f0c040;
    margin-bottom: 1rem;
  }

  .intro-section p {
    color: #a0a0a0;
    line-height: 1.8;
    font-size: 1.1rem;
  }

  h2 {
    font-size: 1.5rem;
    color: #e0e0e0;
    margin-bottom: 1.5rem;
    padding-left: 1rem;
    border-left: 4px solid #f0c040;
  }

  .elements-grid {
    display: flex;
    gap: 1rem;
    margin-bottom: 3rem;
    flex-wrap: wrap;
  }

  .element-card {
    flex: 1;
    min-width: 150px;
    background: #1a1a2e;
    border-radius: 12px;
    padding: 1.2rem;
    border: 2px solid var(--el-color);
    text-align: center;
  }

  .el-name {
    font-size: 1.5rem;
    font-weight: bold;
    color: var(--el-color);
    display: block;
    margin-bottom: 0.8rem;
  }

  .el-relations {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    font-size: 0.85rem;
  }

  .el-generates { color: #40b040; }
  .el-weakens { color: #f04040; }

  .matches-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .match-card {
    background: #1a1a2e;
    border-radius: 12px;
    padding: 1.2rem;
    border: 1px solid #2a2a4a;
    transition: transform 0.3s ease;
  }

  .match-card:hover {
    transform: translateY(-4px);
  }

  .match-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
  }

  .match-year {
    font-size: 1.2rem;
    font-weight: bold;
    color: #f0c040;
  }

  .match-animal {
    background: #2a2a4a;
    padding: 0.3rem 0.8rem;
    border-radius: 20px;
    font-size: 0.9rem;
    color: #c0c0c0;
  }

  .match-element {
    font-size: 1rem;
    margin-bottom: 0.8rem;
    font-weight: bold;
  }

  .match-trait {
    color: #a0a0a0;
    font-size: 0.9rem;
    line-height: 1.5;
    margin-bottom: 1rem;
  }

  .match-compatibility {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding-top: 0.8rem;
    border-top: 1px solid #2a2a4a;
    font-size: 0.85rem;
  }

  .comp-label {
    color: #808080;
  }

  .compatible span:last-child { color: #40b040; }
  .incompatible span:last-child { color: #f04040; }

  .tips-list {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    padding: 1.5rem;
    background: #1a1a2e;
    border-radius: 12px;
    border-left: 4px solid #f0c040;
  }

  .tips-list li {
    color: #a0a0a0;
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .birth-page {
      padding: 1rem;
    }

    .matches-grid {
      grid-template-columns: 1fr;
    }

    .elements-grid {
      flex-direction: column;
    }
  }
</style>