---
import ModuleLayout from '../../layouts/ModuleLayout.astro';

const evilBeasts = [
  { name: '饕餮', danger: '极高', color: '#8b0000', desc: '羊身人面，虎齿人爪，大头贪食。象征贪婪无度，为四大凶兽之一。', power: '吞噬万物', avoidance: '忌贪心、忌暴饮暴食' },
  { name: '混沌', danger: '极高', color: '#4a0080', desc: '有目却不见，有耳却不闻。善恶不分，是非不明。象征颠倒黑白。', power: '迷人心智', avoidance: '忌迷惑、忌决策不明' },
  { name: '穷奇', danger: '高', color: '#ff4500', desc: '牛身蛇尾，翅如蝙蝠。闻人斗则赠恶人，反助其杀。象征助纣为虐。', power: '颠倒黑白', avoidance: '忌结交小人、忌偏听偏信' },
  { name: '梼杌', danger: '高', color: '#2f4f4f', desc: '西方荒兽，人面虎足，猪口獠牙。顽固不化，一意孤行。象征刚愎自用。', power: '顽固凶暴', avoidance: '忌固执、忌不听劝告' },
  { name: '九婴', danger: '高', color: '#006400', desc: '九头蛇怪，能喷水火。凶焰滔天，为水火之精。遇之则有大灾。', power: '水火双行', avoidance: '忌水火并用、忌南北走向' },
  { name: '相柳', danger: '高', color: '#3cb371', desc: '九头蛇身，共工之臣。吐出的水苦涩，所在之处皆为泽国。', power: '毒水漫溢', avoidance: '忌近水、忌低洼之地' },
  { name: '烛龙', danger: '中', color: '#ff6347', desc: '人面龙身，赤目蛇尾。睁眼为昼，闭眼为夜。呼气为冬，吸气为夏。', power: '主宰昼夜', avoidance: '忌逆天而行' },
  { name: '应龙', danger: '中', color: '#4682b4', desc: '有翼之龙，助黄帝伐蚩尤。杀蚩尤、夸父，为功勋之兽。', power: '战争之力', avoidance: '忌轻启战端' },
];
---

<ModuleLayout moduleId="hong" title="异兽图" description="凶险异兽图鉴，四大凶兽">
  <div class="evil-beasts-page">
    <section class="intro-section">
      <h2>异兽图鉴</h2>
      <p>洪荒之时，亦有凶兽横行。它们或为上古怨气所化，或为妖魔修炼而成。修行者当知其形、识其性，方能趋吉避凶。</p>
    </section>

    <section class="four-evil">
      <h2>四大凶兽</h2>
      <div class="evils-grid">
        {evilBeasts.slice(0, 4).map(beast => (
          <div class="evil-card" style={`--evil-color: ${beast.color}`}>
            <div class="evil-badge">
              <span class="danger-level">危险: {beast.danger}</span>
            </div>
            <h3>{beast.name}</h3>
            <p class="evil-desc">{beast.desc}</p>
            <div class="evil-powers">
              <div class="power">
                <span class="power-label">能力:</span>
                <span>{beast.power}</span>
              </div>
              <div class="avoid">
                <span class="avoid-label">趋避:</span>
                <span>{beast.avoidance}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="other-evils">
      <h2>其他凶兽</h2>
      <div class="evils-grid">
        {evilBeasts.slice(4).map(beast => (
          <div class="evil-card" style={`--evil-color: ${beast.color}`}>
            <div class="evil-badge">
              <span class="danger-level">危险: {beast.danger}</span>
            </div>
            <h3>{beast.name}</h3>
            <p class="evil-desc">{beast.desc}</p>
            <div class="evil-powers">
              <div class="power">
                <span class="power-label">能力:</span>
                <span>{beast.power}</span>
              </div>
              <div class="avoid">
                <span class="avoid-label">趋避:</span>
                <span>{beast.avoidance}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="protection-section">
      <h2>驱凶之法</h2>
      <div class="protection-cards">
        <div class="protection-card">
          <h3>符箓镇邪</h3>
          <p>以朱砂书符，贴于门户。常用镇宅符、五雷符可驱散凶兽之气。</p>
        </div>
        <div class="protection-card">
          <h3>阵法避凶</h3>
          <p>布置八卦阵、四象阵可改变气场，令凶兽难以接近。</p>
        </div>
        <div class="protection-card">
          <h3>德行化凶</h3>
          <p>心存善念、正气内存。凶兽感应到浩然之气，自会退避三舍。</p>
        </div>
      </div>
    </section>
  </div>
</ModuleLayout>

<style>
  .evil-beasts-page {
    max-width: 1200px;
    margin: 0 auto;
  }

  .intro-section {
    text-align: center;
    margin-bottom: 3rem;
  }

  .intro-section h2 {
    font-size: 1.8rem;
    color: #d4af37;
    margin-bottom: 1rem;
  }

  .intro-section p {
    color: #888;
    line-height: 1.8;
    max-width: 800px;
    margin: 0 auto;
  }

  section {
    margin-bottom: 3rem;
  }

  section h2 {
    font-size: 1.4rem;
    color: #c9a227;
    margin-bottom: 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(201, 162, 39, 0.2);
  }

  .evils-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .evil-card {
    background: linear-gradient(135deg, rgba(30, 10, 10, 0.9), rgba(20, 20, 20, 0.8));
    border: 1px solid var(--evil-color);
    border-radius: 12px;
    padding: 1.5rem;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .evil-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--evil-color);
  }

  .evil-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.5), 0 0 20px color-mix(in srgb, var(--evil-color) 20%, transparent);
  }

  .evil-badge {
    margin-bottom: 1rem;
  }

  .danger-level {
    background: rgba(139, 0, 0, 0.3);
    color: #ff4444;
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    font-size: 0.8rem;
    font-weight: 600;
  }

  .evil-card h3 {
    color: var(--evil-color);
    font-size: 1.4rem;
    margin-bottom: 1rem;
  }

  .evil-desc {
    color: #ccc;
    line-height: 1.6;
    margin-bottom: 1rem;
    font-size: 0.9rem;
  }

  .evil-powers {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .power, .avoid {
    font-size: 0.85rem;
  }

  .power-label, .avoid-label {
    margin-right: 0.5rem;
  }

  .power-label {
    color: #ff6347;
  }

  .avoid-label {
    color: #40b040;
  }

  .power span:last-child, .avoid span:last-child {
    color: #aaa;
  }

  .protection-cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 1.5rem;
  }

  .protection-card {
    background: rgba(20, 20, 20, 0.6);
    border: 1px solid rgba(64, 176, 64, 0.3);
    border-radius: 8px;
    padding: 1.5rem;
  }

  .protection-card h3 {
    color: #40b040;
    margin-bottom: 0.8rem;
  }

  .protection-card p {
    color: #888;
    line-height: 1.6;
    margin: 0;
  }
</style>
