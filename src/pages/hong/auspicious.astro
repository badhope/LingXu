---
import ModuleLayout from '../../layouts/ModuleLayout.astro';

const auspiciousItems = [
  { name: '龙', element: '水', color: '#6040f0', desc: '鳞虫之长，四灵之首。九似之物：角似鹿、头似驼、眼似兔、耳似牛、足似蜃...', meaning: '尊贵、祥瑞、权力', appears: '真龙现世，天下太平' },
  { name: '凤凰', element: '火', color: '#ff6b6b', desc: '百鸟之王，涅槃重生。五色备举，飞则百鸟从之。为火之精。', meaning: '吉祥、爱情、不死', appears: '凤凰鸣兮，盛世将至' },
  { name: '麒麟', element: '土', color: '#c08040', desc: '中央之神，走兽之长。麒麟出圣人现，天下太平。仁兽也，不履生虫。', meaning: '仁德、太平、子孙昌盛', appears: '麟趾呈祥，圣人出世' },
  { name: '白鹤', element: '金', color: '#e0e0e0', desc: '羽族君子，寿享千年。鹤鸣九皋，声闻于天。修道者常以鹤为伴。', meaning: '长寿、君子、羽化登仙', appears: '一鹤冲天，功名成就' },
  { name: '神龟', element: '水', color: '#4080f0', desc: '介虫之王，寿高万万岁。背有九宫，腹有八卦。镇宅避煞，延年益寿。', meaning: '长寿、智慧、镇宅', appears: '神龟出洛，文明将兴' },
  { name: '貔貅', element: '土', color: '#f08040', desc: '凶猛瑞兽，有嘴无肛。只进不出，招财镇宅。天龙八部之一。', meaning: '招财、镇宅、辟邪', appears: '貔貅坐镇，财源广进' },
  { name: '白鹿', element: '木', color: '#40b040', desc: '仙兽之一，寿千年以上。鹿角可入药，血能续命。常与仙人为伴。', meaning: '长寿、祥瑞、灵性', appears: '白鹿衔草，灵芝献瑞' },
  { name: '金蟾', element: '金', color: '#ffd700', desc: '三足金蟾，居住月宫。口含铜钱，利于商贾。可旺财转运。', meaning: '旺财、转运、辟小人', appears: '金蟾吐宝，财星高照' },
];

const phenomena = [
  { name: '瑞雪兆丰年', desc: '冬季大雪，预示来年丰收。是天地灵气滋养大地之象。', meaning: '吉祥' },
  { name: '枯木逢春', desc: '枯死之树重新发芽，预示绝处逢生，转危为安。', meaning: '转机' },
  { name: '乌鸦报丧', desc: '乌鸦叫不祥，但若久旱逢甘霖，则为吉兆。', meaning: '警示' },
  { name: '鲤鱼跃龙门', desc: '鲤鱼跳过龙门化为龙，科举功名高中之兆。', meaning: '功名' },
  { name: '铁树开花', desc: '铁树千年一开，开则天下大治，盛世将临。', meaning: '盛世' },
  { name: '紫气东来', desc: '东方有紫气浮现，是老子西出函关或贵人将至之兆。', meaning: '贵人' },
  { name: '日月同辉', desc: '太阳与月亮同时出现在天空，是天地交泰之象。', meaning: '和谐' },
  { name: '五星连珠', desc: '金木水火土五星连成一线，是天降大任或改朝换代之兆。', meaning: '大变' },
];

const plantAuspicious = [
  { name: '灵芝', color: '#c080f0', desc: '仙草，服之可长生不老。深山老林方有。' },
  { name: '人参', color: '#f04040', desc: '人形，寿千年可化形。补气固元，延年益寿。' },
  { name: '蟠桃', color: '#ff6b6b', desc: '天界仙果，三千年一熟。食之可飞升成仙。' },
  { name: '甘露', color: '#4080f0', desc: '天界圣水，可治愈一切伤病。凝结天地灵气。' },
];
---

<ModuleLayout moduleId="hong" title="祥瑞" description="祥瑞之物与吉凶征兆">
  <div class="auspicious-page">
    <section class="intro-section">
      <h2>祥瑞图鉴</h2>
      <p>祥瑞者，天地感应之象也。圣人出世，必有祥瑞；盛世降临，必有征兆。修行者观天地之变，可知祸福吉凶。</p>
    </section>

    <section class="beasts-section">
      <h2>瑞兽灵禽</h2>
      <div class="beasts-grid">
        {auspiciousItems.map(item => (
          <div class="beast-card" style={`--beast-color: ${item.color}`}>
            <div class="beast-icon">{item.name[0]}</div>
            <div class="beast-header">
              <h3>{item.name}</h3>
              <span class="beast-element">{item.element}属</span>
            </div>
            <p class="beast-desc">{item.desc}</p>
            <div class="beast-meaning">
              <span class="meaning-label">寓意:</span>
              <span>{item.meaning}</span>
            </div>
            <div class="beast-appears">
              <span class="appears-icon">✨</span>
              <span>{item.appears}</span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="phenomena-section">
      <h2>天地异象</h2>
      <div class="phenomena-grid">
        {phenomena.map(p => (
          <div class="phenomenon-card">
            <h3>{p.name}</h3>
            <p class="phen-desc">{p.desc}</p>
            <span class="phen-meaning">{p.meaning}</span>
          </div>
        ))}
      </div>
    </section>

    <section class="plants-section">
      <h2>灵植仙草</h2>
      <div class="plants-grid">
        {plantAuspicious.map(plant => (
          <div class="plant-card" style={`--plant-color: ${plant.color}`}>
            <span class="plant-icon">🌿</span>
            <h3>{plant.name}</h3>
            <p class="plant-desc">{plant.desc}</p>
          </div>
        ))}
      </div>
    </section>
  </div>
</ModuleLayout>

<style>
  .auspicious-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }

  .intro-section {
    text-align: center;
    margin-bottom: 3rem;
    padding: 2rem;
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
    border-radius: 12px;
  }

  .intro-section h2 {
    font-size: 2rem;
    color: #f0c040;
    margin-bottom: 1rem;
  }

  .intro-section p {
    color: #a0a0a0;
    line-height: 1.8;
    font-size: 1.1rem;
  }

  h2 {
    font-size: 1.5rem;
    color: #e0e0e0;
    margin-bottom: 1.5rem;
    padding-left: 1rem;
    border-left: 4px solid #f0c040;
  }

  .beasts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .beast-card {
    background: #1a1a2e;
    border-radius: 12px;
    padding: 1.5rem;
    border: 1px solid var(--beast-color);
    transition: transform 0.3s ease;
  }

  .beast-card:hover {
    transform: translateY(-4px);
  }

  .beast-icon {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background: var(--beast-color);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    font-weight: bold;
    color: #1a1a2e;
    margin-bottom: 1rem;
  }

  .beast-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.8rem;
  }

  .beast-header h3 {
    font-size: 1.2rem;
    color: var(--beast-color);
    margin: 0;
  }

  .beast-element {
    background: #2a2a4a;
    padding: 0.2rem 0.6rem;
    border-radius: 8px;
    font-size: 0.8rem;
    color: #808080;
  }

  .beast-desc {
    color: #a0a0a0;
    line-height: 1.6;
    margin-bottom: 1rem;
    font-size: 0.9rem;
  }

  .beast-meaning {
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }

  .meaning-label { color: #808080; }
  .beast-meaning span:last-child { color: #f0c040; }

  .beast-appears {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem;
    background: #2a2a4a;
    border-radius: 6px;
    font-size: 0.85rem;
    color: #c0c0c0;
  }

  .appears-icon { font-size: 1rem; }

  .phenomena-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1rem;
    margin-bottom: 3rem;
  }

  .phenomenon-card {
    background: #1a1a2e;
    border-radius: 10px;
    padding: 1rem;
    border: 1px solid #2a2a4a;
  }

  .phenomenon-card h3 {
    font-size: 1rem;
    color: #f0c040;
    margin: 0 0 0.5rem 0;
  }

  .phen-desc {
    color: #a0a0a0;
    font-size: 0.85rem;
    line-height: 1.5;
    margin-bottom: 0.5rem;
  }

  .phen-meaning {
    display: inline-block;
    background: #2a2a4a;
    padding: 0.2rem 0.5rem;
    border-radius: 8px;
    font-size: 0.8rem;
    color: #40b040;
  }

  .plants-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1rem;
  }

  .plant-card {
    background: #1a1a2e;
    border-radius: 12px;
    padding: 1.2rem;
    border: 1px solid var(--plant-color);
    text-align: center;
  }

  .plant-icon {
    font-size: 2rem;
    display: block;
    margin-bottom: 0.8rem;
  }

  .plant-card h3 {
    font-size: 1.1rem;
    color: var(--plant-color);
    margin: 0 0 0.5rem 0;
  }

  .plant-desc {
    color: #a0a0a0;
    font-size: 0.85rem;
    line-height: 1.5;
    margin: 0;
  }

  @media (max-width: 768px) {
    .auspicious-page {
      padding: 1rem;
    }

    .beasts-grid, .phenomena-grid, .plants-grid {
      grid-template-columns: 1fr;
    }
  }
</style>