---
import ModuleLayout from '../../layouts/ModuleLayout.astro';

const ruins = [
  { name: '三十三天外天', location: '混沌之中', danger: '极高', desc: '圣人所居之地，凡人不可至。三十三重天各有主宰，是修行者最终目标。', feature: '灵气最为纯净', status: '存' },
  { name: '不周山遗址', location: '洪荒大陆', danger: '高', desc: '共工触山之处，天柱折断之地。残留先天灵气与上古遗迹。', feature: '可感悟上古法则', status: '残存' },
  { name: '妖庭废墟', location: '三十三天外', danger: '高', desc: '帝俊、东皇太一建立的妖庭遗迹。巫妖大战后化为废墟。', feature: '有妖族传承', status: '废墟' },
  { name: '紫霄宫', location: '混沌之中', danger: '中', desc: '鸿钧道祖讲道之所。虽已隐匿，但有缘者或可寻得。', feature: '道祖传承', status: '隐匿' },
  { name: '昆仑山秘境', location: '西域', danger: '中', desc: '西王母道场，瑶池所在。有不死药与蟠桃树。', feature: '不死药', status: '半开放' },
  { name: '东海龙宫', location: '东海深渊', danger: '中', desc: '龙族聚居之地，四海龙王统领。有众多水族传承。', feature: '水族功法', status: '存' },
  { name: '幽冥血海', location: '幽冥界', danger: '极高', desc: '盘古污血所化，阿修罗族居地。血海之中有冥河老祖。', feature: '血道功法', status: '存' },
  { name: '万寿山五庄观', location: '西牛贺洲', danger: '低', desc: '镇元大仙道场，有人参果树。可延寿万载。', feature: '人参果', status: '存' },
  { name: '斜月三星洞', location: '灵台方寸山', danger: '低', desc: '菩提祖师道场，孙悟空学艺之所。现已隐匿。', feature: '菩提心法', status: '隐匿' },
  { name: '天庭遗迹', location: '三十三天', danger: '中', desc: '封神大战后天庭重建，旧天庭遗迹被封存。', feature: '封神榜原件', status: '封印' },
  { name: '女娲宫', location: '大地各处', danger: '低', desc: '女娲娘娘庙宇，内有造人池。虽已衰败，仍有灵验。', feature: '造人之基', status: '衰败' },
  { name: '火云洞', location: '三十三天外', danger: '低', desc: '三皇居所，人族圣地。伏羲、神农、黄帝坐镇。', feature: '人族气运', status: '存' },
];

const statusColors: Record<string, string> = {
  '存': '#40b040',
  '残存': '#f08040',
  '废墟': '#606060',
  '隐匿': '#4080f0',
  '半开放': '#f0c040',
  '封印': '#8040f0',
  '衰败': '#a0a0a0',
};

const dangerLevels = [
  { level: '极高', color: '#f04040', count: 2 },
  { level: '高', color: '#f08040', count: 2 },
  { level: '中', color: '#f0c040', count: 4 },
  { level: '低', color: '#40b040', count: 4 },
];
---

<ModuleLayout moduleId="huang-lost" title="遗迹" description="失落遗迹与秘境">
  <div class="ruins-page">
    <section class="intro-section">
      <h2>失落遗迹</h2>
      <p>天地之大，遗迹无数。上古大能的道场、神魔大战的战场、先天灵宝的埋藏地……遗迹之中，有机缘亦有危险。探索遗迹，需有大机缘与大勇气。</p>
    </section>

    <section class="danger-section">
      <h2>危险等级</h2>
      <div class="danger-grid">
        {dangerLevels.map(d => (
          <div class="danger-card" style={`--danger-color: ${d.color}`}>
            <span class="danger-count">{d.count}</span>
            <span class="danger-level">{d.level}</span>
          </div>
        ))}
      </div>
    </section>

    <section class="ruins-grid-section">
      <h2>遗迹详解</h2>
      <div class="ruins-grid">
        {ruins.map(ruin => (
          <div class="ruin-card">
            <div class="ruin-header">
              <h3>{ruin.name}</h3>
              <span class="ruin-status" style={`background: ${statusColors[ruin.status]}`}>
                {ruin.status}
              </span>
            </div>
            <div class="ruin-location">
              <span class="location-icon">📍</span>
              <span>{ruin.location}</span>
            </div>
            <p class="ruin-desc">{ruin.desc}</p>
            <div class="ruin-footer">
              <div class="ruin-feature">
                <span class="feature-icon">✨</span>
                <span>{ruin.feature}</span>
              </div>
              <div class="ruin-danger" data-level={ruin.danger}>
                <span class="danger-icon">⚠️</span>
                <span>{ruin.danger}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>
  </div>
</ModuleLayout>

<style>
  .ruins-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }

  .intro-section {
    text-align: center;
    margin-bottom: 3rem;
    padding: 2rem;
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
    border-radius: 12px;
  }

  .intro-section h2 {
    font-size: 2rem;
    color: #f0c040;
    margin-bottom: 1rem;
  }

  .intro-section p {
    color: #a0a0a0;
    line-height: 1.8;
    font-size: 1.1rem;
  }

  h2 {
    font-size: 1.5rem;
    color: #e0e0e0;
    margin-bottom: 1.5rem;
    padding-left: 1rem;
    border-left: 4px solid #f0c040;
  }

  .danger-grid {
    display: flex;
    gap: 1rem;
    margin-bottom: 3rem;
    flex-wrap: wrap;
  }

  .danger-card {
    flex: 1;
    min-width: 120px;
    background: #1a1a2e;
    border-radius: 12px;
    padding: 1rem;
    border: 1px solid var(--danger-color);
    text-align: center;
  }

  .danger-count {
    font-size: 1.8rem;
    font-weight: bold;
    color: var(--danger-color);
    display: block;
  }

  .danger-level {
    color: #c0c0c0;
    font-size: 0.95rem;
  }

  .ruins-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  .ruin-card {
    background: #1a1a2e;
    border-radius: 12px;
    padding: 1.5rem;
    border: 1px solid #2a2a4a;
    transition: transform 0.3s ease;
  }

  .ruin-card:hover {
    transform: translateY(-4px);
  }

  .ruin-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .ruin-header h3 {
    font-size: 1.2rem;
    color: #f0c040;
    margin: 0;
  }

  .ruin-status {
    padding: 0.2rem 0.6rem;
    border-radius: 8px;
    font-size: 0.8rem;
    color: #1a1a2e;
    font-weight: bold;
  }

  .ruin-location {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
    font-size: 0.9rem;
  }

  .location-icon { font-size: 1rem; }
  .ruin-location span:last-child { color: #808080; }

  .ruin-desc {
    color: #a0a0a0;
    line-height: 1.6;
    margin-bottom: 1rem;
    font-size: 0.9rem;
  }

  .ruin-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1rem;
    border-top: 1px solid #2a2a4a;
  }

  .ruin-feature {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
  }

  .feature-icon { font-size: 1rem; }
  .ruin-feature span:last-child { color: #f08040; }

  .ruin-danger {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.2rem 0.5rem;
    border-radius: 6px;
    font-size: 0.8rem;
  }

  .ruin-danger[data-level="极高"] { background: #f04040; color: #fff; }
  .ruin-danger[data-level="高"] { background: #f08040; color: #1a1a2e; }
  .ruin-danger[data-level="中"] { background: #f0c040; color: #1a1a2e; }
  .ruin-danger[data-level="低"] { background: #40b040; color: #fff; }

  @media (max-width: 768px) {
    .ruins-page {
      padding: 1rem;
    }

    .ruins-grid {
      grid-template-columns: 1fr;
    }
  }
</style>