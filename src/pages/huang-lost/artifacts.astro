---
import ModuleLayout from '../../layouts/ModuleLayout.astro';

const artifacts = [
  { name: '东皇钟', rank: '先天至宝', owner: '东皇太一', power: '镇杀圣人，毁天灭地', desc: '混沌钟，隐于苍穹。攻防一体，可镇杀圣人。巫妖大战中东皇太一陨落后下落不明。', status: '失传' },
  { name: '盘古斧', rank: '先天至宝', owner: '盘古', power: '开天辟地', desc: '盘古开天所用神斧，一斧劈开混沌。一用即损，早已不存于世。', status: '已毁' },
  { name: '太极图', rank: '先天至宝', owner: '老子', power: '化解一切攻击', desc: '老子镇教之宝，展开可化尽一切攻击。金桥横渡，镇压气运。', status: '存于老子' },
  { name: '盘古幡', rank: '先天至宝', owner: '元始天尊', power: '撕裂混沌', desc: '元始天尊镇教之宝，可撕裂混沌，毁天灭地。', status: '存于元始' },
  { name: '混沌钟', rank: '先天至宝', owner: '东皇太一', power: '镇杀圣人', desc: '同东皇钟，隐于苍穹。', status: '失传' },
  { name: '诛仙剑阵', rank: '先天至宝', owner: '通天教主', power: '非四圣不可破', desc: '截教镇教之宝，四剑配合阵法，威力无穷，需四位圣人联手方可破解。', status: '已散' },
  { name: '十二品莲台', rank: '先天宝物', owner: '接引道人', power: '镇压气运', desc: '接引道人证道之宝，后被蚊道人吃掉三品，化为九品莲台。', status: '受损' },
  { name: '昊天塔', rank: '先天至宝', owner: '昊天上帝', power: '镇压一切', desc: '天庭镇殿之宝，可镇压一切妖邪。玉帝随身携带。', status: '存于天庭' },
  { name: '玲珑塔', rank: '后天至宝', owner: '李靖', power: '困人收人', desc: '李靖随身宝物，可困人收人。哪吒曾被此塔所困。', status: '存于李靖' },
  { name: '金葫芦', rank: '后天宝物', owner: '女娲', power: '炼化圣人', desc: '可炼化圣人的葫芦，后被陆压道人所得。', status: '下落不明' },
  { name: '金刚琢', rank: '后天至宝', owner: '太上老君', power: '套取万物', desc: '老君随身法宝，可套取一切宝物与兵器。青牛曾借此琢横行。', status: '存于老君' },
  { name: '芭蕉扇', rank: '先天灵宝', owner: '罗刹女', power: '灭火生风', desc: '一扇熄火，二扇生风，三扇下雨。铁扇公主曾借予孙悟空。', status: '存于罗刹女' },
];

const ranks = [
  { name: '先天至宝', color: '#f0c040', count: 7 },
  { name: '先天灵宝', color: '#f08040', count: 2 },
  { name: '后天至宝', color: '#4080f0', count: 2 },
  { name: '后天灵宝', color: '#40b040', count: 1 },
];
---

<ModuleLayout moduleId="huang-lost" title="神器" description="失落神器与传说宝物">
  <div class="artifacts-page">
    <section class="intro-section">
      <h2>失落神器</h2>
      <p>神器者，先天所生或大能所炼，可镇教立派，毁天灭地。然神器有灵，时应劫而失，时隐于世不出。得之者可得天下，失之者亦随之沉浮。</p>
    </section>

    <section class="ranks-section">
      <h2>神器等级</h2>
      <div class="ranks-grid">
        {ranks.map(rank => (
          <div class="rank-card" style={`--rank-color: ${rank.color}`}>
            <span class="rank-count">{rank.count}</span>
            <span class="rank-name">{rank.name}</span>
          </div>
        ))}
      </div>
    </section>

    <section class="artifacts-grid-section">
      <h2>神器图鉴</h2>
      <div class="artifacts-grid">
        {artifacts.map(artifact => (
          <div class="artifact-card">
            <div class="artifact-header">
              <div class="artifact-icon">{artifact.name[0]}</div>
              <div class="artifact-title">
                <h3>{artifact.name}</h3>
                <span class="artifact-rank" data-rank={artifact.rank}>{artifact.rank}</span>
              </div>
            </div>
            <div class="artifact-owner">
              <span class="owner-label">持有者:</span>
              <span>{artifact.owner}</span>
            </div>
            <p class="artifact-desc">{artifact.desc}</p>
            <div class="artifact-footer">
              <div class="artifact-power">
                <span class="power-icon">⚡</span>
                <span>{artifact.power}</span>
              </div>
              <div class="artifact-status" data-status={artifact.status}>
                {artifact.status}
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>
  </div>
</ModuleLayout>

<style>
  .artifacts-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }

  .intro-section {
    text-align: center;
    margin-bottom: 3rem;
    padding: 2rem;
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
    border-radius: 12px;
  }

  .intro-section h2 {
    font-size: 2rem;
    color: #f0c040;
    margin-bottom: 1rem;
  }

  .intro-section p {
    color: #a0a0a0;
    line-height: 1.8;
    font-size: 1.1rem;
  }

  h2 {
    font-size: 1.5rem;
    color: #e0e0e0;
    margin-bottom: 1.5rem;
    padding-left: 1rem;
    border-left: 4px solid #f0c040;
  }

  .ranks-grid {
    display: flex;
    gap: 1rem;
    margin-bottom: 3rem;
    flex-wrap: wrap;
  }

  .rank-card {
    flex: 1;
    min-width: 150px;
    background: #1a1a2e;
    border-radius: 12px;
    padding: 1rem;
    border: 1px solid var(--rank-color);
    text-align: center;
  }

  .rank-count {
    font-size: 1.8rem;
    font-weight: bold;
    color: var(--rank-color);
    display: block;
  }

  .rank-name {
    color: #c0c0c0;
    font-size: 0.95rem;
  }

  .artifacts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  .artifact-card {
    background: #1a1a2e;
    border-radius: 12px;
    padding: 1.5rem;
    border: 1px solid #2a2a4a;
    transition: transform 0.3s ease, border-color 0.3s ease;
  }

  .artifact-card:hover {
    transform: translateY(-4px);
    border-color: #f0c040;
  }

  .artifact-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .artifact-icon {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background: linear-gradient(135deg, #f0c040, #f08040);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    font-weight: bold;
    color: #1a1a2e;
  }

  .artifact-title h3 {
    font-size: 1.3rem;
    color: #f0c040;
    margin: 0;
  }

  .artifact-rank {
    background: #2a2a4a;
    padding: 0.2rem 0.6rem;
    border-radius: 8px;
    font-size: 0.8rem;
    color: #c0c0c0;
  }

  .artifact-rank[data-rank="先天至宝"] { color: #f0c040; border: 1px solid #f0c040; }
  .artifact-rank[data-rank="先天灵宝"] { color: #f08040; border: 1px solid #f08040; }
  .artifact-rank[data-rank="后天至宝"] { color: #4080f0; border: 1px solid #4080f0; }

  .artifact-owner {
    font-size: 0.95rem;
    margin-bottom: 0.8rem;
  }

  .owner-label { color: #808080; }
  .artifact-owner span:last-child { color: #c0c0c0; }

  .artifact-desc {
    color: #a0a0a0;
    line-height: 1.6;
    margin-bottom: 1rem;
    font-size: 0.9rem;
  }

  .artifact-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1rem;
    border-top: 1px solid #2a2a4a;
  }

  .artifact-power {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
  }

  .power-icon { font-size: 1rem; }
  .artifact-power span:last-child { color: #f08040; }

  .artifact-status {
    padding: 0.2rem 0.6rem;
    border-radius: 8px;
    font-size: 0.8rem;
    font-weight: bold;
  }

  .artifact-status[data-status="失传"] { background: #f04040; color: #fff; }
  .artifact-status[data-status="已毁"] { background: #606060; color: #fff; }
  .artifact-status[data-status="存于老子"] { background: #f0c040; color: #1a1a2e; }
  .artifact-status[data-status="存于元始"] { background: #f0c040; color: #1a1a2e; }
  .artifact-status[data-status="已散"] { background: #f08040; color: #1a1a2e; }
  .artifact-status[data-status="受损"] { background: #f08040; color: #1a1a2e; }
  .artifact-status[data-status="存于天庭"] { background: #4080f0; color: #fff; }
  .artifact-status[data-status="存于李靖"] { background: #4080f0; color: #fff; }
  .artifact-status[data-status="存于老君"] { background: #f0c040; color: #1a1a2e; }
  .artifact-status[data-status="存于罗刹女"] { background: #40b040; color: #fff; }
  .artifact-status[data-status="下落不明"] { background: #808080; color: #fff; }

  @media (max-width: 768px) {
    .artifacts-page {
      padding: 1rem;
    }

    .artifacts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>