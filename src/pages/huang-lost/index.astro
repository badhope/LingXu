---
import ModuleLayout from '../../layouts/ModuleLayout.astro';
import { withBase } from '../../lib/utils';
---

<ModuleLayout moduleId="huang-lost" title="失落">
  <div class="huang-lost-overview">
    <section class="intro-section">
      <h2>失落文明之谜</h2>
      <p>荒者，文明断绝之谓也。远古之时，诸多秘术失传，功法断绝。唯有遗迹之中，尚存一二残篇。探索失落文明，拾遗远古智慧。</p>
    </section>

    <section class="features-grid">
      <a href={withBase('/huang-lost/techniques')} class="feature-card">
        <div class="card-icon">⚔️</div>
        <h3>失传功法</h3>
        <p>远古功法秘籍</p>
      </a>
      <a href={withBase('/huang-lost/medicine')} class="feature-card">
        <div class="card-icon">💊</div>
        <h3>医道秘术</h3>
        <p>岐黄之术秘方</p>
      </a>
      <a href={withBase('/huang-lost/artifacts')} class="feature-card">
        <div class="card-icon">🔧</div>
        <h3>炼器之道</h3>
        <p>神器法宝图纸</p>
      </a>
      <a href={withBase('/huang-lost/charms')} class="feature-card">
        <div class="card-icon">📋</div>
        <h3>符咒大全</h3>
        <p>符咒秘笈禁忌</p>
      </a>
      <a href={withBase('/huang-lost/ruins')} class="feature-card">
        <div class="card-icon">🏛️</div>
        <h3>遗迹探查</h3>
        <p>远古遗迹宝藏</p>
      </a>
    </section>

    <section class="secrecy-section">
      <h2>隐秘等级</h2>
      <div class="secrecy-levels">
        <div class="secrecy-level">
          <div class="level-badge s">S</div>
          <div class="level-info">
            <h3>绝密</h3>
            <p>可致天地巨变，禁毁级别，非大机缘不可见</p>
          </div>
        </div>
        <div class="secrecy-level">
          <div class="level-badge a">A</div>
          <div class="level-info">
            <h3>机密</h3>
            <p>可致大乱，历代掌门相传，轻易不可外泄</p>
          </div>
        </div>
        <div class="secrecy-level">
          <div class="level-badge b">B</div>
          <div class="level-info">
            <h3>秘密</h3>
            <p>各派核心功法，需有一定修为方可观阅</p>
          </div>
        </div>
        <div class="secrecy-level">
          <div class="level-badge c">C</div>
          <div class="level-info">
            <h3>内部</h3>
            <p>入门级秘术，初入修行者可学</p>
          </div>
        </div>
      </div>
    </section>
  </div>

  <style>
    .huang-lost-overview { max-width: 1200px; margin: 0 auto; }
    .intro-section { text-align: center; margin-bottom: 3rem; padding: 2rem; background: rgba(128, 96, 64, 0.05); border: 1px solid rgba(128, 96, 64, 0.2); border-radius: 8px; }
    .intro-section h2 { color: #a08060; margin-bottom: 1rem; }
    .intro-section p { color: #888; line-height: 1.8; max-width: 600px; margin: 0 auto; }
    .features-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem; margin-bottom: 3rem; }
    .feature-card { display: flex; flex-direction: column; align-items: center; padding: 2rem 1.5rem; background: rgba(10, 10, 15, 0.8); border: 1px solid rgba(128, 96, 64, 0.2); border-radius: 8px; text-decoration: none; transition: all 0.3s ease; }
    .feature-card:hover { transform: translateY(-4px); border-color: #806040; box-shadow: 0 8px 24px rgba(128, 96, 64, 0.15); }
    .card-icon { font-size: 2.5rem; margin-bottom: 1rem; }
    .feature-card h3 { color: #e8e0d0; margin: 0 0 0.5rem 0; }
    .feature-card p { color: #888; margin: 0; font-size: 0.85rem; }
    .secrecy-section h2 { color: #806040; font-size: 1.25rem; margin-bottom: 1.5rem; text-align: center; }
    .secrecy-levels { display: flex; flex-direction: column; gap: 1rem; }
    .secrecy-level { display: flex; align-items: center; gap: 1.5rem; padding: 1.5rem; background: rgba(10, 10, 15, 0.8); border: 1px solid rgba(128, 96, 64, 0.2); border-radius: 8px; }
    .level-badge { width: 50px; height: 50px; display: flex; align-items: center; justify-content: center; border-radius: 8px; font-size: 1.5rem; font-weight: bold; }
    .level-badge.s { background: linear-gradient(135deg, #800000, #400000); color: #ff6060; border: 1px solid #ff0000; }
    .level-badge.a { background: linear-gradient(135deg, #4a3000, #2a1800); color: #ffd700; border: 1px solid #c9a227; }
    .level-badge.b { background: linear-gradient(135deg, #1a3060, #0a1830); color: #6080ff; border: 1px solid #4080ff; }
    .level-badge.c { background: linear-gradient(135deg, #1a3020, #0a1808); color: #60d080; border: 1px solid #40b060; }
    .level-info h3 { color: #e8e0d0; margin: 0 0 0.25rem 0; }
    .level-info p { color: #888; margin: 0; font-size: 0.85rem; }
  </style>
</ModuleLayout>
