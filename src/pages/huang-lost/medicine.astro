---
import ModuleLayout from '../../layouts/ModuleLayout.astro';

const medicines = [
  { name: '九转还魂丹', grade: '神', color: '#f0c040', desc: '可令濒死之人起死回生，修复破碎的灵魂。仅有一颗主药引，需天时地利方可炼制。', effect: '生死人，肉白骨', difficulty: '极难' },
  { name: '筑基丹', grade: '上', color: '#4080f0', desc: '辅助筑基的灵药，可提高筑基成功率。对筑基期以上修士无效。', effect: '助筑基', difficulty: '难' },
  { name: '培元丹', grade: '中', color: '#40b040', desc: '温养元气，固本培元。适合久病体虚或重伤恢复之人。', effect: '固本培元', difficulty: '中' },
  { name: '解毒丹', grade: '普', color: '#c08040', desc: '化解常见毒素，对特殊剧毒效果有限。修士居家旅行必备。', effect: '解毒', difficulty: '易' },
  { name: '破境丹', grade: '上', color: '#8040f0', desc: '辅助突破瓶颈，但使用后会有短暂虚弱期。不可多用。', effect: '助破境', difficulty: '难' },
  { name: '续命丹', grade: '上', color: '#f04080', desc: '延长寿元三月，但有副作用。适用于寿元将尽者苟延残喘。', effect: '延寿三月', difficulty: '极难' },
];

const herbs = [
  { name: '灵芝', location: '深山老林', desc: '千年灵芝可遇不可求，服用可增寿元', rarity: '极稀' },
  { name: '人参', location: '东北长白山', desc: '百年人参已是难得，千年人参有价无市', rarity: '稀' },
  { name: '何首乌', location: '各地均有', desc: '首乌可乌发益精，但需九蒸九晒方可用', rarity: '中' },
  { name: '冬虫夏草', location: '高原地带', desc: '虫草兼备虫草双重性，滋补上品', rarity: '稀' },
  { name: '天麻', location: '南方山地', desc: '平肝息风，对神魂修炼有辅助作用', rarity: '中' },
  { name: '雪莲', location: '雪线以上', desc: '生长于极寒之地，可炼制筑基丹', rarity: '稀' },
];

const techniques = [
  { name: '九蒸九晒', desc: '将药材反复蒸晒九次，以去其毒性、增其药性。如何首乌等药材必经此法方能入药。' },
  { name: '文火慢炖', desc: '对火候要求极高，需文火慢炖数日乃至数月，药力方可渗透融合。' },
  { name: '以意引药', desc: '炼丹时以神识引导药力走向，使各药材精华完美融合。此法对神识消耗极大。' },
  { name: '药浴淬体', desc: '将药材煎煮后以药水浸泡身体，使药力从皮肤渗入。对体道修士尤为重要。' },
];
---

<ModuleLayout moduleId="huang-lost" title="医道秘术" description="岐黄之术秘方，医道仙药">
  <div class="medicine-page">
    <section class="intro-section">
      <h2>医道秘术</h2>
      <p>医道者，救命之术也。修行界之医术，远超凡尘。上古之时，有神农尝百草、扁鹊治百病。医道之学，博大精深。</p>
    </section>

    <section class="medicines-gallery">
      <h2>灵丹妙药</h2>
      <div class="medicines-grid">
        {medicines.map(med => (
          <div class="medicine-card" style={`--med-color: ${med.color}`}>
            <div class="medicine-header">
              <span class="medicine-grade">{med.grade}</span>
              <h3>{med.name}</h3>
            </div>
            <p class="medicine-desc">{med.desc}</p>
            <div class="medicine-meta">
              <span class="meta-effect">
                <span class="effect-label">功效:</span>
                <span class="effect-value">{med.effect}</span>
              </span>
              <span class="meta-difficulty">
                <span class="difficulty-label">炼制:</span>
                <span class="difficulty-value">{med.difficulty}</span>
              </span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="herbs-section">
      <h2>灵药本草</h2>
      <div class="herbs-table">
        <div class="herb-header">
          <span>药材</span>
          <span>产地</span>
          <span>功效</span>
          <span>稀有度</span>
        </div>
        {herbs.map(herb => (
          <div class="herb-row">
            <span class="herb-name">{herb.name}</span>
            <span class="herb-location">{herb.location}</span>
            <span class="herb-desc">{herb.desc}</span>
            <span class="herb-rarity">{herb.rarity}</span>
          </div>
        ))}
      </div>
    </section>

    <section class="techniques-section">
      <h2>炼制秘法</h2>
      <div class="techniques-grid">
        {techniques.map(tech => (
          <div class="technique-item">
            <h3>{tech.name}</h3>
            <p>{tech.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="healing-knowledge">
      <h2>医道要义</h2>
      <div class="knowledge-cards">
        <div class="knowledge-card">
          <h3>治未病</h3>
          <p>上医医未病，中医医欲病，下医医已病。修行者当注重日常调养，不使病邪入侵。</p>
        </div>
        <div class="knowledge-card">
          <h3>药食同源</h3>
          <p>许多药材亦是食材，日常饮食中便可养生。修行者当注重饮食之道。</p>
        </div>
        <div class="knowledge-card">
          <h3>心药合一</h3>
          <p>治病需治心，心病还需心药医。情绪波动影响灵气运行，对修行影响重大。</p>
        </div>
      </div>
    </section>

    <section class="warning-section">
      <h2>用药警示</h2>
      <div class="warnings">
        <div class="warning">
          <h3>是药三分毒</h3>
          <p>任何丹药都有副作用，不可盲目服用。需根据自身情况选择合适的药物。</p>
        </div>
        <div class="warning">
          <h3>不可贪多</h3>
          <p>丹药效果虽好，但身体有承受极限。过度服用会导致药力冲突，得不偿失。</p>
        </div>
        <div class="warning">
          <h3>资质各异</h3>
          <p>同一种药对不同人效果不同，需了解自身体质后再做选择。</p>
        </div>
      </div>
    </section>
  </div>
</ModuleLayout>

<style>
  .medicine-page {
    max-width: 1200px;
    margin: 0 auto;
  }

  .intro-section {
    text-align: center;
    margin-bottom: 3rem;
  }

  .intro-section h2 {
    font-size: 1.8rem;
    color: #d4af37;
    margin-bottom: 1rem;
  }

  .intro-section p {
    color: #888;
    line-height: 1.8;
    max-width: 800px;
    margin: 0 auto;
  }

  section {
    margin-bottom: 3rem;
  }

  section h2 {
    font-size: 1.4rem;
    color: #c9a227;
    margin-bottom: 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(201, 162, 39, 0.2);
  }

  .medicines-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .medicine-card {
    background: linear-gradient(135deg, rgba(20, 30, 20, 0.9), rgba(20, 20, 20, 0.8));
    border: 1px solid var(--med-color);
    border-radius: 12px;
    padding: 1.5rem;
    transition: all 0.3s ease;
  }

  .medicine-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3), 0 0 20px color-mix(in srgb, var(--med-color) 20%, transparent);
  }

  .medicine-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .medicine-grade {
    width: 32px;
    height: 32px;
    background: var(--med-color);
    color: #000;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    font-size: 0.9rem;
  }

  .medicine-card h3 {
    color: var(--med-color);
    font-size: 1.2rem;
    margin: 0;
  }

  .medicine-desc {
    color: #ccc;
    line-height: 1.6;
    margin-bottom: 1rem;
    font-size: 0.9rem;
  }

  .medicine-meta {
    display: flex;
    justify-content: space-between;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    font-size: 0.85rem;
  }

  .effect-label, .difficulty-label {
    color: #666;
    margin-right: 0.3rem;
  }

  .effect-value {
    color: #40b040;
  }

  .difficulty-value {
    color: #f04040;
  }

  .herbs-table {
    background: rgba(20, 20, 20, 0.8);
    border-radius: 8px;
    overflow: hidden;
  }

  .herb-header, .herb-row {
    display: grid;
    grid-template-columns: 1fr 1fr 2fr 0.8fr;
    text-align: center;
    padding: 1rem;
  }

  .herb-header {
    background: rgba(64, 176, 64, 0.2);
    color: #40b040;
    font-weight: 600;
  }

  .herb-row {
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    font-size: 0.9rem;
  }

  .herb-row:last-child {
    border-bottom: none;
  }

  .herb-name {
    color: #e8d48b;
    font-weight: 600;
  }

  .herb-location {
    color: #888;
  }

  .herb-desc {
    color: #aaa;
    text-align: left !important;
  }

  .herb-rarity {
    color: #f04040;
  }

  .techniques-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 1.5rem;
  }

  .technique-item {
    background: rgba(20, 20, 20, 0.6);
    border: 1px solid rgba(64, 176, 64, 0.2);
    border-radius: 8px;
    padding: 1.5rem;
  }

  .technique-item h3 {
    color: #40b040;
    margin-bottom: 0.8rem;
  }

  .technique-item p {
    color: #888;
    line-height: 1.6;
    margin: 0;
  }

  .knowledge-cards, .warnings {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .knowledge-card {
    background: rgba(20, 20, 20, 0.6);
    border: 1px solid rgba(201, 162, 39, 0.2);
    border-radius: 8px;
    padding: 1.5rem;
  }

  .knowledge-card h3 {
    color: #d4af37;
    margin-bottom: 0.8rem;
  }

  .knowledge-card p {
    color: #888;
    line-height: 1.6;
    margin: 0;
  }

  .warning {
    background: rgba(20, 20, 20, 0.6);
    border: 1px solid rgba(240, 64, 64, 0.2);
    border-radius: 8px;
    padding: 1.5rem;
  }

  .warning h3 {
    color: #f04040;
    margin-bottom: 0.8rem;
  }

  .warning p {
    color: #888;
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 768px) {
    .herb-header, .herb-row {
      grid-template-columns: 1fr 1fr;
      gap: 0.5rem;
    }

    .herb-desc {
      grid-column: span 2;
      text-align: left !important;
    }
  }
</style>
