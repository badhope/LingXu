---
import ModuleLayout from '../../layouts/ModuleLayout.astro';

const techniques = [
  { name: '天魔解体大法', level: '禁', color: '#8b0000', desc: '以燃烧自身精血为代价，换取短时间内爆发的战力。伤敌一千，自损八百。', danger: '极高', status: '已失传' },
  { name: '元神分割术', level: '密', color: '#4a0080', desc: '将元神一分为二，可同时做两件事。但每分裂一次，修为大减。', danger: '高', status: '部分失传' },
  { name: '夺舍重生法', level: '禁', color: '#ff4500', desc: '夺他人之身，以续自身命数。被夺舍者魂飞魄散，极伤天和。', danger: '极高', status: '有流传' },
  { name: '穿墙术', level: '普', color: '#40b040', desc: '可穿越普通墙壁，但对结界无效。修炼到极致可穿山裂石。', danger: '低', status: '有流传' },
  { name: '定身术', level: '中', color: '#4080f0', desc: '封锁目标行动能力，对修为高于己身者效果大减。', danger: '中', status: '部分失传' },
  { name: '召魂术', level: '密', color: '#806040', desc: '召唤亡魂问询，但亡魂未必说实话，且易被反噬。', danger: '高', status: '有流传' },
];

const cultivationSystems = [
  { name: '丹道', desc: '以炼丹服药为主，内外丹结合', feature: '见效快，但依赖外物' },
  { name: '气道', desc: '以练气为主，培育自身元气', feature: '根基稳，但进度较慢' },
  { name: '体道', desc: '以炼体为主，打熬筋骨皮肉', feature: '肉身强，但耗时长' },
  { name: '神道', desc: '以炼神为主，壮大元神灵魂', feature: '神通强，但风险大' },
  { name: '符道', desc: '以画符为主，借天地之力', feature: '应用广，但需材料' },
  { name: '阵道', desc: '以布阵为主，困敌于阵中', feature: '威力大，但需时间' },
];
---

<ModuleLayout moduleId="huang-lost" title="失传功法" description="远古功法秘籍，失传功法">
  <div class="techniques-page">
    <section class="intro-section">
      <h2>失落功法</h2>
      <p>荒者，文明断绝之谓也。远古之时，诸多秘术失传，功法断绝。唯有遗迹之中，尚存一二残篇。探索失落文明，拾遗远古智慧。</p>
    </section>

    <section class="techniques-gallery">
      <h2>功法图鉴</h2>
      <div class="techniques-grid">
        {techniques.map(tech => (
          <div class="technique-card" style={`--tech-color: ${tech.color}`}>
            <div class="technique-header">
              <span class="technique-level">{tech.level}</span>
              <h3>{tech.name}</h3>
            </div>
            <p class="technique-desc">{tech.desc}</p>
            <div class="technique-meta">
              <span class="meta-danger">
                <span class="danger-label">危险:</span>
                <span class="danger-value">{tech.danger}</span>
              </span>
              <span class="meta-status">
                <span class="status-label">状态:</span>
                <span class="status-value">{tech.status}</span>
              </span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="systems-section">
      <h2>修行体系</h2>
      <div class="systems-grid">
        {cultivationSystems.map(system => (
          <div class="system-card">
            <h3>{system.name}</h3>
            <p class="system-desc">{system.desc}</p>
            <span class="system-feature">{system.feature}</span>
          </div>
        ))}
      </div>
    </section>

    <section class="recovery-section">
      <h2>功法复原</h2>
      <div class="recovery-info">
        <div class="recovery-method">
          <h3>遗迹探索</h3>
          <p>上古遗迹中常藏有功法残篇，但遗迹多有危险，需结伴而行。</p>
        </div>
        <div class="recovery-method">
          <h3>师承传承</h3>
          <p>有些功法通过师徒口耳相传，虽有缺漏但较为完整。</p>
        </div>
        <div class="recovery-method">
          <h3>古籍解读</h3>
          <p>有些功法载于古籍，需具备相应知识方能解读。</p>
        </div>
      </div>
    </section>

    <section class="warning-section">
      <h2>修行警示</h2>
      <div class="warnings">
        <div class="warning">
          <h3>禁术莫修</h3>
          <p>禁术虽有奇效，但代价惨重。修行者当以此为鉴，不可贪一时之快。</p>
        </div>
        <div class="warning">
          <h3>量力而行</h3>
          <p>选择功法需根据自身条件，强行修炼不适合自己的功法，轻则走火入魔，重则魂飞魄散。</p>
        </div>
        <div class="warning">
          <h3>传承有序</h3>
          <p>无师自通者十不存一，有明师指点可少走弯路，事半功倍。</p>
        </div>
      </div>
    </section>
  </div>
</ModuleLayout>

<style>
  .techniques-page {
    max-width: 1200px;
    margin: 0 auto;
  }

  .intro-section {
    text-align: center;
    margin-bottom: 3rem;
  }

  .intro-section h2 {
    font-size: 1.8rem;
    color: #d4af37;
    margin-bottom: 1rem;
  }

  .intro-section p {
    color: #888;
    line-height: 1.8;
    max-width: 800px;
    margin: 0 auto;
  }

  section {
    margin-bottom: 3rem;
  }

  section h2 {
    font-size: 1.4rem;
    color: #c9a227;
    margin-bottom: 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(201, 162, 39, 0.2);
  }

  .techniques-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .technique-card {
    background: linear-gradient(135deg, rgba(30, 20, 20, 0.9), rgba(20, 20, 20, 0.8));
    border: 1px solid var(--tech-color);
    border-radius: 12px;
    padding: 1.5rem;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .technique-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--tech-color);
  }

  .technique-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.5), 0 0 20px color-mix(in srgb, var(--tech-color) 20%, transparent);
  }

  .technique-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .technique-level {
    background: var(--tech-color);
    color: #fff;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    font-size: 0.85rem;
    font-weight: bold;
  }

  .technique-card h3 {
    color: var(--tech-color);
    font-size: 1.2rem;
    margin: 0;
  }

  .technique-desc {
    color: #ccc;
    line-height: 1.6;
    margin-bottom: 1rem;
    font-size: 0.9rem;
  }

  .technique-meta {
    display: flex;
    justify-content: space-between;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    font-size: 0.85rem;
  }

  .danger-label, .status-label {
    color: #666;
    margin-right: 0.3rem;
  }

  .danger-value {
    color: #f04040;
  }

  .status-value {
    color: #40b040;
  }

  .systems-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .system-card {
    background: rgba(20, 20, 20, 0.8);
    border: 1px solid rgba(128, 96, 64, 0.3);
    border-radius: 8px;
    padding: 1.5rem;
  }

  .system-card h3 {
    color: #c08040;
    font-size: 1.1rem;
    margin-bottom: 0.8rem;
  }

  .system-desc {
    color: #888;
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .system-feature {
    color: #40b040;
    font-size: 0.85rem;
  }

  .recovery-info {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 1.5rem;
  }

  .recovery-method {
    background: rgba(20, 20, 20, 0.6);
    border: 1px solid rgba(201, 162, 39, 0.2);
    border-radius: 8px;
    padding: 1.5rem;
  }

  .recovery-method h3 {
    color: #d4af37;
    margin-bottom: 0.8rem;
  }

  .recovery-method p {
    color: #888;
    line-height: 1.6;
    margin: 0;
  }

  .warnings {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .warning {
    background: rgba(20, 20, 20, 0.6);
    border: 1px solid rgba(240, 64, 64, 0.2);
    border-radius: 8px;
    padding: 1.5rem;
  }

  .warning h3 {
    color: #f04040;
    margin-bottom: 0.8rem;
  }

  .warning p {
    color: #888;
    line-height: 1.6;
    margin: 0;
  }
</style>
