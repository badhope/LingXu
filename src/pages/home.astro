---
/**
 * 灵墟 - 首页
 * LingXu Homepage
 * 
 * 失落修行文明档案馆的入口页面
 * Entry page for the Archive of a Lost Cultivation Civilization
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import ModuleCard from '@components/ui/ModuleCard.astro';
import { SITE_CONFIG } from '@lib/constants';
import { withBase } from '@lib/utils';

// 八大模块数据
const MODULES = [
  { 
    char: '天', 
    name: '天时', 
    pinyin: 'Tiān', 
    description: '天道运行，星辰变化',
    href: withBase('/tian'),
    color: '#f0c040'
  },
  { 
    char: '地', 
    name: '地理', 
    pinyin: 'Dì', 
    description: '山川地理，风水堪舆',
    href: withBase('/di'),
    color: '#40b040'
  },
  { 
    char: '玄', 
    name: '玄学', 
    pinyin: 'Xuán', 
    description: '易经八卦，符箓命理',
    href: withBase('/xuan'),
    color: '#8040f0'
  },
  { 
    char: '黄', 
    name: '历史', 
    pinyin: 'Huáng', 
    description: '千古兴亡，秘辛档案',
    href: withBase('/huang'),
    color: '#c08040'
  },
  { 
    char: '宇', 
    name: '空间', 
    pinyin: 'Yǔ', 
    description: '万界苍茫，空间层次',
    href: withBase('/yu'),
    color: '#4080f0'
  },
  { 
    char: '宙', 
    name: '时间', 
    pinyin: 'Zhòu', 
    description: '时间长河，轮回因果',
    href: withBase('/zhou'),
    color: '#f04080'
  },
  { 
    char: '洪', 
    name: '洪荒', 
    pinyin: 'Hóng', 
    description: '神怪异兽，洪荒神话',
    href: withBase('/hong'),
    color: '#f06040'
  },
  { 
    char: '荒', 
    name: '失落', 
    pinyin: 'Huāng', 
    description: '失传秘术，失落文明',
    href: withBase('/huang-lost'),
    color: '#806040'
  },
];

// 浮动符号
const SYMBOLS = ['☯', '⚝', '✧', '❂', '⬡', '☆', '✦', '◈', '❃', '⚹', '⟡', '⊛', '✴', '⬢', '❋', '✵'];
---

<BaseLayout title="灵墟 - 天地玄黄宇宙洪荒">
  <!-- 增强版首页容器 -->
  <div class="home-container" id="home-container">
    <!-- 动态星空背景 -->
    <div class="stars-field">
      <canvas id="stars-canvas"></canvas>
    </div>

    <!-- 旋转轨道背景 -->
    <div class="orbital-system" aria-hidden="true">
      <div class="orbit orbit-1"></div>
      <div class="orbit orbit-2"></div>
      <div class="orbit orbit-3"></div>
      <div class="orbit orbit-4"></div>
      <div class="orbit orbit-5"></div>
    </div>

    <!-- 主标题区域 -->
    <section class="hero-section" id="hero-section">
      <!-- 装饰性符号 -->
      <div class="hero-symbols" id="hero-symbols" aria-hidden="true"></div>
      
      <!-- 光粒子容器 -->
      <div class="light-particles" id="light-particles" aria-hidden="true"></div>
      
      <!-- 核心标题 -->
      <div class="hero-content">
        <h1 class="site-title" aria-label="灵墟">
          <span class="title-char" data-char="灵">灵</span>
          <span class="title-char" data-char="墟">墟</span>
        </h1>
        <p class="site-subtitle">
          <span class="subtitle-line">天地玄黄</span>
          <span class="subtitle-separator">·</span>
          <span class="subtitle-line">宇宙洪荒</span>
        </p>
        <p class="site-tagline">末法时代 · 失落修行文明档案馆</p>
      </div>

      <!-- 滚动提示 -->
      <div class="scroll-indicator" id="scroll-indicator">
        <span class="scroll-text">向下探索</span>
        <div class="scroll-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M12 5v14M19 12l-7 7-7-7"/>
          </svg>
        </div>
      </div>
    </section>

    <!-- 模块导航区域 -->
    <section class="modules-section" id="modules-section">
      <!-- 装饰线 -->
      <div class="section-decoration">
        <div class="deco-line left"></div>
        <div class="deco-ornament">
          <svg viewBox="0 0 100 20" class="ornament-svg">
            <path d="M0 10 L30 10 L40 5 L50 10 L60 5 L70 10 L100 10" stroke="currentColor" fill="none" stroke-width="0.5"/>
            <circle cx="50" cy="10" r="3" fill="currentColor"/>
            <circle cx="30" cy="10" r="1.5" fill="currentColor"/>
            <circle cx="70" cy="10" r="1.5" fill="currentColor"/>
          </svg>
        </div>
        <div class="deco-line right"></div>
      </div>

      <!-- 副标题 -->
      <div class="section-header">
        <h2 class="section-title">
          <span class="title-prefix">◇</span>
          <span class="title-text">八大修行模块</span>
          <span class="title-suffix">◇</span>
        </h2>
        <p class="section-subtitle">探索失落文明的奥秘</p>
      </div>

      <!-- 模块网格 -->
      <div class="modules-grid">
        {MODULES.map((module, index) => (
          <ModuleCard
            char={module.char}
            name={module.name}
            pinyin={module.pinyin}
            description={module.description}
            href={module.href}
            color={module.color}
            index={index}
          />
        ))}
      </div>

      <!-- 底部诗句 -->
      <div class="poem-banner">
        <p class="poem-text">
          <span class="poem-line">天行健，君子以自强不息</span>
          <span class="poem-divider">｜</span>
          <span class="poem-line">地势坤，君子以厚德载物</span>
        </p>
      </div>
    </section>

    <!-- 快捷导航 -->
    <nav class="quick-nav" id="quick-nav">
      <a href={withBase('/search')} class="quick-link search-link">
        <svg class="link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="11" cy="11" r="8"/>
          <path d="m21 21-4.35-4.35"/>
        </svg>
        <span class="link-text">搜索</span>
      </a>
      <a href={withBase('/bookmarks')} class="quick-link bookmark-link">
        <svg class="link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="m19 21-7-4-7 4V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16z"/>
        </svg>
        <span class="link-text">收藏</span>
      </a>
      <a href={withBase('/profile')} class="quick-link profile-link">
        <svg class="link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="12" cy="8" r="5"/>
          <path d="M20 21a8 8 0 0 0-16 0"/>
        </svg>
        <span class="link-text">我的</span>
      </a>
      <a href={withBase('/about')} class="quick-link about-link">
        <svg class="link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="12" cy="12" r="10"/>
          <path d="M12 16v-4M12 8h.01"/>
        </svg>
        <span class="link-text">关于</span>
      </a>
    </nav>
  </div>
</BaseLayout>

<style>
  /* ==========================================
     首页容器
     ========================================== */
  .home-container {
    min-height: 100vh;
    background: radial-gradient(ellipse at center, #0a0a0f 0%, #050508 100%);
    position: relative;
    overflow-x: hidden;
    isolation: isolate;
  }

  /* ==========================================
     星空背景
     ========================================== */
  .stars-field {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  #stars-canvas {
    width: 100%;
    height: 100%;
  }

  /* ==========================================
     轨道系统
     ========================================== */
  .orbital-system {
    position: fixed;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    overflow: hidden;
  }

  .orbit {
    position: absolute;
    top: 50%;
    left: 50%;
    border: 1px solid rgba(201, 162, 39, 0.06);
    border-radius: 50%;
    transform: translate(-50%, -50%);
  }

  .orbit-1 {
    width: 300px;
    height: 300px;
    animation: orbitRotate 25s linear infinite;
  }

  .orbit-2 {
    width: 450px;
    height: 450px;
    border-color: rgba(201, 162, 39, 0.04);
    animation: orbitRotate 35s linear infinite reverse;
  }

  .orbit-3 {
    width: 600px;
    height: 600px;
    border-color: rgba(201, 162, 39, 0.03);
    animation: orbitRotate 45s linear infinite;
  }

  .orbit-4 {
    width: 750px;
    height: 750px;
    border-color: rgba(201, 162, 39, 0.02);
    animation: orbitRotate 55s linear infinite reverse;
  }

  .orbit-5 {
    width: 900px;
    height: 900px;
    border-color: rgba(201, 162, 39, 0.015);
    animation: orbitRotate 65s linear infinite;
  }

  @keyframes orbitRotate {
    from { transform: translate(-50%, -50%) rotate(0deg); }
    to { transform: translate(-50%, -50%) rotate(360deg); }
  }

  /* ==========================================
     主标题区域
     ========================================== */
  .hero-section {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    z-index: 10;
    padding: 2rem;
  }

  /* 装饰符号 */
  .hero-symbols {
    position: absolute;
    width: 600px;
    height: 600px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
  }

  .hero-symbol {
    position: absolute;
    color: rgba(201, 162, 39, 0.3);
    font-size: 14px;
    text-shadow: 0 0 15px rgba(201, 162, 39, 0.4);
    animation: symbolOrbit 30s linear infinite;
  }

  @keyframes symbolOrbit {
    from { transform: rotate(0deg) translateX(var(--orbit-radius)) rotate(0deg); }
    to { transform: rotate(360deg) translateX(var(--orbit-radius)) rotate(-360deg); }
  }

  /* 光粒子 */
  .light-particles {
    position: absolute;
    width: 800px;
    height: 800px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
  }

  .light-particle {
    position: absolute;
    width: 3px;
    height: 3px;
    background: #f0c040;
    border-radius: 50%;
    box-shadow: 0 0 8px 2px rgba(240, 192, 64, 0.8);
    animation: lightOrbit 20s linear infinite;
  }

  @keyframes lightOrbit {
    from {
      transform: rotate(0deg) translateX(var(--orbit-radius)) rotate(0deg);
      opacity: 0;
    }
    10% { opacity: 1; }
    90% { opacity: 1; }
    to {
      transform: rotate(360deg) translateX(var(--orbit-radius)) rotate(-360deg);
      opacity: 0;
    }
  }

  /* 标题内容 */
  .hero-content {
    text-align: center;
    animation: heroEnter 1.5s cubic-bezier(0.16, 1, 0.3, 1) backwards;
    animation-delay: 0.3s;
  }

  @keyframes heroEnter {
    from {
      opacity: 0;
      transform: translateY(40px) scale(0.95);
      filter: blur(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
      filter: blur(0);
    }
  }

  .site-title {
    font-size: clamp(4rem, 15vw, 8rem);
    font-weight: 300;
    letter-spacing: 0.4em;
    margin: 0;
    display: flex;
    justify-content: center;
    gap: 0.2em;
  }

  .title-char {
    display: inline-block;
    background: linear-gradient(
      135deg,
      #f0d78c 0%,
      #c9a227 25%,
      #e8c76b 50%,
      #c9a227 75%,
      #f0d78c 100%
    );
    background-size: 200% 200%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: titleShimmer 8s ease-in-out infinite;
    text-shadow: none;
    filter: drop-shadow(0 0 30px rgba(201, 162, 39, 0.5));
  }

  .title-char:nth-child(2) {
    animation-delay: 0.2s;
  }

  @keyframes titleShimmer {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  .site-subtitle {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    font-size: clamp(1rem, 3vw, 1.5rem);
    color: #c9a227;
    letter-spacing: 0.5em;
    margin: 1.5rem 0 1rem;
    opacity: 0;
    animation: fadeInUp 1s ease 0.8s forwards;
  }

  .subtitle-separator {
    color: #666;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .site-tagline {
    font-size: clamp(0.75rem, 2vw, 1rem);
    color: #777;
    letter-spacing: 0.3em;
    margin: 0;
    opacity: 0;
    animation: fadeInUp 1s ease 1s forwards;
  }

  /* 滚动提示 */
  .scroll-indicator {
    position: absolute;
    bottom: 3rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    opacity: 0;
    animation: fadeInUp 1s ease 1.5s forwards, scrollPulse 2s ease-in-out 2.5s infinite;
    cursor: pointer;
  }

  .scroll-text {
    font-size: 0.8rem;
    color: #808080;
    letter-spacing: 0.2em;
  }

  .scroll-icon {
    width: 24px;
    height: 24px;
    color: #808080;
    animation: scrollBounce 1.5s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.6; }
    50% { opacity: 1; }
  }

  @keyframes scrollBounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(8px); }
  }

  /* ==========================================
     模块区域
     ========================================== */
  .modules-section {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 4rem 2rem;
    z-index: 10;
  }

  /* 装饰线 */
  .section-decoration {
    display: flex;
    align-items: center;
    gap: 1rem;
    width: 100%;
    max-width: 600px;
    margin-bottom: 3rem;
  }

  .deco-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(201, 162, 39, 0.4), transparent);
  }

  .deco-ornament {
    color: rgba(201, 162, 39, 0.6);
  }

  .ornament-svg {
    width: 100px;
    height: 20px;
  }

  /* 区块标题 */
  .section-header {
    text-align: center;
    margin-bottom: 3rem;
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .section-header.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .section-title {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    font-weight: 400;
    color: #e8d48b;
    letter-spacing: 0.3em;
    margin: 0;
  }

  .title-prefix,
  .title-suffix {
    font-size: 0.8em;
    color: rgba(201, 162, 39, 0.5);
  }

  .section-subtitle {
    font-size: 0.9rem;
    color: #888;
    letter-spacing: 0.2em;
    margin: 0.75rem 0 0;
  }

  /* 模块网格 */
  .modules-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    max-width: 1000px;
    width: 100%;
    padding: 1rem;
  }

  /* 诗句横幅 */
  .poem-banner {
    margin-top: 4rem;
    text-align: center;
    padding: 1.5rem 2rem;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(201, 162, 39, 0.05),
      rgba(201, 162, 39, 0.08),
      rgba(201, 162, 39, 0.05),
      transparent
    );
    border-top: 1px solid rgba(201, 162, 39, 0.1);
    border-bottom: 1px solid rgba(201, 162, 39, 0.1);
  }

  .poem-text {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    font-size: 1rem;
    color: #c9a227;
    letter-spacing: 0.2em;
    margin: 0;
  }

  .poem-divider {
    color: rgba(201, 162, 39, 0.4);
  }

  /* ==========================================
     快捷导航
     ========================================== */
  .quick-nav {
    position: fixed;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 1rem;
    padding: 0.75rem 1.5rem;
    background: rgba(10, 10, 15, 0.9);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(201, 162, 39, 0.2);
    border-radius: 50px;
    z-index: 100;
    opacity: 0;
    animation: fadeInUp 1s ease 1.2s forwards;
  }

  .quick-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.2rem;
    background: transparent;
    border: 1px solid rgba(201, 162, 39, 0.2);
    border-radius: 25px;
    color: #c9a227;
    text-decoration: none;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .quick-link:hover {
    background: rgba(201, 162, 39, 0.15);
    border-color: #c9a227;
    transform: translateY(-3px) scale(1.05);
    box-shadow: 0 10px 25px rgba(201, 162, 39, 0.2);
  }

  .quick-link:active {
    transform: translateY(-1px) scale(1.02);
  }

  .link-icon {
    width: 18px;
    height: 18px;
  }

  /* ==========================================
     响应式设计
     ========================================== */
  @media (max-width: 1024px) {
    .modules-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.25rem;
    }
  }

  @media (max-width: 768px) {
    .hero-section {
      padding: 1.5rem;
    }

    .site-title {
      letter-spacing: 0.2em;
    }

    .hero-symbols,
    .light-particles {
      width: 300px;
      height: 300px;
    }

    .modules-section {
      padding: 3rem 1rem;
    }

    .modules-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
      padding: 0.5rem;
    }

    .poem-text {
      flex-direction: column;
      gap: 0.5rem;
      font-size: 0.9rem;
    }

    .poem-divider {
      display: none;
    }

    .quick-nav {
      bottom: 1rem;
      padding: 0.5rem 1rem;
      gap: 0.5rem;
    }

    .quick-link {
      padding: 0.5rem 0.8rem;
      font-size: 0.75rem;
    }

    .link-text {
      display: none;
    }

    .orbital-system {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .modules-grid {
      grid-template-columns: 1fr 1fr;
      gap: 0.75rem;
    }

    .section-decoration {
      max-width: 300px;
    }

    .deco-ornament {
      display: none;
    }
  }

  /* ==========================================
     减少动画偏好
     ========================================== */
  @media (prefers-reduced-motion: reduce) {
    .title-char,
    .site-title,
    .hero-content,
    .site-subtitle,
    .site-tagline,
    .scroll-indicator,
    .section-header,
    .quick-nav,
    .hero-symbol,
    .light-particle,
    .orbit {
      animation: none;
    }

    .hero-content,
    .section-header {
      opacity: 1;
      transform: none;
      filter: none;
    }
  }
</style>

<script define:vars={{ SYMBOLS }}>
  /**
   * 首页交互脚本
   * Homepage Interaction Scripts
   */
  class HomeController {
    constructor() {
      this.symbolContainer = document.getElementById('hero-symbols');
      this.particleContainer = document.getElementById('light-particles');
      this.starsCanvas = document.getElementById('stars-canvas');
      this.modulesSection = document.getElementById('modules-section');
      this.sectionHeader = document.querySelector('.section-header');
      this.scrollIndicator = document.getElementById('scroll-indicator');
      
      this.init();
    }

    init() {
      this.initHeroSymbols();
      this.initLightParticles();
      this.initStarsCanvas();
      this.initScrollObserver();
      this.initScrollToExplore();
    }

    /**
     * 初始化装饰符号
     */
    initHeroSymbols() {
      if (!this.symbolContainer) return;
      
      const symbolCount = 40;
      
      for (let i = 0; i < symbolCount; i++) {
        const symbol = document.createElement('span');
        symbol.className = 'hero-symbol';
        symbol.textContent = SYMBOLS[i % SYMBOLS.length];
        
        const orbitRadius = 100 + Math.random() * 200;
        const startAngle = Math.random() * 360;
        const duration = 15 + Math.random() * 25;
        const delay = Math.random() * -duration;
        const size = 10 + Math.random() * 12;
        
        symbol.style.cssText = `
          --orbit-radius: ${orbitRadius}px;
          font-size: ${size}px;
          animation-duration: ${duration}s;
          animation-delay: ${delay}s;
          transform: rotate(${startAngle}deg) translateX(${orbitRadius}px);
          opacity: ${0.2 + Math.random() * 0.4};
        `;
        
        this.symbolContainer.appendChild(symbol);
      }
    }

    /**
     * 初始化光粒子
     */
    initLightParticles() {
      if (!this.particleContainer) return;
      
      const particleCount = 20;
      
      for (let i = 0; i < particleCount; i++) {
        const particle = document.createElement('span');
        particle.className = 'light-particle';
        
        const orbitRadius = 150 + Math.random() * 250;
        const startAngle = Math.random() * 360;
        const duration = 10 + Math.random() * 15;
        const delay = Math.random() * -duration;
        const size = 2 + Math.random() * 3;
        
        particle.style.cssText = `
          --orbit-radius: ${orbitRadius}px;
          width: ${size}px;
          height: ${size}px;
          animation-duration: ${duration}s;
          animation-delay: ${delay}s;
          transform: rotate(${startAngle}deg) translateX(${orbitRadius}px);
        `;
        
        this.particleContainer.appendChild(particle);
      }
    }

    /**
     * 初始化星空画布
     */
    initStarsCanvas() {
      if (!this.starsCanvas) return;
      
      const ctx = this.starsCanvas.getContext('2d');
      let stars = [];
      let animationId;
      const isMobile = window.innerWidth < 768;
      const maxStars = isMobile ? 50 : 100;

      const resize = () => {
        const dpr = window.devicePixelRatio || 1;
        this.starsCanvas.width = window.innerWidth * dpr;
        this.starsCanvas.height = window.innerHeight * dpr;
        ctx.scale(dpr, dpr);
      };

      const createStars = () => {
        stars = [];
        for (let i = 0; i < maxStars; i++) {
          stars.push({
            x: Math.random() * window.innerWidth,
            y: Math.random() * window.innerHeight,
            radius: Math.random() * 1.5,
            alpha: Math.random(),
            alphaDirection: Math.random() > 0.5 ? 1 : -1,
            speed: 0.002 + Math.random() * 0.008,
            twinkle: Math.random() > 0.8
          });
        }
      };

      const animate = () => {
        ctx.clearRect(0, 0, this.starsCanvas.width, this.starsCanvas.height);

        stars.forEach(star => {
          if (star.twinkle) {
            star.alpha += star.speed * star.alphaDirection;
            if (star.alpha >= 1 || star.alpha <= 0.1) {
              star.alphaDirection *= -1;
            }
          }

          ctx.beginPath();
          ctx.arc(star.x, star.y, star.radius, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(255, 255, 255, ${star.alpha})`;
          ctx.fill();
        });

        animationId = requestAnimationFrame(animate);
      };

      resize();
      createStars();
      animate();

      // 响应式处理
      let resizeTimeout;
      window.addEventListener('resize', () => {
        clearTimeout(resizeTimeout);
        resizeTimeout = setTimeout(() => {
          cancelAnimationFrame(animationId);
          resize();
          createStars();
          animate();
        }, 200);
      }, { passive: true });
    }

    /**
     * 初始化滚动观察器
     */
    initScrollObserver() {
      if (!this.sectionHeader) return;

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
            }
          });
        },
        {
          threshold: 0.2,
          rootMargin: '0px 0px -50px 0px'
        }
      );

      observer.observe(this.sectionHeader);
    }

    /**
     * 初始化滚动探索
     */
    initScrollToExplore() {
      if (!this.scrollIndicator) return;

      this.scrollIndicator.addEventListener('click', () => {
        this.modulesSection?.scrollIntoView({
          behavior: 'smooth',
          block: 'start'
        });
      });
    }
  }

  // 页面加载完成后初始化
  document.addEventListener('DOMContentLoaded', () => {
    new HomeController();
  });
</script>
