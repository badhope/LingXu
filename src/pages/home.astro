---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_CONFIG } from '../lib/constants';
import { withBase } from '../lib/utils';

const MODULES = [
  { char: '天', name: '天时', pinyin: 'Tiān', description: '天道运行，星辰变化', href: withBase('/tian'), color: '#f0c040' },
  { char: '地', name: '地理', pinyin: 'Dì', description: '山川地理，风水堪舆', href: withBase('/di'), color: '#40b040' },
  { char: '玄', name: '玄学', pinyin: 'Xuán', description: '易经八卦，符箓命理', href: withBase('/xuan'), color: '#8040f0' },
  { char: '黄', name: '历史', pinyin: 'Huáng', description: '千古兴亡，秘辛档案', href: withBase('/huang'), color: '#c08040' },
  { char: '宇', name: '空间', pinyin: 'Yǔ', description: '万界苍茫，空间层次', href: withBase('/yu'), color: '#4080f0' },
  { char: '宙', name: '时间', pinyin: 'Zhòu', description: '时间长河，轮回因果', href: withBase('/zhou'), color: '#f04080' },
  { char: '洪', name: '洪荒', pinyin: 'Hóng', description: '神怪异兽，洪荒神话', href: withBase('/hong'), color: '#f06040' },
  { char: '荒', name: '失落', pinyin: 'Huāng', description: '失传秘术，失落文明', href: withBase('/huang-lost'), color: '#806040' },
];
---

<BaseLayout title="灵墟 - 天地玄黄宇宙洪荒">
  <div class="home-container">
    <div class="stars-container">
      <canvas id="stars-canvas"></canvas>
    </div>
    <div class="nebula-layer"></div>
    <div class="mist-layer"></div>

    <header class="home-header">
      <h1 class="site-title">
        <span class="title-word">灵</span>
        <span class="title-word">墟</span>
      </h1>
      <p class="site-subtitle">末法时代 · 失落修行文明档案馆</p>
    </header>

    <main class="modules-grid">
      {MODULES.map((module, index) => (
        <a
          href={module.href}
          class="module-char"
          data-module={module.char}
          style={`--char-color: ${module.color}; --delay: ${index * 0.1}s`}
        >
          <span class="char">{module.char}</span>
          <span class="char-info">
            <span class="char-name">{module.name}</span>
            <span class="char-pinyin">{module.pinyin}</span>
          </span>
          <span class="char-desc">{module.description}</span>
          <div class="char-glow"></div>
          <div class="char-particles"></div>
        </a>
      ))}
    </main>

    <div class="poem-line">
      <span>天地玄黄</span>
      <span class="separator">·</span>
      <span>宇宙洪荒</span>
    </div>

    <nav class="quick-nav">
      <a href={withBase('/search')} class="nav-btn search-btn">
        <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.35-4.35"></path>
        </svg>
        <span>搜索</span>
      </a>
      <a href={withBase('/bookmarks')} class="nav-btn bookmark-btn">
        <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="m19 21-7-4-7 4V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16z"></path>
        </svg>
        <span>收藏</span>
      </a>
      <a href={withBase('/profile')} class="nav-btn profile-btn">
        <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="8" r="5"></circle>
          <path d="M20 21a8 8 0 0 0-16 0"></path>
        </svg>
        <span>我的</span>
      </a>
    </nav>

    <div class="cosmic-bg">
      <div class="orbit orbit-1"></div>
      <div class="orbit orbit-2"></div>
      <div class="orbit orbit-3"></div>
      <div class="orbit orbit-4"></div>
    </div>
  </div>

  <style>
    .home-container {
      min-height: 100vh;
      background: radial-gradient(ellipse at center, #0a0a0f 0%, #050508 100%);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 2rem;
      position: relative;
      overflow: hidden;
    }

    .stars-container {
      position: absolute;
      inset: 0;
      z-index: 1;
      will-change: transform;
    }

    #stars-canvas {
      width: 100%;
      height: 100%;
    }

    .nebula-layer {
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse at 20% 30%, rgba(201, 162, 39, 0.03) 0%, transparent 50%),
        radial-gradient(ellipse at 80% 70%, rgba(107, 74, 138, 0.03) 0%, transparent 50%),
        radial-gradient(ellipse at 50% 50%, rgba(45, 138, 138, 0.02) 0%, transparent 60%);
      animation: nebulaPulse 20s ease-in-out infinite;
      z-index: 2;
      pointer-events: none;
    }

    @keyframes nebulaPulse {
      0%, 100% { opacity: 0.5; transform: scale(1); }
      50% { opacity: 0.8; transform: scale(1.02); }
    }

    .mist-layer {
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse at 50% 50%, transparent 0%, rgba(5, 5, 8, 0.6) 100%);
      z-index: 3;
      pointer-events: none;
    }

    .home-header {
      text-align: center;
      margin-bottom: 3rem;
      z-index: 10;
      position: relative;
    }

    .site-title {
      font-size: 4rem;
      font-weight: 400;
      letter-spacing: 0.5em;
      margin: 0;
      display: flex;
      justify-content: center;
      gap: 0.3em;
    }

    .title-word {
      color: #e8d48b;
      text-shadow:
        0 0 20px rgba(201, 162, 39, 0.5),
        0 0 40px rgba(201, 162, 39, 0.3),
        0 0 60px rgba(201, 162, 39, 0.2);
      animation: titleGlow 4s ease-in-out infinite, fadeSlideDown 1s ease backwards;
      will-change: transform, text-shadow;
    }

    .title-word:nth-child(2) {
      animation-delay: 0.15s;
    }

    @keyframes titleGlow {
      0%, 100% {
        text-shadow:
          0 0 20px rgba(201, 162, 39, 0.5),
          0 0 40px rgba(201, 162, 39, 0.3);
      }
      50% {
        text-shadow:
          0 0 30px rgba(201, 162, 39, 0.7),
          0 0 60px rgba(201, 162, 39, 0.4),
          0 0 80px rgba(201, 162, 39, 0.2);
      }
    }

    @keyframes fadeSlideDown {
      from {
        opacity: 0;
        transform: translateY(-20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .site-subtitle {
      font-size: 1rem;
      color: #888;
      letter-spacing: 0.3em;
      margin-top: 1rem;
      animation: fadeIn 1s ease 0.3s backwards;
    }

    .modules-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 2rem;
      max-width: 900px;
      z-index: 10;
    }

    .module-char {
      position: relative;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 2rem 1.5rem;
      background: rgba(10, 10, 15, 0.8);
      border: 1px solid rgba(201, 162, 39, 0.2);
      border-radius: 12px;
      text-decoration: none;
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      overflow: hidden;
      animation: fadeSlideIn 0.8s ease backwards;
      animation-delay: var(--delay);
      will-change: transform, box-shadow;
    }

    .module-char::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at center, var(--char-color), transparent 70%);
      opacity: 0;
      transition: opacity 0.4s ease;
    }

    .module-char::after {
      content: '';
      position: absolute;
      inset: -50%;
      background: radial-gradient(circle, var(--char-color) 0%, transparent 70%);
      opacity: 0;
      transform: scale(0.5);
      transition: all 0.6s ease;
      pointer-events: none;
    }

    .module-char:hover {
      transform: translateY(-8px) scale(1.05);
      border-color: var(--char-color);
      box-shadow:
        0 20px 40px rgba(0, 0, 0, 0.5),
        0 0 40px color-mix(in srgb, var(--char-color) 30%, transparent);
    }

    .module-char:hover::before {
      opacity: 0.15;
    }

    .module-char:hover::after {
      opacity: 0.1;
      transform: scale(1.5);
    }

    .module-char:hover .char {
      text-shadow:
        0 0 20px var(--char-color),
        0 0 40px var(--char-color);
      transform: scale(1.1);
    }

    .module-char:hover .char-glow {
      opacity: 0.6;
      transform: translateX(-50%) scale(1.2);
    }

    .module-char:hover .char-particles {
      opacity: 1;
    }

    .char {
      font-size: 3.5rem;
      color: var(--char-color);
      line-height: 1;
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      position: relative;
      z-index: 2;
    }

    .char-info {
      display: flex;
      flex-direction: column;
      align-items: center;
      margin-top: 1rem;
      position: relative;
      z-index: 2;
    }

    .char-name {
      font-size: 1.25rem;
      color: #e8d48b;
      letter-spacing: 0.2em;
    }

    .char-pinyin {
      font-size: 0.75rem;
      color: #666;
      margin-top: 0.25rem;
      letter-spacing: 0.1em;
    }

    .char-desc {
      font-size: 0.8rem;
      color: #555;
      margin-top: 0.75rem;
      text-align: center;
      line-height: 1.4;
      position: relative;
      z-index: 2;
      transition: color 0.3s ease;
    }

    .module-char:hover .char-desc {
      color: #888;
    }

    .char-glow {
      position: absolute;
      bottom: -50%;
      left: 50%;
      transform: translateX(-50%);
      width: 100px;
      height: 100px;
      background: radial-gradient(circle, var(--char-color), transparent 70%);
      opacity: 0;
      transition: all 0.4s ease;
      pointer-events: none;
      will-change: transform, opacity;
    }

    .char-particles {
      position: absolute;
      inset: 0;
      opacity: 0;
      transition: opacity 0.4s ease;
      pointer-events: none;
      overflow: hidden;
    }

    .char-particles::before,
    .char-particles::after {
      content: '';
      position: absolute;
      width: 4px;
      height: 4px;
      background: var(--char-color);
      border-radius: 50%;
      animation: particleFloat 2s ease-in-out infinite;
    }

    .char-particles::before {
      top: 20%;
      left: 20%;
      animation-delay: 0s;
    }

    .char-particles::after {
      bottom: 30%;
      right: 25%;
      animation-delay: 0.5s;
    }

    @keyframes particleFloat {
      0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.6; }
      50% { transform: translate(10px, -15px) scale(1.2); opacity: 1; }
    }

    .poem-line {
      display: flex;
      align-items: center;
      gap: 1.5rem;
      margin-top: 4rem;
      font-size: 1.25rem;
      color: #c9a227;
      letter-spacing: 0.3em;
      animation: fadeIn 1s ease 0.8s backwards;
      z-index: 10;
    }

    .poem-line .separator {
      color: #666;
    }

    .quick-nav {
      display: flex;
      gap: 2rem;
      margin-top: 3rem;
      z-index: 10;
      animation: fadeSlideUp 0.8s ease 1s backwards;
    }

    .nav-btn {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.75rem 1.5rem;
      background: rgba(10, 10, 15, 0.6);
      border: 1px solid rgba(201, 162, 39, 0.3);
      border-radius: 6px;
      color: #c9a227;
      text-decoration: none;
      font-size: 0.9rem;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      backdrop-filter: blur(8px);
      will-change: transform, background, border-color;
    }

    .nav-btn:hover {
      background: rgba(201, 162, 39, 0.15);
      border-color: #c9a227;
      transform: translateY(-3px);
      box-shadow: 0 8px 20px rgba(201, 162, 39, 0.2);
    }

    .nav-btn:active {
      transform: translateY(-1px);
    }

    .nav-btn .icon {
      width: 1.25rem;
      height: 1.25rem;
      transition: transform 0.3s ease;
    }

    .nav-btn:hover .icon {
      transform: scale(1.1);
    }

    .cosmic-bg {
      position: absolute;
      inset: 0;
      pointer-events: none;
      z-index: 4;
      overflow: hidden;
    }

    .orbit {
      position: absolute;
      border: 1px solid rgba(201, 162, 39, 0.08);
      border-radius: 50%;
      will-change: transform;
    }

    .orbit-1 {
      width: 400px;
      height: 400px;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      animation: orbitRotate 30s linear infinite;
    }

    .orbit-2 {
      width: 550px;
      height: 550px;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      animation: orbitRotate 40s linear infinite reverse;
    }

    .orbit-3 {
      width: 700px;
      height: 700px;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      animation: orbitRotate 50s linear infinite;
      animation-delay: -10s;
    }

    .orbit-4 {
      width: 850px;
      height: 850px;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      animation: orbitRotate 60s linear infinite reverse;
      animation-delay: -20s;
    }

    @keyframes orbitRotate {
      from { transform: translate(-50%, -50%) rotate(0deg); }
      to { transform: translate(-50%, -50%) rotate(360deg); }
    }

    @keyframes fadeSlideIn {
      from {
        opacity: 0;
        transform: translateY(30px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes fadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }

    @keyframes fadeSlideUp {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .title-word,
      .module-char,
      .poem-line,
      .quick-nav,
      .nebula-layer,
      .orbit,
      .char-particles::before,
      .char-particles::after {
        animation: none;
      }
      .module-char:hover {
        transform: none;
      }
      .module-char:hover .char {
        transform: none;
      }
      .nav-btn:hover {
        transform: none;
      }
    }

    @media (max-width: 768px) {
      .modules-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
      }
      .site-title {
        font-size: 3rem;
      }
      .poem-line {
        font-size: 1rem;
        flex-direction: column;
        gap: 0.5rem;
      }
      .quick-nav {
        gap: 1rem;
      }
      .nav-btn {
        padding: 0.6rem 1rem;
        font-size: 0.8rem;
      }
      .orbit {
        display: none;
      }
    }
  </style>

  <script>
    class StarsCanvas {
      constructor(canvas) {
        this.canvas = canvas;
        this.ctx = canvas.getContext('2d');
        this.stars = [];
        this.maxStars = 120;
        this.animationId = 0;
        this.isMobile = window.innerWidth < 768;
        this.init();
      }

      init() {
        this.resize();
        this.createStars();
        this.bindEvents();
        this.animate();
      }

      resize() {
        const dpr = window.devicePixelRatio || 1;
        this.canvas.width = window.innerWidth * dpr;
        this.canvas.height = window.innerHeight * dpr;
        this.ctx.scale(dpr, dpr);
        this.stars = [];
        this.createStars();
      }

      createStars() {
        const count = this.isMobile ? 60 : this.maxStars;
        for (let i = 0; i < count; i++) {
          this.stars.push({
            x: Math.random() * window.innerWidth,
            y: Math.random() * window.innerHeight,
            radius: Math.random() * 1.5 + 0.3,
            alpha: Math.random() * 0.5 + 0.3,
            alphaChange: (Math.random() - 0.5) * 0.01,
            twinkleSpeed: Math.random() * 0.015 + 0.005
          });
        }
      }

      bindEvents() {
        let resizeTimeout;
        window.addEventListener('resize', () => {
          clearTimeout(resizeTimeout);
          resizeTimeout = setTimeout(() => {
            this.isMobile = window.innerWidth < 768;
            this.resize();
          }, 200);
        });
      }

      animate() {
        this.ctx.clearRect(0, 0, window.innerWidth, window.innerHeight);

        this.stars.forEach(star => {
          star.alpha += star.alphaChange;
          if (star.alpha <= 0.2 || star.alpha >= 0.9) {
            star.alphaChange *= -1;
          }

          const twinkle = Math.sin(Date.now() * star.twinkleSpeed) * 0.2 + 0.8;

          this.ctx.beginPath();
          this.ctx.arc(star.x, star.y, star.radius, 0, Math.PI * 2);
          this.ctx.fillStyle = `rgba(232, 212, 139, ${star.alpha * twinkle})`;
          this.ctx.fill();
        });

        this.animationId = requestAnimationFrame(() => this.animate());
      }
    }

    const canvas = document.getElementById('stars-canvas');
    if (canvas) {
      new StarsCanvas(canvas);
    }

    const moduleChars = document.querySelectorAll('.module-char');
    moduleChars.forEach((card) => {
      card.addEventListener('mouseenter', () => {
        card.querySelector('.char-particles')?.classList.add('active');
      });
      card.addEventListener('mouseleave', () => {
        card.querySelector('.char-particles')?.classList.remove('active');
      });
    });
  </script>
</BaseLayout>