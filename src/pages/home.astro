---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_CONFIG } from '../lib/constants';

const MODULES = [
  { char: '天', name: '天时', pinyin: 'Tiān', description: '天道运行，星辰变化', href: '/tian', color: '#f0c040' },
  { char: '地', name: '地理', pinyin: 'Dì', description: '山川地理，风水堪舆', href: '/di', color: '#40b040' },
  { char: '玄', name: '玄学', pinyin: 'Xuán', description: '易经八卦，符箓命理', href: '/xuan', color: '#8040f0' },
  { char: '黄', name: '历史', pinyin: 'Huáng', description: '千古兴亡，秘辛档案', href: '/huang', color: '#c08040' },
  { char: '宇', name: '空间', pinyin: 'Yǔ', description: '万界苍茫，空间层次', href: '/yu', color: '#4080f0' },
  { char: '宙', name: '时间', pinyin: 'Zhòu', description: '时间长河，轮回因果', href: '/zhou', color: '#f04080' },
  { char: '洪', name: '洪荒', pinyin: 'Hóng', description: '神怪异兽，洪荒神话', href: '/hong', color: '#f06040' },
  { char: '荒', name: '失落', pinyin: 'Huāng', description: '失传秘术，失落文明', href: '/huang-lost', color: '#806040' },
];
---

<BaseLayout title="灵墟 - 天地玄黄宇宙洪荒">
  <div class="home-container">
    <div class="stars-layer"></div>
    <div class="mist-layer"></div>

    <header class="home-header">
      <h1 class="site-title">灵墟</h1>
      <p class="site-subtitle">末法时代 · 失落修行文明档案馆</p>
    </header>

    <main class="modules-grid">
      {MODULES.map((module, index) => (
        <a
          href={module.href}
          class="module-char"
          data-module={module.char}
          style={`--char-color: ${module.color}; --delay: ${index * 0.1}s`}
        >
          <span class="char">{module.char}</span>
          <span class="char-info">
            <span class="char-name">{module.name}</span>
            <span class="char-pinyin">{module.pinyin}</span>
          </span>
          <span class="char-desc">{module.description}</span>
          <div class="char-glow"></div>
        </a>
      ))}
    </main>

    <div class="poem-line">
      <span>天地玄黄</span>
      <span class="separator">·</span>
      <span>宇宙洪荒</span>
    </div>

    <nav class="quick-nav">
      <a href="/search" class="nav-btn search-btn">
        <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.35-4.35"></path>
        </svg>
        <span>搜索</span>
      </a>
      <a href="/bookmarks" class="nav-btn bookmark-btn">
        <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="m19 21-7-4-7 4V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16z"></path>
        </svg>
        <span>收藏</span>
      </a>
      <a href="/profile" class="nav-btn profile-btn">
        <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="8" r="5"></circle>
          <path d="M20 21a8 8 0 0 0-16 0"></path>
        </svg>
        <span>我的</span>
      </a>
    </nav>

    <div class="cosmic-bg">
      <div class="orbit orbit-1"></div>
      <div class="orbit orbit-2"></div>
      <div class="orbit orbit-3"></div>
    </div>
  </div>

  <style>
    .home-container {
      min-height: 100vh;
      background: radial-gradient(ellipse at center, #0a0a0f 0%, #050508 100%);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 2rem;
      position: relative;
      overflow: hidden;
    }

    .stars-layer {
      position: absolute;
      inset: 0;
      background-image:
        radial-gradient(2px 2px at 100px 50px, rgba(201, 162, 39, 0.8), transparent),
        radial-gradient(2px 2px at 200px 150px, rgba(212, 175, 55, 0.6), transparent),
        radial-gradient(1px 1px at 300px 80px, rgba(232, 212, 139, 0.7), transparent),
        radial-gradient(2px 2px at 400px 200px, rgba(201, 162, 39, 0.5), transparent),
        radial-gradient(1px 1px at 500px 120px, rgba(212, 175, 55, 0.6), transparent),
        radial-gradient(2px 2px at 150px 250px, rgba(232, 212, 139, 0.7), transparent),
        radial-gradient(1px 1px at 350px 300px, rgba(201, 162, 39, 0.5), transparent),
        radial-gradient(2px 2px at 50px 180px, rgba(212, 175, 55, 0.6), transparent);
      background-size: 550px 400px;
      animation: drift 60s linear infinite;
    }

    .mist-layer {
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse at 20% 30%, rgba(45, 138, 138, 0.1) 0%, transparent 50%),
        radial-gradient(ellipse at 80% 70%, rgba(107, 74, 138, 0.1) 0%, transparent 50%);
      pointer-events: none;
    }

    .home-header {
      text-align: center;
      margin-bottom: 3rem;
      z-index: 10;
    }

    .site-title {
      font-size: 4rem;
      font-weight: 400;
      color: #e8d48b;
      letter-spacing: 0.5em;
      margin: 0;
      text-shadow:
        0 0 20px rgba(201, 162, 39, 0.5),
        0 0 40px rgba(201, 162, 39, 0.3);
      animation: titleGlow 4s ease-in-out infinite;
    }

    .site-subtitle {
      font-size: 1rem;
      color: #888;
      letter-spacing: 0.3em;
      margin-top: 1rem;
    }

    .modules-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 2rem;
      max-width: 900px;
      z-index: 10;
    }

    .module-char {
      position: relative;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 2rem 1.5rem;
      background: rgba(10, 10, 15, 0.8);
      border: 1px solid rgba(201, 162, 39, 0.2);
      border-radius: 8px;
      text-decoration: none;
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      overflow: hidden;
      animation: fadeSlideIn 0.8s ease backwards;
      animation-delay: var(--delay);
    }

    .module-char::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at center, var(--char-color), transparent 70%);
      opacity: 0;
      transition: opacity 0.4s ease;
    }

    .module-char:hover {
      transform: translateY(-8px) scale(1.05);
      border-color: var(--char-color);
      box-shadow:
        0 20px 40px rgba(0, 0, 0, 0.5),
        0 0 30px color-mix(in srgb, var(--char-color) 30%, transparent);
    }

    .module-char:hover::before {
      opacity: 0.15;
    }

    .module-char:hover .char {
      text-shadow:
        0 0 20px var(--char-color),
        0 0 40px var(--char-color);
      transform: scale(1.1);
    }

    .module-char:hover .char-glow {
      opacity: 0.6;
    }

    .char {
      font-size: 3.5rem;
      color: var(--char-color);
      line-height: 1;
      transition: all 0.4s ease;
      position: relative;
      z-index: 2;
    }

    .char-info {
      display: flex;
      flex-direction: column;
      align-items: center;
      margin-top: 1rem;
      position: relative;
      z-index: 2;
    }

    .char-name {
      font-size: 1.25rem;
      color: #e8d48b;
      letter-spacing: 0.2em;
    }

    .char-pinyin {
      font-size: 0.75rem;
      color: #666;
      margin-top: 0.25rem;
      letter-spacing: 0.1em;
    }

    .char-desc {
      font-size: 0.8rem;
      color: #555;
      margin-top: 0.75rem;
      text-align: center;
      line-height: 1.4;
      position: relative;
      z-index: 2;
    }

    .char-glow {
      position: absolute;
      bottom: -50%;
      left: 50%;
      transform: translateX(-50%);
      width: 100px;
      height: 100px;
      background: radial-gradient(circle, var(--char-color), transparent 70%);
      opacity: 0;
      transition: opacity 0.4s ease;
      pointer-events: none;
    }

    .poem-line {
      display: flex;
      align-items: center;
      gap: 1.5rem;
      margin-top: 4rem;
      font-size: 1.25rem;
      color: #c9a227;
      letter-spacing: 0.3em;
      animation: fadeIn 1s ease 0.8s backwards;
    }

    .poem-line .separator {
      color: #666;
    }

    .quick-nav {
      display: flex;
      gap: 2rem;
      margin-top: 3rem;
      z-index: 10;
      animation: fadeSlideUp 0.8s ease 1s backwards;
    }

    .nav-btn {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.75rem 1.5rem;
      background: rgba(10, 10, 15, 0.6);
      border: 1px solid rgba(201, 162, 39, 0.3);
      border-radius: 4px;
      color: #c9a227;
      text-decoration: none;
      font-size: 0.9rem;
      transition: all 0.3s ease;
    }

    .nav-btn:hover {
      background: rgba(201, 162, 39, 0.1);
      border-color: #c9a227;
      transform: translateY(-2px);
    }

    .nav-btn .icon {
      width: 1.25rem;
      height: 1.25rem;
    }

    .cosmic-bg {
      position: absolute;
      inset: 0;
      pointer-events: none;
      overflow: hidden;
    }

    .orbit {
      position: absolute;
      border: 1px solid rgba(201, 162, 39, 0.1);
      border-radius: 50%;
      animation: orbitFloat 20s ease-in-out infinite;
    }

    .orbit-1 {
      width: 400px;
      height: 400px;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      animation-delay: 0s;
    }

    .orbit-2 {
      width: 600px;
      height: 600px;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      animation-delay: -5s;
    }

    .orbit-3 {
      width: 800px;
      height: 800px;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      animation-delay: -10s;
    }

    @keyframes drift {
      from { transform: translateX(0); }
      to { transform: translateX(-550px); }
    }

    @keyframes titleGlow {
      0%, 100% { text-shadow: 0 0 20px rgba(201, 162, 39, 0.5), 0 0 40px rgba(201, 162, 39, 0.3); }
      50% { text-shadow: 0 0 30px rgba(201, 162, 39, 0.7), 0 0 60px rgba(201, 162, 39, 0.4); }
    }

    @keyframes fadeSlideIn {
      from {
        opacity: 0;
        transform: translateY(30px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes fadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }

    @keyframes fadeSlideUp {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes orbitFloat {
      0%, 100% {
        transform: translate(-50%, -50%) rotate(0deg);
      }
      50% {
        transform: translate(-50%, -50%) rotate(180deg);
      }
    }

    @media (max-width: 900px) {
      .modules-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
      }

      .char {
        font-size: 2.5rem;
      }

      .site-title {
        font-size: 2.5rem;
      }
    }

    @media (max-width: 480px) {
      .modules-grid {
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
      }

      .char {
        font-size: 2rem;
      }

      .char-desc {
        display: none;
      }

      .quick-nav {
        gap: 1rem;
      }

      .nav-btn span {
        display: none;
      }
    }
  </style>

  <script>
    const moduleChars = document.querySelectorAll('.module-char');

    moduleChars.forEach((module) => {
      const char = module.querySelector('.char') as HTMLElement;

      module.addEventListener('mousemove', (e) => {
        const rect = module.getBoundingClientRect();
        const x = e.clientX - rect.left - rect.width / 2;
        const y = e.clientY - rect.top - rect.height / 2;

        char.style.transform = `perspective(500px) rotateX(${-y / 20}deg) rotateY(${x / 20}deg) scale(1.1)`;
      });

      module.addEventListener('mouseleave', () => {
        char.style.transform = 'scale(1)';
      });
    });
  </script>
</BaseLayout>
