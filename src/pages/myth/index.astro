---
import PageLayout from '../../layouts/PageLayout.astro';
import ArticleCard from '@components/widgets/ArticleCard.astro';
import ScrollReveal from '@components/interactive/ScrollReveal.astro';

const basePath = import.meta.env.BASE_URL || '';

const featuredArticles = [
  {
    title: '失落地理',
    subtitle: '《山海经》与失落时代的空间观念',
    description: '深入分析《山海经》所记载的神秘地理，探讨其中反映的上古修行空间观念，以及这些地理与后世仙道传说的关联。',
    href: `${basePath}/myth/lost-geography`,
    category: '核心卷宗',
    era: '太初纪-鸿蒙纪',
    tags: ['山海经', '地理', '洞天福地', '仙山'],
    readTime: '16分钟',
    color: 'amethyst' as const,
    featured: true,
  },
  {
    title: '神山圣境',
    subtitle: '修行传说中的神圣山脉与神秘场所',
    description: '系统梳理昆仑、蓬莱、方丈等神山的文献记载，分析其在中国神话体系中的地位与修行意义。',
    href: `${basePath}/myth/sacred-mountains-and-sites`,
    category: '核心卷宗',
    era: '太初纪-末法纪',
    tags: ['神山', '昆仑', '蓬莱', '洞天'],
    readTime: '14分钟',
    color: 'amethyst' as const,
  },
  {
    title: '异兽录',
    subtitle: '记录在案的奇异生物与其修行关联',
    description: '考证古籍中记载的神话生物，分析其作为修行文明符号的象征意义与文献学价值。',
    href: `${basePath}/myth/strange-beasts`,
    category: '核心卷宗',
    era: '各时代',
    tags: ['异兽', '神兽', '山海经', '祥瑞'],
    readTime: '12分钟',
    color: 'amethyst' as const,
  },
  {
    title: '神话总述',
    subtitle: '中国神话体系的整体梳理与分类',
    description: '从宏观视角梳理中国神话的体系结构，分析其与修行文明的内在关联及在末法时代的演变。',
    href: `${basePath}/myth/shanhai-overview`,
    category: '概论',
    era: '太初纪-末法纪',
    tags: ['神话', '体系', '中国神话', '分类'],
    readTime: '10分钟',
    color: 'amethyst' as const,
  },
];

const geographyCategories = [
  {
    title: '洞天福地',
    description: '隐藏在名山中的神仙居所',
    icon: '㊣',
    features: ['外小内大', '时空异常', '灵气充沛', '凡人难入'],
    count: '十大洞天、三十六小洞天、七十二福地',
  },
  {
    title: '海外仙山',
    description: '渤海之中的仙人所居',
    icon: '蓬',
    features: ['东海三神山', '扶桑若木', '十日浴于下', '灵气充沛'],
    count: '蓬莱、方丈、瀛洲',
  },
  {
    title: '幽冥空间',
    description: '与天上相对的幽冥地底世界',
    icon: '冥',
    features: ['酆都鬼城', '黄泉之路', '九幽之地', '亡魂归处'],
    count: '酆都、黄泉、九幽、罗酆',
  },
  {
    title: '异界通道',
    description: '连接不同地理空间的节点',
    icon: '∮',
    features: ['天门地门', '洞穴裂隙', '传送阵法', '梦中神游'],
    count: '门、穴、阵、梦',
  },
];

const beastCategories = [
  { category: '神兽', examples: ['青龙', '白虎', '朱雀', '玄武'], description: '四方守护神' },
  { category: '瑞兽', examples: ['麒麟', '凤凰', '龙龟', '白泽'], description: '吉祥征兆' },
  { category: '凶兽', examples: ['梼杌', '穷奇', '混沌', '饕餮'], description: '邪恶象征' },
  { category: '灵兽', examples: ['九尾狐', '乘黄', '讙', '鹿蜀'], description: '异能有灵' },
];
---

<PageLayout
  title="神话"
  description="失落时代的空间地理与文明印记"
  section="神话"
  sectionColor="amethyst"
>
  <article class="pt-20 pb-16">
    <header class="relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-b from-[#6b4a8a]/[0.03] via-transparent to-transparent"></div>
      <div class="absolute top-0 left-1/4 w-96 h-96 rounded-full bg-gradient-to-br from-[#6b4a8a]/[0.06] to-transparent blur-3xl"></div>
      <div class="absolute bottom-0 right-1/4 w-64 h-64 rounded-full bg-gradient-to-tr from-[#a878b8]/[0.04] to-transparent blur-2xl"></div>

      <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-12">
        <nav class="flex items-center gap-2 text-sm mb-8" aria-label="面包屑导航">
          <a href={basePath} class="text-[#666666] hover:text-[#a878b8] transition-colors">首页</a>
          <span class="text-[#444444]">/</span>
          <span class="text-[#888888]">神话</span>
        </nav>

        <div class="flex items-center gap-3 mb-6">
          <span class="px-3 py-1 text-xs font-medium tracking-[0.15em] uppercase border border-[#a878b8]/40 text-[#a878b8] rounded-full">
            神话
          </span>
          <span class="px-3 py-1 text-xs text-[#888888] border border-[#333333]/50 rounded-full">
            失落地理
          </span>
        </div>

        <h1 class="text-4xl sm:text-5xl md:text-6xl font-display text-[#a878b8] mb-6 tracking-wide leading-tight">
          失落地理
        </h1>

        <p class="text-xl sm:text-2xl text-[#a878b8]/80 font-light mb-6 leading-relaxed">
          神话传说中的神圣空间
        </p>

        <blockquote class="border-l-2 border-[#6b4a8a] pl-6 py-3 my-6 max-w-3xl">
          <p class="text-lg text-[#888888] italic leading-relaxed">
            天地之偏者，山海之荒忽。
          </p>
        </blockquote>

        <p class="text-[#888888] leading-relaxed mb-8 max-w-3xl">
          在末法纪之前的世界图景中，地理空间并非均质单一的。在日常可及的山川河流之下，存在着一系列常人难以感知的「异界空间」——这些空间或藏于名山大川深处，或隐于四海八荒之外，或悬浮于九霄云端，或沉眠于幽冥地底。
        </p>

        <div class="flex flex-wrap gap-4">
          <a
            href={`${basePath}/myth/lost-geography`}
            class="group inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-[#6b4a8a]/[0.08] border border-[#6b4a8a]/30 text-[#a878b8] hover:bg-[#6b4a8a]/[0.12] hover:border-[#a878b8]/50 transition-all"
          >
            <span>探索地理</span>
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 17L17 7M17 7H7M17 7V17" />
            </svg>
          </a>
          <a
            href={`${basePath}/myth/strange-beasts`}
            class="group inline-flex items-center gap-2 px-6 py-3 rounded-lg border border-[#333333] text-[#888888] hover:text-[#a878b8] hover:border-[#6b4a8a]/30 transition-all"
          >
            <span>异兽录</span>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7m0 0l-7-7m7 7V3" />
            </svg>
          </a>
        </div>

        <div class="mt-12 max-w-[240px] h-[1px] bg-gradient-to-r from-transparent via-[#a878b8]/50 to-transparent"></div>
      </div>
    </header>

    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <ScrollReveal>
        <section class="py-16 border-b border-[#2a2a2a]/50">
          <h2 class="text-2xl sm:text-3xl font-display text-[#a878b8] mb-8 tracking-wide">核心典籍</h2>
          <div class="grid gap-4">
            {featuredArticles.slice(0, 1).map((article) => (
              <ArticleCard
                title={article.title}
                subtitle={article.subtitle}
                description={article.description}
                href={article.href}
                category={article.category}
                era={article.era}
                tags={article.tags}
                readTime={article.readTime}
                featured={article.featured}
                color={article.color}
              />
            ))}
          </div>
          <div class="grid sm:grid-cols-2 gap-4 mt-4">
            {featuredArticles.slice(1).map((article) => (
              <ArticleCard
                title={article.title}
                subtitle={article.subtitle}
                description={article.description}
                href={article.href}
                category={article.category}
                era={article.era}
                tags={article.tags}
                readTime={article.readTime}
                color={article.color}
              />
            ))}
          </div>
        </section>
      </ScrollReveal>

      <ScrollReveal>
        <section class="py-16 border-b border-[#2a2a2a]/50">
          <h2 class="text-2xl sm:text-3xl font-display text-[#a878b8] mb-8 tracking-wide">地理分类</h2>
          <p class="text-[#888888] mb-8 max-w-3xl">
            根据灵墟档案的研究，古代典籍中记载的失落地理可分为以下几类：
          </p>
          <div class="grid sm:grid-cols-2 gap-4">
            {geographyCategories.map((category) => (
              <ScrollReveal>
                <div class="p-5 rounded-lg bg-[#0d0d0d]/50 border border-[#6b4a8a]/30 hover:border-[#a878b8]/60 hover:bg-[#6b4a8a]/[0.03] transition-all">
                  <div class="flex items-center gap-3 mb-4">
                    <span class="text-2xl text-[#6b4a8a] hover:text-[#a878b8] transition-colors flex-shrink-0" style="font-family: serif;">
                      {category.icon}
                    </span>
                    <div>
                      <h3 class="text-lg font-display text-[#a878b8] group-hover:text-[#b888c8] transition-colors">
                        {category.title}
                      </h3>
                      <p class="text-xs text-[#666666]">{category.description}</p>
                    </div>
                  </div>
                  <div class="flex flex-wrap gap-2 mb-3">
                    {category.features.map((feature) => (
                      <span class="text-xs px-2 py-0.5 rounded bg-[#1a1a1a] text-[#888888] border border-[#2a2a2a]/50">
                        {feature}
                      </span>
                    ))}
                  </div>
                  <p class="text-xs text-[#555555]">
                    <span class="text-[#6b4a8a]/60">代表：</span>{category.count}
                  </p>
                </div>
              </ScrollReveal>
            ))}
          </div>
        </section>
      </ScrollReveal>

      <ScrollReveal>
        <section class="py-16 border-b border-[#2a2a2a]/50">
          <h2 class="text-2xl sm:text-3xl font-display text-[#a878b8] mb-8 tracking-wide">异兽分类</h2>
          <p class="text-[#888888] mb-8 max-w-3xl">
            《山海经》等典籍中记载了大量神话生物，它们在修行文明中具有重要的符号意义：
          </p>
          <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
            {beastCategories.map((category, index) => (
              <ScrollReveal delay={index * 100}>
                <div class="p-4 rounded-lg bg-[#6b4a8a]/[0.03] border border-[#6b4a8a]/20 text-center">
                  <h3 class="text-md font-display text-[#a878b8] mb-2">{category.category}</h3>
                  <p class="text-xs text-[#666666] mb-3">{category.description}</p>
                  <div class="space-y-1">
                    {category.examples.map((beast) => (
                      <span class="inline-block text-xs px-2 py-0.5 mx-1 rounded bg-[#1a1a1a] text-[#a878b8]/70">
                        {beast}
                      </span>
                    ))}
                  </div>
                </div>
              </ScrollReveal>
            ))}
          </div>
        </section>
      </ScrollReveal>

      <ScrollReveal>
        <section class="py-16">
          <h2 class="text-2xl sm:text-3xl font-display text-[#a878b8] mb-8 tracking-wide">关联路径</h2>
          <p class="text-[#888888] mb-8 max-w-3xl">
            从失落地理出发，可沿以下路径深入探索修行文明的各个面向。
          </p>
          <div class="space-y-4">
            <a
              href={`${basePath}/archive`}
              class="group block p-5 rounded-lg bg-[#c9a227]/[0.04] border border-[#c9a227]/20 hover:border-[#d4af37]/40 transition-all"
            >
              <h3 class="text-lg font-display text-[#d4af37] mb-1">末法档案</h3>
              <p class="text-sm text-[#888888]">探索末法纪的形成与修行文明衰退的进程 → 档案馆</p>
            </a>
            <a
              href={`${basePath}/dharma`}
              class="group block p-5 rounded-lg bg-[#2d4a6b]/[0.04] border border-[#2d4a6b]/20 hover:border-[#6b9ad4]/40 transition-all"
            >
              <h3 class="text-lg font-display text-[#6b9ad4] mb-1">佛道思想</h3>
              <p class="text-sm text-[#888888]">梳理佛教东渐与道教兴起的修行传承 → 法门</p>
            </a>
            <a
              href={`${basePath}/realms`}
              class="group block p-5 rounded-lg bg-[#8a4a2d]/[0.04] border border-[#8a4a2d]/20 hover:border-[#ba7a5a]/40 transition-all"
            >
              <h3 class="text-lg font-display text-[#ba7a5a] mb-1">境界体系</h3>
              <p class="text-sm text-[#888888]">从仙侠小说看失落文明的文学再造 → 境界</p>
            </a>
          </div>
        </section>
      </ScrollReveal>

      <footer class="py-12 text-center">
        <div class="max-w-[200px] mx-auto mb-8 h-[1px] bg-gradient-to-r from-transparent via-[#a878b8]/30 to-transparent"></div>
        <p class="text-[#666666] text-sm">
          失落地理 · 灵墟 · 末法时代修行文明档案馆
        </p>
        <p class="text-[#555555] text-xs mt-2">
          天地之偏，山海之荒
        </p>
      </footer>
    </div>
  </article>
</PageLayout>