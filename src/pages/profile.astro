---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../lib/utils';
---

<BaseLayout title="个人中心 - 灵墟">
  <div class="profile-page">
    <header class="page-header">
      <a href={withBase('/home')} class="back-link">← 返回</a>
      <h1>个人中心</h1>
    </header>

    <div class="profile-container">
      <section class="profile-card">
        <div class="profile-avatar">
          <div class="avatar-ring"></div>
          <div class="avatar-inner">仙</div>
        </div>
        <div class="profile-info">
          <h2>修行者</h2>
          <p class="profile-level">境界：炼气期</p>
          <p class="profile-stat">探索进度：<span>12</span>/28 模块</p>
        </div>
      </section>

      <section class="stats-section">
        <h3>探索统计</h3>
        <div class="stats-grid">
          <div class="stat-card">
            <div class="stat-value">5</div>
            <div class="stat-label">天</div>
          </div>
          <div class="stat-card">
            <div class="stat-value">5</div>
            <div class="stat-label">地</div>
          </div>
          <div class="stat-card">
            <div class="stat-value">5</div>
            <div class="stat-label">玄</div>
          </div>
          <div class="stat-card">
            <div class="stat-value">5</div>
            <div class="stat-label">黄</div>
          </div>
          <div class="stat-card">
            <div class="stat-value">4</div>
            <div class="stat-label">宇</div>
          </div>
          <div class="stat-card">
            <div class="stat-value">4</div>
            <div class="stat-label">宙</div>
          </div>
          <div class="stat-card">
            <div class="stat-value">5</div>
            <div class="stat-label">洪</div>
          </div>
          <div class="stat-card">
            <div class="stat-value">5</div>
            <div class="stat-label">荒</div>
          </div>
        </div>
      </section>

      <section class="settings-section">
        <h3>偏好设置</h3>

        <div class="setting-item">
          <div class="setting-info">
            <h4>阅读进度</h4>
            <p>在文章页面显示阅读进度条</p>
          </div>
          <label class="toggle">
            <input type="checkbox" id="progressToggle" checked />
            <span class="toggle-slider"></span>
          </label>
        </div>

        <div class="setting-item">
          <div class="setting-info">
            <h4>字体大小</h4>
            <p>调整内容文字大小</p>
          </div>
          <div class="font-size-selector">
            <button class="size-btn" data-size="small">小</button>
            <button class="size-btn active" data-size="medium">中</button>
            <button class="size-btn" data-size="large">大</button>
          </div>
        </div>
      </section>

      <section class="history-section">
        <h3>最近浏览</h3>
        <div class="history-list" id="historyList">
          <div class="history-empty">暂无浏览记录</div>
        </div>
      </section>
    </div>
  </div>

  <style>
    .profile-page {
      min-height: 100vh;
      background: radial-gradient(ellipse at center, #0a0a0f 0%, #050508 100%);
      padding: 2rem;
    }

    .page-header {
      max-width: 800px;
      margin: 0 auto 2rem;
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .back-link {
      color: #c9a227;
      text-decoration: none;
      font-size: 0.9rem;
      padding: 0.5rem 1rem;
      border: 1px solid rgba(201, 162, 39, 0.3);
      border-radius: 4px;
      transition: all 0.3s ease;
    }

    .back-link:hover {
      background: rgba(201, 162, 39, 0.1);
    }

    .page-header h1 {
      color: #e8d48b;
      font-size: 1.5rem;
      margin: 0;
      letter-spacing: 0.2em;
    }

    .profile-container {
      max-width: 800px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .profile-card {
      display: flex;
      align-items: center;
      gap: 2rem;
      padding: 2rem;
      background: rgba(10, 10, 15, 0.8);
      border: 1px solid rgba(201, 162, 39, 0.2);
      border-radius: 12px;
    }

    .profile-avatar {
      position: relative;
      width: 100px;
      height: 100px;
    }

    .avatar-ring {
      position: absolute;
      inset: 0;
      border: 2px solid #c9a227;
      border-radius: 50%;
      animation: rotate 10s linear infinite;
    }

    .avatar-ring::before {
      content: '';
      position: absolute;
      top: -4px;
      left: 50%;
      transform: translateX(-50%);
      width: 8px;
      height: 8px;
      background: #c9a227;
      border-radius: 50%;
    }

    .avatar-inner {
      position: absolute;
      inset: 10px;
      background: linear-gradient(135deg, #1a1500, #0a0a0a);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2.5rem;
      color: #c9a227;
    }

    .profile-info h2 {
      color: #e8d48b;
      margin: 0 0 0.5rem 0;
    }

    .profile-level {
      color: #c9a227;
      margin: 0 0 0.25rem 0;
      font-size: 0.9rem;
    }

    .profile-stat {
      color: #888;
      margin: 0;
      font-size: 0.85rem;
    }

    .profile-stat span {
      color: #c9a227;
      font-weight: bold;
    }

    .stats-section,
    .settings-section,
    .history-section {
      padding: 1.5rem;
      background: rgba(10, 10, 15, 0.8);
      border: 1px solid rgba(201, 162, 39, 0.2);
      border-radius: 12px;
    }

    .stats-section h3,
    .settings-section h3,
    .history-section h3 {
      color: #888;
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin: 0 0 1.5rem 0;
      padding-bottom: 1rem;
      border-bottom: 1px solid rgba(201, 162, 39, 0.1);
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
    }

    .stat-card {
      text-align: center;
      padding: 1rem;
      background: rgba(5, 5, 8, 0.6);
      border: 1px solid rgba(201, 162, 39, 0.1);
      border-radius: 8px;
    }

    .stat-value {
      font-size: 1.5rem;
      color: #c9a227;
      font-weight: bold;
    }

    .stat-label {
      font-size: 0.8rem;
      color: #666;
      margin-top: 0.25rem;
    }

    .setting-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1rem 0;
      border-bottom: 1px solid rgba(201, 162, 39, 0.1);
    }

    .setting-item:last-child {
      border-bottom: none;
    }

    .setting-info h4 {
      color: #e8d48b;
      margin: 0 0 0.25rem 0;
      font-size: 1rem;
    }

    .setting-info p {
      color: #666;
      margin: 0;
      font-size: 0.85rem;
    }

    .toggle {
      position: relative;
      width: 50px;
      height: 26px;
    }

    .toggle input {
      opacity: 0;
      width: 0;
      height: 0;
    }

    .toggle-slider {
      position: absolute;
      cursor: pointer;
      inset: 0;
      background: rgba(201, 162, 39, 0.2);
      border-radius: 26px;
      transition: all 0.3s ease;
    }

    .toggle-slider::before {
      content: '';
      position: absolute;
      width: 20px;
      height: 20px;
      left: 3px;
      bottom: 3px;
      background: #888;
      border-radius: 50%;
      transition: all 0.3s ease;
    }

    .toggle input:checked + .toggle-slider {
      background: rgba(201, 162, 39, 0.4);
    }

    .toggle input:checked + .toggle-slider::before {
      transform: translateX(24px);
      background: #c9a227;
    }

    .font-size-selector {
      display: flex;
      gap: 0.5rem;
    }

    .size-btn {
      padding: 0.5rem 1rem;
      background: rgba(10, 10, 15, 0.6);
      border: 1px solid rgba(201, 162, 39, 0.2);
      border-radius: 4px;
      color: #888;
      cursor: pointer;
      transition: all 0.3s ease;
    }

    .size-btn:hover,
    .size-btn.active {
      background: rgba(201, 162, 39, 0.2);
      border-color: #c9a227;
      color: #c9a227;
    }

    .history-empty {
      text-align: center;
      padding: 2rem;
      color: #666;
    }

    @keyframes rotate {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }

    @media (max-width: 600px) {
      .profile-card {
        flex-direction: column;
        text-align: center;
      }

      .stats-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }
  </style>

  <script>
    const progressToggle = document.getElementById('progressToggle') as HTMLInputElement;
    const sizeBtns = document.querySelectorAll('.size-btn');

    progressToggle?.addEventListener('change', () => {
      const stored = localStorage.getItem('lingxu-user-store');
      if (stored) {
        const data = JSON.parse(stored);
        data.state.preferences.readingProgress = progressToggle.checked;
        localStorage.setItem('lingxu-user-store', JSON.stringify(data));
      }
    });

    sizeBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        sizeBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const size = btn.getAttribute('data-size');
        const stored = localStorage.getItem('lingxu-user-store');
        if (stored) {
          const data = JSON.parse(stored);
          data.state.preferences.fontSize = size;
          localStorage.setItem('lingxu-user-store', JSON.stringify(data));
        }
      });
    });
  </script>
</BaseLayout>
