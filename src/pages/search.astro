---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../lib/utils';
---

<BaseLayout title="搜索 - 灵墟">
  <div class="search-page">
    <header class="search-header">
      <a href={withBase('/home')} class="back-link">← 返回</a>
      <h1>搜索</h1>
    </header>

    <div class="search-container">
      <div class="search-box">
        <input
          type="text"
          id="searchInput"
          placeholder="输入关键词搜索..."
          autofocus
        />
        <button class="search-btn" id="searchBtn">🔍</button>
        <button class="clear-btn" id="clearBtn" style="display: none;">✕</button>
      </div>

      <div class="search-suggestions" id="searchSuggestions">
        <div class="suggestion-header">
          <span>热门搜索</span>
        </div>
        <div class="suggestion-tags" id="suggestionTags"></div>
      </div>

      <div class="search-modules">
        <button class="module-filter active" data-module="all">全部</button>
        <button class="module-filter" data-module="tian">天</button>
        <button class="module-filter" data-module="di">地</button>
        <button class="module-filter" data-module="xuan">玄</button>
        <button class="module-filter" data-module="huang">黄</button>
        <button class="module-filter" data-module="yu">宇</button>
        <button class="module-filter" data-module="zhou">宙</button>
        <button class="module-filter" data-module="hong">洪</button>
        <button class="module-filter" data-module="huang-lost">荒</button>
      </div>

      <div class="search-results" id="searchResults">
        <div class="results-placeholder">
          <p>输入关键词开始搜索</p>
          <p class="hints">尝试搜索：龙、凤凰、八卦、黄历、修炼、功法、神话...</p>
        </div>
      </div>
    </div>
  </div>

  <style>
    .search-page {
      min-height: 100vh;
      background: radial-gradient(ellipse at center, #0a0a0f 0%, #050508 100%);
      padding: 2rem;
    }

    .search-header {
      max-width: 800px;
      margin: 0 auto 2rem;
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .back-link {
      color: #c9a227;
      text-decoration: none;
      font-size: 0.9rem;
      padding: 0.5rem 1rem;
      border: 1px solid rgba(201, 162, 39, 0.3);
      border-radius: 4px;
      transition: all 0.3s ease;
    }

    .back-link:hover {
      background: rgba(201, 162, 39, 0.1);
    }

    .search-header h1 {
      color: #e8d48b;
      font-size: 1.5rem;
      margin: 0;
      letter-spacing: 0.2em;
    }

    .search-container {
      max-width: 800px;
      margin: 0 auto;
    }

    .search-box {
      display: flex;
      gap: 0.5rem;
      margin-bottom: 1rem;
      position: relative;
    }

    .search-box input {
      flex: 1;
      padding: 1rem 1.5rem;
      padding-right: 4rem;
      background: rgba(10, 10, 15, 0.8);
      border: 1px solid rgba(201, 162, 39, 0.3);
      border-radius: 8px;
      color: #e8d48b;
      font-size: 1rem;
      outline: none;
      transition: all 0.3s ease;
    }

    .search-box input:focus {
      border-color: #c9a227;
      box-shadow: 0 0 20px rgba(201, 162, 39, 0.2);
    }

    .search-box input::placeholder {
      color: #666;
    }

    .search-btn,
    .clear-btn {
      position: absolute;
      right: 0.5rem;
      top: 50%;
      transform: translateY(-50%);
      padding: 0.75rem 1rem;
      background: transparent;
      border: none;
      font-size: 1rem;
      cursor: pointer;
      transition: all 0.3s ease;
    }

    .search-btn {
      right: 2.5rem;
    }

    .clear-btn:hover {
      color: #c9a227;
    }

    .search-modules {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
      margin-bottom: 2rem;
    }

    .module-filter {
      padding: 0.5rem 1rem;
      background: rgba(10, 10, 15, 0.6);
      border: 1px solid rgba(201, 162, 39, 0.2);
      border-radius: 20px;
      color: #888;
      font-size: 0.85rem;
      cursor: pointer;
      transition: all 0.3s ease;
    }

    .module-filter:hover,
    .module-filter.active {
      background: rgba(201, 162, 39, 0.2);
      border-color: #c9a227;
      color: #c9a227;
    }

    .search-suggestions {
      margin-bottom: 1.5rem;
      padding: 1rem;
      background: rgba(10, 10, 15, 0.4);
      border-radius: 8px;
    }

    .suggestion-header {
      font-size: 0.75rem;
      color: #666;
      margin-bottom: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
    }

    .suggestion-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .suggestion-tag {
      padding: 0.35rem 0.75rem;
      background: rgba(201, 162, 39, 0.08);
      border: 1px solid rgba(201, 162, 39, 0.15);
      border-radius: 15px;
      color: #888;
      font-size: 0.8rem;
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .suggestion-tag:hover {
      background: rgba(201, 162, 39, 0.15);
      color: #c9a227;
      border-color: rgba(201, 162, 39, 0.3);
    }

    .search-results {
      min-height: 300px;
    }

    .results-placeholder {
      text-align: center;
      padding: 4rem 2rem;
      color: #666;
    }

    .results-placeholder p {
      margin: 0 0 1rem 0;
    }

    .results-placeholder .hints {
      font-size: 0.85rem;
      color: #555;
    }

    .result-item {
      padding: 1.5rem;
      background: rgba(10, 10, 15, 0.8);
      border: 1px solid rgba(201, 162, 39, 0.2);
      border-radius: 8px;
      margin-bottom: 1rem;
      text-decoration: none;
      display: block;
      transition: all 0.3s ease;
    }

    .result-item:hover {
      border-color: #c9a227;
      transform: translateX(4px);
      box-shadow: 0 0 20px rgba(201, 162, 39, 0.1);
    }

    .result-module {
      font-size: 0.75rem;
      color: #c9a227;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-bottom: 0.5rem;
    }

    .result-title {
      color: #e8d48b;
      font-size: 1.1rem;
      margin: 0 0 0.5rem 0;
    }

    .result-excerpt {
      color: #888;
      font-size: 0.9rem;
      line-height: 1.5;
      margin: 0;
    }

    .result-tags {
      display: flex;
      gap: 0.5rem;
      margin-top: 0.75rem;
    }

    .result-tag {
      padding: 0.25rem 0.5rem;
      background: rgba(201, 162, 39, 0.1);
      border-radius: 4px;
      font-size: 0.75rem;
      color: #c9a227;
    }

    .highlight {
      background: rgba(201, 162, 39, 0.3);
      color: #f0c040;
      padding: 0 2px;
      border-radius: 2px;
    }

    .results-stats {
      text-align: center;
      padding: 1rem;
      color: #666;
      font-size: 0.85rem;
      margin-bottom: 1rem;
    }

    .results-stats strong {
      color: #c9a227;
    }

    @media (max-width: 640px) {
      .search-page {
        padding: 1rem;
      }

      .module-filter {
        padding: 0.4rem 0.75rem;
        font-size: 0.8rem;
      }
    }
  </style>

  <script>
    const searchInput = document.getElementById('searchInput') as HTMLInputElement;
    const searchResults = document.getElementById('searchResults');
    const searchBtn = document.getElementById('searchBtn');
    const clearBtn = document.getElementById('clearBtn');
    const suggestionTags = document.getElementById('suggestionTags');
    const moduleFilters = document.querySelectorAll('.module-filter');

    const allContent = [
      { module: 'tian', moduleName: '天时', title: '黄历吉凶', excerpt: '每日宜忌查询，今日运势解读，包含吉凶方位、时辰吉凶等信息', tags: ['黄历', '吉凶', '宜忌', '时辰', '运势'], href: '/tian/calendar' },
      { module: 'tian', moduleName: '天时', title: '八字排盘', excerpt: '生辰八字四柱推演，分析命理格局、大运流年，掌握命运轨迹', tags: ['八字', '命理', '四柱', '大运', '流年'], href: '/tian/bazi' },
      { module: 'tian', moduleName: '天时', title: '星辰运行', excerpt: '二十八宿分布，灵气潮汐变化，星象与修行息息相关', tags: ['星辰', '二十八宿', '灵气', '星象'], href: '/tian/stars' },
      { module: 'tian', moduleName: '天时', title: '节气养生', excerpt: '二十四节气养生要点，农事指导，与自然和谐共处', tags: ['节气', '养生', '农事', '自然'], href: '/tian/solar-terms' },
      { module: 'tian', moduleName: '天时', title: '每日吉言', excerpt: '每日箴言指引，运势提示，古人智慧结晶', tags: ['吉言', '箴言', '运势', '智慧'], href: '/tian/daily-quote' },
      { module: 'di', moduleName: '地理', title: '罗盘定向', excerpt: '八卦方位分析，风水吉凶判断，环境气场探查', tags: ['罗盘', '八卦', '风水', '方位'], href: '/di/compass' },
      { module: 'di', moduleName: '地理', title: '洞天福地', excerpt: '三十六洞天、七十二福地分布，修行圣地介绍', tags: ['洞天', '福地', '仙山', '圣地'], href: '/di/caves' },
      { module: 'di', moduleName: '地理', title: '风水堪舆', excerpt: '风水分析，阳宅阴宅选址，龙脉走向探查', tags: ['风水', '堪舆', '龙脉', '阳宅'], href: '/di/fengshui' },
      { module: 'di', moduleName: '地理', title: '地理志', excerpt: '山川地理志，疆域沿革，名山大川介绍', tags: ['地理', '山川', '疆域'], href: '/di/geography' },
      { module: 'di', moduleName: '地理', title: '方位吉凶', excerpt: '方位查询，时辰吉凶，宜忌方位指南', tags: ['方位', '吉凶', '宜忌'], href: '/di/directions' },
      { module: 'xuan', moduleName: '玄学', title: '易经占卜', excerpt: '六十四卦详解，铜钱卦、蓍草卦占卜方法', tags: ['易经', '八卦', '占卜', '六十四卦'], href: '/xuan/yijing' },
      { module: 'xuan', moduleName: '玄学', title: '命理推演', excerpt: '四柱八字，紫微斗数，命盘全面解读', tags: ['命理', '紫微斗数', '命盘'], href: '/xuan/destiny' },
      { module: 'xuan', moduleName: '玄学', title: '符箓识别', excerpt: '各类符箓图鉴，符咒制作方法，使用禁忌', tags: ['符箓', '符咒', '制作', '禁忌'], href: '/xuan/talismans' },
      { module: 'xuan', moduleName: '玄学', title: '阵法布局', excerpt: '各类阵法图解，八卦阵、七星阵等原理', tags: ['阵法', '八卦阵', '七星阵'], href: '/xuan/formations' },
      { module: 'xuan', moduleName: '玄学', title: '玄学典籍', excerpt: '经典文献收录，知识检索，玄学藏书阁', tags: ['典籍', '文献', '藏书'], href: '/xuan/classics' },
      { module: 'huang', moduleName: '历史', title: '历史卷轴', excerpt: '朝代更迭浏览，历史事件查阅，卷轴式阅读体验', tags: ['历史', '卷轴', '朝代', '事件'], href: '/huang/scrolls' },
      { module: 'huang', moduleName: '历史', title: '纪年转换', excerpt: '公元农历换算，神话纪年互转，时间跨度计算', tags: ['纪年', '农历', '公元', '转换'], href: '/huang/era-convert' },
      { module: 'huang', moduleName: '历史', title: '人物谱', excerpt: '历史人物传记，帝王将相事迹，圣贤传说', tags: ['人物', '帝王', '圣贤'], href: '/huang/figures' },
      { module: 'huang', moduleName: '历史', title: '大事件', excerpt: '历史时间线，因果追溯，战争与政治变革', tags: ['事件', '时间线', '战争'], href: '/huang/events' },
      { module: 'huang', moduleName: '历史', title: '秘辛档案', excerpt: '禁毁档案收录，隐秘历史记载，野史秘闻', tags: ['秘辛', '档案', '野史'], href: '/huang/secrets' },
      { module: 'yu', moduleName: '空间', title: '世界地图', excerpt: '各界地域分布图，势力范围标注，世界结构', tags: ['地图', '各界', '地域', '势力'], href: '/yu/world-map' },
      { module: 'yu', moduleName: '空间', title: '空间层级', excerpt: '仙界冥界人间界，万界结构图，空间层次论', tags: ['层级', '仙界', '冥界', '人间'], href: '/yu/layers' },
      { module: 'yu', moduleName: '空间', title: '界域详情', excerpt: '各界特色介绍，资源分布详情，区域探索', tags: ['界域', '资源', '特色'], href: '/yu/realms' },
      { module: 'yu', moduleName: '空间', title: '方位世界', excerpt: '东西南北中五方世界，五方神兽守护', tags: ['方位', '五方', '神兽'], href: '/yu/directions-world' },
      { module: 'zhou', moduleName: '时间', title: '轮回查询', excerpt: '前世今生因果探索，六道轮回原理，因果报应', tags: ['轮回', '因果', '前世', '六道'], href: '/zhou/reincarnation' },
      { module: 'zhou', moduleName: '时间', title: '纪年系统', excerpt: '多纪元浏览，时间单位换算，历法系统大全', tags: ['纪年', '历法', '纪元'], href: '/zhou/calendar-system' },
      { module: 'zhou', moduleName: '时间', title: '时代划分', excerpt: '各时代浏览，历史分期介绍，文明演变', tags: ['时代', '分期', '文明'], href: '/zhou/eras' },
      { module: 'zhou', moduleName: '时间', title: '时间线', excerpt: '大事年表，时间轴展示，因果链条分析', tags: ['时间线', '年表', '因果'], href: '/zhou/timeline' },
      { module: 'hong', moduleName: '洪荒', title: '神兽图鉴', excerpt: '青龙白虎朱雀玄武，上古四大神兽详解', tags: ['神兽', '青龙', '白虎', '朱雀', '玄武'], href: '/hong/divine-beasts' },
      { module: 'hong', moduleName: '洪荒', title: '凶兽异志', excerpt: '饕餮穷奇梼杌混沌，上古四大凶兽记载', tags: ['凶兽', '饕餮', '穷奇', '梼杌', '混沌'], href: '/hong/evil-beasts' },
      { module: 'hong', moduleName: '洪荒', title: '出生匹配', excerpt: '根据出生日期匹配神兽守护灵，缘分测试', tags: ['匹配', '守护灵', '缘分', '神兽'], href: '/hong/birth-match' },
      { module: 'hong', moduleName: '洪荒', title: '神系谱图', excerpt: '神系关系图谱，血脉传承谱系，神族历史', tags: ['谱图', '血脉', '神系'], href: '/hong/deity-tree' },
      { module: 'hong', moduleName: '洪荒', title: '祥瑞之兽', excerpt: '麒麟凤凰等祥瑞之兽，吉兆象征解读', tags: ['祥瑞', '麒麟', '凤凰'], href: '/hong/auspicious' },
      { module: 'huang-lost', moduleName: '失落', title: '失传秘术', excerpt: '远古功法秘籍，修炼秘诀，失传秘术大全', tags: ['秘术', '功法', '修炼', '秘籍'], href: '/huang-lost/techniques' },
      { module: 'huang-lost', moduleName: '失落', title: '远古药方', excerpt: '失传药方汇编，丹药炼制方法，药草图鉴', tags: ['药方', '丹药', '药草'], href: '/huang-lost/medicine' },
      { module: 'huang-lost', moduleName: '失落', title: '失落神器', excerpt: '上古神器谱系，失落法宝介绍，神器传说', tags: ['神器', '法宝', '传说'], href: '/huang-lost/artifacts' },
      { module: 'huang-lost', moduleName: '失落', title: '古物法器', excerpt: '古代法器图鉴，护身符功效，古物鉴定', tags: ['法器', '护身符', '古物'], href: '/huang-lost/charms' },
      { module: 'huang-lost', moduleName: '失落', title: '文明遗迹', excerpt: '远古文明遗迹位置，失落文明探索', tags: ['遗迹', '文明', '探索'], href: '/huang-lost/ruins' },
      { module: 'huang-lost', moduleName: '失落', title: '功法典籍', excerpt: '修炼功法收录，典籍解读，传承体系', tags: ['功法', '典籍', '传承'], href: '/huang-lost/cultivation' },
    ];

    const hotSearchTerms = ['黄历', '八卦', '神兽', '修炼', '符箓', '易经', '风水', '命理'];

    let currentModule = 'all';
    let currentQuery = '';
    let debounceTimer: ReturnType<typeof setTimeout>;

    function initSuggestions() {
      if (suggestionTags) {
        suggestionTags.innerHTML = hotSearchTerms.map(term =>
          `<span class="suggestion-tag" data-term="${term}">${term}</span>`
        ).join('');

        suggestionTags.querySelectorAll('.suggestion-tag').forEach(tag => {
          tag.addEventListener('click', () => {
            const term = tag.getAttribute('data-term');
            if (term && searchInput) {
              searchInput.value = term;
              currentQuery = term;
              performSearch();
            }
          });
        });
      }
    }

    function escapeHtml(text: string): string {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    function highlightText(text: string, query: string): string {
      if (!query) return escapeHtml(text);
      const escaped = escapeHtml(text);
      const escapedQuery = escapeHtml(query);
      const regex = new RegExp(`(${escapedQuery.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');
      return escaped.replace(regex, '<span class="highlight">$1</span>');
    }

    function performSearch() {
      const query = currentQuery.toLowerCase().trim();

      if (suggestionTags) {
        suggestionTags.style.display = query ? 'none' : 'flex';
      }

      if (clearBtn) {
        clearBtn.style.display = query ? 'block' : 'none';
      }

      if (!query) {
        searchResults.innerHTML = `
          <div class="results-placeholder">
            <p>输入关键词开始搜索</p>
            <p class="hints">尝试搜索：龙、凤凰、八卦、黄历、修炼、功法、神话...</p>
          </div>
        `;
        return;
      }

      const filtered = allContent.filter(item => {
        const matchesModule = currentModule === 'all' || item.module === currentModule;
        const matchesQuery =
          item.title.toLowerCase().includes(query) ||
          item.excerpt.toLowerCase().includes(query) ||
          item.tags.some(tag => tag.toLowerCase().includes(query));
        return matchesModule && matchesQuery;
      });

      if (filtered.length === 0) {
        searchResults.innerHTML = `
          <div class="results-placeholder">
            <p>未找到与「${currentQuery}」相关的结果</p>
            <p class="hints">尝试：简化关键词 / 切换板块 / 检查拼写</p>
          </div>
        `;
        return;
      }

      const statsHtml = `<div class="results-stats">找到 <strong>${filtered.length}</strong> 个相关结果</div>`;

      searchResults.innerHTML = statsHtml + filtered.map(item => `
        <a href="${item.href}" class="result-item">
          <div class="result-module">${item.moduleName}</div>
          <h3 class="result-title">${highlightText(item.title, currentQuery)}</h3>
          <p class="result-excerpt">${highlightText(item.excerpt, currentQuery)}</p>
          <div class="result-tags">
            ${item.tags.map(tag => `<span class="result-tag">${tag}</span>`).join('')}
          </div>
        </a>
      `).join('');
    }

    searchInput?.addEventListener('input', (e) => {
      currentQuery = (e.target as HTMLInputElement).value;

      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => {
        performSearch();
      }, 150);
    });

    searchInput?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        clearTimeout(debounceTimer);
        performSearch();
      }
    });

    searchBtn?.addEventListener('click', () => {
      clearTimeout(debounceTimer);
      performSearch();
    });

    clearBtn?.addEventListener('click', () => {
      if (searchInput) {
        searchInput.value = '';
        currentQuery = '';
        performSearch();
        searchInput.focus();
      }
    });

    moduleFilters.forEach(filter => {
      filter.addEventListener('click', () => {
        moduleFilters.forEach(f => f.classList.remove('active'));
        filter.classList.add('active');
        currentModule = filter.getAttribute('data-module') || 'all';
        performSearch();
      });
    });

    initSuggestions();
  </script>
</BaseLayout>