---
import PageLayout from '../../layouts/PageLayout.astro';
import ArticleCard from '@components/widgets/ArticleCard.astro';
import ScrollReveal from '@components/interactive/ScrollReveal.astro';

const basePath = import.meta.env.BASE_URL || '';

const featuredArticles = [
  {
    title: '经络与气脉',
    subtitle: '人体能量网络的系统解析',
    description: '深入探讨中医经络系统与道教气脉理论，分析其生理基础与修行应用，为理解身心修炼提供医学依据。',
    href: `${basePath}/medicine/meridians-and-body`,
    category: '核心卷宗',
    era: '太初纪-末法纪',
    tags: ['经络', '气脉', '穴位'],
    readTime: '15分钟',
    color: 'jade' as const,
    featured: true,
  },
  {
    title: '精气神三位一体',
    subtitle: '生命能量的根本要素',
    description: '系统阐述精、气、神三大生命要素的概念内涵、相互转化关系及在日常养生中的应用方法。',
    href: `${basePath}/medicine/essence-qi-spirit`,
    category: '基础理论',
    era: '太初纪-末法纪',
    tags: ['精', '气', '神', '三位一体'],
    readTime: '12分钟',
    color: 'jade' as const,
  },
  {
    title: '五脏六腑与五行',
    subtitle: '脏腑系统的能量对应',
    description: '深入解析五脏六腑与五行属性的对应关系，探讨脏腑功能在修行中的意义与养护方法。',
    href: `${basePath}/medicine/five-phases-and-organs`,
    category: '基础理论',
    era: '太初纪-末法纪',
    tags: ['五行', '脏腑', '中医'],
    readTime: '10分钟',
    color: 'jade' as const,
  },
  {
    title: '《黄帝内经》导读',
    subtitle: '中医经典的修行解读',
    description: '从修行视角解读《黄帝内经》的核心理论，包括阴阳五行、藏象经络、养生之道等核心内容。',
    href: `${basePath}/medicine/huangdi-neijing`,
    category: '经典解读',
    era: '先秦-汉',
    tags: ['黄帝内经', '中医', '经典'],
    readTime: '18分钟',
    color: 'jade' as const,
  },
];

const articleCategories = [
  {
    title: '经络气脉',
    description: '十二正经、奇经八脉、穴位系统与气脉运行',
    href: `${basePath}/medicine/meridians-and-body`,
    icon: '◉',
    articles: [
      { title: '十二正经循行', desc: '手三阴三阳经的循行路线与主病' },
      { title: '奇经八脉要义', desc: '任督冲带的特殊功能与修炼意义' },
      { title: '丹田系统', desc: '上中下丹田的位置与炼精化气的关系' },
    ],
  },
  {
    title: '脏腑养生',
    description: '五脏六腑的功能维护与五行调理',
    href: `${basePath}/medicine/five-phases-and-organs`,
    icon: '◇',
    articles: [
      { title: '心系统', desc: '君主之官，神明出焉' },
      { title: '肝系统', desc: '将军之官，谋虑出焉' },
      { title: '肾系统', desc: '作强之官，技巧出焉' },
    ],
  },
  {
    title: '养生功法',
    description: '导引、吐纳、按摩等养生实践方法',
    href: `${basePath}/medicine/huangdi-neijing`,
    icon: '○',
    articles: [
      { title: '八段锦', desc: '八个动作调理脏腑气机' },
      { title: '五禽戏', desc: '仿生运动，疏通经络' },
      { title: '六字诀', desc: '嘘呵呼嘶吹嘻，调理五脏' },
    ],
  },
];

const healthPrinciples = [
  { principle: '法于阴阳', description: '顺应天地阴阳变化，春夏养阳，秋冬养阴' },
  { principle: '和于术数', description: '适度运用养生方法，不过度，不偏废' },
  { principle: '食饮有节', description: '饮食定时定量，五味调和，不过饥过饱' },
  { principle: '起居有常', description: '作息规律，日出而作，日落而息' },
  { principle: '不妄作劳', description: '劳逸结合，节制房事，爱惜精气' },
  { principle: '形与神俱', description: '身形与心神和谐统一，身心俱养' },
];
---

<PageLayout
  title="典籍"
  description="身心修炼的古老智慧，医道同源的千年传承"
  section="典籍"
  sectionColor="jade"
>
  <article class="pt-20 pb-16">
    <header class="relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-b from-[#2d8a8a]/[0.03] via-transparent to-transparent"></div>
      <div class="absolute top-0 left-1/4 w-96 h-96 rounded-full bg-gradient-to-br from-[#2d8a8a]/[0.06] to-transparent blur-3xl"></div>
      <div class="absolute bottom-0 right-1/4 w-64 h-64 rounded-full bg-gradient-to-tr from-[#5ababa]/[0.04] to-transparent blur-2xl"></div>

      <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-12">
        <nav class="flex items-center gap-2 text-sm mb-8" aria-label="面包屑导航">
          <a href={basePath} class="text-[#666666] hover:text-[#5ababa] transition-colors">首页</a>
          <span class="text-[#444444]">/</span>
          <span class="text-[#888888]">典籍</span>
        </nav>

        <div class="flex items-center gap-3 mb-6">
          <span class="px-3 py-1 text-xs font-medium tracking-[0.15em] uppercase border border-[#5ababa]/40 text-[#5ababa] rounded-full">
            典籍
          </span>
          <span class="px-3 py-1 text-xs text-[#888888] border border-[#333333]/50 rounded-full">
            身心修持
          </span>
        </div>

        <h1 class="text-4xl sm:text-5xl md:text-6xl font-display text-[#5ababa] mb-6 tracking-wide leading-tight">
          身体修持
        </h1>

        <p class="text-xl sm:text-2xl text-[#5ababa]/80 font-light mb-6 leading-relaxed">
          医道同源的千年传承
        </p>

        <blockquote class="border-l-2 border-[#2d8a8a] pl-6 py-3 my-6 max-w-3xl">
          <p class="text-lg text-[#888888] italic leading-relaxed">
            上医治未病，中医治欲病，下医治已病。
          </p>
        </blockquote>

        <p class="text-[#888888] leading-relaxed mb-8 max-w-3xl">
          从《黄帝内经》到《伤寒杂病论》，从经络穴位到脏腑五行，中国传统医学体系蕴含着深邃的生命智慧。这些智慧不仅可用于治病救人，更是身心修炼的重要基础。
        </p>

        <div class="flex flex-wrap gap-4">
          <a
            href={`${basePath}/medicine/meridians-and-body`}
            class="group inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-[#2d8a8a]/[0.08] border border-[#2d8a8a]/30 text-[#5ababa] hover:bg-[#2d8a8a]/[0.12] hover:border-[#5ababa]/50 transition-all"
          >
            <span>探索经络</span>
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 17L17 7M17 7H7M17 7V17" />
            </svg>
          </a>
          <a
            href={`${basePath}/medicine/essence-qi-spirit`}
            class="group inline-flex items-center gap-2 px-6 py-3 rounded-lg border border-[#333333] text-[#888888] hover:text-[#5ababa] hover:border-[#2d8a8a]/30 transition-all"
          >
            <span>精气神理论</span>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7m0 0l-7-7m7 7V3" />
            </svg>
          </a>
        </div>

        <div class="mt-12 max-w-[240px] h-[1px] bg-gradient-to-r from-transparent via-[#2d8a8a]/50 to-transparent"></div>
      </div>
    </header>

    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <ScrollReveal>
        <section class="py-16 border-b border-[#2a2a2a]/50">
          <h2 class="text-2xl sm:text-3xl font-display text-[#5ababa] mb-8 tracking-wide">核心典籍</h2>
          <div class="grid gap-4">
            {featuredArticles.slice(0, 1).map((article) => (
              <ArticleCard
                title={article.title}
                subtitle={article.subtitle}
                description={article.description}
                href={article.href}
                category={article.category}
                era={article.era}
                tags={article.tags}
                readTime={article.readTime}
                featured={article.featured}
                color={article.color}
              />
            ))}
          </div>
          <div class="grid sm:grid-cols-2 gap-4 mt-4">
            {featuredArticles.slice(1).map((article) => (
              <ArticleCard
                title={article.title}
                subtitle={article.subtitle}
                description={article.description}
                href={article.href}
                category={article.category}
                era={article.era}
                tags={article.tags}
                readTime={article.readTime}
                color={article.color}
              />
            ))}
          </div>
        </section>
      </ScrollReveal>

      <ScrollReveal>
        <section class="py-16 border-b border-[#2a2a2a]/50">
          <h2 class="text-2xl sm:text-3xl font-display text-[#5ababa] mb-8 tracking-wide">典籍分类</h2>
          <div class="grid sm:grid-cols-3 gap-4">
            {articleCategories.map((category) => (
              <a
                href={category.href}
                class="group p-5 rounded-lg bg-[#0d0d0d]/50 border border-[#2d8a8a]/30 hover:border-[#5ababa]/60 hover:bg-[#2d8a8a]/[0.03] transition-all"
              >
                <div class="flex items-center gap-3 mb-4">
                  <span class="text-2xl text-[#2d8a8a] group-hover:text-[#5ababa] transition-colors">{category.icon}</span>
                  <div>
                    <h3 class="text-lg font-display text-[#5ababa] group-hover:text-[#6bcbcb] transition-colors">
                      {category.title}
                    </h3>
                    <p class="text-xs text-[#666666]">{category.description}</p>
                  </div>
                </div>
                <ul class="space-y-2">
                  {category.articles.map((article) => (
                    <li class="text-sm text-[#888888] group-hover:text-[#a0a0a0] transition-colors flex items-start gap-2">
                      <span class="text-[#2d8a8a]/60 mt-1">·</span>
                      <div>
                        <span class="font-medium text-[#5ababa]/80">{article.title}</span>
                        <span class="text-[#666666]"> — {article.desc}</span>
                      </div>
                    </li>
                  ))}
                </ul>
              </a>
            ))}
          </div>
        </section>
      </ScrollReveal>

      <ScrollReveal>
        <section class="py-16 border-b border-[#2a2a2a]/50">
          <h2 class="text-2xl sm:text-3xl font-display text-[#5ababa] mb-8 tracking-wide">养生六原则</h2>
          <p class="text-[#888888] mb-8 max-w-3xl">
            《黄帝内经·上古天真论》提出的养生纲领，是所有修习者应当遵循的基本原则。
          </p>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {healthPrinciples.map((item, index) => (
              <ScrollReveal delay={index * 100}>
                <div class="p-5 rounded-lg bg-[#2d8a8a]/[0.03] border border-[#2d8a8a]/20">
                  <h3 class="text-lg font-display text-[#5ababa] mb-2">{item.principle}</h3>
                  <p class="text-sm text-[#888888] leading-relaxed">{item.description}</p>
                </div>
              </ScrollReveal>
            ))}
          </div>
        </section>
      </ScrollReveal>

      <ScrollReveal>
        <section class="py-16">
          <h2 class="text-2xl sm:text-3xl font-display text-[#5ababa] mb-8 tracking-wide">关联路径</h2>
          <p class="text-[#888888] mb-8 max-w-3xl">
            从身体修持出发，可沿以下路径深入探索修行文明的各个面向。
          </p>
          <div class="space-y-4">
            <a
              href={`${basePath}/archive`}
              class="group block p-5 rounded-lg bg-[#c9a227]/[0.04] border border-[#c9a227]/20 hover:border-[#d4af37]/40 transition-all"
            >
              <h3 class="text-lg font-display text-[#d4af37] mb-1">末法档案</h3>
              <p class="text-sm text-[#888888]">探索末法纪的形成与修行文明衰退的进程 → 档案馆</p>
            </a>
            <a
              href={`${basePath}/dharma`}
              class="group block p-5 rounded-lg bg-[#2d4a6b]/[0.04] border border-[#2d4a6b]/20 hover:border-[#6b9ad4]/40 transition-all"
            >
              <h3 class="text-lg font-display text-[#6b9ad4] mb-1">佛道思想</h3>
              <p class="text-sm text-[#888888]">梳理佛教东渐与道教兴起的修行传承 → 法门</p>
            </a>
            <a
              href={`${basePath}/realms`}
              class="group block p-5 rounded-lg bg-[#8a4a2d]/[0.04] border border-[#8a4a2d]/20 hover:border-[#ba7a5a]/40 transition-all"
            >
              <h3 class="text-lg font-display text-[#ba7a5a] mb-1">境界体系</h3>
              <p class="text-sm text-[#888888]">从仙侠小说看失落文明的文学再造 → 境界</p>
            </a>
          </div>
        </section>
      </ScrollReveal>

      <footer class="py-12 text-center">
        <div class="max-w-[200px] mx-auto mb-8 h-[1px] bg-gradient-to-r from-transparent via-[#2d8a8a]/30 to-transparent"></div>
        <p class="text-[#666666] text-sm">
          身体修持 · 灵墟 · 末法时代修行文明档案馆
        </p>
        <p class="text-[#555555] text-xs mt-2">
          养精蓄锐，性命双修
        </p>
      </footer>
    </div>
  </article>
</PageLayout>