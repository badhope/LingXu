---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '@lib/utils';
---

<BaseLayout title="页面未找到" description="您访问的页面不存在">
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-[#050505] via-[#080808] to-[#080808]"></div>

    <div class="absolute inset-0">
      <div class="sacred-geometry -top-20 -left-20 animate-twinkle opacity-20"></div>
      <div class="sacred-geometry -bottom-40 -right-20 animate-twinkle opacity-20" style="animation-delay: 1.5s;"></div>
    </div>

    <div class="relative z-10 text-center max-w-2xl mx-auto px-6">
      <div class="mb-8">
        <span class="text-8xl font-display text-[#c9a227]/30">404</span>
      </div>

      <div class="gold-line max-w-xs mx-auto mb-8 opacity-50"></div>

      <h1 class="text-3xl font-display text-[#e8d48b] mb-6 tracking-wide">
        页面未找到
      </h1>

      <div class="space-y-4 text-[#888888] mb-12">
        <p>您进入的领域尚未被探索。</p>
        <p>这片废墟中，或许还有其他遗迹等待发现。</p>
      </div>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href={withBase('/')}
          class="group relative px-8 py-3 rounded-lg overflow-hidden transition-all duration-500 hover:scale-105"
        >
          <div class="absolute inset-0 bg-gradient-to-r from-[#c9a227]/20 via-[#d4af37]/10 to-[#c9a227]/20 border border-[#c9a227]/40 rounded-lg"></div>
          <span class="relative text-[#d4af37] tracking-wider group-hover:text-shadow-gold transition-all">
            返回首页
          </span>
        </a>

        <a
          href={withBase('/home')}
          class="group px-8 py-3 rounded-lg border border-[#333333]/60 text-[#666666] hover:text-[#c9a227] hover:border-[#444444] transition-all duration-500"
        >
          <span class="tracking-wider">探索首页</span>
        </a>
      </div>

      <div class="mt-16 pt-8 border-t border-[#222222]">
        <p class="text-sm text-[#555555] mb-4">或者选择一个板块：</p>
        <div class="flex flex-wrap justify-center gap-3">
          <a href={withBase('/tian')} class="text-[#c9a227]/60 hover:text-[#d4af37] transition-colors text-sm">天时</a>
          <span class="text-[#333333]">·</span>
          <a href={withBase('/di')} class="text-[#40b040]/60 hover:text-[#60d060] transition-colors text-sm">地理</a>
          <span class="text-[#333333]">·</span>
          <a href={withBase('/xuan')} class="text-[#8040f0]/60 hover:text-[#a060ff] transition-colors text-sm">玄学</a>
          <span class="text-[#333333]">·</span>
          <a href={withBase('/huang')} class="text-[#c08040]/60 hover:text-[#e0a060] transition-colors text-sm">历史</a>
        </div>
      </div>
    </div>

    <div class="absolute bottom-0 left-0 right-0 h-40 bg-gradient-to-t from-[#080808] to-transparent pointer-events-none"></div>
  </section>
</BaseLayout>