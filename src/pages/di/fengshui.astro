---
import ModuleLayout from '../../layouts/ModuleLayout.astro';

const compassDirections = [
  { name: '正北', angle: '0°', element: '水', trigram: '坎', fortune: '凶', usage: '忌动土，宜静养' },
  { name: '东北', angle: '45°', element: '土', trigram: '艮', fortune: '平', usage: '可修造，慎选择' },
  { name: '正东', angle: '90°', element: '木', trigram: '震', fortune: '吉', usage: '宜开拓，利发展' },
  { name: '东南', angle: '135°', element: '木', trigram: '巽', fortune: '吉', usage: '利文事，宜学习' },
  { name: '正南', angle: '180°', element: '火', trigram: '离', fortune: '大吉', usage: '旺财运，利名声' },
  { name: '西南', angle: '225°', element: '土', trigram: '坤', fortune: '凶', usage: '忌婚嫁，慎出行' },
  { name: '正西', angle: '270°', element: '金', trigram: '兑', fortune: '吉', usage: '利谈判，宜交易' },
  { name: '西北', angle: '315°', element: '金', trigram: '乾', fortune: '大吉', usage: '旺事业，利贵人' },
];

const dragonVeins = [
  { type: '山龙', direction: '西北来龙', nature: '刚健', suit: '阳宅', desc: '主事业腾飞，利功名' },
  { type: '水龙', direction: '东北来水', nature: '柔顺', suit: '阴宅', desc: '主财运亨通，利商贾' },
  { type: '平龙', direction: '横贯东西', nature: '中和', suit: '阴阳宅', desc: '主平安吉祥，万事顺' },
];

const houseAnalysis = {
  facing: '坐北朝南',
  gate: '东南门',
  layout: [
    { area: '客厅', position: '正南', element: '火', note: '采光充足，旺财运' },
    { area: '主卧', position: '正北', element: '水', note: '宜静养，助睡眠' },
    { area: '厨房', position: '正东', element: '木', note: '灶台朝东，木生火' },
    { area: '书房', position: '正西', element: '金', note: '利文昌，宜学习' },
  ]
};
---

<ModuleLayout moduleId="di" title="风水堪舆" description="风水分析，阳宅阴宅，龙脉走向">
  <div class="fengshui-page">
    <section class="compass-section">
      <h2>罗盘八宫</h2>
      <div class="compass-display">
        <div class="compass-center">
          <span class="compass-icon">🧭</span>
          <span class="compass-title">方位盘</span>
        </div>
        <div class="compass-ring">
          {compassDirections.map((dir) => (
            <div class={`compass-direction ${dir.fortune}`}>
              <span class="dir-name">{dir.name}</span>
              <span class="dir-angle">{dir.angle}</span>
              <span class={`dir-element ${dir.element}`}>{dir.element}</span>
              <span class="dir-trigram">{dir.trigram}</span>
              <span class={`dir-fortune ${dir.fortune}`}>{dir.fortune}</span>
            </div>
          ))}
        </div>
      </div>
      <div class="usage-guide">
        <p>注：大吉/吉方位宜积极行动，凶方位宜静守避凶</p>
      </div>
    </section>

    <section class="dragon-veins">
      <h2>龙脉走向</h2>
      <div class="veins-cards">
        {dragonVeins.map((vein) => (
          <div class="vein-card">
            <div class="vein-header">
              <span class="vein-type">{vein.type}</span>
              <span class="vein-direction">{vein.direction}</span>
            </div>
            <div class="vein-body">
              <p class="vein-nature">性质：<span>{vein.nature}</span></p>
              <p class="vein-suit">适用：<span>{vein.suit}</span></p>
              <p class="vein-desc">{vein.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="house-analysis">
      <h2>阳宅分析示例</h2>
      <div class="analysis-header">
        <div class="analysis-info">
          <span class="info-label">坐向</span>
          <span class="info-value">{houseAnalysis.facing}</span>
        </div>
        <div class="analysis-info">
          <span class="info-label">大门</span>
          <span class="info-value">{houseAnalysis.gate}</span>
        </div>
      </div>
      <div class="layout-grid">
        {houseAnalysis.layout.map((area) => (
          <div class={`layout-card ${area.element}`}>
            <div class="layout-header">
              <span class="area-name">{area.area}</span>
              <span class={`element-badge ${area.element}`}>{area.element}</span>
            </div>
            <div class="layout-body">
              <p class="area-position">位置：{area.position}</p>
              <p class="area-note">{area.note}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="five-elements-flow">
      <h2>五行流转</h2>
      <div class="flow-diagram">
        <div class="flow-cycle">
          <span class="flow-element wood">木</span>
          <span class="flow-arrow">→</span>
          <span class="flow-element fire">火</span>
          <span class="flow-arrow">→</span>
          <span class="flow-element earth">土</span>
          <span class="flow-arrow">→</span>
          <span class="flow-element metal">金</span>
          <span class="flow-arrow">→</span>
          <span class="flow-element water">水</span>
          <span class="flow-arrow">→</span>
          <span class="flow-element wood">木</span>
        </div>
        <p class="flow-note">五行相生，循环不息。阳宅布局宜顺应五行相生之理，避免相克。</p>
      </div>
    </section>

    <section class="taboo-section">
      <h2>风水禁忌</h2>
      <div class="taboo-grid">
        <div class="taboo-item">
          <span class="taboo-icon">⚠️</span>
          <div class="taboo-content">
            <h3>门对门</h3>
            <p>大门不宜与邻居大门相对，宜挂珠帘或设置玄关化解</p>
          </div>
        </div>
        <div class="taboo-item">
          <span class="taboo-icon">⚠️</span>
          <div class="taboo-content">
            <h3>路冲</h3>
            <p>大门正对直路或尖角建筑，易遭意外破财，宜立石敢当</p>
          </div>
        </div>
        <div class="taboo-item">
          <span class="taboo-icon">⚠️</span>
          <div class="taboo-content">
            <h3>背后空</h3>
            <p>座位背后不宜临窗或空荡，宜有实墙靠山</p>
          </div>
        </div>
        <div class="taboo-item">
          <span class="taboo-icon">⚠️</span>
          <div class="taboo-content">
            <h3>压梁</h3>
            <p>横梁压顶主压力大，装修时应隐藏或转移</p>
          </div>
        </div>
      </div>
    </section>

    <section class="enhancement-tips">
      <h2>增运布局</h2>
      <div class="tips-list">
        <div class="tip-item">
          <span class="tip-icon">💰</span>
          <div class="tip-content">
            <h3>财运</h3>
            <p>财位（大门对角线位置）宜放置聚宝盆、鱼缸或貔貅</p>
          </div>
        </div>
        <div class="tip-item">
          <span class="tip-icon">📚</span>
          <div class="tip-content">
            <h3>文昌</h3>
            <p>文昌位（正东或东北）宜放置文昌塔、毛笔或书籍</p>
          </div>
        </div>
        <div class="tip-item">
          <span class="tip-icon">💑</span>
          <div class="tip-content">
            <h3>桃花</h3>
            <p>桃花位（正西）宜放置鲜花或成双成对的装饰物</p>
          </div>
        </div>
        <div class="tip-item">
          <span class="tip-icon">🛡️</span>
          <div class="tip-content">
            <h3>化煞</h3>
            <p>使用八卦镜、铜狮或泰山石敢当化解外部煞气</p>
          </div>
        </div>
      </div>
    </section>
  </div>

  <style>
    .fengshui-page { max-width: 1000px; margin: 0 auto; }

    .compass-section, .dragon-veins, .house-analysis, .five-elements-flow, .taboo-section, .enhancement-tips {
      background: rgba(64, 176, 64, 0.05);
      border: 1px solid rgba(64, 176, 64, 0.2);
      border-radius: 8px;
      padding: 1.5rem;
      margin-bottom: 2rem;
    }

    h2 {
      color: #40b040;
      font-size: 1.25rem;
      margin-bottom: 1rem;
      border-bottom: 1px solid rgba(64, 176, 64, 0.2);
      padding-bottom: 0.5rem;
    }

    .compass-display {
      display: flex;
      flex-direction: column;
      align-items: center;
      margin-bottom: 1rem;
    }

    .compass-center {
      display: flex;
      flex-direction: column;
      align-items: center;
      margin-bottom: 1rem;
    }

    .compass-icon { font-size: 3rem; }
    .compass-title { color: #40b040; font-size: 1rem; }

    .compass-ring {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0.5rem;
      width: 100%;
      max-width: 600px;
    }

    .compass-direction {
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 0.75rem;
      background: rgba(0, 0, 0, 0.3);
      border-radius: 6px;
      border: 1px solid rgba(64, 176, 64, 0.2);
    }

    .compass-direction.大吉 { border-color: rgba(74, 222, 128, 0.5); background: rgba(74, 222, 128, 0.1); }
    .compass-direction.凶 { border-color: rgba(248, 113, 113, 0.5); background: rgba(248, 113, 113, 0.1); }

    .dir-name { color: #66d066; font-weight: 600; font-size: 0.9rem; }
    .dir-angle { color: #888; font-size: 0.7rem; }
    .dir-element { font-size: 0.8rem; font-weight: 600; }
    .dir-element.木 { color: #4ade80; }
    .dir-element.火 { color: #f87171; }
    .dir-element.土 { color: #fbbf24; }
    .dir-element.金 { color: #c0c0c0; }
    .dir-element.水 { color: #60a5fa; }
    .dir-trigram { color: #888; font-size: 0.8rem; }
    .dir-fortune { font-size: 0.75rem; font-weight: 600; margin-top: 0.25rem; }
    .dir-fortune.大吉 { color: #4ade80; }
    .dir-fortune.吉 { color: #86efac; }
    .dir-fortune.平 { color: #fbbf24; }
    .dir-fortune.凶 { color: #f87171; }

    .usage-guide { text-align: center; margin-top: 1rem; }
    .usage-guide p { color: #888; font-size: 0.85rem; }

    .veins-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }

    .vein-card {
      background: rgba(0, 0, 0, 0.3);
      border-radius: 8px;
      overflow: hidden;
    }

    .vein-header {
      display: flex;
      justify-content: space-between;
      padding: 0.75rem;
      background: rgba(64, 176, 64, 0.15);
    }

    .vein-type { color: #66d066; font-weight: 600; }
    .vein-direction { color: #888; font-size: 0.8rem; }

    .vein-body { padding: 1rem; }
    .vein-body p { margin-bottom: 0.5rem; font-size: 0.85rem; color: #888; }
    .vein-body p span { color: #ccc; }
    .vein-desc { color: #aaa !important; font-style: italic; }

    .analysis-header { display: flex; gap: 2rem; margin-bottom: 1.5rem; }

    .analysis-info { display: flex; flex-direction: column; }
    .info-label { color: #888; font-size: 0.8rem; }
    .info-value { color: #66d066; font-size: 1.1rem; font-weight: 600; }

    .layout-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; }

    .layout-card {
      background: rgba(0, 0, 0, 0.3);
      border-radius: 8px;
      overflow: hidden;
    }

    .layout-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.75rem;
      background: rgba(64, 176, 64, 0.1);
    }

    .area-name { color: #66d066; font-weight: 600; }
    .element-badge { font-size: 0.7rem; padding: 0.2rem 0.4rem; border-radius: 4px; }
    .element-badge.木 { background: rgba(34, 139, 34, 0.3); color: #4ade80; }
    .element-badge.火 { background: rgba(255, 69, 0, 0.3); color: #f87171; }
    .element-badge.土 { background: rgba(139, 69, 19, 0.3); color: #fbbf24; }
    .element-badge.金 { background: rgba(192, 192, 192, 0.3); color: #c0c0c0; }
    .element-badge.水 { background: rgba(30, 144, 255, 0.3); color: #60a5fa; }

    .layout-body { padding: 0.75rem; }
    .area-position { color: #888; font-size: 0.8rem; margin-bottom: 0.25rem; }
    .area-note { color: #aaa; font-size: 0.75rem; }

    .flow-diagram { text-align: center; }

    .flow-cycle {
      display: flex;
      align-items: center;
      justify-content: center;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-bottom: 1rem;
    }

    .flow-element {
      padding: 0.5rem 1rem;
      border-radius: 6px;
      font-weight: 600;
    }

    .flow-element.木 { background: rgba(34, 139, 34, 0.3); color: #4ade80; }
    .flow-element.火 { background: rgba(255, 69, 0, 0.3); color: #f87171; }
    .flow-element.土 { background: rgba(139, 69, 19, 0.3); color: #fbbf24; }
    .flow-element.金 { background: rgba(192, 192, 192, 0.3); color: #c0c0c0; }
    .flow-element.水 { background: rgba(30, 144, 255, 0.3); color: #60a5fa; }

    .flow-arrow { color: #888; }

    .flow-note { color: #888; font-size: 0.85rem; }

    .taboo-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; }

    .taboo-item {
      display: flex;
      gap: 1rem;
      padding: 1rem;
      background: rgba(0, 0, 0, 0.3);
      border-radius: 8px;
    }

    .taboo-icon { font-size: 1.5rem; }
    .taboo-content h3 { color: #66d066; margin-bottom: 0.25rem; font-size: 0.95rem; }
    .taboo-content p { color: #888; font-size: 0.8rem; }

    .tips-list { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; }

    .tip-item {
      display: flex;
      gap: 1rem;
      padding: 1rem;
      background: rgba(0, 0, 0, 0.3);
      border-radius: 8px;
    }

    .tip-icon { font-size: 1.5rem; }
    .tip-content h3 { color: #66d066; margin-bottom: 0.25rem; font-size: 0.95rem; }
    .tip-content p { color: #888; font-size: 0.8rem; }

    @media (max-width: 768px) {
      .compass-ring { grid-template-columns: repeat(2, 1fr); }
      .veins-cards, .layout-grid, .tips-list, .taboo-grid { grid-template-columns: 1fr; }
    }
  </style>
</ModuleLayout>