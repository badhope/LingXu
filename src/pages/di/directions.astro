---
import ModuleLayout from '../../layouts/ModuleLayout.astro';

const directions = [
  { name: '正东', symbol: '甲卯乙', element: '木', color: '#40b040', deity: '青龙', desc: '日出之地，木气旺盛，主生发、成长。利修身养性，不利杀伐。', taboos: '忌动土、忌竖柱' },
  { name: '正南', symbol: '丙午丁', element: '火', color: '#f04040', deity: '朱雀', desc: '向阳之地，火气炽盛，主长养、光明。利文书、利功名，不利口舌。', taboos: '忌是非、忌灯火暗淡' },
  { name: '正西', symbol: '庚酉辛', element: '金', color: '#e0e0e0', deity: '白虎', desc: '日落之地，金气清冽，主收肃、变革。利财利武，不利姻缘。', taboos: '忌讨债、忌争执' },
  { name: '正北', symbol: '壬子癸', element: '水', color: '#4080f0', deity: '玄武', desc: '坎位，水气深藏，主闭藏、潜伏。利智谋、利隐遁，不利公开。', taboos: '忌出行、忌大兴土木' },
  { name: '东南', symbol: '辰巽巳', element: '木', color: '#60b060', deity: '巽', desc: '风起之地，木气动荡，主利市利交易。文人多吉，商人有利。', taboos: '忌安床、忌新婚' },
  { name: '西南', symbol: '未坤申', element: '土', color: '#c08040', deity: '坤', desc: '地户所在，土气厚重，主丧病惊恐。阴气较重，不利阳事。', taboos: '忌动土、忌婚嫁' },
  { name: '东北', symbol: '丑艮寅', element: '土', color: '#b08040', deity: '艮', desc: '鬼门所在，土气凝结，主少男姻亲。修行者需谨慎，易有阴灵干扰。', taboos: '忌深夜独行、忌探病' },
  { name: '西北', symbol: '戌乾亥', element: '金', color: '#a0a0c0', deity: '乾', desc: '天门所在，金气刚健，主老年姻亲。利决策、利外交，不利内部。', taboos: '忌固执、忌蛮干' },
];

const timeDirections = [
  { time: '23:00-01:00', direction: '子', name: '正北', element: '水', suitable: '静坐修炼、参悟', unsuitable: '出行、争吵' },
  { time: '01:00-03:00', direction: '丑', name: '东北', element: '土', suitable: '整理、规划', unsuitable: '动工、搬家' },
  { time: '03:00-05:00', direction: '寅', name: '东北', element: '木', suitable: '起床、晨练', unsuitable: '纵欲、饮酒' },
  { time: '05:00-07:00', direction: '卯', name: '正东', element: '木', suitable: '读书、会友', unsuitable: '争执、杀伐' },
  { time: '07:00-09:00', direction: '辰', name: '东南', element: '土', suitable: '商业、谈判', unsuitable: '安床、动土' },
  { time: '09:00-11:00', direction: '巳', name: '东南', element: '火', suitable: '文书、功名', unsuitable: '口舌是非' },
  { time: '11:00-13:00', direction: '午', name: '正南', element: '火', suitable: '会客、宴请', unsuitable: '争吵、搬迁' },
  { time: '13:00-15:00', direction: '未', name: '西南', element: '土', suitable: '休整、沉思', unsuitable: '婚嫁、动土' },
  { time: '15:00-17:00', direction: '申', name: '西南', element: '金', suitable: '决策、诉讼', unsuitable: '恋爱、开业' },
  { time: '17:00-19:00', direction: '酉', name: '正西', element: '金', suitable: '收账、交易', unsuitable: '约会、求婚' },
  { time: '19:00-21:00', direction: '戌', name: '西北', element: '土', suitable: '反省、静修', unsuitable: '搬家、动工' },
  { time: '21:00-23:00', direction: '亥', name: '西北', element: '水', suitable: '研究、创作', unsuitable: '出行、谈判' },
];
---

<ModuleLayout moduleId="di" title="方位吉凶" description="八方五行方位时辰宜忌">
  <div class="directions-page">
    <section class="intro-section">
      <h2>方位之道</h2>
      <p>方位者，天地之气交于不同空间之所也。修行者顺之则昌，逆之则凶。择吉位而居，选良时而动，方能得天时地利之和。</p>
    </section>

    <section class="main-directions">
      <h2>八方吉凶</h2>
      <div class="directions-grid">
        {directions.map(dir => (
          <div class="direction-card" style={`--dir-color: ${dir.color}`}>
            <div class="dir-header">
              <span class="dir-icon">{dir.element === '木' ? '🌲' : dir.element === '火' ? '🔥' : dir.element === '金' ? '⚔️' : '💧'}</span>
              <div class="dir-title">
                <h3>{dir.name}</h3>
                <span class="dir-element">{dir.element} · {dir.deity}</span>
              </div>
            </div>
            <div class="dir-symbol">{dir.symbol}</div>
            <p class="dir-desc">{dir.desc}</p>
            <div class="dir-taboo">
              <span class="taboo-label">忌:</span>
              <span>{dir.taboos}</span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="time-table">
      <h2>时辰方位宜忌</h2>
      <div class="time-grid">
        {timeDirections.map(t => (
          <div class="time-card">
            <div class="time-header">
              <span class="time-range">{t.time}</span>
              <span class="time-direction">{t.direction} {t.name}</span>
            </div>
            <div class="time-element">{t.element}</div>
            <div class="time-suitable">
              <span class="suitable-label">宜:</span>
              <span>{t.suitable}</span>
            </div>
            <div class="time-unsuitable">
              <span class="unsuitable-label">忌:</span>
              <span>{t.unsuitable}</span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="tips-section">
      <h2>修行方位要诀</h2>
      <div class="tips-grid">
        <div class="tip-card">
          <h3>修炼方位</h3>
          <p>木气旺盛之处宜养肝，火气充沛之地宜养心。每日寅时面东而坐，吸纳青龙之气，可助修炼。</p>
        </div>
        <div class="tip-card">
          <h3>闭关择地</h3>
          <p>闭关修炼宜择西北乾位或正北坎位，此二处灵气最为纯净，不易被外界干扰。</p>
        </div>
        <div class="tip-card">
          <h3>突破时机</h3>
          <p>境界突破宜在卯时或午时，此时阴阳交泰，天地灵气最为活跃，突破成功率倍增。</p>
        </div>
      </div>
    </section>
  </div>
</ModuleLayout>

<style>
  .directions-page {
    max-width: 1200px;
    margin: 0 auto;
  }

  .intro-section {
    text-align: center;
    margin-bottom: 3rem;
  }

  .intro-section h2 {
    font-size: 1.8rem;
    color: #d4af37;
    margin-bottom: 1rem;
  }

  .intro-section p {
    color: #888;
    line-height: 1.8;
    max-width: 800px;
    margin: 0 auto;
  }

  section {
    margin-bottom: 3rem;
  }

  section h2 {
    font-size: 1.4rem;
    color: #c9a227;
    margin-bottom: 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(201, 162, 39, 0.2);
  }

  .directions-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .direction-card {
    background: linear-gradient(135deg, rgba(20, 20, 20, 0.9), rgba(30, 30, 30, 0.8));
    border: 1px solid var(--dir-color);
    border-radius: 12px;
    padding: 1.5rem;
    transition: all 0.3s ease;
  }

  .direction-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3), 0 0 20px color-mix(in srgb, var(--dir-color) 20%, transparent);
  }

  .dir-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .dir-icon {
    font-size: 2rem;
  }

  .dir-title h3 {
    color: var(--dir-color);
    font-size: 1.3rem;
    margin: 0;
  }

  .dir-element {
    color: #888;
    font-size: 0.85rem;
  }

  .dir-symbol {
    font-size: 1.5rem;
    color: var(--dir-color);
    text-align: center;
    padding: 0.5rem;
    background: rgba(0, 0, 0, 0.3);
    border-radius: 6px;
    margin-bottom: 1rem;
    letter-spacing: 0.5rem;
  }

  .dir-desc {
    color: #ccc;
    line-height: 1.6;
    margin-bottom: 1rem;
    font-size: 0.9rem;
  }

  .dir-taboo {
    color: #f04040;
    font-size: 0.85rem;
  }

  .taboo-label {
    color: #888;
    margin-right: 0.5rem;
  }

  .time-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1rem;
  }

  .time-card {
    background: rgba(20, 20, 20, 0.8);
    border: 1px solid rgba(64, 128, 240, 0.2);
    border-radius: 8px;
    padding: 1rem;
  }

  .time-card:hover {
    border-color: rgba(64, 128, 240, 0.5);
  }

  .time-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
  }

  .time-range {
    color: #e8d48b;
    font-size: 0.9rem;
    font-weight: 600;
  }

  .time-direction {
    color: #4080f0;
    font-size: 0.85rem;
  }

  .time-element {
    text-align: center;
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
  }

  .time-suitable, .time-unsuitable {
    font-size: 0.8rem;
    margin-bottom: 0.3rem;
  }

  .suitable-label {
    color: #40b040;
    margin-right: 0.5rem;
  }

  .unsuitable-label {
    color: #f04040;
    margin-right: 0.5rem;
  }

  .time-suitable span:last-child,
  .time-unsuitable span:last-child {
    color: #888;
  }

  .tips-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .tip-card {
    background: rgba(20, 20, 20, 0.6);
    border: 1px solid rgba(201, 162, 39, 0.2);
    border-radius: 8px;
    padding: 1.5rem;
  }

  .tip-card h3 {
    color: #d4af37;
    margin-bottom: 0.8rem;
  }

  .tip-card p {
    color: #888;
    line-height: 1.6;
    margin: 0;
  }
</style>
