---
import ModuleLayout from '../../layouts/ModuleLayout.astro';

const sixRealms = [
  { name: '天道', color: '#f0c040', desc: '最上一层，享尽天福，无需劳作。寿尽仍会堕落轮回。', level: '最高', population: '稀少', lifespan: '极长' },
  { name: '人道', color: '#40b040', desc: '苦乐参半，适宜修行。转世重修之最佳选择。', level: '中等', population: '最多', lifespan: '中等' },
  { name: '阿修罗道', color: '#8040f0', desc: '福报似天，但嗔心炽盛，常起战争。', level: '中等偏上', population: '较少', lifespan: '较长' },
  { name: '畜生道', color: '#c08040', desc: '愚痴为业，受人驱使。或为家畜，或为野兽。', level: '低', population: '极多', lifespan: '不等' },
  { name: '饿鬼道', color: '#f04040', desc: '饥渴所困，百千年不闻水浆之名。业力所缠，不得饮食。', level: '低', population: '众多', lifespan: '极长' },
  { name: '地狱道', color: '#202020', desc: '最苦之处，八寒八热。造极重恶业者堕此。', level: '最低', population: '不定', lifespan: '极长' },
];

const reincarnationFactors = [
  { factor: '业力', importance: '最重', desc: '善恶业决定转世去处' },
  { factor: '愿力', importance: '重要', desc: '临终之愿影响投生方向' },
  { factor: '习气', importance: '次要', desc: '深重习气牵引同类道' },
  { factor: '缘分', importance: '辅助', desc: '与某道众生之缘促投生' },
];
---

<ModuleLayout moduleId="zhou" title="轮回查询" description="前世今生因果，六道轮回">
  <div class="reincarnation-page">
    <section class="intro-section">
      <h2>轮回之道</h2>
      <p>轮回者，生死流转之谓也。六道轮回，苦海无涯。修行者超脱轮回，方能归于大道。知轮回之理，方能断轮回之因。</p>
    </section>

    <section class="six-realms">
      <h2>六道轮回</h2>
      <div class="realms-diagram">
        <div class="realm-position top-realm">
          <div class="realm-badge" style={`--realm-color: ${sixRealms[0].color}`}>
            <span class="realm-name">{sixRealms[0].name}</span>
          </div>
        </div>
        <div class="realm-position middle-realms">
          {sixRealms.slice(1, 4).map(realm => (
            <div class="realm-badge" style={`--realm-color: ${realm.color}`}>
              <span class="realm-name">{realm.name}</span>
            </div>
          ))}
        </div>
        <div class="realm-position bottom-realms">
          {sixRealms.slice(4).map(realm => (
            <div class="realm-badge" style={`--realm-color: ${realm.color}`}>
              <span class="realm-name">{realm.name}</span>
            </div>
          ))}
        </div>
      </div>

      <div class="realms-grid">
        {sixRealms.map(realm => (
          <div class="realm-card" style={`--realm-color: ${realm.color}`}>
            <h3>{realm.name}</h3>
            <p class="realm-desc">{realm.desc}</p>
            <div class="realm-stats">
              <div class="stat">
                <span class="stat-label">等级</span>
                <span class="stat-value">{realm.level}</span>
              </div>
              <div class="stat">
                <span class="stat-label">数量</span>
                <span class="stat-value">{realm.population}</span>
              </div>
              <div class="stat">
                <span class="stat-label">寿命</span>
                <span class="stat-value">{realm.lifespan}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="factors-section">
      <h2>轮回之因</h2>
      <div class="factors-table">
        <div class="factor-header">
          <span>因素</span>
          <span>重要程度</span>
          <span>说明</span>
        </div>
        {reincarnationFactors.map(f => (
          <div class="factor-row">
            <span class="factor-name">{f.factor}</span>
            <span class="factor-importance">{f.importance}</span>
            <span class="factor-desc">{f.desc}</span>
          </div>
        ))}
      </div>
    </section>

    <section class="escape-section">
      <h2>脱离轮回</h2>
      <div class="escape-cards">
        <div class="escape-card">
          <h3>天道</h3>
          <p>虽享天福，但寿尽仍堕。唯有修习出世间法，方能彻底超脱。</p>
        </div>
        <div class="escape-card">
          <h3>人道</h3>
          <p>苦乐参半，智慧渐开。佛言"人身难得"，为人道修行之最佳时机。</p>
        </div>
        <div class="escape-card">
          <h3>修行之路</h3>
          <p>明心见性、悟道证真。三学圆满、八正道修，可证阿罗汉、菩萨、佛果。</p>
        </div>
      </div>
    </section>

    <section class="karma-section">
      <h2>因果律</h2>
      <div class="karma-knowledge">
        <div class="karma-rule">
          <h3>业力因果</h3>
          <p>种瓜得瓜，种豆得豆。善恶有报，时候未到。修行者当勤种善因，莫问前程。</p>
        </div>
        <div class="karma-rule">
          <h3>三世因果</h3>
          <p>欲知前世因，今生受者是。欲知来世果，今生作者是。莫怨天尤人，皆是自作自受。</p>
        </div>
        <div class="karma-rule">
          <h3>转染成净</h3>
          <p>虽受轮回之苦，然可借假修真。烦恼即菩提，生死即涅槃。一念觉悟，轮回永断。</p>
        </div>
      </div>
    </section>
  </div>
</ModuleLayout>

<style>
  .reincarnation-page {
    max-width: 1200px;
    margin: 0 auto;
  }

  .intro-section {
    text-align: center;
    margin-bottom: 3rem;
  }

  .intro-section h2 {
    font-size: 1.8rem;
    color: #d4af37;
    margin-bottom: 1rem;
  }

  .intro-section p {
    color: #888;
    line-height: 1.8;
    max-width: 800px;
    margin: 0 auto;
  }

  section {
    margin-bottom: 3rem;
  }

  section h2 {
    font-size: 1.4rem;
    color: #c9a227;
    margin-bottom: 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(201, 162, 39, 0.2);
  }

  .realms-diagram {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
    padding: 2rem;
    background: rgba(20, 20, 20, 0.5);
    border-radius: 12px;
  }

  .realm-position {
    display: flex;
    justify-content: center;
    gap: 1rem;
  }

  .realm-badge {
    background: linear-gradient(135deg, var(--realm-color), color-mix(in srgb, var(--realm-color) 50%, #000));
    border: 2px solid var(--realm-color);
    border-radius: 50%;
    width: 80px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 0 20px color-mix(in srgb, var(--realm-color) 30%, transparent);
  }

  .realm-name {
    color: #fff;
    font-weight: bold;
    font-size: 1rem;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.5);
  }

  .top-realm .realm-badge {
    width: 100px;
    height: 100px;
  }

  .top-realm .realm-name {
    font-size: 1.2rem;
  }

  .realms-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .realm-card {
    background: rgba(20, 20, 20, 0.8);
    border: 1px solid var(--realm-color);
    border-radius: 12px;
    padding: 1.5rem;
    transition: all 0.3s ease;
  }

  .realm-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3), 0 0 20px color-mix(in srgb, var(--realm-color) 20%, transparent);
  }

  .realm-card h3 {
    color: var(--realm-color);
    font-size: 1.3rem;
    margin-bottom: 1rem;
  }

  .realm-desc {
    color: #ccc;
    line-height: 1.6;
    margin-bottom: 1rem;
    font-size: 0.9rem;
  }

  .realm-stats {
    display: flex;
    justify-content: space-between;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .stat {
    text-align: center;
  }

  .stat-label {
    display: block;
    color: #666;
    font-size: 0.75rem;
    margin-bottom: 0.25rem;
  }

  .stat-value {
    color: #aaa;
    font-size: 0.85rem;
  }

  .factors-table {
    background: rgba(20, 20, 20, 0.8);
    border-radius: 8px;
    overflow: hidden;
  }

  .factor-header, .factor-row {
    display: grid;
    grid-template-columns: 1fr 1fr 2fr;
    text-align: center;
    padding: 1rem;
  }

  .factor-header {
    background: rgba(201, 162, 39, 0.2);
    color: #c9a227;
    font-weight: 600;
  }

  .factor-row {
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    color: #888;
    font-size: 0.9rem;
  }

  .factor-row:last-child {
    border-bottom: none;
  }

  .factor-name {
    color: #e8d48b;
    font-weight: 600;
  }

  .factor-importance {
    color: #f04080;
  }

  .escape-cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 1.5rem;
  }

  .escape-card {
    background: rgba(20, 20, 20, 0.6);
    border: 1px solid rgba(201, 162, 39, 0.2);
    border-radius: 8px;
    padding: 1.5rem;
  }

  .escape-card h3 {
    color: #d4af37;
    margin-bottom: 0.8rem;
  }

  .escape-card p {
    color: #888;
    line-height: 1.6;
    margin: 0;
  }

  .karma-knowledge {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .karma-rule {
    background: rgba(20, 20, 20, 0.6);
    border: 1px solid rgba(240, 64, 128, 0.2);
    border-radius: 8px;
    padding: 1.5rem;
  }

  .karma-rule h3 {
    color: #f04080;
    margin-bottom: 0.8rem;
  }

  .karma-rule p {
    color: #888;
    line-height: 1.6;
    margin: 0;
  }
</style>
