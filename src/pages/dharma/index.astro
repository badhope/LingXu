---
import PageLayout from '../../layouts/PageLayout.astro';
import ArticleCard from '@components/widgets/ArticleCard.astro';
import ScrollReveal from '@components/interactive/ScrollReveal.astro';

const basePath = import.meta.env.BASE_URL || '';

const featuredArticles = [
  {
    title: '佛教修行体系',
    subtitle: '从声闻乘到金刚乘的完整修行路径',
    description: '系统梳理佛教各派修行方法，包括小乘、大乘、密乘的核心理论与实践体系，分析其在中国的发展与演变。',
    href: `${basePath}/dharma/buddhist-cultivation-system`,
    category: '核心卷宗',
    era: '太初纪-末法纪',
    tags: ['佛教', '修行', '戒定慧', '禅定'],
    readTime: '20分钟',
    color: 'sapphire' as const,
    featured: true,
  },
  {
    title: '佛教末法思想',
    subtitle: '佛法衰颓与修行困境的宗教反思',
    description: '深入分析佛教对末法时代的理论建构，探讨末法思想的形成、发展及其对修行者心态的深远影响。',
    href: `${basePath}/dharma/end-of-dharma-in-buddhism`,
    category: '核心卷宗',
    era: '末法纪',
    tags: ['末法', '佛教', '三时判教'],
    readTime: '15分钟',
    color: 'sapphire' as const,
  },
  {
    title: '道教修行体系',
    subtitle: '从炼气到丹道的完整路径',
    description: '全面梳理道教各派修行方法，包括炼气、筑基、结丹、元婴等核心阶段，分析其原理与实践要点。',
    href: `${basePath}/dharma/daoist-lineages`,
    category: '核心卷宗',
    era: '太初纪-末法纪',
    tags: ['道教', '丹道', '炼气', '元婴'],
    readTime: '18分钟',
    color: 'sapphire' as const,
  },
  {
    title: '佛道比较研究',
    subtitle: '两家的异同与融合之道',
    description: '从哲学基础、修行目标、方法论三个维度系统比较佛道两家的异同，探讨历史上儒释道三教的融合模式。',
    href: `${basePath}/dharma/buddism-and-daoism`,
    category: '比较研究',
    era: '各时代',
    tags: ['佛教', '道教', '比较', '融合'],
    readTime: '12分钟',
    color: 'sapphire' as const,
  },
];

const schoolCategories = [
  {
    title: '佛教诸宗',
    description: '大乘佛教八大宗派的核心理论与修行方法',
    schools: [
      { name: '禅宗', focus: '直指人心，见性成佛', method: '参话头、打坐' },
      { name: '净土宗', focus: '念佛求生西方极乐', method: '持名念佛、观想' },
      { name: '天台宗', focus: '一念三千，止观双运', method: '六妙门、五渐次' },
      { name: '华严宗', focus: '法界缘起，一真法界', method: '法界观、普贤行' },
    ],
  },
  {
    title: '道教诸派',
    description: '道教主要流派的传承体系与修持特色',
    schools: [
      { name: '全真道', focus: '性命双修，三教合一', method: '打坐、导引、丹道' },
      { name: '正一道', focus: '符箓斋醮，驱邪降魔', method: '符咒、法术、科仪' },
      { name: '金丹派', focus: '内丹修炼，即身成仙', method: '炼精化气、炼气化神' },
      { name: '积善派', focus: '积德行善，功德成仙', method: '行善积德、布施' },
    ],
  },
];

const dharmaTypes = [
  { type: '小乘法', description: '追求个人解脱的修行道路，以四圣谛为核心', color: '#6b9ad4' },
  { type: '大乘法', description: '以普度众生为目标的菩萨道，以六度万行为实践', color: '#a878b8' },
  { type: '密乘法', description: '即身成佛的快速道路，以三密相应为核心', color: '#d4af37' },
];
---

<PageLayout
  title="法门"
  description="佛教东渐与道教兴起的修行传承"
  section="法门"
  sectionColor="sapphire"
>
  <article class="pt-20 pb-16">
    <header class="relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-b from-[#2d4a6b]/[0.03] via-transparent to-transparent"></div>
      <div class="absolute top-0 left-1/4 w-96 h-96 rounded-full bg-gradient-to-br from-[#2d4a6b]/[0.06] to-transparent blur-3xl"></div>
      <div class="absolute bottom-0 right-1/4 w-64 h-64 rounded-full bg-gradient-to-tr from-[#6b9ad4]/[0.04] to-transparent blur-2xl"></div>

      <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-12">
        <nav class="flex items-center gap-2 text-sm mb-8" aria-label="面包屑导航">
          <a href={basePath} class="text-[#666666] hover:text-[#6b9ad4] transition-colors">首页</a>
          <span class="text-[#444444]">/</span>
          <span class="text-[#888888]">法门</span>
        </nav>

        <div class="flex items-center gap-3 mb-6">
          <span class="px-3 py-1 text-xs font-medium tracking-[0.15em] uppercase border border-[#6b9ad4]/40 text-[#6b9ad4] rounded-full">
            法门
          </span>
          <span class="px-3 py-1 text-xs text-[#888888] border border-[#333333]/50 rounded-full">
            佛道思想
          </span>
        </div>

        <h1 class="text-4xl sm:text-5xl md:text-6xl font-display text-[#6b9ad4] mb-6 tracking-wide leading-tight">
          佛道思想
        </h1>

        <p class="text-xl sm:text-2xl text-[#6b9ad4]/80 font-light mb-6 leading-relaxed">
          末法时代的法脉传承
        </p>

        <blockquote class="border-l-2 border-[#2d4a6b] pl-6 py-3 my-6 max-w-3xl">
          <p class="text-lg text-[#888888] italic leading-relaxed">
            法尚应舍，何况非法。
          </p>
        </blockquote>

        <p class="text-[#888888] leading-relaxed mb-8 max-w-3xl">
          自佛教东渐，道教复兴，儒释道三家思想在中国大地交汇融合，形成了独特的修行文明景观。纵然末法已至，这些古老的智慧仍以其独特的方式影响着世人的精神生活。
        </p>

        <div class="flex flex-wrap gap-4">
          <a
            href={`${basePath}/dharma/buddhist-cultivation-system`}
            class="group inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-[#2d4a6b]/[0.08] border border-[#2d4a6b]/30 text-[#6b9ad4] hover:bg-[#2d4a6b]/[0.12] hover:border-[#6b9ad4]/50 transition-all"
          >
            <span>佛教修行</span>
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 17L17 7M17 7H7M17 7V17" />
            </svg>
          </a>
          <a
            href={`${basePath}/dharma/daoist-lineages`}
            class="group inline-flex items-center gap-2 px-6 py-3 rounded-lg border border-[#333333] text-[#888888] hover:text-[#6b9ad4] hover:border-[#2d4a6b]/30 transition-all"
          >
            <span>道教修行</span>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7m0 0l-7-7m7 7V3" />
            </svg>
          </a>
        </div>

        <div class="mt-12 max-w-[240px] h-[1px] bg-gradient-to-r from-transparent via-[#6b9ad4]/50 to-transparent"></div>
      </div>
    </header>

    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <ScrollReveal>
        <section class="py-16 border-b border-[#2a2a2a]/50">
          <h2 class="text-2xl sm:text-3xl font-display text-[#6b9ad4] mb-8 tracking-wide">核心典籍</h2>
          <div class="grid gap-4">
            {featuredArticles.slice(0, 1).map((article) => (
              <ArticleCard
                title={article.title}
                subtitle={article.subtitle}
                description={article.description}
                href={article.href}
                category={article.category}
                era={article.era}
                tags={article.tags}
                readTime={article.readTime}
                featured={article.featured}
                color={article.color}
              />
            ))}
          </div>
          <div class="grid sm:grid-cols-2 gap-4 mt-4">
            {featuredArticles.slice(1).map((article) => (
              <ArticleCard
                title={article.title}
                subtitle={article.subtitle}
                description={article.description}
                href={article.href}
                category={article.category}
                era={article.era}
                tags={article.tags}
                readTime={article.readTime}
                color={article.color}
              />
            ))}
          </div>
        </section>
      </ScrollReveal>

      <ScrollReveal>
        <section class="py-16 border-b border-[#2a2a2a]/50">
          <h2 class="text-2xl sm:text-3xl font-display text-[#6b9ad4] mb-8 tracking-wide">修行体系分类</h2>
          <p class="text-[#888888] mb-8 max-w-3xl">
            根据解脱路径与修行目标的不同，修行法门可分为三大类型：
          </p>
          <div class="grid md:grid-cols-3 gap-4">
            {dharmaTypes.map((item, index) => (
              <ScrollReveal delay={index * 100}>
                <div
                  class="p-5 rounded-lg bg-[#0d0d0d]/50 border transition-all hover:scale-[1.02]"
                  style={`border-color: ${item.color}30; background: linear-gradient(135deg, ${item.color}08, transparent);`}
                >
                  <h3
                    class="text-lg font-display mb-2"
                    style={`color: ${item.color};`}
                  >
                    {item.type}
                  </h3>
                  <p class="text-sm text-[#888888] leading-relaxed">{item.description}</p>
                </div>
              </ScrollReveal>
            ))}
          </div>
        </section>
      </ScrollReveal>

      <ScrollReveal>
        <section class="py-16 border-b border-[#2a2a2a]/50">
          <h2 class="text-2xl sm:text-3xl font-display text-[#6b9ad4] mb-8 tracking-wide">主要宗派</h2>
          <div class="grid md:grid-cols-2 gap-6">
            {schoolCategories.map((category) => (
              <div class="p-6 rounded-lg bg-[#0d0d0d]/50 border border-[#2a2a2a]/50">
                <h3 class="text-xl font-display text-[#6b9ad4] mb-2">{category.title}</h3>
                <p class="text-sm text-[#888888] mb-4">{category.description}</p>
                <div class="space-y-3">
                  {category.schools.map((school) => (
                    <div class="p-3 rounded bg-[#1a1a1a]/50 border border-[#2a2a2a]/30">
                      <div class="flex items-center justify-between mb-1">
                        <span class="font-medium text-[#6b9ad4]">{school.name}</span>
                      </div>
                      <p class="text-xs text-[#666666] mb-1">{school.focus}</p>
                      <p class="text-xs text-[#555555]">
                        <span class="text-[#6b9ad4]/60">方法：</span>{school.method}
                      </p>
                    </div>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </section>
      </ScrollReveal>

      <ScrollReveal>
        <section class="py-16">
          <h2 class="text-2xl sm:text-3xl font-display text-[#6b9ad4] mb-8 tracking-wide">关联路径</h2>
          <p class="text-[#888888] mb-8 max-w-3xl">
            从佛道思想出发，可沿以下路径深入探索修行文明的各个面向。
          </p>
          <div class="space-y-4">
            <a
              href={`${basePath}/archive`}
              class="group block p-5 rounded-lg bg-[#c9a227]/[0.04] border border-[#c9a227]/20 hover:border-[#d4af37]/40 transition-all"
            >
              <h3 class="text-lg font-display text-[#d4af37] mb-1">末法档案</h3>
              <p class="text-sm text-[#888888]">探索末法纪的形成与修行文明衰退的进程 → 档案馆</p>
            </a>
            <a
              href={`${basePath}/medicine`}
              class="group block p-5 rounded-lg bg-[#2d8a8a]/[0.04] border border-[#2d8a8a]/20 hover:border-[#5ababa]/40 transition-all"
            >
              <h3 class="text-lg font-display text-[#5ababa] mb-1">身体修持</h3>
              <p class="text-sm text-[#888888]">从《黄帝内经》探索身体与能量的奥秘 → 典籍</p>
            </a>
            <a
              href={`${basePath}/realms`}
              class="group block p-5 rounded-lg bg-[#8a4a2d]/[0.04] border border-[#8a4a2d]/20 hover:border-[#ba7a5a]/40 transition-all"
            >
              <h3 class="text-lg font-display text-[#ba7a5a] mb-1">境界体系</h3>
              <p class="text-sm text-[#888888]">从仙侠小说看失落文明的文学再造 → 境界</p>
            </a>
          </div>
        </section>
      </ScrollReveal>

      <footer class="py-12 text-center">
        <div class="max-w-[200px] mx-auto mb-8 h-[1px] bg-gradient-to-r from-transparent via-[#6b9ad4]/30 to-transparent"></div>
        <p class="text-[#666666] text-sm">
          佛道思想 · 灵墟 · 末法时代修行文明档案馆
        </p>
        <p class="text-[#555555] text-xs mt-2">
          诸行无常，是生灭法
        </p>
      </footer>
    </div>
  </article>
</PageLayout>