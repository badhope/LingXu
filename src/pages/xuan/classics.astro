---
import ModuleLayout from '../../layouts/ModuleLayout.astro';

const classics = [
  {
    name: '周易',
    alias: '易经',
    dynasty: '商周',
    author: '周文王姬昌',
    category: '群经之首',
    chapters: '上经三十卦，下经三十卦',
    description: '《易经》为群经之首，大道之源。以阴阳爻变化演述天地万物之理，是中华文明的源头活水。',
    keyConcepts: ['阴阳', '八卦', '六十四卦', '易象', '易理'],
    quote: '天行健，君子以自强不息；地势坤，君子以厚德载物。'
  },
  {
    name: '道德经',
    alias: '老子',
    dynasty: '春秋',
    author: '李耳（老子）',
    category: '道家经典',
    chapters: '八十一章',
    description: '道家学派的开山之作，阐述"道法自然"的核心思想，主张无为而治，是东方智慧的结晶。',
    keyConcepts: ['道', '德', '自然', '无为', '柔弱胜刚强'],
    quote: '道可道，非常道；名可名，非常名。'
  },
  {
    name: '黄帝内经',
    alias: '内经',
    dynasty: '战国至汉',
    author: '托名黄帝',
    category: '医典',
    chapters: '素问八十一篇，灵枢八十一篇',
    description: '中医理论的奠基之作，建立以"阴阳五行"为核心的医学体系，阐述了精气神与养生的关系。',
    keyConcepts: ['阴阳', '五行', '经络', '脏腑', '养生'],
    quote: '上医治未病，中医治欲病，下医治已病。'
  },
  {
    name: '抱朴子',
    alias: '内篇·外篇',
    dynasty: '东晋',
    author: '葛洪',
    category: '仙道',
    chapters: '内篇二十卷，外篇五十卷',
    description: '道教神仙派的理论奠基之作，系统论述了神仙信仰、炼丹术、符箓法术等内容。',
    keyConcepts: ['神仙', '金丹', '符箓', '修炼', '阐教'],
    quote: '故治身养性，务谨其细，不可以小益为不平而不修，不可以小损为无伤而不防。'
  },
];

const daoistTexts = [
  { name: '太平经', period: '东汉', importance: '道教早期经典' },
  { name: '度人经', period: '东晋', importance: '道教重要经典' },
  { name: '阴符经', period: '战国', importance: '道家秘典' },
  { name: '南华经', period: '战国', importance: '即《庄子》' },
  { name: '冲虚经', period: '战国', importance: '即《列子》' },
  { name: '通玄经', period: '战国', importance: '即《文子》' },
];

const confucianTexts = [
  { name: '易传', period: '战国', importance: '易经注释' },
  { name: '礼记', period: '汉代', importance: '儒家礼学' },
  { name: '尚书', period: '先秦', importance: '上古历史' },
  { name: '诗经', period: '先秦', importance: '诗歌总集' },
  { name: '春秋', period: '先秦', importance: '鲁国史记' },
];

const cultivationTexts = [
  { name: '参同契', author: '魏伯阳', period: '东汉', type: '炼丹' },
  { name: '抱朴子', author: '葛洪', period: '东晋', type: '仙道' },
  { name: '悟真篇', author: '张伯端', period: '宋代', type: '内丹' },
  { name: '太乙金华宗旨', author: '吕洞宾', period: '唐代', type: '内丹' },
  { name: '心印经', author: '太上老君', period: '不详', type: '心法' },
  { name: '青华秘文', author: '钟离权', period: '唐代', type: '内丹' },
];
---

<ModuleLayout moduleId="xuan" title="玄学典籍" description="经典文献阅读与解读">
  <div class="classics-page">
    <section class="intro-section">
      <h2>典籍概述</h2>
      <p>玄学典籍浩如烟海，是中华文明数千年智慧的结晶。从《周易》到《抱朴子》，这些典籍构建了东方独特的宇宙观、生命观和修行体系。</p>
    </section>

    <section class="main-classics">
      <h2>核心典籍</h2>
      <div class="classics-grid">
        {classics.map((classic) => (
          <div class="classic-card">
            <div class="classic-header">
              <div class="classic-title">
                <span class="classic-name">{classic.name}</span>
                <span class="classic-alias">（{classic.alias}）</span>
              </div>
              <span class="classic-category">{classic.category}</span>
            </div>
            <div class="classic-body">
              <div class="classic-meta">
                <div class="meta-item">
                  <span class="meta-label">时代</span>
                  <span class="meta-value">{classic.dynasty}</span>
                </div>
                <div class="meta-item">
                  <span class="meta-label">作者</span>
                  <span class="meta-value">{classic.author}</span>
                </div>
                <div class="meta-item">
                  <span class="meta-label">结构</span>
                  <span class="meta-value">{classic.chapters}</span>
                </div>
              </div>
              <p class="classic-desc">{classic.description}</p>
              <div class="classic-concepts">
                {classic.keyConcepts.map((concept) => (
                  <span class="concept-tag">{concept}</span>
                ))}
              </div>
              <blockquote class="classic-quote">
                <p>"{classic.quote}"</p>
              </blockquote>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="texts-categories">
      <h2>典籍分类</h2>
      <div class="category-tabs">
        <div class="category-panel">
          <h3>道家经典</h3>
          <div class="texts-list">
            {daoistTexts.map((text) => (
              <div class="text-item">
                <span class="text-name">{text.name}</span>
                <span class="text-period">{text.period}</span>
                <span class="text-importance">{text.importance}</span>
              </div>
            ))}
          </div>
        </div>

        <div class="category-panel">
          <h3>儒家经典</h3>
          <div class="texts-list">
            {confucianTexts.map((text) => (
              <div class="text-item">
                <span class="text-name">{text.name}</span>
                <span class="text-period">{text.period}</span>
                <span class="text-importance">{text.importance}</span>
              </div>
            ))}
          </div>
        </div>

        <div class="category-panel">
          <h3>修炼典籍</h3>
          <div class="texts-list cultivation">
            {cultivationTexts.map((text) => (
              <div class="text-item">
                <span class="text-name">{text.name}</span>
                <span class="text-author">{text.author}</span>
                <span class="text-type">{text.type}</span>
                <span class="text-period">{text.period}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="reading-guide">
      <h2>阅读指南</h2>
      <div class="guide-grid">
        <div class="guide-item">
          <span class="guide-icon">📖</span>
          <div class="guide-content">
            <h3>入门推荐</h3>
            <p>初学者宜从《周易》及《道德经》入手，理解阴阳五行基础概念后再涉猎其他典籍。</p>
          </div>
        </div>
        <div class="guide-item">
          <span class="guide-icon">🔍</span>
          <div class="guide-content">
            <h3>版本选择</h3>
            <p>古籍版本众多，建议选择中华书局、上海古籍等权威出版社的整理本，有注释更佳。</p>
          </div>
        </div>
        <div class="guide-item">
          <span class="guide-icon">💡</span>
          <div class="guide-content">
            <h3>学习方法</h3>
            <p>玄学典籍需反复研读，结合实践体悟。切忌断章取义，需整体把握文意。</p>
          </div>
        </div>
        <div class="guide-item">
          <span class="guide-icon">⚠️</span>
          <div class="guide-content">
            <h3>注意事项</h3>
            <p>典籍中多有隐语术语，需有师承或可靠注释指引。切忌盲修瞎练，以免走火入魔。</p>
          </div>
        </div>
      </div>
    </section>
  </div>

  <style>
    .classics-page { max-width: 1000px; margin: 0 auto; }

    .intro-section, .main-classics, .texts-categories, .reading-guide {
      background: rgba(128, 64, 240, 0.05);
      border: 1px solid rgba(128, 64, 240, 0.2);
      border-radius: 8px;
      padding: 1.5rem;
      margin-bottom: 2rem;
    }

    h2 {
      color: #a78bfa;
      font-size: 1.25rem;
      margin-bottom: 1rem;
      border-bottom: 1px solid rgba(128, 64, 240, 0.2);
      padding-bottom: 0.5rem;
    }

    .intro-section p { color: #aaa; line-height: 1.7; }

    .classics-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }

    .classic-card {
      background: rgba(0, 0, 0, 0.3);
      border-radius: 8px;
      overflow: hidden;
    }

    .classic-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1rem 1.25rem;
      background: rgba(128, 64, 240, 0.15);
    }

    .classic-title { display: flex; align-items: baseline; gap: 0.5rem; }
    .classic-name { color: #c4b5fd; font-size: 1.1rem; font-weight: 600; }
    .classic-alias { color: #888; font-size: 0.85rem; }
    .classic-category { font-size: 0.7rem; padding: 0.2rem 0.5rem; background: rgba(128, 64, 240, 0.2); color: #a78bfa; border-radius: 4px; }

    .classic-body { padding: 1.25rem; }

    .classic-meta {
      display: flex;
      gap: 1.5rem;
      margin-bottom: 1rem;
      padding-bottom: 1rem;
      border-bottom: 1px solid rgba(128, 64, 240, 0.1);
    }

    .meta-item { display: flex; flex-direction: column; gap: 0.25rem; }
    .meta-label { color: #888; font-size: 0.7rem; }
    .meta-value { color: #c4b5fd; font-size: 0.85rem; }

    .classic-desc { color: #aaa; font-size: 0.9rem; line-height: 1.6; margin-bottom: 1rem; }

    .classic-concepts { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1rem; }

    .concept-tag {
      font-size: 0.7rem;
      padding: 0.2rem 0.5rem;
      background: rgba(128, 64, 240, 0.15);
      border: 1px solid rgba(128, 64, 240, 0.2);
      border-radius: 4px;
      color: #a78bfa;
    }

    .classic-quote {
      background: rgba(0, 0, 0, 0.2);
      padding: 0.75rem 1rem;
      border-left: 3px solid rgba(128, 64, 240, 0.5);
      margin: 0;
    }

    .classic-quote p { color: #888; font-size: 0.85rem; font-style: italic; margin: 0; }

    .category-tabs {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .category-panel h3 {
      color: #a78bfa;
      font-size: 1rem;
      margin-bottom: 1rem;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid rgba(128, 64, 240, 0.15);
    }

    .texts-list {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0.75rem;
    }

    .texts-list.cultivation {
      grid-template-columns: repeat(3, 1fr);
    }

    .text-item {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.75rem 1rem;
      background: rgba(0, 0, 0, 0.2);
      border-radius: 6px;
    }

    .text-name { color: #c4b5fd; font-size: 0.9rem; flex: 1; }
    .text-period { color: #888; font-size: 0.75rem; }
    .text-importance { color: #666; font-size: 0.75rem; }
    .text-author { color: #a78bfa; font-size: 0.75rem; }
    .text-type { font-size: 0.65rem; padding: 0.1rem 0.4rem; background: rgba(128, 64, 240, 0.15); color: #a78bfa; border-radius: 3px; }

    .guide-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }

    .guide-item {
      display: flex;
      gap: 1rem;
      padding: 1.25rem;
      background: rgba(0, 0, 0, 0.3);
      border-radius: 8px;
    }

    .guide-icon { font-size: 1.5rem; flex-shrink: 0; }
    .guide-content h3 { color: #c4b5fd; font-size: 0.95rem; margin-bottom: 0.5rem; }
    .guide-content p { color: #888; font-size: 0.85rem; line-height: 1.5; margin: 0; }

    @media (max-width: 768px) {
      .classics-grid, .guide-grid { grid-template-columns: 1fr; }
      .texts-list, .texts-list.cultivation { grid-template-columns: 1fr; }
    }
  </style>
</ModuleLayout>