---
import ModuleLayout from '../../layouts/ModuleLayout.astro';
import FlipCard from '../../components/ui/FlipCard.astro';

const talismanTypes = [
  { name: '平安符', type: '护身', effect: '驱邪避凶', usage: '随身携带或挂于门上', rarity: '常见', detail: '平安符是最常见的护身符咒，可驱散邪气，保护人身安全。古人出行前常请一道平安符以求顺利。' },
  { name: '镇宅符', type: '镇宅', effect: '安定家宅', usage: '贴于大门或客厅', rarity: '常见', detail: '镇宅符用于保护家居安宁，驱除宅中邪祟，使家宅平安，人丁兴旺。' },
  { name: '招财符', type: '财运', effect: '招财进宝', usage: '放置于财位', rarity: '常见', detail: '招财符可增强财运，促进财富流入，适合经商之人或希望改善财务状况者。' },
  { name: '文昌符', type: '学业', effect: '增长智慧', usage: '放置于书房', rarity: '常见', detail: '文昌符助于学业进步，考试顺利，适合学生及学术研究者使用。' },
  { name: '姻缘符', type: '感情', effect: '增进姻缘', usage: '放置于桃花位', rarity: '中等', detail: '姻缘符可增强人际关系，促进姻缘早日到来，适合单身者寻求伴侣。' },
  { name: '健康符', type: '健康', effect: '驱除病气', usage: '随身携带', rarity: '中等', detail: '健康符有助于祛病强身，加速康复，可作为辅助保健之用。' },
];

const talismanSymbols = [
  { symbol: '☰', name: '乾', meaning: '天，代表阳刚之力', usage: '事业符、护身符' },
  { symbol: '☱', name: '兑', meaning: '泽，代表喜悦之气', usage: '姻缘符、人缘符' },
  { symbol: '☲', name: '离', meaning: '火，代表光明智慧', usage: '文昌符、智慧符' },
  { symbol: '☳', name: '震', meaning: '雷，代表震动之力', usage: '驱邪符、镇宅符' },
  { symbol: '☴', name: '巽', meaning: '风，代表流动之气', usage: '财运符、流通符' },
  { symbol: '☵', name: '坎', meaning: '水，代表深沉之力', usage: '健康符、平安符' },
  { symbol: '☶', name: '艮', meaning: '山，代表稳定之力', usage: '镇宅符、稳固符' },
  { symbol: '☷', name: '坤', meaning: '地，代表包容之德', usage: '护身符、和谐符' },
];

const identificationPoints = [
  { point: '纸质', desc: '正统符咒多用黄纸、朱砂，久经年代不会褪色' },
  { point: '墨迹', desc: '符咒墨迹有光泽，伪品多为普通墨水' },
  { point: '气味', desc: '古符有檀香或药草香气，年代越久越醇厚' },
  { point: '印章', desc: '正统符咒必有法师印章，位置端正清晰' },
  { point: '笔锋', desc: '真符一气呵成，笔锋有力，伪品常有描摹痕迹' },
];

const cautionaryNotes = [
  '符咒需请专业人士书写，不可随意使用',
  '不同符咒有不同禁忌，需遵行法师嘱咐',
  '符咒不可让外人触碰，否则效力减弱',
  '女性经期或身体不适时，不宜接触符咒',
  '符咒需定期供养或更换，不可一劳永逸',
];
---

<ModuleLayout moduleId="xuan" title="符箓识别" description="符箓识别，真伪鉴别，使用禁忌">
  <div class="talismans-page">
    <section class="intro-section">
      <h2>符箓概述</h2>
      <p>符箓者，天地之信也。古之修仙者，以符咒沟通天地，调遣神灵，驱邪治病。符为笔画，箓为名册，合而用之，可召神劾鬼，镇邪祈福。</p>
    </section>

    <section class="talisman-types">
      <h2>常见符咒类型</h2>
      <p class="section-hint">点击卡片查看详细信息</p>
      <div class="types-grid">
        {talismanTypes.map((talisman, index) => (
          <FlipCard
            id={`talisman-${index}`}
            title={talisman.name}
            description={`功效：${talisman.effect}`}
            icon={talisman.type === '护身' ? '🛡️' : talisman.type === '镇宅' ? '🏠' : talisman.type === '财运' ? '💰' : talisman.type === '学业' ? '📚' : talisman.type === '感情' ? '💕' : '💊'}
            backTitle={`${talisman.name}详解`}
            backDescription={talisman.detail}
            backIcon="📜"
            type="click"
            color="amethyst"
            class="flip-card-item"
          />
        ))}
      </div>
    </section>

    <section class="trigram-meanings">
      <h2>八卦符号含义</h2>
      <div class="symbols-grid">
        {talismanSymbols.map((sym) => (
          <div class="symbol-card">
            <span class="symbol-char">{sym.symbol}</span>
            <div class="symbol-info">
              <h3>{sym.name}</h3>
              <p class="symbol-meaning">{sym.meaning}</p>
              <p class="symbol-usage"><strong>常用于：</strong>{sym.usage}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="identification">
      <h2>符咒真伪鉴别</h2>
      <div class="id-grid">
        {identificationPoints.map((item) => (
          <div class="id-card">
            <span class="id-icon">✓</span>
            <div class="id-content">
              <h3>{item.point}</h3>
              <p>{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="caution-section">
      <h2>使用禁忌</h2>
      <div class="caution-list">
        {cautionaryNotes.map((note, i) => (
          <div class="caution-item">
            <span class="caution-num">{i + 1}</span>
            <p>{note}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="maintenance-section">
      <h2>符咒养护</h2>
      <div class="maintenance-grid">
        <div class="maintenance-card">
          <span class="maint-icon">🔆</span>
          <h3>避免潮湿</h3>
          <p>符咒应放置于干燥处，潮湿会导致墨迹晕染失效</p>
        </div>
        <div class="maintenance-card">
          <span class="maint-icon">🚫</span>
          <h3>忌沾污秽</h3>
          <p>不可让符咒沾染血液或污物，否则需重新请符</p>
        </div>
        <div class="maintenance-card">
          <span class="maint-icon">⏰</span>
          <h3>定期更换</h3>
          <p>一般符咒有效期为一年，需在期限届满前重新请符</p>
        </div>
        <div class="maintenance-card">
          <span class="maint-icon">🙏</span>
          <h3>诚心供养</h3>
          <p>每逢初一十五可上香供养，显示对神灵之敬重</p>
        </div>
      </div>
    </section>
  </div>

  <style>
    .talismans-page { max-width: 1000px; margin: 0 auto; }

    .intro-section, .talisman-types, .trigram-meanings, .identification, .caution-section, .maintenance-section {
      background: rgba(128, 64, 240, 0.05);
      border: 1px solid rgba(128, 64, 240, 0.2);
      border-radius: 8px;
      padding: 1.5rem;
      margin-bottom: 2rem;
    }

    h2 {
      color: #a78bfa;
      font-size: 1.25rem;
      margin-bottom: 1rem;
      border-bottom: 1px solid rgba(128, 64, 240, 0.2);
      padding-bottom: 0.5rem;
    }

    .section-hint {
      color: #888;
      font-size: 0.8rem;
      margin-bottom: 1rem;
      text-align: center;
      animation: fadeIn 0.5s ease-out;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(-5px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .intro-section p { color: #aaa; line-height: 1.7; }

    .types-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
    }

    .flip-card-item {
      height: 180px;
    }

    .talisman-card {
      background: rgba(0, 0, 0, 0.3);
      border-radius: 8px;
      overflow: hidden;
    }

    .talisman-card.常见 { border: 1px solid rgba(128, 64, 240, 0.2); }
    .talisman-card.中等 { border: 1px solid rgba(128, 64, 240, 0.4); }
    .talisman-card.稀有 { border: 1px solid rgba(192, 192, 192, 0.4); }

    .talisman-header {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 1rem;
      background: rgba(128, 64, 240, 0.15);
    }

    .talisman-icon { font-size: 1.5rem; }
    .talisman-name { color: #c4b5fd; font-weight: 600; font-size: 1rem; }

    .talisman-body { padding: 1rem; }

    .talisman-info {
      display: flex;
      justify-content: space-between;
      margin-bottom: 0.5rem;
      font-size: 0.85rem;
    }

    .info-label { color: #888; }
    .info-value { color: #ccc; }

    .rarity-badge {
      display: inline-block;
      padding: 0.2rem 0.5rem;
      border-radius: 4px;
      font-size: 0.7rem;
      margin-top: 0.5rem;
    }

    .rarity-badge.常见 { background: rgba(128, 64, 240, 0.2); color: #a78bfa; }
    .rarity-badge.中等 { background: rgba(192, 192, 192, 0.2); color: #c0c0c0; }
    .rarity-badge.稀有 { background: rgba(240, 192, 64, 0.2); color: #f0c040; }

    .symbols-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
    }

    .symbol-card {
      display: flex;
      gap: 1rem;
      padding: 1rem;
      background: rgba(0, 0, 0, 0.3);
      border-radius: 8px;
      transition: all 0.3s ease;
    }

    .symbol-card:hover {
      background: rgba(128, 64, 240, 0.1);
      transform: translateY(-2px);
    }

    .symbol-char {
      font-size: 2rem;
      color: #c4b5fd;
      font-weight: 700;
      line-height: 1;
    }

    .symbol-info h3 { color: #c4b5fd; font-size: 1rem; margin-bottom: 0.25rem; }
    .symbol-meaning { color: #888; font-size: 0.75rem; margin-bottom: 0.25rem; }
    .symbol-usage { color: #666; font-size: 0.7rem; }
    .symbol-usage strong { color: #a78bfa; }

    .id-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }

    .id-card {
      display: flex;
      gap: 1rem;
      padding: 1rem;
      background: rgba(0, 0, 0, 0.3);
      border-radius: 8px;
      transition: all 0.3s ease;
    }

    .id-card:hover {
      background: rgba(74, 222, 128, 0.05);
      transform: translateX(4px);
    }

    .id-icon {
      width: 2rem;
      height: 2rem;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(74, 222, 128, 0.2);
      color: #4ade80;
      border-radius: 50%;
      font-size: 0.875rem;
      flex-shrink: 0;
    }

    .id-content h3 { color: #c4b5fd; font-size: 0.95rem; margin-bottom: 0.25rem; }
    .id-content p { color: #888; font-size: 0.8rem; line-height: 1.5; }

    .caution-list { display: flex; flex-direction: column; gap: 0.75rem; }

    .caution-item {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
      padding: 1rem;
      background: rgba(0, 0, 0, 0.3);
      border-radius: 8px;
      transition: all 0.3s ease;
    }

    .caution-item:hover {
      background: rgba(248, 113, 113, 0.05);
      transform: translateX(4px);
    }

    .caution-num {
      width: 1.75rem;
      height: 1.75rem;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(248, 113, 113, 0.2);
      color: #f87171;
      border-radius: 50%;
      font-size: 0.8rem;
      font-weight: 600;
      flex-shrink: 0;
    }

    .caution-item p { color: #aaa; font-size: 0.9rem; line-height: 1.5; }

    .maintenance-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
    }

    .maintenance-card {
      text-align: center;
      padding: 1.5rem 1rem;
      background: rgba(0, 0, 0, 0.3);
      border-radius: 8px;
      transition: all 0.4s ease;
    }

    .maintenance-card:hover {
      background: rgba(128, 64, 240, 0.1);
      transform: translateY(-4px);
    }

    .maint-icon { font-size: 2rem; display: block; margin-bottom: 0.75rem; animation: iconBreathe 3s ease-in-out infinite; }

    @keyframes iconBreathe {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.05); }
    }

    .maintenance-card:hover .maint-icon {
      animation: iconPulse 1s ease-in-out infinite;
    }

    @keyframes iconPulse {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.15); }
    }

    .maintenance-card h3 { color: #c4b5fd; font-size: 0.95rem; margin-bottom: 0.5rem; }
    .maintenance-card p { color: #888; font-size: 0.8rem; line-height: 1.5; }

    @media (max-width: 768px) {
      .types-grid { grid-template-columns: repeat(2, 1fr); }
      .symbols-grid { grid-template-columns: repeat(2, 1fr); }
      .id-grid, .maintenance-grid { grid-template-columns: 1fr; }
      .flip-card-item { height: 160px; }
    }
  </style>
</ModuleLayout>