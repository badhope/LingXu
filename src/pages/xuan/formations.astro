---
import ModuleLayout from '../../layouts/ModuleLayout.astro';

const basicFormations = [
  { name: '八卦阵', type: '防御', difficulty: '中', elements: ['乾', '兑', '离', '震', '巽', '坎', '艮', '坤'], effect: '以八卦之力构建防护屏障，可抵挡外敌入侵' },
  { name: '五行阵', type: '相生相克', difficulty: '高', elements: ['金', '木', '水', '火', '土'], effect: '利用五行相生相克之理，增强或削弱特定属性' },
  { name: '三才阵', type: '辅助', difficulty: '低', elements: ['天', '地', '人'], effect: '天地人三才合一，提升阵法内所有成员修为' },
  { name: '七星阵', type: '聚灵', difficulty: '高', elements: ['天枢', '天璇', '天玑', '天权', '玉衡', '开阳', '摇光'], effect: '借北斗七星之力，汇聚天地灵气' },
];

const advancedFormations = [
  { name: '十方俱灭阵', type: '攻击', difficulty: '极难', range: '十丈方圆', consumption: '大量灵气', desc: '十方俱灭，天地失色。此阵一旦布下，方圆十丈内一切生灵尽皆湮灭。需十名金丹期以上修士合力方可施展。' },
  { name: '混元一气阵', type: '防御', difficulty: '极难', range: '三丈方圆', consumption: '中等灵气', desc: '混元如一，固若金汤。此阵以自身灵气为引，形成绝对防御屏障，可抵挡化神期以下任何攻击。' },
  { name: '两仪微尘阵', type: '困锁', difficulty: '极高', range: '一丈方圆', consumption: '少量灵气', desc: '两仪化微尘，天地尽尘埃。此阵内自成一界，入阵者将迷失于微尘世界，不知所踪。' },
  { name: '周天星斗大阵', type: '召唤', difficulty: '传说', range: '百里方圆', consumption: '海量灵气', desc: '以天为棋，星辰为子。此阵需365名修士对应365颗周天星斗，布成后可召唤星辰之力，毁天灭地。' },
];

const formationMaterials = [
  { name: '阵旗', desc: '最常见的布阵器具，分五色对应五行', icon: '🚩' },
  { name: '灵石', desc: '布阵的能量来源，也可作为阵眼', icon: '💎' },
  { name: '符箓', desc: '配合符咒可增强阵法威力', icon: '📜' },
  { name: '法器', desc: '如铜钱、铜铃等，可作为阵眼', icon: '🔔' },
  { name: '自然之物', desc: '山河草木皆可布阵，因地制宜', icon: '🌿' },
];

const tips = [
  '布阵前需先勘察地形，选择灵气充沛之处',
  '阵眼选择至关重要，关系到阵法稳定性',
  '布阵时需全神贯注，不可有丝毫分心',
  '撤退时需按正确顺序收回阵眼，切忌胡乱收取',
  '恶劣天气可能影响阵法效果，雷雨天慎用',
];
---

<ModuleLayout moduleId="xuan" title="阵法布局" description="阵法图鉴与布置方法详解">
  <div class="formations-page">
    <section class="intro-section">
      <h2>阵法概述</h2>
      <p>阵者，天地之锁也。古之修士，以阵法沟通天地之力，布阵御敌，困锁妖魔。阵法分八卦、五行、星辰诸派，各有妙用。布阵需天时地利，更需精通五行八卦之理。</p>
    </section>

    <section class="basic-formations">
      <h2>基础阵法</h2>
      <div class="formations-grid">
        {basicFormations.map((formation) => (
          <div class="formation-card">
            <div class="formation-header">
              <span class="formation-icon">⚙️</span>
              <span class="formation-name">{formation.name}</span>
              <span class={`formation-type ${formation.type}`}>{formation.type}</span>
            </div>
            <div class="formation-body">
              <div class="formation-info">
                <span class="info-label">难度</span>
                <span class={`info-value ${formation.difficulty}`}>{formation.difficulty}</span>
              </div>
              <div class="formation-elements">
                <span class="info-label">构成</span>
                <div class="elements-list">
                  {formation.elements.map((el) => (
                    <span class="element-tag">{el}</span>
                  ))}
                </div>
              </div>
              <p class="formation-effect">{formation.effect}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="advanced-formations">
      <h2>高阶阵法</h2>
      <div class="advanced-grid">
        {advancedFormations.map((formation) => (
          <div class="advanced-card">
            <div class="advanced-header">
              <span class="advanced-name">{formation.name}</span>
              <span class={`advanced-type ${formation.type}`}>{formation.type}</span>
            </div>
            <div class="advanced-body">
              <div class="advanced-stats">
                <div class="stat">
                  <span class="stat-label">难度</span>
                  <span class={`stat-value ${formation.difficulty}`}>{formation.difficulty}</span>
                </div>
                <div class="stat">
                  <span class="stat-label">范围</span>
                  <span class="stat-value">{formation.range}</span>
                </div>
                <div class="stat">
                  <span class="stat-label">消耗</span>
                  <span class="stat-value">{formation.consumption}</span>
                </div>
              </div>
              <p class="advanced-desc">{formation.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="materials-section">
      <h2>布阵器具</h2>
      <div class="materials-grid">
        {formationMaterials.map((material) => (
          <div class="material-card">
            <span class="material-icon">{material.icon}</span>
            <div class="material-info">
              <h3>{material.name}</h3>
              <p>{material.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="layout-diagram">
      <h2>八卦阵布局图</h2>
      <div class="diagram-container">
        <div class="bagua-layout">
          <div class="bagua-cell north" data-gua="坎">坎</div>
          <div class="bagua-cell northeast" data-gua="艮">艮</div>
          <div class="bagua-cell east" data-gua="震">震</div>
          <div class="bagua-cell southeast" data-gua="巽">巽</div>
          <div class="bagua-cell south" data-gua="离">离</div>
          <div class="bagua-cell southwest" data-gua="坤">坤</div>
          <div class="bagua-cell west" data-gua="兑">兑</div>
          <div class="bagua-cell northwest" data-gua="乾">乾</div>
          <div class="bagua-center">
            <span>阵眼</span>
            <span>中央</span>
          </div>
        </div>
        <div class="diagram-note">
          <p>八卦阵以中央为阵眼，八方各立一旗，形成八门金锁阵。入阵者若不通八卦易理，必困于阵中。</p>
        </div>
      </div>
    </section>

    <section class="tips-section">
      <h2>布阵要诀</h2>
      <div class="tips-grid">
        {tips.map((tip, i) => (
          <div class="tip-item">
            <span class="tip-num">{i + 1}</span>
            <p>{tip}</p>
          </div>
        ))}
      </div>
    </section>
  </div>

  <style>
    .formations-page { max-width: 1000px; margin: 0 auto; }

    .intro-section, .basic-formations, .advanced-formations, .materials-section, .layout-diagram, .tips-section {
      background: rgba(128, 64, 240, 0.05);
      border: 1px solid rgba(128, 64, 240, 0.2);
      border-radius: 8px;
      padding: 1.5rem;
      margin-bottom: 2rem;
    }

    h2 {
      color: #a78bfa;
      font-size: 1.25rem;
      margin-bottom: 1rem;
      border-bottom: 1px solid rgba(128, 64, 240, 0.2);
      padding-bottom: 0.5rem;
    }

    .intro-section p { color: #aaa; line-height: 1.7; }

    .formations-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }

    .formation-card {
      background: rgba(0, 0, 0, 0.3);
      border-radius: 8px;
      overflow: hidden;
    }

    .formation-header {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 1rem;
      background: rgba(128, 64, 240, 0.15);
    }

    .formation-icon { font-size: 1.25rem; }
    .formation-name { color: #c4b5fd; font-weight: 600; flex: 1; }

    .formation-type {
      font-size: 0.7rem;
      padding: 0.2rem 0.5rem;
      border-radius: 4px;
    }

    .formation-type.防御 { background: rgba(96, 165, 250, 0.2); color: #60a5fa; }
    .formation-type.相生相克 { background: rgba(192, 192, 192, 0.2); color: #c0c0c0; }
    .formation-type.辅助 { background: rgba(74, 222, 128, 0.2); color: #4ade80; }
    .formation-type.聚灵 { background: rgba(240, 192, 64, 0.2); color: #f0c040; }

    .formation-body { padding: 1rem; }

    .formation-info {
      display: flex;
      gap: 1rem;
      margin-bottom: 0.75rem;
      font-size: 0.85rem;
    }

    .info-label { color: #888; }
    .info-value { font-weight: 600; }
    .info-value.低 { color: #4ade80; }
    .info-value.中 { color: #fbbf24; }
    .info-value.高 { color: #f87171; }
    .info-value.极难, .info-value.极高, .info-value.传说 { color: #c4b5fd; }

    .formation-elements { margin-bottom: 0.75rem; }
    .elements-list { display: flex; flex-wrap: wrap; gap: 0.25rem; margin-top: 0.25rem; }

    .element-tag {
      font-size: 0.65rem;
      padding: 0.15rem 0.4rem;
      background: rgba(128, 64, 240, 0.15);
      border-radius: 3px;
      color: #a78bfa;
    }

    .formation-effect { color: #888; font-size: 0.8rem; line-height: 1.5; }

    .advanced-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }

    .advanced-card {
      background: rgba(0, 0, 0, 0.4);
      border: 1px solid rgba(128, 64, 240, 0.3);
      border-radius: 8px;
      overflow: hidden;
    }

    .advanced-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1rem;
      background: rgba(128, 64, 240, 0.2);
    }

    .advanced-name { color: #c4b5fd; font-weight: 600; font-size: 1rem; }

    .advanced-type {
      font-size: 0.7rem;
      padding: 0.2rem 0.5rem;
      border-radius: 4px;
    }

    .advanced-type.攻击 { background: rgba(248, 113, 113, 0.2); color: #f87171; }
    .advanced-type.防御 { background: rgba(96, 165, 250, 0.2); color: #60a5fa; }
    .advanced-type.困锁 { background: rgba(192, 192, 192, 0.2); color: #c0c0c0; }
    .advanced-type.召唤 { background: rgba(240, 192, 64, 0.2); color: #f0c040; }

    .advanced-body { padding: 1rem; }

    .advanced-stats {
      display: flex;
      gap: 1rem;
      margin-bottom: 1rem;
    }

    .stat { display: flex; flex-direction: column; gap: 0.25rem; }
    .stat-label { color: #888; font-size: 0.7rem; }
    .stat-value { color: #c4b5fd; font-size: 0.85rem; font-weight: 600; }

    .advanced-desc { color: #aaa; font-size: 0.85rem; line-height: 1.6; font-style: italic; }

    .materials-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 1rem;
    }

    .material-card {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 1.5rem 1rem;
      background: rgba(0, 0, 0, 0.3);
      border-radius: 8px;
    }

    .material-icon { font-size: 2rem; margin-bottom: 0.75rem; }
    .material-info h3 { color: #c4b5fd; font-size: 0.95rem; margin-bottom: 0.5rem; }
    .material-info p { color: #888; font-size: 0.75rem; line-height: 1.4; }

    .diagram-container { text-align: center; }

    .bagua-layout {
      display: grid;
      grid-template-areas:
        ". north ."
        "west center east"
        ". south .";
      grid-template-columns: repeat(3, 1fr);
      grid-template-rows: repeat(3, 80px);
      gap: 4px;
      max-width: 300px;
      margin: 0 auto 1.5rem;
    }

    .bagua-cell {
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(128, 64, 240, 0.2);
      border-radius: 8px;
      font-size: 1.25rem;
      color: #c4b5fd;
      font-weight: 600;
    }

    .bagua-cell.north { grid-area: north; }
    .bagua-cell.east { grid-area: east; }
    .bagua-cell.south { grid-area: south; }
    .bagua-cell.west { grid-area: west; }

    .bagua-cell.northeast { background: rgba(128, 64, 240, 0.1); }
    .bagua-cell.southeast { background: rgba(128, 64, 240, 0.1); }
    .bagua-cell.northwest { background: rgba(128, 64, 240, 0.1); }
    .bagua-cell.southwest { background: rgba(128, 64, 240, 0.1); }

    .bagua-center {
      grid-area: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      background: rgba(128, 64, 240, 0.3);
      border-radius: 50%;
      border: 2px solid rgba(128, 64, 240, 0.5);
    }

    .bagua-center span { color: #a78bfa; font-size: 0.8rem; }
    .bagua-center span:first-child { font-size: 0.9rem; font-weight: 600; }

    .diagram-note {
      background: rgba(0, 0, 0, 0.3);
      padding: 1rem;
      border-radius: 6px;
      max-width: 500px;
      margin: 0 auto;
    }

    .diagram-note p { color: #888; font-size: 0.85rem; line-height: 1.6; }

    .tips-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }

    .tip-item {
      display: flex;
      gap: 1rem;
      padding: 1rem;
      background: rgba(0, 0, 0, 0.3);
      border-radius: 8px;
    }

    .tip-num {
      width: 1.75rem;
      height: 1.75rem;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(128, 64, 240, 0.2);
      color: #a78bfa;
      border-radius: 50%;
      font-size: 0.8rem;
      font-weight: 600;
      flex-shrink: 0;
    }

    .tip-item p { color: #aaa; font-size: 0.9rem; line-height: 1.5; }

    @media (max-width: 768px) {
      .formations-grid, .advanced-grid, .tips-grid { grid-template-columns: 1fr; }
      .materials-grid { grid-template-columns: repeat(2, 1fr); }
    }
  </style>
</ModuleLayout>