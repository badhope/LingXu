---
/**
 * 灵墟 - 增强型头部导航
 * Enhanced Header Navigation
 * 
 * 带有动态效果和高级交互动画的头部导航栏
 */

import { MODULES } from '@data/modules';
import { withBase } from '@lib/utils';

export interface Props {
  currentPath?: string;
  showSearch?: boolean;
  showUser?: boolean;
}

const { 
  currentPath = '/', 
  showSearch = true, 
  showUser = true 
} = Astro.props;

// 简化路径获取模块ID
function getModuleId(path: string): string | null {
  if (path === '/home') return 'home';
  const match = path.match(/\/([^\/]+)/);
  return match ? match[1] : null;
}

const currentModule = getModuleId(currentPath);
---

<header class="enhanced-header" id="main-header" data-module={currentModule}>
  <!-- 背景模糊层 -->
  <div class="header-bg"></div>
  
  <!-- 顶部渐变线 -->
  <div class="header-line"></div>
  
  <div class="header-container">
    <!-- Logo 区域 -->
    <a href={withBase('/home')} class="logo-wrapper" aria-label="返回首页">
      <div class="logo-symbol">
        <svg viewBox="0 0 60 60" class="logo-svg">
          <defs>
            <radialGradient id="logoGlow" cx="50%" cy="50%" r="50%">
              <stop offset="0%" stop-color="#d4af37" stop-opacity="0.4"/>
              <stop offset="100%" stop-color="#d4af37" stop-opacity="0"/>
            </radialGradient>
          </defs>
          <circle cx="30" cy="30" r="28" fill="url(#logoGlow)"/>
          <circle cx="30" cy="30" r="20" fill="none" stroke="#c9a227" stroke-width="0.5" stroke-dasharray="2 4"/>
          <text x="30" y="38" text-anchor="middle" fill="#e8d48b" font-size="20" font-family="serif">灵</text>
        </svg>
      </div>
      <span class="logo-text">灵墟</span>
    </a>

    <!-- 主导航 -->
    <nav class="main-nav" aria-label="主导航">
      <ul class="nav-list">
        {MODULES.map((module, index) => (
          <li class="nav-item" style={`--index: ${index}`}>
            <a 
              href={module.href}
              class={`nav-link ${currentModule === module.id ? 'active' : ''}`}
              data-module-id={module.id}
              style={`--module-color: ${module.color}`}
            >
              <span class="nav-char">{module.char}</span>
              <span class="nav-name">{module.name}</span>
              <span class="nav-indicator"></span>
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- 工具按钮 -->
    <div class="header-tools">
      {showSearch && (
        <a href={withBase('/search')} class="tool-btn search-btn" aria-label="搜索">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"/>
            <path d="m21 21-4.35-4.35"/>
          </svg>
        </a>
      )}
      
      <a href={withBase('/bookmarks')} class="tool-btn bookmark-btn" aria-label="收藏">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="m19 21-7-4-7 4V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16z"/>
        </svg>
      </a>
      
      {showUser && (
        <a href={withBase('/profile')} class="tool-btn user-btn" aria-label="个人中心">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="8" r="5"/>
            <path d="M20 21a8 8 0 0 0-16 0"/>
          </svg>
        </a>
      )}

      <!-- 移动端菜单按钮 -->
      <button class="mobile-menu-btn" id="mobile-menu-btn" aria-label="菜单">
        <span class="menu-line"></span>
        <span class="menu-line"></span>
        <span class="menu-line"></span>
      </button>
    </div>
  </div>

  <!-- 移动端菜单 -->
  <div class="mobile-menu" id="mobile-menu">
    <div class="mobile-menu-bg"></div>
    <nav class="mobile-nav">
      <ul class="mobile-nav-list">
        {MODULES.map((module) => (
          <li>
            <a 
              href={module.href}
              class={`mobile-nav-link ${currentModule === module.id ? 'active' : ''}`}
              style={`--module-color: ${module.color}`}
            >
              <span class="mobile-nav-char">{module.char}</span>
              <span class="mobile-nav-name">{module.name}</span>
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .enhanced-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    height: 70px;
    will-change: transform;
    transition: transform 0.3s ease, background 0.3s ease;
  }

  .header-bg {
    position: absolute;
    inset: 0;
    background: rgba(5, 5, 8, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(201, 162, 39, 0.1);
  }

  .header-line {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(201, 162, 39, 0.3) 20%,
      rgba(201, 162, 39, 0.5) 50%,
      rgba(201, 162, 39, 0.3) 80%,
      transparent 100%
    );
  }

  .header-container {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Logo */
  .logo-wrapper {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    color: #e8d48b;
    transition: all 0.3s ease;
  }

  .logo-wrapper:hover {
    color: #f0d78c;
  }

  .logo-wrapper:hover .logo-symbol {
    transform: scale(1.1) rotate(5deg);
  }

  .logo-symbol {
    width: 42px;
    height: 42px;
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .logo-svg {
    width: 100%;
    height: 100%;
  }

  .logo-text {
    font-size: 1.25rem;
    font-weight: 400;
    letter-spacing: 0.2em;
  }

  /* 主导航 */
  .main-nav {
    display: flex;
    align-items: center;
  }

  .nav-list {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-item {
    animation: navItemEnter 0.5s ease backwards;
    animation-delay: calc(var(--index) * 0.05s);
  }

  @keyframes navItemEnter {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .nav-link {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0.5rem 0.75rem;
    text-decoration: none;
    color: #888;
    transition: color 0.3s ease;
    overflow: hidden;
  }

  .nav-link:hover {
    color: var(--module-color);
  }

  .nav-link.active {
    color: var(--module-color);
  }

  .nav-char {
    font-size: 1.1rem;
    line-height: 1;
    transition: transform 0.3s ease, text-shadow 0.3s ease;
  }

  .nav-link:hover .nav-char,
  .nav-link.active .nav-char {
    transform: translateY(-2px);
    text-shadow: 0 0 15px var(--module-color);
  }

  .nav-name {
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    margin-top: 0.25rem;
    opacity: 0.7;
    transition: opacity 0.3s ease;
  }

  .nav-link:hover .nav-name,
  .nav-link.active .nav-name {
    opacity: 1;
  }

  .nav-indicator {
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 0;
    height: 2px;
    background: var(--module-color);
    transform: translateX(-50%);
    transition: width 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    box-shadow: 0 0 10px var(--module-color);
  }

  .nav-link:hover .nav-indicator,
  .nav-link.active .nav-indicator {
    width: 80%;
  }

  /* 工具按钮 */
  .header-tools {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .tool-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(201, 162, 39, 0.15);
    border-radius: 8px;
    color: #888;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .tool-btn:hover {
    background: rgba(201, 162, 39, 0.1);
    border-color: rgba(201, 162, 39, 0.4);
    color: #c9a227;
    transform: translateY(-2px);
  }

  .tool-btn:active {
    transform: translateY(0) scale(0.95);
  }

  .tool-btn svg {
    width: 18px;
    height: 18px;
  }

  /* 移动端菜单按钮 */
  .mobile-menu-btn {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
  }

  .menu-line {
    display: block;
    width: 20px;
    height: 2px;
    background: #888;
    border-radius: 1px;
    transition: all 0.3s ease;
  }

  .mobile-menu-btn:hover .menu-line {
    background: #c9a227;
  }

  /* 移动端菜单 */
  .mobile-menu {
    display: none;
    position: fixed;
    inset: 0;
    top: 70px;
    z-index: 999;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }

  .mobile-menu.open {
    opacity: 1;
    visibility: visible;
  }

  .mobile-menu-bg {
    position: absolute;
    inset: 0;
    background: rgba(5, 5, 8, 0.95);
    backdrop-filter: blur(20px);
  }

  .mobile-nav {
    position: relative;
    padding: 2rem;
    max-height: calc(100vh - 70px);
    overflow-y: auto;
  }

  .mobile-nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .mobile-nav-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 1.5rem 1rem;
    background: rgba(10, 10, 15, 0.8);
    border: 1px solid rgba(201, 162, 39, 0.1);
    border-radius: 12px;
    text-decoration: none;
    color: #888;
    transition: all 0.3s ease;
  }

  .mobile-nav-link:hover,
  .mobile-nav-link.active {
    background: rgba(201, 162, 39, 0.1);
    border-color: var(--module-color);
    color: var(--module-color);
  }

  .mobile-nav-char {
    font-size: 2rem;
  }

  .mobile-nav-name {
    font-size: 0.85rem;
    margin-top: 0.5rem;
  }

  /* 响应式 */
  @media (max-width: 1024px) {
    .main-nav {
      display: none;
    }

    .mobile-menu-btn {
      display: flex;
    }

    .mobile-menu {
      display: block;
    }
  }

  @media (max-width: 480px) {
    .header-container {
      padding: 0 1rem;
    }

    .logo-text {
      display: none;
    }

    .tool-btn {
      width: 36px;
      height: 36px;
    }
  }

  /* 滚动效果 */
  .enhanced-header.scrolled {
    transform: translateY(-10px);
  }

  .enhanced-header.scrolled .header-bg {
    background: rgba(5, 5, 8, 0.95);
  }

  /* 减少动画 */
  @media (prefers-reduced-motion: reduce) {
    .nav-item,
    .logo-wrapper,
    .logo-symbol,
    .tool-btn,
    .nav-char,
    .nav-indicator,
    .mobile-menu {
      animation: none;
      transition: none;
    }
  }
</style>

<script>
  class HeaderController {
    private header: HTMLElement | null;
    private mobileMenuBtn: HTMLElement | null;
    private mobileMenu: HTMLElement | null;
    private isMenuOpen: boolean = false;
    private lastScrollY: number = 0;

    constructor() {
      this.header = document.getElementById('main-header');
      this.mobileMenuBtn = document.getElementById('mobile-menu-btn');
      this.mobileMenu = document.getElementById('mobile-menu');
      this.init();
    }

    private init(): void {
      this.bindScroll();
      this.bindMobileMenu();
      this.initActiveState();
    }

    private bindScroll(): void {
      let ticking = false;

      window.addEventListener('scroll', () => {
        this.lastScrollY = window.scrollY;

        if (!ticking) {
          window.requestAnimationFrame(() => {
            this.updateOnScroll();
            ticking = false;
          });
          ticking = true;
        }
      }, { passive: true });
    }

    private updateOnScroll(): void {
      if (!this.header) return;

      const scrollY = this.lastScrollY;

      if (scrollY > 50) {
        this.header.classList.add('scrolled');
      } else {
        this.header.classList.remove('scrolled');
      }
    }

    private bindMobileMenu(): void {
      this.mobileMenuBtn?.addEventListener('click', () => {
        this.toggleMenu();
      });

      // 点击菜单外关闭
      document.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        if (this.isMenuOpen && !this.mobileMenu?.contains(target) && !this.mobileMenuBtn?.contains(target)) {
          this.closeMenu();
        }
      });

      // ESC 键关闭
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && this.isMenuOpen) {
          this.closeMenu();
        }
      });
    }

    private toggleMenu(): void {
      if (this.isMenuOpen) {
        this.closeMenu();
      } else {
        this.openMenu();
      }
    }

    private openMenu(): void {
      this.isMenuOpen = true;
      this.mobileMenu?.classList.add('open');
      this.mobileMenuBtn?.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }

    private closeMenu(): void {
      this.isMenuOpen = false;
      this.mobileMenu?.classList.remove('open');
      this.mobileMenuBtn?.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }

    private initActiveState(): void {
      const currentPath = window.location.pathname;
      const navLinks = document.querySelectorAll('.nav-link, .mobile-nav-link');

      navLinks.forEach(link => {
        const href = link.getAttribute('href');
        if (href && currentPath.includes(href.replace('/', ''))) {
          link.classList.add('active');
        }
      });
    }
  }

  // 初始化
  document.addEventListener('DOMContentLoaded', () => {
    new HeaderController();
  });
</script>
