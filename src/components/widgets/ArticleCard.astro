---
interface Props {
  title: string;
  subtitle?: string;
  description: string;
  href: string;
  category: string;
  era?: string;
  tags?: string[];
  readTime?: string;
  featured?: boolean;
  color?: 'gold' | 'jade' | 'ochre' | 'amethyst' | 'sapphire';
}

const {
  title,
  subtitle,
  description,
  href,
  category,
  era,
  tags = [],
  readTime,
  featured = false,
  color = 'gold'
} = Astro.props;

const colorMap = {
  gold: {
    border: 'border-[#c9a227]/30 hover:border-[#d4af37]/60',
    text: 'text-[#d4af37]',
    textHover: 'group-hover:text-[#e8d48b]',
    bg: 'hover:bg-[#c9a227]/[0.03]',
    glow: 'hover:shadow-[0_0_30px_-5px_rgba(201,162,39,0.15)]',
    icon: 'text-[#c9a227]/60 group-hover:text-[#d4af37]',
    gradient: 'from-[#c9a227]/5 to-transparent',
    accent: '#c9a227',
    tagBg: 'bg-[#c9a227]/10 text-[#c9a227]',
  },
  jade: {
    border: 'border-[#2d8a8a]/30 hover:border-[#5ababa]/60',
    text: 'text-[#5ababa]',
    textHover: 'group-hover:text-[#6bcbcb]',
    bg: 'hover:bg-[#2d8a8a]/[0.03]',
    glow: 'hover:shadow-[0_0_30px_-5px_rgba(90,186,186,0.15)]',
    icon: 'text-[#2d8a8a]/60 group-hover:text-[#5ababa]',
    gradient: 'from-[#5ababa]/5 to-transparent',
    accent: '#5ababa',
    tagBg: 'bg-[#5ababa]/10 text-[#5ababa]',
  },
  ochre: {
    border: 'border-[#8a4a2d]/30 hover:border-[#ba7a5a]/60',
    text: 'text-[#ba7a5a]',
    textHover: 'group-hover:text-[#ca8a6a]',
    bg: 'hover:bg-[#8a4a2d]/[0.03]',
    glow: 'hover:shadow-[0_0_30px_-5px_rgba(186,122,90,0.15)]',
    icon: 'text-[#8a4a2d]/60 group-hover:text-[#ba7a5a]',
    gradient: 'from-[#ba7a5a]/5 to-transparent',
    accent: '#ba7a5a',
    tagBg: 'bg-[#ba7a5a]/10 text-[#ba7a5a]',
  },
  amethyst: {
    border: 'border-[#6b4a8a]/30 hover:border-[#a878b8]/60',
    text: 'text-[#a878b8]',
    textHover: 'group-hover:text-[#b888c8]',
    bg: 'hover:bg-[#6b4a8a]/[0.03]',
    glow: 'hover:shadow-[0_0_30px_-5px_rgba(168,120,184,0.15)]',
    icon: 'text-[#6b4a8a]/60 group-hover:text-[#a878b8]',
    gradient: 'from-[#a878b8]/5 to-transparent',
    accent: '#a878b8',
    tagBg: 'bg-[#a878b8]/10 text-[#a878b8]',
  },
  sapphire: {
    border: 'border-[#2d4a6b]/30 hover:border-[#6b9ad4]/60',
    text: 'text-[#6b9ad4]',
    textHover: 'group-hover:text-[#7baae4]',
    bg: 'hover:bg-[#2d4a6b]/[0.03]',
    glow: 'hover:shadow-[0_0_30px_-5px_rgba(107,154,212,0.15)]',
    icon: 'text-[#2d4a6b]/60 group-hover:text-[#6b9ad4]',
    gradient: 'from-[#6b9ad4]/5 to-transparent',
    accent: '#6b9ad4',
    tagBg: 'bg-[#6b9ad4]/10 text-[#6b9ad4]',
  },
};

const colors = colorMap[color] || colorMap.gold;
---

<a
  href={href}
  class:list={[
    'group relative overflow-hidden rounded-lg bg-[#0d0d0d]/50 border transition-all duration-300',
    'active:scale-[0.98]',
    colors.border,
    colors.bg,
    colors.glow,
    featured && 'md:flex md:items-stretch'
  ]}
  data-article-card
>
  <div class:list={[
    'absolute inset-0 bg-gradient-to-br opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none',
    colors.gradient
  ]}></div>

  <div class:list={['relative z-10 p-5', featured && 'md:flex md:flex-1 md:flex-col']}>
    <div class="flex items-start justify-between gap-4 mb-3">
      <div class="flex items-center gap-2 flex-wrap">
        <span class:list={['text-xs uppercase tracking-widest font-medium', colors.text]}>
          {category}
        </span>
        {era && (
          <span class="text-xs text-[#555555] px-2 py-0.5 rounded bg-[#1a1a1a] border border-[#333333]/30">
            {era}
          </span>
        )}
        {readTime && (
          <span class="text-xs text-[#666666] flex items-center gap-1">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            {readTime}
          </span>
        )}
      </div>
      <svg
        class:list={['w-4 h-4 flex-shrink-0 transition-all duration-300', colors.icon, 'group-hover:translate-x-0.5 group-hover:-translate-y-0.5']}
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 17L17 7M17 7H7M17 7V17" />
      </svg>
    </div>

    {subtitle && (
      <p class:list={['text-xs mb-1', colors.text, 'opacity-70']}>
        {subtitle}
      </p>
    )}

    <h3 class:list={[
      'text-lg font-display mb-2 transition-colors duration-300',
      colors.text,
      colors.textHover
    ]}>
      {title}
    </h3>

    <p class="text-sm text-[#888888] group-hover:text-[#a0a0a0] transition-colors duration-300 leading-relaxed">
      {description}
    </p>

    {tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mt-4">
        {tags.slice(0, 3).map((tag) => (
          <span class:list={[
            'text-xs px-2 py-0.5 rounded transition-colors duration-300',
            colors.tagBg,
            'group-hover:opacity-80'
          ]}>
            {tag}
          </span>
        ))}
        {tags.length > 3 && (
          <span class="text-xs text-[#666666]">
            +{tags.length - 3}
          </span>
        )}
      </div>
    )}

    {featured && (
      <div class="mt-auto pt-4">
        <span class:list={[
          'inline-flex items-center gap-2 text-xs font-medium transition-all duration-300',
          colors.text,
          'group-hover:gap-3'
        ]}>
          阅读全文
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7V17" />
          </svg>
        </span>
      </div>
    )}
  </div>

  <div
    class="absolute bottom-0 left-0 right-0 h-[2px] scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left"
    style={`background: linear-gradient(90deg, transparent, ${colors.accent}, transparent)`}
  ></div>
</a>

<script>
  document.querySelectorAll('[data-article-card]').forEach((card) => {
    const element = card as HTMLElement;
    let isPressed = false;

    element.addEventListener('mousedown', () => {
      isPressed = true;
      element.style.transform = 'scale(0.98)';
    });

    element.addEventListener('mouseup', () => {
      isPressed = false;
      element.style.transform = '';
    });

    element.addEventListener('mouseleave', () => {
      if (isPressed) {
        isPressed = false;
        element.style.transform = '';
      }
    });
  });
</script>