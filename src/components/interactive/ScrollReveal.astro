---
/**
 * 灵墟 - 滚动揭示动画控制器
 * Scroll Reveal Animation Controller
 * 
 * 监听滚动事件，触发元素入场动画
 * Listens to scroll events to trigger element reveal animations
 */

export interface Props {
  // 观察选项
  rootMargin?: string;
  threshold?: number | number[];
  // 动画类型
  animation?: 'fade-up' | 'fade-down' | 'fade-left' | 'fade-right' | 'scale' | 'blur' | 'stagger';
  // 延迟增量（毫秒）
  staggerDelay?: number;
  // 是否启用
  enabled?: boolean;
}

const {
  rootMargin = '0px 0px -100px 0px',
  threshold = 0.1,
  animation = 'fade-up',
  staggerDelay = 100,
  enabled = true,
} = Astro.props;
---

{enabled && (
  <script
    define:vars={{
      rootMargin,
      threshold,
      animation,
      staggerDelay,
    }}
  >
    class ScrollRevealController {
      constructor() {
        this.init();
      }

      init() {
        // 检查是否支持 IntersectionObserver
        if (!('IntersectionObserver' in window)) {
          // 不支持则直接显示所有元素
          document.querySelectorAll('[data-reveal]').forEach(el => {
            el.classList.add('revealed');
          });
          return;
        }

        const options = {
          root: null,
          rootMargin,
          threshold,
        };

        this.observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              this.revealElement(entry.target);
              this.observer.unobserve(entry.target);
            }
          });
        }, options);

        // 观察所有需要动画的元素
        document.querySelectorAll('[data-reveal]').forEach(el => {
          this.observer.observe(el);
        });
      }

      revealElement(el) {
        const delay = el.dataset.revealDelay || 0;
        const duration = el.dataset.revealDuration || 300;

        // 如果有 stagger 父容器，处理子元素
        if (el.dataset.revealStagger) {
          const parent = el.closest('[data-reveal-stagger]');
          if (parent) {
            const siblings = Array.from(parent.querySelectorAll('[data-reveal]'));
            const index = siblings.indexOf(el);
            const calculatedDelay = index * staggerDelay;
            el.style.transitionDelay = `${calculatedDelay}ms`;
          }
        }

        // 添加动画类
        setTimeout(() => {
          el.classList.add('revealed');
          el.classList.add(`reveal-${animation}`);
        }, parseInt(delay));

        // 动画完成后移除动画类（可选）
        setTimeout(() => {
          el.classList.remove(`reveal-${animation}`);
        }, parseInt(delay) + parseInt(duration) + 100);
      }
    }

    // 初始化
    document.addEventListener('DOMContentLoaded', () => {
      new ScrollRevealController();
    });

    // Astro 页面切换后重新初始化
    document.addEventListener('astro:page-load', () => {
      new ScrollRevealController();
    });
  </script>
)}

<style is:global>
  /* 滚动揭示动画基础样式 */
  [data-reveal] {
    opacity: 0;
    transition-property: opacity, transform, filter;
    transition-duration: 0.6s;
    transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1);
  }

  [data-reveal].revealed {
    opacity: 1;
  }

  /* 上浮动画 */
  [data-reveal="fade-up"],
  .reveal-fade-up {
    transform: translateY(40px);
  }

  [data-reveal="fade-up"].revealed,
  .reveal-fade-up.revealed {
    transform: translateY(0);
  }

  /* 下浮动画 */
  [data-reveal="fade-down"],
  .reveal-fade-down {
    transform: translateY(-40px);
  }

  [data-reveal="fade-down"].revealed,
  .reveal-fade-down.revealed {
    transform: translateY(0);
  }

  /* 左浮动画 */
  [data-reveal="fade-left"],
  .reveal-fade-left {
    transform: translateX(40px);
  }

  [data-reveal="fade-left"].revealed,
  .reveal-fade-left.revealed {
    transform: translateX(0);
  }

  /* 右浮动画 */
  [data-reveal="fade-right"],
  .reveal-fade-right {
    transform: translateX(-40px);
  }

  [data-reveal="fade-right"].revealed,
  .reveal-fade-right.revealed {
    transform: translateX(0);
  }

  /* 缩放动画 */
  [data-reveal="scale"],
  .reveal-scale {
    transform: scale(0.9);
  }

  [data-reveal="scale"].revealed,
  .reveal-scale.revealed {
    transform: scale(1);
  }

  /* 模糊动画 */
  [data-reveal="blur"],
  .reveal-blur {
    filter: blur(10px);
  }

  [data-reveal="blur"].revealed,
  .reveal-blur.revealed {
    filter: blur(0);
  }

  /* 组合动画 */
  [data-reveal="fade-scale"] {
    opacity: 0;
    transform: translateY(30px) scale(0.95);
  }

  [data-reveal="fade-scale"].revealed {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  /* 打字机效果 */
  [data-reveal="typewriter"] {
    overflow: hidden;
    white-space: nowrap;
    border-right: 2px solid currentColor;
    animation: typewriterReveal 2s steps(40) forwards, blinkCaret 0.75s step-end infinite;
  }

  @keyframes typewriterReveal {
    from { width: 0; }
    to { width: 100%; }
  }

  @keyframes blinkCaret {
    50% { border-color: transparent; }
  }

  /* 波浪效果 */
  [data-reveal="wave"] {
    opacity: 0;
    transform: translateY(20px);
  }

  [data-reveal="wave"].revealed {
    animation: waveReveal 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes waveReveal {
    0% {
      opacity: 0;
      transform: translateY(20px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* 减少动画偏好 */
  @media (prefers-reduced-motion: reduce) {
    [data-reveal] {
      opacity: 1;
      transform: none;
      filter: none;
      transition: none;
      animation: none;
    }
  }
</style>
