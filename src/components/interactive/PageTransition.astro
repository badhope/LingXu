---
/**
 * 灵墟 - 页面过渡动画组件
 * Page Transition Component
 * 
 * 实现流畅的页面切换动画效果
 * Implements smooth page transition animations
 */

import { PAGE_TRANSITIONS, DURATIONS, EASINGS, type TransitionType } from '@lib/animations';

export interface Props {
  // 过渡类型
  type?: TransitionType;
  // 自定义时长
  duration?: number;
  // 自定义缓动
  easing?: string;
  // 延迟
  delay?: number;
  // 模块ID（用于主题色）
  moduleId?: string;
}

const {
  type = 'fade',
  duration = DURATIONS.page,
  easing = EASINGS.standard,
  delay = 0,
  moduleId,
} = Astro.props;
---

<div id="page-transition-overlay" class="page-transition-overlay" data-module={moduleId}>
  <div class="transition-layer layer-1"></div>
  <div class="transition-layer layer-2"></div>
  <div class="transition-layer layer-3"></div>
  <div class="transition-symbol" id="transition-symbol">
    <svg viewBox="0 0 100 100" fill="none">
      <circle cx="50" cy="50" r="45" stroke="currentColor" stroke-width="0.5" opacity="0.3"/>
      <circle cx="50" cy="50" r="35" stroke="currentColor" stroke-width="0.3" opacity="0.2"/>
      <circle cx="50" cy="50" r="25" stroke="currentColor" stroke-width="0.2" opacity="0.1"/>
      <path d="M50 10 L50 90" stroke="currentColor" stroke-width="0.3" opacity="0.2"/>
      <path d="M10 50 L90 50" stroke="currentColor" stroke-width="0.3" opacity="0.2"/>
    </svg>
  </div>
  <div class="transition-particles" id="transition-particles"></div>
</div>

<style>
  .page-transition-overlay {
    position: fixed;
    inset: 0;
    z-index: 99998;
    pointer-events: none;
    opacity: 0;
    --transition-color: var(--module-color, #c9a227);
  }

  .transition-layer {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .layer-1 {
    background: radial-gradient(ellipse at center, 
      rgba(201, 162, 39, 0.05) 0%, 
      transparent 70%);
  }

  .layer-2 {
    background: radial-gradient(circle at 50% 50%, 
      rgba(0, 0, 0, 0.9) 0%, 
      rgba(0, 0, 0, 0.7) 30%, 
      transparent 70%);
  }

  .layer-3 {
    background: linear-gradient(135deg, 
      rgba(201, 162, 39, 0.1) 0%, 
      transparent 50%, 
      rgba(128, 64, 240, 0.1) 100%);
  }

  .transition-symbol {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 200px;
    height: 200px;
    transform: translate(-50%, -50%) scale(0);
    color: var(--transition-color);
    opacity: 0;
    pointer-events: none;
  }

  .transition-symbol svg {
    width: 100%;
    height: 100%;
    animation: symbolRotate 10s linear infinite;
  }

  @keyframes symbolRotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .transition-particles {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .transition-particle {
    position: absolute;
    width: 4px;
    height: 4px;
    background: var(--transition-color);
    border-radius: 50%;
    opacity: 0;
    box-shadow: 0 0 10px var(--transition-color);
  }

  /* 过渡动画状态 */
  .page-transition-overlay.transitioning {
    pointer-events: auto;
  }

  .page-transition-overlay.fade-in .transition-layer {
    animation: fadeIn 0.6s ease forwards;
  }

  .page-transition-overlay.fade-out .transition-layer {
    animation: fadeOut 0.6s ease forwards;
  }

  .page-transition-overlay.portal-enter {
    animation: portalEnter 1s ease forwards;
  }

  .page-transition-overlay.portal-enter .transition-symbol {
    animation: symbolEnter 1s ease forwards;
  }

  .page-transition-overlay.portal-exit {
    animation: portalExit 1s ease forwards;
  }

  .page-transition-overlay.dissolve {
    animation: dissolve 0.8s ease forwards;
  }

  .page-transition-overlay.vortex-enter {
    animation: vortexEnter 1s ease forwards;
  }

  .page-transition-overlay.vortex-exit {
    animation: vortexExit 1s ease forwards;
  }

  .page-transition-overlay.revelation {
    animation: revelation 1.2s ease forwards;
  }

  .page-transition-overlay.slide-up {
    animation: slideUp 0.6s ease forwards;
  }

  .page-transition-overlay.slide-down {
    animation: slideDown 0.6s ease forwards;
  }

  /* 关键帧动画 */
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes fadeOut {
    from { opacity: 1; }
    to { opacity: 0; }
  }

  @keyframes portalEnter {
    0% {
      opacity: 0;
      transform: scale(0.8);
      filter: blur(10px);
    }
    50% {
      opacity: 1;
      transform: scale(1.1);
      filter: blur(5px);
    }
    100% {
      opacity: 1;
      transform: scale(1);
      filter: blur(0);
    }
  }

  @keyframes portalExit {
    0% {
      opacity: 1;
      transform: scale(1);
      filter: blur(0);
    }
    50% {
      opacity: 0.8;
      transform: scale(1.1);
      filter: blur(5px);
    }
    100% {
      opacity: 0;
      transform: scale(0.8);
      filter: blur(10px);
    }
  }

  @keyframes symbolEnter {
    0% {
      opacity: 0;
      transform: translate(-50%, -50%) scale(0) rotate(-180deg);
    }
    50% {
      opacity: 0.5;
      transform: translate(-50%, -50%) scale(1.5) rotate(0deg);
    }
    100% {
      opacity: 0;
      transform: translate(-50%, -50%) scale(2) rotate(180deg);
    }
  }

  @keyframes dissolve {
    0% {
      opacity: 1;
      filter: blur(0);
    }
    50% {
      opacity: 0.5;
      filter: blur(3px);
    }
    100% {
      opacity: 0;
      filter: blur(10px);
    }
  }

  @keyframes vortexEnter {
    0% {
      opacity: 0;
      transform: scale(2) rotate(-180deg);
    }
    50% {
      opacity: 0.8;
      transform: scale(1.2) rotate(-90deg);
    }
    100% {
      opacity: 1;
      transform: scale(1) rotate(0deg);
    }
  }

  @keyframes vortexExit {
    0% {
      opacity: 1;
      transform: scale(1) rotate(0deg);
    }
    50% {
      opacity: 0.8;
      transform: scale(0.8) rotate(90deg);
    }
    100% {
      opacity: 0;
      transform: scale(0) rotate(180deg);
    }
  }

  @keyframes revelation {
    0% {
      opacity: 1;
      clip-path: circle(0% at 50% 50%);
    }
    100% {
      opacity: 1;
      clip-path: circle(150% at 50% 50%);
    }
  }

  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(100%);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-100%);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* 减少动画偏好 */
  @media (prefers-reduced-motion: reduce) {
    .page-transition-overlay,
    .transition-layer,
    .transition-symbol,
    .transition-symbol svg {
      animation: none !important;
      transition: none !important;
    }
  }
</style>

<script>
  import { PAGE_TRANSITIONS, DURATIONS, EASINGS, MODULE_THEMES } from '@lib/animations';

  class PageTransitionController {
    private overlay: HTMLElement | null;
    private isTransitioning: boolean = false;
    private currentModule: string | null = null;

    constructor() {
      this.overlay = document.getElementById('page-transition-overlay');
      this.init();
    }

    private init(): void {
      // 监听链接点击
      document.addEventListener('click', this.handleLinkClick.bind(this));
      
      // 监听浏览器导航
      window.addEventListener('popstate', this.handlePopState.bind(this));
      
      // 页面加载完成
      this.handlePageLoad();
    }

    private handleLinkClick(e: MouseEvent): void {
      const target = e.target as HTMLElement;
      const link = target.closest('a[href]');
      
      if (!link) return;
      
      const href = link.getAttribute('href');
      if (!href || href.startsWith('http') || href.startsWith('#') || href.startsWith('javascript:')) return;
      
      // 获取模块信息
      const moduleEl = link.closest('[data-module]');
      const moduleId = moduleEl?.getAttribute('data-module') || this.extractModule(href);
      
      // 执行过渡动画
      e.preventDefault();
      this.transitionTo(href, moduleId);
    }

    private handlePopState(e: PopStateEvent): void {
      // 浏览器前进/后退
      this.animate('fade', true);
    }

    private handlePageLoad(): void {
      // 页面加载完成后的入场动画
      document.body.classList.add('page-loaded');
      
      // 触发页面入场效果
      setTimeout(() => {
        this.animate('revelation', false);
      }, 100);
    }

    private extractModule(href: string): string | null {
      const moduleIds = ['tian', 'di', 'xuan', 'huang', 'yu', 'zhou', 'hong', 'huang-lost'];
      for (const id of moduleIds) {
        if (href.includes(`/${id}`)) return id;
      }
      return null;
    }

    public async transitionTo(href: string, moduleId: string | null): Promise<void> {
      if (this.isTransitioning) return;
      this.isTransitioning = true;

      // 设置模块主题色
      if (moduleId && MODULE_THEMES[moduleId as keyof typeof MODULE_THEMES]) {
        const theme = MODULE_THEMES[moduleId as keyof typeof MODULE_THEMES];
        this.overlay?.style.setProperty('--module-color', theme.primary);
      }

      // 选择过渡类型
      const transitionType = moduleId ? 'portal' : 'fade';
      
      // 执行离场动画
      await this.animate(transitionType, true);

      // 导航到新页面
      window.location.href = href;
    }

    public async animate(type: string, isExit: boolean): Promise<void> {
      return new Promise((resolve) => {
        if (!this.overlay) {
          resolve();
          return;
        }

        const duration = isExit ? DURATIONS.page : DURATIONS.enter;
        
        // 清除之前的类
        this.overlay.className = 'page-transition-overlay';
        
        // 强制重绘
        void this.overlay.offsetWidth;
        
        // 添加过渡类
        this.overlay.classList.add('transitioning');
        this.overlay.classList.add(isExit ? `${type}-exit` : `${type}-enter`);
        
        // 动画完成
        setTimeout(() => {
          if (!isExit) {
            this.overlay?.classList.remove('transitioning');
          }
          this.isTransitioning = false;
          resolve();
        }, duration);
      });
    }

    // 创建粒子效果
    private createParticles(count: number): void {
      const container = document.getElementById('transition-particles');
      if (!container) return;

      for (let i = 0; i < count; i++) {
        const particle = document.createElement('div');
        particle.className = 'transition-particle';
        
        const angle = (Math.PI * 2 * i) / count;
        const radius = 100 + Math.random() * 100;
        const x = 50 + Math.cos(angle) * (radius / 4);
        const y = 50 + Math.sin(angle) * (radius / 4);
        
        particle.style.cssText = `
          left: ${x}%;
          top: ${y}%;
          animation: particleFly 1s ease-out ${i * 0.02}s forwards;
        `;
        
        container.appendChild(particle);
        
        // 清理
        setTimeout(() => particle.remove(), 1500);
      }
    }
  }

  // 初始化
  document.addEventListener('DOMContentLoaded', () => {
    new PageTransitionController();
  });
</script>
