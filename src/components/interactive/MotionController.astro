<script>
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function initScrollReveal() {
    if (prefersReducedMotion) return;

    const revealElements = document.querySelectorAll('.reveal-on-scroll');

    if (revealElements.length === 0) return;

    const observerOptions = {
      root: null,
      rootMargin: '0px 0px -60px 0px',
      threshold: 0.1,
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);

    revealElements.forEach((el) => {
      observer.observe(el);
    });
  }

  function initDividers() {
    if (prefersReducedMotion) return;

    const dividers = document.querySelectorAll('.divider-reveal');

    if (dividers.length === 0) return;

    const observerOptions = {
      root: null,
      rootMargin: '0px 0px -20px 0px',
      threshold: 0.5,
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);

    dividers.forEach((el) => {
      observer.observe(el);
    });
  }

  function initTOC() {
    if (prefersReducedMotion) return;

    const tocItems = document.querySelectorAll('.toc-item');
    const sections = document.querySelectorAll('.article-section[id]');

    if (tocItems.length === 0 || sections.length === 0) return;

    const observerOptions = {
      root: null,
      rootMargin: '-80px 0px -70% 0px',
      threshold: 0,
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const id = entry.target.getAttribute('id');
          tocItems.forEach((item) => {
            item.classList.remove('toc-active');
            if (item.getAttribute('href') === `#${id}`) {
              item.classList.add('toc-active');
            }
          });
        }
      });
    }, observerOptions);

    sections.forEach((section) => {
      observer.observe(section);
    });
  }

  function initTimeline() {
    const timelineNodes = document.querySelectorAll('.timeline-node');

    if (timelineNodes.length === 0) return;

    const observerOptions = {
      root: null,
      rootMargin: '0px 0px -40% 0px',
      threshold: 0.3,
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
        }
      });
    }, observerOptions);

    timelineNodes.forEach((node) => {
      observer.observe(node);
    });
  }

  function initTouchFeedback() {
    const touchElements = document.querySelectorAll('.card-glow, .btn-press, .tag-interaction');

    touchElements.forEach((el) => {
      el.addEventListener('touchstart', () => {
        el.classList.add('touch-active');
      }, { passive: true });

      el.addEventListener('touchend', () => {
        setTimeout(() => {
          el.classList.remove('touch-active');
        }, 150);
      }, { passive: true });
    });
  }

  function initAccordions() {
    const accordionHeaders = document.querySelectorAll('.accordion-header');

    accordionHeaders.forEach((header) => {
      header.addEventListener('click', () => {
        const content = header.nextElementSibling;
        const isOpen = content?.classList.contains('open');

        content?.classList.toggle('open', !isOpen);
        header.setAttribute('aria-expanded', String(!isOpen));
      });

      header.addEventListener('touchstart', () => {
        header.classList.add('touch-active');
      }, { passive: true });

      header.addEventListener('touchend', () => {
        setTimeout(() => {
          header.classList.remove('touch-active');
        }, 150);
      }, { passive: true });
    });
  }

  function initPageLoadAnimations() {
    if (prefersReducedMotion) {
      document.querySelectorAll('.motion-fade-up, .motion-fade-in, .stagger-children > *').forEach((el) => {
        (el as HTMLElement).style.opacity = '1';
        (el as HTMLElement).style.transform = 'none';
      });
      return;
    }

    const elements = document.querySelectorAll('[data-animate-on-load]');

    elements.forEach((el, index) => {
      const delay = parseInt(el.getAttribute('data-delay') || '0', 10);
      (el as HTMLElement).style.animationDelay = `${delay}ms`;
      el.classList.add('motion-fade-up');
    });
  }

  function handleReducedMotionChange(e: MediaQueryListEvent) {
    if (e.matches) {
      document.querySelectorAll('.reveal-on-scroll').forEach((el) => {
        el.classList.add('revealed');
      });
      document.querySelectorAll('.motion-glow-pulse, .motion-float, .motion-breathe').forEach((el) => {
        (el as HTMLElement).style.animation = 'none';
      });
    } else {
      initScrollReveal();
      initDividers();
      initTOC();
    }
  }

  if (prefersReducedMotion) {
    document.querySelectorAll('.reveal-on-scroll').forEach((el) => {
      el.classList.add('revealed');
    });
  } else {
    initScrollReveal();
    initDividers();
    initTOC();
    initTimeline();
  }

  initTouchFeedback();
  initAccordions();
  initPageLoadAnimations();

  window.matchMedia('(prefers-reduced-motion: reduce)').addEventListener('change', handleReducedMotionChange);

  document.addEventListener('astro:page-load', () => {
    initScrollReveal();
    initDividers();
    initTOC();
    initTimeline();
    initTouchFeedback();
    initAccordions();
    initPageLoadAnimations();
  });
</script>
