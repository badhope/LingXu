---
export interface Props {
  text: string;
  speed?: number;
  delay?: number;
  cursor?: boolean;
  class?: string;
  element?: 'span' | 'p' | 'h1' | 'h2' | 'h3' | 'div';
}

const {
  text,
  speed = 50,
  delay = 0,
  cursor = true,
  class: className = '',
  element = 'span'
} = Astro.props;

const Tag = element;
---

<Tag
  class:list={['typewriter', className]}
  data-text={text}
  data-speed={speed}
  data-delay={delay}
  data-cursor={cursor ? 'true' : 'false'}
>
</Tag>

<script>
  class TypewriterElement {
    constructor(el) {
      this.el = el;
      this.text = el.dataset.text || '';
      this.speed = parseInt(el.dataset.speed || '50', 10);
      this.delay = parseInt(el.dataset.delay || '0', 10);
      this.showCursor = el.dataset.cursor === 'true';
      this.cursorVisible = true;
      this.animationFrame = 0;
      this.isMobile = window.innerWidth < 640;

      if (this.isMobile) {
        this.speed = Math.max(30, this.speed * 0.7);
      }

      this.init();
    }

    init() {
      this.el.style.visibility = 'hidden';
      const span = document.createElement('span');
      span.className = 'typewriter-text';
      this.el.appendChild(span);

      if (this.showCursor) {
        const cursorSpan = document.createElement('span');
        cursorSpan.className = 'typewriter-cursor';
        cursorSpan.textContent = '|';
        this.el.appendChild(cursorSpan);
      }

      setTimeout(() => this.start(), this.delay);
    }

    start() {
      this.el.style.visibility = 'visible';
      let index = 0;

      const type = () => {
        if (index < this.text.length) {
          const textSpan = this.el.querySelector('.typewriter-text');
          if (textSpan) {
            textSpan.textContent = this.text.slice(0, index + 1);
          }
          index++;
          this.animationFrame = setTimeout(type, this.speed);
        } else {
          this.onComplete();
        }
      };

      type();
    }

    onComplete() {
      if (this.showCursor) {
        this.blinkCursor();
      }
      this.el.dispatchEvent(new CustomEvent('typewriter:complete'));
    }

    blinkCursor() {
      const cursor = this.el.querySelector('.typewriter-cursor');
      if (!cursor) return;

      this.cursorVisible = true;
      const blink = () => {
        if (!this.el.isConnected) return;
        this.cursorVisible = !this.cursorVisible;
        cursor.style.opacity = this.cursorVisible ? '1' : '0';
        this.animationFrame = setTimeout(blink, 530);
      };
      blink();
    }

    destroy() {
      clearTimeout(this.animationFrame);
    }
  }

  function initTypewriters() {
    const typewriters = document.querySelectorAll('.typewriter');

    typewriters.forEach((el) => {
      const existing = el.dataset.processed;
      if (existing) return;

      el.dataset.processed = 'true';
      new TypewriterElement(el);
    });
  }

  document.addEventListener('astro:page-load', initTypewriters);
  initTypewriters();
</script>

<style>
  .typewriter {
    visibility: hidden;
    display: inline-block;
  }

  .typewriter-text {
    display: inline;
  }

  .typewriter-cursor {
    display: inline-block;
    margin-left: 2px;
    color: #c9a227;
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
</style>
