---
---

<canvas id="portal-particle-canvas" class="fixed inset-0 pointer-events-none z-[10000]"></canvas>

<style>
  #portal-particle-canvas {
    background: transparent;
  }
</style>

<script lang="ts">
  interface PortalParticle {
    x: number;
    y: number;
    z: number;
    size: number;
    speed: number;
    opacity: number;
    color: string;
  }

  const canvas = document.getElementById('portal-particle-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d');

  let width = window.innerWidth;
  let height = window.innerHeight;
  canvas.width = width;
  canvas.height = height;

  const particles: PortalParticle[] = [];
  const particleCount = Math.floor((width * height) / 8000);
  const centerX = width / 2;
  const centerY = height / 2;
  let isActive = false;
  let animationId: number;

  function createParticle(): PortalParticle {
    const angle = Math.random() * Math.PI * 2;
    const distance = Math.random() * Math.max(width, height) * 0.5;
    return {
      x: centerX + Math.cos(angle) * distance,
      y: centerY + Math.sin(angle) * distance,
      z: Math.random() * 100,
      size: Math.random() * 2 + 0.5,
      speed: Math.random() * 3 + 1,
      opacity: Math.random() * 0.6 + 0.2,
      color: Math.random() > 0.7 ? '#d4af37' : '#c9a227'
    };
  }

  function initParticles() {
    for (let i = 0; i < particleCount; i++) {
      particles.push(createParticle());
    }
  }

  function animateTransit() {
    if (!isActive) return;

    ctx.clearRect(0, 0, width, height);

    particles.forEach((p, index) => {
      const dx = centerX - p.x;
      const dy = centerY - p.y;
      const distance = Math.sqrt(dx * dx + dy * dy);

      if (distance > 10) {
        p.x += (dx / distance) * p.speed;
        p.y += (dy / distance) * p.speed;
        p.z -= 2;
      } else {
        particles[index] = createParticle();
      }

      if (p.z <= 0) {
        particles[index] = createParticle();
      }

      const screenSize = p.size * (p.z / 100);
      const alpha = p.opacity * Math.min(1, p.z / 50);

      ctx.beginPath();
      ctx.arc(p.x, p.y, Math.max(0.5, screenSize), 0, Math.PI * 2);
      ctx.fillStyle = p.color.replace(')', `, ${alpha})`).replace('rgb', 'rgba').replace('#d4af37', 'rgba(212, 175, 55').replace('#c9a227', 'rgba(201, 162, 39');

      const gradient = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, screenSize * 2);
      gradient.addColorStop(0, `rgba(212, 175, 55, ${alpha})`);
      gradient.addColorStop(1, 'rgba(212, 175, 55, 0)');
      ctx.fillStyle = gradient;
      ctx.fill();
    });

    animationId = requestAnimationFrame(animateTransit);
  }

  function startTransit() {
    isActive = true;
    animateTransit();
  }

  function stopTransit() {
    isActive = false;
    cancelAnimationFrame(animationId);
    ctx.clearRect(0, 0, width, height);
  }

  function updateSize() {
    width = window.innerWidth;
    height = window.innerHeight;
    canvas.width = width;
    canvas.height = height;
  }

  window.addEventListener('resize', updateSize);

  (window as any).startPortalTransit = startTransit;
  (window as any).stopPortalTransit = stopTransit;

  initParticles();
</script>
