---
/**
 * 灵墟 - 动画文字组件
 * Animated Text Component
 * 
 * 多种文字动画效果
 * Multiple text animation effects
 */

export interface Props {
  // 文字内容
  text: string;
  // 动画类型
  type?: 'typing' | 'shuffle' | 'wave' | 'gradient' | 'char-reveal' | 'line-reveal';
  // 速度（毫秒每字符）
  speed?: number;
  // 是否循环
  loop?: boolean;
  // 是否自动播放
  autoplay?: boolean;
  // 文字颜色
  color?: string;
  // 尺寸
  size?: 'sm' | 'md' | 'lg' | 'xl';
  // 额外类名
  class?: string;
}

const {
  text,
  type = 'char-reveal',
  speed = 100,
  loop = false,
  autoplay = true,
  color = '#c9a227',
  size = 'md',
  class: className = '',
} = Astro.props;

// 计算字数
const charCount = text.length;

// 拆分文字为数组
const chars = text.split('');

const sizeClasses = {
  sm: 'text-sm',
  md: 'text-md',
  lg: 'text-lg',
  xl: 'text-xl',
};
---

<span
  class:list={['animated-text', `anim-${type}`, sizeClasses[size], className]}
  data-text={text}
  data-type={type}
  data-speed={speed}
  data-loop={loop}
  data-autoplay={autoplay}
  style={`--text-color: ${color}; --char-count: ${charCount}`}
  aria-label={text}
>
  {type === 'char-reveal' || type === 'wave' ? (
    <span class="char-container">
      {chars.map((char, i) => (
        <span 
          class="char" 
          style={`--char-index: ${i}`}
          data-char={char}
        >
          {char === ' ' ? '\u00A0' : char}
        </span>
      ))}
    </span>
  ) : (
    <span class="text-content">{text}</span>
  )}
</span>

<style>
  .animated-text {
    display: inline-block;
    color: var(--text-color);
    line-height: 1.4;
  }

  /* 打字机效果 */
  .anim-typing .text-content {
    overflow: hidden;
    white-space: nowrap;
    border-right: 2px solid var(--text-color);
    animation: 
      typing var(--char-count) steps(var(--char-count)) forwards,
      blink 0.75s step-end infinite;
    width: 0;
  }

  .anim-typing[data-loop="true"] .text-content {
    animation: 
      typing var(--char-count) steps(var(--char-count)) forwards,
      blink 0.75s step-end infinite,
      typingLoop 3s steps(var(--char-count)) infinite;
    animation-delay: 0s, calc(var(--char-count) * 100ms / 10 * 1s + 0.5s) forwards, calc(var(--char-count) * 100ms / 10 * 1s + 1s) forwards;
  }

  @keyframes typing {
    from { width: 0; }
    to { width: 100%; }
  }

  @keyframes blink {
    50% { border-color: transparent; }
  }

  @keyframes typingLoop {
    0%, 100% { width: 0; }
    10%, 90% { width: 100%; }
  }

  /* 洗牌效果 */
  .anim-shuffle .text-content {
    display: inline-block;
  }

  .anim-shuffle.playing .text-content {
    animation: textShuffle 0.5s steps(5) forwards;
  }

  @keyframes textShuffle {
    0% { filter: blur(0); }
    50% { filter: blur(2px); opacity: 0.5; }
    100% { filter: blur(0); }
  }

  /* 波浪效果 */
  .char-container {
    display: inline-flex;
  }

  .anim-wave .char {
    display: inline-block;
    animation: charWave 2s ease-in-out infinite;
    animation-delay: calc(var(--char-index) * 0.1s);
  }

  @keyframes charWave {
    0%, 100% { 
      transform: translateY(0);
      opacity: 1;
    }
    25% {
      transform: translateY(-8px);
      opacity: 0.8;
    }
    50% {
      transform: translateY(0);
      opacity: 1;
    }
    75% {
      transform: translateY(4px);
      opacity: 0.9;
    }
  }

  /* 渐变流动效果 */
  .anim-gradient .text-content {
    background: linear-gradient(
      90deg,
      var(--text-color) 0%,
      #e8d48b 25%,
      var(--text-color) 50%,
      #e8d48b 75%,
      var(--text-color) 100%
    );
    background-size: 200% auto;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: gradientFlow 3s linear infinite;
  }

  @keyframes gradientFlow {
    0% { background-position: 0% center; }
    100% { background-position: 200% center; }
  }

  /* 字符揭示效果 */
  .anim-char-reveal .char {
    display: inline-block;
    opacity: 0;
    transform: translateY(20px);
    animation: charReveal 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: calc(var(--char-index) * (var(--char-count) * 20ms));
  }

  .anim-char-reveal[data-autoplay="true"] .char {
    animation-play-state: running;
  }

  .anim-char-reveal:not([data-autoplay="true"]) .char {
    opacity: 1;
    transform: none;
    animation: none;
  }

  .anim-char-reveal.hover-trigger:hover .char {
    animation: charReveal 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: calc(var(--char-index) * 50ms);
  }

  @keyframes charReveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* 行揭示效果 */
  .anim-line-reveal .text-content {
    overflow: hidden;
  }

  .anim-line-reveal .text-content::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: var(--text-color);
    animation: lineReveal 1s ease forwards;
    animation-delay: 0.3s;
  }

  @keyframes lineReveal {
    from { transform: translateX(0); }
    to { transform: translateX(100%); }
  }

  /* 发光效果 */
  .anim-glow .text-content {
    text-shadow: 
      0 0 10px var(--text-color),
      0 0 20px var(--text-color),
      0 0 40px var(--text-color);
    animation: glow 2s ease-in-out infinite alternate;
  }

  @keyframes glow {
    from {
      text-shadow: 
        0 0 10px var(--text-color),
        0 0 20px var(--text-color),
        0 0 40px var(--text-color);
    }
    to {
      text-shadow: 
        0 0 15px var(--text-color),
        0 0 30px var(--text-color),
        0 0 60px var(--text-color);
    }
  }

  /* 尺寸 */
  .text-sm { font-size: 0.875rem; }
  .text-md { font-size: 1.125rem; }
  .text-lg { font-size: 1.5rem; }
  .text-xl { font-size: 2rem; }

  /* 减少动画 */
  @media (prefers-reduced-motion: reduce) {
    .anim-wave .char {
      animation: none;
    }

    .anim-char-reveal .char {
      opacity: 1;
      transform: none;
      animation: none;
    }

    .anim-typing .text-content {
      animation: none;
      width: auto;
      border: none;
    }
  }
</style>

<script>
  class AnimatedText {
    private elements: NodeListOf<Element>;

    constructor() {
      this.elements = document.querySelectorAll('.animated-text');
      this.init();
    }

    private init(): void {
      this.elements.forEach((el) => {
        const type = el.getAttribute('data-type');
        const autoplay = el.getAttribute('data-autoplay') === 'true';

        if (autoplay && type !== 'char-reveal') {
          this.play(el);
        }
      });
    }

    public play(el: Element): void {
      const type = el.getAttribute('data-type');

      switch (type) {
        case 'shuffle':
          el.classList.add('playing');
          setTimeout(() => el.classList.remove('playing'), 500);
          break;

        case 'char-reveal':
          const chars = el.querySelectorAll('.char');
          chars.forEach((char, index) => {
            (char as HTMLElement).style.animationDelay = `${index * 50}ms`;
          });
          break;
      }
    }

    public reset(el: Element): void {
      const type = el.getAttribute('data-type');

      if (type === 'char-reveal') {
        const chars = el.querySelectorAll('.char');
        chars.forEach((char) => {
          (char as HTMLElement).style.animation = 'none';
          (char as HTMLElement).offsetHeight; // 触发重排
          (char as HTMLElement).style.animation = '';
        });
      }
    }
  }

  function initAnimatedText(): void {
    new AnimatedText();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAnimatedText);
  } else {
    initAnimatedText();
  }

  document.addEventListener('astro:page-load', initAnimatedText);
</script>
