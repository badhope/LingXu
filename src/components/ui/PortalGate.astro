---
/**
 * 灵墟 - 传送门入场组件
 * Portal Gate Entry Component
 * 
 * 华丽的传送门入场动画效果
 * Magnificent portal entrance animation
 */

export interface Props {
  // 标题
  title?: string;
  // 副标题
  subtitle?: string;
  // 引言
  quote?: string;
  // 自动跳转延迟（毫秒）
  autoRedirectDelay?: number;
  // 是否启用自动跳转
  autoRedirect?: boolean;
  // 主题色
  color?: string;
}

const {
  title = '灵墟',
  subtitle = '失落修行文明档案',
  quote = '法门虽隐，真机未亡',
  autoRedirectDelay = 8000,
  autoRedirect = true,
  color = '#c9a227',
} = Astro.props;

// 符号配置
const symbols = ['☯', '⚝', '✧', '❂', '⬡', '☆', '✦', '◈'];
---

<div 
  id="portal-gate" 
  class="portal-container"
  data-auto={autoRedirect}
  data-delay={autoRedirectDelay}
  style={`--portal-color: ${color}`}
>
  <!-- 背景层 -->
  <div class="portal-bg">
    <div class="bg-gradient"></div>
    <div class="mist mist-1"></div>
    <div class="mist mist-2"></div>
    <div class="mist mist-3"></div>
  </div>

  <!-- 粒子画布 -->
  <canvas id="portal-particles" class="portal-canvas"></canvas>

  <!-- 中心传送门 -->
  <div class="portal-center">
    <!-- 外环 -->
    <div class="portal-ring ring-outer">
      <svg viewBox="0 0 400 400" class="ring-svg">
        <circle cx="200" cy="200" r="190" class="ring-line dashed"/>
        <circle cx="200" cy="200" r="175" class="ring-line dotted"/>
      </svg>
    </div>

    <!-- 中环 -->
    <div class="portal-ring ring-mid">
      <svg viewBox="0 0 400 400" class="ring-svg">
        <circle cx="200" cy="200" r="150" class="ring-line"/>
      </svg>
    </div>

    <!-- 内环 -->
    <div class="portal-ring ring-inner">
      <svg viewBox="0 0 400 400" class="ring-svg">
        <circle cx="200" cy="200" r="120" class="ring-line rotate"/>
        <circle cx="200" cy="200" r="100" class="ring-line rotate-reverse"/>
      </svg>
    </div>

    <!-- 符文环 -->
    <div class="portal-runes" id="portal-runes">
      <div class="rune rune-1">☰</div>
      <div class="rune rune-2">☱</div>
      <div class="rune rune-3">☲</div>
      <div class="rune rune-4">☳</div>
      <div class="rune rune-5">☴</div>
      <div class="rune rune-6">☵</div>
      <div class="rune rune-7">☶</div>
      <div class="rune rune-8">☷</div>
    </div>

    <!-- 核心光球 -->
    <div class="portal-core" id="portal-core">
      <div class="core-glow"></div>
      <div class="core-inner"></div>
    </div>

    <!-- 光芒射线 -->
    <div class="light-rays">
      <div class="ray ray-1"></div>
      <div class="ray ray-2"></div>
      <div class="ray ray-3"></div>
      <div class="ray ray-4"></div>
      <div class="ray ray-5"></div>
      <div class="ray ray-6"></div>
      <div class="ray ray-7"></div>
      <div class="ray ray-8"></div>
    </div>
  </div>

  <!-- 文字内容 -->
  <div class="portal-content" id="portal-content">
    <h1 class="portal-title">{title}</h1>
    <p class="portal-subtitle">{subtitle}</p>
    <div class="portal-divider"></div>
    <p class="portal-quote">{quote}</p>
  </div>

  <!-- 按钮 -->
  <div class="portal-actions" id="portal-actions">
    <button class="enter-button" id="enter-btn" type="button">
      <span class="btn-text">叩启封印</span>
      <span class="btn-arrow">→</span>
    </button>
    <button class="skip-button" id="skip-btn" type="button">
      <span>直接进入</span>
    </button>
  </div>

  <!-- 跳转进度 -->
  <div class="redirect-progress" id="redirect-progress">
    <div class="progress-bar"></div>
  </div>
</div>

<style>
  .portal-container {
    position: fixed;
    inset: 0;
    z-index: 99999;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #030305 0%, #060608 50%, #050507 100%);
    overflow: hidden;
  }

  /* 背景 */
  .portal-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .bg-gradient {
    position: absolute;
    inset: 0;
    background: 
      radial-gradient(ellipse at 50% 40%, rgba(201, 162, 39, 0.08) 0%, transparent 50%),
      radial-gradient(ellipse at 30% 70%, rgba(107, 74, 138, 0.06) 0%, transparent 40%);
  }

  .mist {
    position: absolute;
    width: 200%;
    height: 200%;
    top: -50%;
    left: -50%;
    background: radial-gradient(ellipse at center, rgba(201, 162, 39, 0.03) 0%, transparent 50%);
    animation: mistFloat 45s ease-in-out infinite;
  }

  .mist-1 { animation-delay: 0s; }
  .mist-2 { animation-delay: -18s; animation-duration: 40s; }
  .mist-3 { animation-delay: -28s; animation-duration: 50s; }

  @keyframes mistFloat {
    0%, 100% { transform: translate(0, 0) rotate(0deg); opacity: 0.5; }
    33% { transform: translate(3%, 2%) rotate(1deg); opacity: 0.7; }
    66% { transform: translate(-2%, 3%) rotate(-1deg); opacity: 0.4; }
  }

  .portal-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  /* 传送门中心 */
  .portal-center {
    position: relative;
    width: 400px;
    height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* 环 */
  .portal-ring {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ring-svg {
    width: 100%;
    height: 100%;
  }

  .ring-line {
    fill: none;
    stroke: var(--portal-color);
    opacity: 0.2;
  }

  .ring-line.dashed {
    stroke-dasharray: 10 15;
    animation: dashMove 30s linear infinite;
  }

  .ring-line.dotted {
    stroke-dasharray: 2 10;
    animation: dashMove 20s linear infinite reverse;
  }

  .ring-outer { animation: ringRotate 100s linear infinite; }
  .ring-mid { animation: ringRotate 70s linear infinite reverse; }
  .ring-inner { animation: ringRotate 50s linear infinite; }

  @keyframes ringRotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  @keyframes dashMove {
    from { stroke-dashoffset: 0; }
    to { stroke-dashoffset: 100; }
  }

  .ring-line.rotate { animation: innerRotate 25s linear infinite; }
  .ring-line.rotate-reverse { animation: innerRotateReverse 18s linear infinite; }

  @keyframes innerRotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  @keyframes innerRotateReverse {
    from { transform: rotate(360deg); }
    to { transform: rotate(0deg); }
  }

  /* 符文 */
  .portal-runes {
    position: absolute;
    width: 300px;
    height: 300px;
    animation: ringRotate 40s linear infinite;
  }

  .rune {
    position: absolute;
    font-size: 1.5rem;
    color: var(--portal-color);
    opacity: 0.4;
    text-shadow: 0 0 10px var(--portal-color);
  }

  .rune-1 { top: 0; left: 50%; transform: translateX(-50%); }
  .rune-2 { top: 15%; right: 15%; }
  .rune-3 { top: 50%; right: 0; transform: translateY(-50%); }
  .rune-4 { bottom: 15%; right: 15%; }
  .rune-5 { bottom: 0; left: 50%; transform: translateX(-50%); }
  .rune-6 { bottom: 15%; left: 15%; }
  .rune-7 { top: 50%; left: 0; transform: translateY(-50%); }
  .rune-8 { top: 15%; left: 15%; }

  /* 核心 */
