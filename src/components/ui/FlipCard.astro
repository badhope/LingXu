---
export interface Props {
  id?: string;
  title: string;
  description?: string;
  icon?: string;
  backTitle?: string;
  backDescription?: string;
  backIcon?: string;
  type?: 'click' | 'hover' | 'swipe';
  color?: 'gold' | 'amethyst' | 'jade' | 'sapphire' | 'ochre';
  class?: string;
}

const {
  id = `flip-card-${Math.random().toString(36).substr(2, 9)}`,
  title,
  description,
  icon,
  backTitle,
  backDescription,
  backIcon,
  type = 'click',
  color = 'gold',
  class: className = ''
} = Astro.props;

const colorMap: Record<string, { accent: string; text: string }> = {
  gold: { accent: '#c9a227', text: '#e8c76b' },
  amethyst: { accent: '#a878b8', text: '#b890c4' },
  jade: { accent: '#5ababa', text: '#7dc4c4' },
  sapphire: { accent: '#6b9ad4', text: '#8ab0e0' },
  ochre: { accent: '#ba7a5a', text: '#c99a7a' }
};

const cardColors = colorMap[color] || colorMap.gold;
const flipType = type === 'hover' ? 'flip-card-hover' : type === 'swipe' ? 'flip-card-swipe' : 'flip-card-click';
---

<div
  class:list={['flip-card-wrapper', flipType, className]}
  data-flip-id={id}
  data-flip-type={type}
  style={`--card-accent: ${cardColors.accent}; --card-text: ${cardColors.text};`}
>
  <div class="flip-card-inner">
    <div class="flip-card-front">
      <div class="card-glow-effect"></div>
      <div class="card-border-effect"></div>
      <div class="card-content">
        {icon && <div class="card-icon">{icon}</div>}
        <h3 class="card-title">{title}</h3>
        {description && <p class="card-desc">{description}</p>}
        <div class="card-hint">
          {type === 'hover' ? (
            <span class="hint-text">悬停查看详情</span>
          ) : type === 'swipe' ? (
            <span class="hint-text">滑动查看详情</span>
          ) : (
            <span class="hint-icon">↻</span>
          )}
        </div>
      </div>
    </div>
    <div class="flip-card-back">
      <div class="card-glow-effect"></div>
      <div class="card-border-effect"></div>
      <div class="card-content">
        {backIcon && <div class="card-icon">{backIcon}</div>}
        <h3 class="card-title">{backTitle || title}</h3>
        {backDescription && <p class="card-desc">{backDescription}</p>}
        <div class="card-hint">
          <span class="hint-text">点击返回</span>
        </div>
      </div>
    </div>
  </div>
</div>

<script define:vars={{ id, type }}>
  class FlipCardController {
    constructor() {
      this.card = document.querySelector(`[data-flip-id="${id}"]`);
      if (!this.card) return;

      this.inner = this.card.querySelector('.flip-card-inner');
      this.isFlipped = false;
      this.startX = 0;
      this.startY = 0;
      this.isDragging = false;

      this.init();
    }

    init() {
      if (type === 'hover') {
        this.card.addEventListener('mouseenter', () => this.flip(), { passive: true });
        this.card.addEventListener('mouseleave', () => this.unflip(), { passive: true });
      } else if (type === 'swipe') {
        this.bindSwipeEvents();
      } else {
        this.card.addEventListener('click', (e) => {
          if (!e.target.closest('.flip-card-back')) {
            this.toggle();
          }
        });
        this.card.querySelector('.flip-card-back')?.addEventListener('click', () => {
          this.unflip();
        });
      }

      if (type !== 'hover') {
        this.bindKeyboardEvents();
      }
    }

    bindSwipeEvents() {
      this.card.addEventListener('touchstart', (e) => {
        this.startX = e.touches[0].clientX;
        this.startY = e.touches[0].clientY;
        this.isDragging = true;
      }, { passive: true });

      this.card.addEventListener('touchmove', (e) => {
        if (!this.isDragging) return;
        const diffX = e.touches[0].clientX - this.startX;
        const diffY = e.touches[0].clientY - this.startY;
        if (Math.abs(diffX) > Math.abs(diffY) && Math.abs(diffX) > 50) {
          if (diffX > 0 && !this.isFlipped) {
            this.flip();
          } else if (diffX < 0 && this.isFlipped) {
            this.unflip();
          }
          this.isDragging = false;
        }
      }, { passive: true });

      this.card.addEventListener('touchend', () => {
        this.isDragging = false;
      }, { passive: true });
    }

    bindKeyboardEvents() {
      this.card.setAttribute('tabindex', '0');
      this.card.setAttribute('role', 'button');
      this.card.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          this.toggle();
        }
      });
    }

    flip() {
      if (this.isFlipped) return;
      this.isFlipped = true;
      this.inner.classList.add('flipped');
    }

    unflip() {
      if (!this.isFlipped) return;
      this.isFlipped = false;
      this.inner.classList.remove('flipped');
    }

    toggle() {
      if (this.isFlipped) {
        this.unflip();
      } else {
        this.flip();
      }
    }
  }

  function initFlipCards() {
    new FlipCardController();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFlipCards);
  } else {
    initFlipCards();
  }

  document.addEventListener('astro:page-load', initFlipCards);
</script>

<style>
  .flip-card-wrapper {
    perspective: 1200px;
    width: 100%;
    height: 100%;
    min-height: 200px;
  }

  .flip-card-inner {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 200px;
    transition: transform 0.7s cubic-bezier(0.4, 0, 0.2, 1);
    transform-style: preserve-3d;
    will-change: transform;
  }

  .flip-card-inner.flipped {
    transform: rotateY(180deg);
  }

  .flip-card-front,
  .flip-card-back {
    position: absolute;
    inset: 0;
    min-height: 200px;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    background: rgba(10, 10, 15, 0.9);
    border: 1px solid var(--card-accent, #c9a227);
    border-radius: 12px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .flip-card-back {
    transform: rotateY(180deg);
  }

  .card-glow-effect {
    position: absolute;
    inset: -1px;
    border-radius: inherit;
    background: linear-gradient(135deg, var(--card-accent, #c9a227) 0%, transparent 50%, var(--card-accent, #c9a227) 100%);
    opacity: 0;
    transition: opacity 0.5s ease;
    z-index: -1;
  }

  .flip-card-wrapper:hover .card-glow-effect,
  .flip-card-inner.flipped .card-glow-effect {
    opacity: 0.15;
  }

  .card-border-effect {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(135deg, var(--card-accent, #c9a227) 0%, transparent 30%, transparent 70%, var(--card-accent, #c9a227) 100%);
    opacity: 0.1;
    pointer-events: none;
  }

  .flip-card-wrapper:hover .card-border-effect {
    opacity: 0.25;
  }

  .card-content {
    position: relative;
    z-index: 1;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    height: 100%;
    justify-content: center;
    align-items: center;
    text-align: center;
  }

  .card-icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    animation: iconFloat 3s ease-in-out infinite;
  }

  @keyframes iconFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-5px); }
  }

  .flip-card-wrapper:hover .card-icon {
    animation: iconPulse 1s ease-in-out infinite;
  }

  @keyframes iconPulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.1); }
  }

  .card-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--card-accent, #c9a227);
    margin-bottom: 0.5rem;
    transition: transform 0.3s ease;
  }

  .flip-card-wrapper:hover .card-title {
    transform: scale(1.02);
  }

  .card-desc {
    font-size: 0.875rem;
    color: #888;
    line-height: 1.6;
    margin-top: 0.5rem;
  }

  .card-hint {
    position: absolute;
    bottom: 1rem;
    left: 50%;
    transform: translateX(-50%);
    opacity: 0.5;
    transition: opacity 0.3s ease;
  }

  .flip-card-wrapper:hover .card-hint {
    opacity: 0.8;
  }

  .hint-text {
    font-size: 0.7rem;
    color: #666;
    letter-spacing: 0.1em;
  }

  .hint-icon {
    font-size: 1.2rem;
    color: var(--card-accent, #c9a227);
    animation: hintRotate 2s ease-in-out infinite;
  }

  @keyframes hintRotate {
    0%, 100% { transform: rotate(0deg); }
    25% { transform: rotate(15deg); }
    75% { transform: rotate(-15deg); }
  }

  .flip-card-wrapper:focus {
    outline: none;
  }

  .flip-card-wrapper:focus-visible {
    outline: 2px solid var(--card-accent, #c9a227);
    outline-offset: 2px;
    border-radius: 12px;
  }

  .flip-card-swipe .flip-card-inner {
    transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  @media (prefers-reduced-motion: reduce) {
    .flip-card-inner,
    .card-glow-effect,
    .card-icon,
    .hint-icon {
      transition: none;
      animation: none;
    }

    .flip-card-inner.flipped {
      transform: rotateY(180deg);
    }
  }
</style>
