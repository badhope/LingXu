---
/**
 * 灵墟 - 滚动揭示动画组件
 * Scroll Reveal Animation Component
 * 
 * 监听元素进入视口时触发动画效果
 * Triggers animations when elements enter the viewport
 */

export interface Props {
  // 动画类型
  type?: 'fade' | 'slide-up' | 'slide-down' | 'slide-left' | 'slide-right' | 'scale' | 'blur';
  // 延迟（毫秒）
  delay?: number;
  // 距离阈值
  threshold?: number;
  // 是否一次性动画
  once?: boolean;
  // 自定义类名
  class?: string;
}

const {
  type = 'fade',
  delay = 0,
  threshold = 0.15,
  once = true,
  class: className = '',
} = Astro.props;

// 生成唯一ID
const id = `reveal-${Math.random().toString(36).substr(2, 9)}`;
---

<div
  id={id}
  class={`scroll-reveal reveal-${type} ${className}`}
  data-reveal-id={id}
  data-reveal-delay={delay}
  data-reveal-threshold={threshold}
  data-reveal-once={once}
>
  <slot />
</div>

<style>
  .scroll-reveal {
    will-change: transform, opacity, filter;
  }

  /* 淡入 */
  .reveal-fade {
    opacity: 0;
    transition: opacity 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .reveal-fade.revealed {
    opacity: 1;
  }

  /* 上滑 */
  .reveal-slide-up {
    opacity: 0;
    transform: translateY(50px);
    transition: 
      opacity 0.8s cubic-bezier(0.4, 0, 0.2, 1),
      transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .reveal-slide-up.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  /* 下滑 */
  .reveal-slide-down {
    opacity: 0;
    transform: translateY(-50px);
    transition: 
      opacity 0.8s cubic-bezier(0.4, 0, 0.2, 1),
      transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .reveal-slide-down.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  /* 左滑 */
  .reveal-slide-left {
    opacity: 0;
    transform: translateX(50px);
    transition: 
      opacity 0.8s cubic-bezier(0.4, 0, 0.2, 1),
      transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .reveal-slide-left.revealed {
    opacity: 1;
    transform: translateX(0);
  }

  /* 右滑 */
  .reveal-slide-right {
    opacity: 0;
    transform: translateX(-50px);
    transition: 
      opacity 0.8s cubic-bezier(0.4, 0, 0.2, 1),
      transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .reveal-slide-right.revealed {
    opacity: 1;
    transform: translateX(0);
  }

  /* 缩放 */
  .reveal-scale {
    opacity: 0;
    transform: scale(0.85);
    transition: 
      opacity 0.8s cubic-bezier(0.4, 0, 0.2, 1),
      transform 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .reveal-scale.revealed {
    opacity: 1;
    transform: scale(1);
  }

  /* 模糊 */
  .reveal-blur {
    opacity: 0;
    filter: blur(15px);
    transition: 
      opacity 0.8s cubic-bezier(0.4, 0, 0.2, 1),
      filter 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .reveal-blur.revealed {
    opacity: 1;
    filter: blur(0);
  }

  /* 减少动画偏好 */
  @media (prefers-reduced-motion: reduce) {
    .scroll-reveal {
      opacity: 1;
      transform: none;
      filter: none;
      transition: none;
    }
  }
</style>

<script>
  class ScrollRevealController {
    private reveals: NodeListOf<Element>;

    constructor() {
      this.reveals = document.querySelectorAll('.scroll-reveal');
      this.init();
    }

    private init(): void {
      if (this.reveals.length === 0) return;

      // 检查 IntersectionObserver 支持
      if ('IntersectionObserver' in window) {
        this.setupObserver();
      } else {
        // 后备方案：直接显示所有元素
        this.reveals.forEach(el => {
          el.classList.add('revealed');
        });
      }

      // 页面切换后重新初始化
      document.addEventListener('astro:page-load', () => {
        this.reveals = document.querySelectorAll('.scroll-reveal');
        this.init();
      });
    }

    private setupObserver(): void {
      const observerOptions: IntersectionObserverInit = {
        root: null,
        rootMargin: '0px 0px -50px 0px',
        threshold: Array.from({ length: 20 }, (_, i) => i * 0.05)
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            const delay = parseInt(el.dataset.revealDelay || '0', 10);
            const once = el.dataset.revealOnce !== 'false';

            setTimeout(() => {
              el.classList.add('revealed');
            }, delay);

            // 如果是一次性动画，停止观察
            if (once) {
              observer.unobserve(el);
            }
          } else {
            // 非一次性动画，移出revealed类
            const el = entry.target as HTMLElement;
            if (el.dataset.revealOnce === 'false') {
              el.classList.remove('revealed');
            }
          }
        });
      }, observerOptions);

      this.reveals.forEach(el => observer.observe(el));
    }
  }

  // 初始化
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => new ScrollRevealController());
  } else {
    new ScrollRevealController();
  }
</script>
